	schema1:keywords "carbon" , "production" ;
	a owl:DatatypeProperty ;
	rdfs:label "bacteria_carb_prod" ;
	rdfs:range xsd:string ;
	skos:definition "Measurement of bacterial carbon production" ;
	skos:inScheme <https://w3id.org/mixs> .
