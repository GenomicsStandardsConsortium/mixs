    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( SO:0000352 SO:0001198 <https://w3id.org/mixs/ViralGenomeTypeEnum#ssDNA> SO:0000356 SO:0001169 SO:0001199 SO:0001201 SO:0001200 <https://w3id.org/mixs/ViralGenomeTypeEnum#mixed> <https://w3id.org/mixs/ViralGenomeTypeEnum#uncharacterized> ) ;
