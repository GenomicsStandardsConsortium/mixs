    schema1:name "missing: data agreement established pre-2023" ;
    rdfs:subClassOf linkml:PermissibleValue,
        MIXS:InsdcMissingValueEnum ;
    skos:definition """Data agreements were established before the 2023 INSDC standard and metadata can not be provided. A value may be given at a later stage.
""" .

