	a owl:DatatypeProperty ;
	rdfs:label "toluene" ;
	rdfs:range xsd:string ;
	skos:definition "Concentration of toluene in the sample" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "milligram per liter, parts per million" .
MIXS:0000155 dcterms:title "ethylbenzene" ;
	a owl:DatatypeProperty ;
	rdfs:label "ethylbenzene" ;
	rdfs:range xsd:string ;
	skos:definition "Concentration of ethylbenzene in the sample" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "milligram per liter, parts per million" .
MIXS:0000156 dcterms:title "xylene" ;
	a owl:DatatypeProperty ;
	rdfs:label "xylene" ;
	rdfs:range xsd:string ;
	skos:definition "Concentration of xylene in the sample" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "milligram per liter, parts per million" .
MIXS:0000157 dcterms:title "API gravity" ;
	a owl:DatatypeProperty ;
	rdfs:label "api" ;
	rdfs:range xsd:string ;
	skos:definition "API gravity is a measure of how heavy or light a petroleum liquid is compared to water (source: https://en.wikipedia.org/wiki/API_gravity) (e.g. 31.1   API)" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "degrees API" .
MIXS:0000158 dcterms:title "door area or size" ;
	schema1:keywords "area" , "door" , "size" ;
	a owl:DatatypeProperty ;
	rdfs:label "door_size" ;
	rdfs:range xsd:string ;
	skos:definition "The size of the door" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "square meter" .
