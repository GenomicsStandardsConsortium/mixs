MIXS:0000017 a owl:DatatypeProperty ;
    rdfs:label "size_frac" ;
    dcterms:title "size fraction selected" ;
    schema1:name "size_frac" ;
    skos:definition "Filtering pore size used in sample preparation" ;
    MIXS:Expected_value "filter size value range" .

MIXS:0000024 a owl:DatatypeProperty ;
    rdfs:label "estimated_genome_size" ;
    dcterms:title "estimated genome size" ;
    schema1:name "estimated_genome_size" ;
    skos:definition "The estimated size of the genome prior to sequencing. Of particular importance in the sequencing of (eukaryotic) genome which could remain in draft form for a long or unspecified period" ;
    skos:note "Slot updated 2026-02-10 `estimated_size` and title 'estimated size'" ;
    MIXS:Expected_value "number of base pairs" .

MIXS:0000029 a owl:DatatypeProperty ;
    rdfs:label "specific_host" ;
    dcterms:title "host scientific name" ;
    schema1:name "specific_host" ;
    skos:definition "Report the host's taxonomic name and/or NCBI taxonomy ID" ;
    MIXS:Expected_value "host scientific name, taxonomy ID" .

MIXS:0000274 a owl:DatatypeProperty ;
    rdfs:label "host_body_temp" ;
    dcterms:title "host body temperature" ;
    schema1:name "host_body_temp" ;
    rdfs:range xsd:string ;
    skos:definition "Core body temperature of the host when sample was collected" ;
    MIXS:Preferred_unit "degree Celsius" .

MIXS:0000412 a owl:DatatypeProperty ;
    rdfs:label "pressure" ;
    dcterms:title "pressure" ;
    schema1:name "pressure" ;
    rdfs:range xsd:string ;
    skos:definition "Pressure to which the sample is subject to, in atmospheres" ;
    MIXS:Preferred_unit "atmosphere" .

