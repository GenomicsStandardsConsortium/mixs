MIXS:0000243 a owl:DatatypeProperty ;
    rdfs:label "room_wall_share" ;
    dcterms:title "rooms that share a wall with sampling room" ;
    schema1:name "room_wall_share" ;
    rdfs:range xsd:string ;
    skos:definition "List of room(s) (room number, room name) sharing a wall with the sampling room" .

MIXS:0000245 a owl:DatatypeProperty ;
    rdfs:label "shading_device_mat" ;
