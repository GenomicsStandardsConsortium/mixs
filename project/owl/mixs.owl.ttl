	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "percentage" .
MIXS:0000664 dcterms:title "inorganic particles" ;
	schema1:keywords "inorganic" , "particle" ;
	a owl:DatatypeProperty ;
	rdfs:label "inorg_particles" ;
