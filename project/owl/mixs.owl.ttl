	a owl:DatatypeProperty ;
	rdfs:label "blood_press_syst" ;
	rdfs:range xsd:string ;
	skos:definition "Resting systolic blood pressure, measured as mm mercury" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "millimeter mercury" .
