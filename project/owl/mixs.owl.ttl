MIXS:0000643 dcterms:title "mean seasonal temperature" ;
	schema1:keywords "mean" , "season" , "temperature" ;
	a owl:DatatypeProperty ;
	rdfs:label "season_temp" ;
	rdfs:range xsd:string ;
	skos:definition "Mean seasonal temperature" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "degree Celsius" .
MIXS:0000644 dcterms:title "mean annual precipitation" ;
	schema1:keywords "mean" ;
	a owl:DatatypeProperty ;
	rdfs:label "annual_precpt" ;
	rdfs:range xsd:string ;
	skos:definition "The average of all annual precipitation values known, or an estimated equivalent value derived by such methods as regional indexes or Isohyetal maps" ;
