    schema1:name "rel_samp_loc" ;
    rdfs:range MIXS:RelSampLocEnum ;
    skos:definition "The sampling location within the train car" .

MIXS:0000822 a owl:ObjectProperty ;
    rdfs:label "room_condt" ;
    dcterms:title "room condition" ;
    schema1:name "room_condt" ;
    rdfs:range MIXS:RoomCondtEnum ;
    skos:definition "The condition of the room at the time of sampling" .

MIXS:0000823 a owl:ObjectProperty ;
    rdfs:label "room_loc" ;
    dcterms:title "room location in building" ;
    schema1:name "room_loc" ;
    rdfs:range MIXS:RoomLocEnum ;
    skos:definition "The position of the room within the building" .

MIXS:0000824 a owl:ObjectProperty ;
    rdfs:label "room_samp_pos" ;
    dcterms:title "room sampling position" ;
    schema1:name "room_samp_pos" ;
    rdfs:range MIXS:RoomSampPosEnum ;
    skos:definition "The horizontal sampling position in the room relative to architectural elements" .

MIXS:0000825 a owl:DatatypeProperty ;
    rdfs:label "room_type" ;
    dcterms:title "room type" ;
    schema1:name "room_type" ;
    skos:definition "The main purpose or activity of the sampling room. A room is any distinguishable space within a structure" ;
    MIXS:Expected_value "enumeration" .

MIXS:0000826 a owl:ObjectProperty ;
    rdfs:label "room_connected" ;
    dcterms:title "rooms connected by a doorway" ;
    schema1:name "room_connected" ;
    rdfs:range MIXS:RoomConnectedEnum ;
    skos:definition "List of rooms connected to the sampling room by a doorway" .

MIXS:0000827 a owl:ObjectProperty ;
    rdfs:label "samp_weather" ;
