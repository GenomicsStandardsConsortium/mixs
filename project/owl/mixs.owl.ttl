    dcterms:title "host infra-specific name" ;
    schema1:name "host_infra_spec_name" ;
    rdfs:range xsd:string ;
    skos:definition "Taxonomic information about the host below subspecies level" .

MIXS:0000254 a owl:DatatypeProperty ;
    rdfs:label "host_infra_spec_rank" ;
