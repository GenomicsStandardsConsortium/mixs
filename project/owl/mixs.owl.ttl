	MIXS:Expected_value "diether lipid name;measurement value" ;
	MIXS:Preferred_unit "nanogram per liter" .
MIXS:0000179 dcterms:title "dissolved hydrogen" ;
	schema1:keywords "dissolved" ;
	a owl:DatatypeProperty ;
	rdfs:label "diss_hydrogen" ;
	rdfs:range xsd:string ;
	skos:definition "Concentration of dissolved hydrogen" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "micromole per liter" .
MIXS:0000180 dcterms:title "phaeopigments" ;
	a owl:DatatypeProperty ;
	rdfs:label "phaeopigments" ;
	skos:definition "Concentration of phaeopigments; can include multiple phaeopigments" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "phaeopigment name;measurement value" ;
	MIXS:Preferred_unit "milligram per cubic meter" .
MIXS:0000181 dcterms:title "phospholipid fatty acid" ;
	a owl:DatatypeProperty ;
	rdfs:label "phosplipid_fatt_acid" ;
	skos:definition "Concentration of phospholipid fatty acids; can include multiple values" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "phospholipid fatty acid name;measurement value" .
MIXS:0000182 dcterms:title "redox potential" ;
	a owl:DatatypeProperty ;
	rdfs:label "redox_potential" ;
	rdfs:range xsd:string ;
	skos:definition "Redox potential, measured relative to a hydrogen cell, indicating oxidation or reduction potential" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "millivolt" .
MIXS:0000183 dcterms:title "salinity" ;
	schema1:keywords "salinity" ;
	a owl:DatatypeProperty ;
	rdfs:label "salinity" ;
	rdfs:range xsd:string ;
	skos:definition "The total concentration of all dissolved salts in a liquid or solid sample. While salinity can be measured by a complete chemical analysis, this method is difficult and time consuming. More often, it is instead derived from the conductivity measurement. This is known as practical salinity. These derivations compare the specific conductance of the sample to a salinity standard such as seawater" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "practical salinity unit, percentage" .
MIXS:0000184 dcterms:title "silicate" ;
	a owl:DatatypeProperty ;
	rdfs:label "silicate" ;
	rdfs:range xsd:string ;
	skos:definition "Concentration of silicate" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "micromole per liter" .
MIXS:0000185 dcterms:title "water content" ;
	schema1:keywords "content" , "water" ;
	a owl:DatatypeProperty ;
	rdfs:label "water_content" ;
	rdfs:range xsd:string ;
	skos:definition "Water content measurement" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "gram per gram or cubic centimeter per cubic centimeter" .
MIXS:0000188 dcterms:title "outside relative humidity" ;
	schema1:keywords "humidity" , "relative" ;
	a owl:DatatypeProperty ;
	rdfs:label "rel_humidity_out" ;
	rdfs:range xsd:string ;
	skos:definition "The recorded outside relative humidity value at the time of sampling" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "gram of air, kilogram of air" .
MIXS:0000191 dcterms:title "turbidity" ;
	a owl:DatatypeProperty ;
	rdfs:label "turbidity" ;
	rdfs:range xsd:string ;
	skos:definition "Measure of the amount of cloudiness or haziness in water caused by individual particles" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000192 dcterms:title "room dimensions" ;
	schema1:keywords "dimensions" , "room" ;
	a owl:DatatypeProperty ;
	rdfs:label "room_dim" ;
	skos:definition "The length, width and height of sampling room" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "measurement value" ;
	MIXS:Preferred_unit "meter" .
MIXS:0000193 dcterms:title "room door distance" ;
	schema1:keywords "distance" , "door" , "room" ;
	a owl:DatatypeProperty ;
	rdfs:label "room_door_dist" ;
	rdfs:range xsd:string ;
	skos:definition "Distance between doors (meters) in the hallway between the sampling room and adjacent rooms" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "meter" .
MIXS:0000194 dcterms:title "room net area" ;
	schema1:keywords "area" , "room" ;
	a owl:DatatypeProperty ;
	rdfs:label "room_net_area" ;
	rdfs:range xsd:string ;
	skos:definition "The net floor area of sampling room. Net area excludes wall thicknesses" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "square feet, square meter" .
MIXS:0000195 dcterms:title "room volume" ;
	schema1:keywords "room" , "volume" ;
	a owl:DatatypeProperty ;
	rdfs:label "room_vol" ;
	rdfs:range xsd:string ;
	skos:definition "Volume of sampling room" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "cubic feet, cubic meter" .
MIXS:0000196 dcterms:title "sampling time outside" ;
	schema1:keywords "time" ;
	a owl:DatatypeProperty ;
	rdfs:label "samp_time_out" ;
	skos:definition "The recent and long term history of outside sampling" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "time" ;
	MIXS:Preferred_unit "hour" .
MIXS:0000197 dcterms:title "temperature outside house" ;
	schema1:keywords "house" , "temperature" ;
	a owl:DatatypeProperty ;
	rdfs:label "temp_out" ;
	rdfs:range xsd:string ;
	skos:definition "The recorded temperature value at sampling time outside" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "degree Celsius" .
MIXS:0000198 dcterms:title "wall area" ;
	schema1:keywords "area" , "wall" ;
	a owl:DatatypeProperty ;
	rdfs:label "wall_area" ;
	rdfs:range xsd:string ;
	skos:definition "The total area of the sampled room's walls" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "square meter" .
MIXS:0000203 dcterms:title "water current" ;
	schema1:keywords "water" ;
	a owl:DatatypeProperty ;
	rdfs:label "water_current" ;
	rdfs:range xsd:string ;
	skos:definition "Measurement of magnitude and direction of flow within a fluid" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "cubic meter per second, knots" .
MIXS:0000204 dcterms:title "organic matter" ;
	schema1:keywords "organic" ;
	a owl:DatatypeProperty ;
	rdfs:label "org_matter" ;
	rdfs:range xsd:string ;
	skos:definition "Concentration of organic matter" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "microgram per liter" .
MIXS:0000205 dcterms:title "organic nitrogen" ;
	schema1:keywords "nitrogen" , "organic" ;
	a owl:DatatypeProperty ;
	rdfs:label "org_nitro" ;
	rdfs:range xsd:string ;
	skos:definition "Concentration of organic nitrogen" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000206 dcterms:title "particle classification" ;
	schema1:keywords "classification" , "particle" ;
	a owl:DatatypeProperty ;
	rdfs:label "particle_class" ;
	skos:definition "Particles are classified, based on their size, into six general categories:clay, silt, sand, gravel, cobbles, and boulders; should include amount of particle preceded by the name of the particle type; can include multiple values" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "particle name;measurement value" ;
	MIXS:Preferred_unit "micrometer" .
MIXS:0000211 dcterms:title "porosity" ;
	schema1:keywords "porosity" ;
	a owl:DatatypeProperty ;
	rdfs:label "porosity" ;
	skos:definition "Porosity of deposited sediment is volume of voids divided by the total volume of sample" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "measurement value or range" ;
	MIXS:Preferred_unit "percentage" .
MIXS:0000214 dcterms:title "specific humidity" ;
	schema1:keywords "humidity" ;
	a owl:DatatypeProperty ;
	rdfs:label "specific_humidity" ;
	rdfs:range xsd:string ;
	skos:definition "The mass of water vapour in a unit mass of moist air, usually expressed as grams of vapour per kilogram of air, or, in air conditioning, as grains per pound" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "gram of air, kilogram of air" .
MIXS:0000215 dcterms:title "sewage type" ;
	schema1:keywords "type" ;
	a owl:DatatypeProperty ;
	rdfs:label "sewage_type" ;
	rdfs:range xsd:string ;
	skos:definition "Type of wastewater treatment plant as municipial or industrial" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "sewage type name" .
MIXS:0000216 dcterms:title "sample size sorting method" ;
	schema1:keywords "method" , "sample" , "size" ;
	a owl:DatatypeProperty ;
	rdfs:label "samp_sort_meth" ;
	rdfs:range xsd:string ;
	skos:definition "Method by which samples are sorted; open face filter collecting total suspended particles, prefilter to remove particles larger than X micrometers in diameter, where common values of X would be 10 and 2.5 full size sorting in a cascade impactor" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000217 dcterms:title "occupant density at sampling" ;
	schema1:keywords "density" ;
	a owl:DatatypeProperty ;
	rdfs:label "occup_density_samp" ;
	rdfs:range xsd:float ;
	skos:definition "Average number of occupants at time of sampling per square footage" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000218 dcterms:title "address" ;
	a owl:DatatypeProperty ;
	rdfs:label "address" ;
	skos:definition "The street name and building number where the sampling occurred" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000219 dcterms:title "adjacent rooms" ;
	schema1:keywords "adjacent" , "room" ;
	a owl:DatatypeProperty ;
	rdfs:label "adj_room" ;
	rdfs:range xsd:string ;
	skos:definition "List of rooms (room number, room name) immediately adjacent to the sampling room" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000220 dcterms:title "exposed pipes" ;
	schema1:keywords "pipes" ;
	a owl:DatatypeProperty ;
	rdfs:label "exp_pipe" ;
	rdfs:range xsd:string ;
	skos:definition "The number of exposed pipes in the room" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000221 dcterms:title "wall height" ;
	schema1:keywords "height" , "wall" ;
	a owl:DatatypeProperty ;
	rdfs:label "wall_height" ;
	rdfs:range xsd:string ;
	skos:definition "The average height of the walls in the sampled room" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "centimeter" .
MIXS:0000222 dcterms:title "wall thermal mass" ;
	schema1:keywords "mass" , "wall" ;
	a owl:DatatypeProperty ;
	rdfs:label "wall_thermal_mass" ;
	rdfs:range xsd:string ;
	skos:definition "The ability of the wall to provide inertia against temperature fluctuations. Generally this means concrete or concrete block that is either exposed or covered only with paint" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "joule per degree Celsius" .
MIXS:0000223 dcterms:title "water feature size" ;
	schema1:keywords "feature" , "size" , "water" ;
	a owl:DatatypeProperty ;
	rdfs:label "water_feat_size" ;
	rdfs:range xsd:string ;
	skos:definition "The size of the water feature" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "square meter" .
MIXS:0000224 dcterms:title "window area/size" ;
	schema1:keywords "window" ;
	a owl:DatatypeProperty ;
	rdfs:label "window_size" ;
	skos:definition "The window's length and width" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "measurement value" ;
	MIXS:Preferred_unit "inch, meter" .
MIXS:0000225 dcterms:title "floor count" ;
	schema1:keywords "count" , "floor" ;
	a owl:DatatypeProperty ;
	rdfs:label "floor_count" ;
	rdfs:range xsd:integer ;
	skos:definition "The number of floors in the building, including basements and mechanical penthouse" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000226 dcterms:title "frequency of cleaning" ;
	schema1:keywords "frequency" ;
	a owl:ObjectProperty ;
	rdfs:label "freq_clean" ;
	rdfs:range MIXS:FreqCleanEnum ;
	skos:definition "The number of times the sample location is cleaned. Frequency of cleaning might be on a Daily basis, Weekly, Monthly, Quarterly or Annually" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000227 dcterms:title "frequency of cooking" ;
	schema1:keywords "frequency" ;
	a owl:DatatypeProperty ;
	rdfs:label "freq_cook" ;
	rdfs:range xsd:string ;
	skos:definition "The number of times a meal is cooked per week" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000228 dcterms:title "hallway/corridor count" ;
	schema1:keywords "corridor" , "count" , "hallway" ;
	a owl:DatatypeProperty ;
	rdfs:label "hall_count" ;
	rdfs:range xsd:integer ;
	skos:definition "The total count of hallways and corridors in the built structure" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000229 dcterms:title "maximum occupancy" ;
	schema1:keywords "maximum" ;
	a owl:DatatypeProperty ;
	rdfs:label "max_occup" ;
	rdfs:range xsd:string ;
	skos:definition "The maximum amount of people allowed in the indoor environment" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000230 dcterms:title "number of houseplants" ;
	schema1:keywords "number" ;
	a owl:DatatypeProperty ;
	rdfs:label "number_plants" ;
	rdfs:range xsd:string ;
	skos:definition "The number of plant(s) in the sampling space" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000231 dcterms:title "number of pets" ;
	schema1:keywords "number" ;
	a owl:DatatypeProperty ;
	rdfs:label "number_pets" ;
	rdfs:range xsd:string ;
	skos:definition "The number of pets residing in the sampled space" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000232 dcterms:title "number of residents" ;
	schema1:keywords "number" ;
	a owl:DatatypeProperty ;
	rdfs:label "number_resident" ;
	rdfs:range xsd:string ;
	skos:definition "The number of individuals currently occupying in the sampling location" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000233 dcterms:title "room architectural elements" ;
	schema1:keywords "room" ;
	a owl:DatatypeProperty ;
	rdfs:label "room_architec_elem" ;
	rdfs:range xsd:string ;
	skos:definition "The unique details and component parts that, together, form the architecture of a distinguishable space within a built structure" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000234 dcterms:title "room count" ;
	schema1:keywords "count" , "room" ;
	a owl:DatatypeProperty ;
	rdfs:label "room_count" ;
	rdfs:range xsd:integer ;
	skos:definition "The total count of rooms in the built structure including all room types" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000235 dcterms:title "room moisture damage or mold history" ;
	schema1:keywords "history" , "moisture" , "room" ;
	a owl:DatatypeProperty ;
	rdfs:label "room_moist_dam_hist" ;
	rdfs:range xsd:integer ;
	skos:definition "The history of moisture damage or mold in the past 12 months. Number of events of moisture damage or mold observed" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000236 dcterms:title "room occupancy" ;
	schema1:keywords "room" ;
	a owl:DatatypeProperty ;
	rdfs:label "room_occup" ;
	rdfs:range xsd:string ;
	skos:definition "Count of room occupancy at time of sampling" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000237 dcterms:title "room window count" ;
	schema1:keywords "count" , "room" , "window" ;
	a owl:DatatypeProperty ;
	rdfs:label "room_window_count" ;
	rdfs:range xsd:integer ;
	skos:definition "Number of windows in the room" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000238 dcterms:title "rooms that are on the same hallway" ;
	schema1:keywords "hallway" , "room" ;
	a owl:DatatypeProperty ;
	rdfs:label "room_hallway" ;
	rdfs:range xsd:string ;
	skos:definition "List of room(s) (room number, room name) located in the same hallway as sampling room" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000242 dcterms:title "rooms that share a door with sampling room" ;
	schema1:keywords "door" , "room" ;
	a owl:DatatypeProperty ;
	rdfs:label "room_door_share" ;
	rdfs:range xsd:string ;
	skos:definition "List of room(s) (room number, room name) sharing a door with the sampling room" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000243 dcterms:title "rooms that share a wall with sampling room" ;
	schema1:keywords "room" , "wall" ;
	a owl:DatatypeProperty ;
	rdfs:label "room_wall_share" ;
	rdfs:range xsd:string ;
	skos:definition "List of room(s) (room number, room name) sharing a wall with the sampling room" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000244 dcterms:title "sampling room ID or name" ;
	schema1:keywords "identifier" , "room" ;
	a owl:DatatypeProperty ;
	rdfs:label "samp_room_id" ;
	rdfs:range xsd:integer ;
	skos:definition "Sampling room number. This ID should be consistent with the designations on the building floor plans" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000245 dcterms:title "shading device material" ;
	schema1:keywords "device" , "material" ;
	a owl:DatatypeProperty ;
	rdfs:label "shading_device_mat" ;
	rdfs:range xsd:string ;
	skos:definition "The material the shading device is composed of" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "material name" .
MIXS:0000246 dcterms:title "window open frequency" ;
	schema1:keywords "frequency" , "window" ;
	a owl:DatatypeProperty ;
	rdfs:label "window_open_freq" ;
	rdfs:range xsd:integer ;
	skos:definition "The number of times windows are opened per week" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000247 dcterms:title "ancestral data" ;
	a owl:DatatypeProperty ;
	rdfs:label "ances_data" ;
	rdfs:range xsd:string ;
	skos:definition "Information about either pedigree or other ancestral information description (e.g. parental variety in case of mutant or selection), e.g. A/3*B (meaning [(A x B) x B] x B)" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000248 dcterms:title "host common name" ;
	schema1:keywords "host" , "host." ;
	a owl:DatatypeProperty ;
	rdfs:label "host_common_name" ;
	rdfs:range xsd:string ;
	skos:definition "Common name of the host" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "" .
MIXS:0000249 dcterms:title "sample disease stage" ;
	schema1:keywords "disease" , "sample" ;
	a owl:ObjectProperty ;
	rdfs:label "samp_dis_stage" ;
	rdfs:range MIXS:SampDisStageEnum ;
	skos:definition "Stage of the disease at the time of sample collection, e.g. inoculation, penetration, infection, growth and reproduction, dissemination of pathogen" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000250 dcterms:title "host taxid" ;
	schema1:keywords "host" , "host." , "taxon" ;
	a owl:DatatypeProperty ;
	rdfs:label "host_taxid" ;
	skos:definition "NCBI taxon id of the host, e.g. 9606" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "NCBI taxon identifier" .
MIXS:0000251 dcterms:title "host life stage" ;
	schema1:keywords "host" , "host." , "life" ;
	a owl:DatatypeProperty ;
	rdfs:label "host_life_stage" ;
	rdfs:range xsd:string ;
	skos:definition "Description of life stage of host" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "stage" .
MIXS:0000252 dcterms:title "host substrate" ;
	schema1:keywords "host" , "host." ;
	a owl:DatatypeProperty ;
	rdfs:label "host_substrate" ;
	rdfs:range xsd:string ;
	skos:definition "The growth substrate of the host" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000253 dcterms:title "host infra-specific name" ;
	schema1:keywords "host" , "host." ;
	a owl:DatatypeProperty ;
	rdfs:label "host_infra_spec_name" ;
	rdfs:range xsd:string ;
	skos:definition "Taxonomic information about the host below subspecies level" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000254 dcterms:title "host infra-specific rank" ;
	schema1:keywords "host" , "host." , "rank" ;
	a owl:DatatypeProperty ;
	rdfs:label "host_infra_spec_rank" ;
	rdfs:range xsd:string ;
	skos:definition "Taxonomic rank information about the host below subspecies level, such as variety, form, rank etc" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000255 dcterms:title "host age" ;
	schema1:keywords "age" , "host" , "host." ;
	a owl:DatatypeProperty ;
	rdfs:label "host_age" ;
	rdfs:range xsd:string ;
	skos:definition "Age of host at the time of sampling; relevant scale depends on species and study, e.g. Could be seconds for amoebae or centuries for trees" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "year, day, hour" .
MIXS:0000256 dcterms:title "host length" ;
	schema1:keywords "host" , "host." , "length" ;
	a owl:DatatypeProperty ;
	rdfs:label "host_length" ;
	rdfs:range xsd:string ;
	skos:definition "The length of subject" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "centimeter, millimeter, meter" .
