	rdfs:range xsd:string ;
	skos:definition "A category of people who identify with each other, usually on the basis of presumed similarities such as a common language, ancestry, history, society, culture, nation or social treatment within their residing area. https://en.wikipedia.org/wiki/List_of_contemporary_ethnic_groups" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "text recommend from Wikipedia list" .
MIXS:0000896 dcterms:title "host occupation" ;
	schema1:keywords "host" , "host." ;
	a owl:DatatypeProperty ;
	rdfs:label "host_occupation" ;
	rdfs:range xsd:string ;
	skos:definition "Most frequent job performed by subject" ;
	skos:inScheme <https://w3id.org/mixs> ;
	skos:note "Couldn't convert host_occupation with value veterinary to integer" , "almost all host_occupation values in the NCBI biosample_set are strings, not integers" .
MIXS:0000897 dcterms:title "medical history performed" ;
	schema1:keywords "history" ;
	a owl:DatatypeProperty ;
	rdfs:label "medic_hist_perform" ;
	rdfs:range xsd:boolean ;
	skos:definition "Whether full medical history was collected" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000898 dcterms:title "study completion status" ;
	schema1:keywords "status" ;
	a owl:DatatypeProperty ;
	rdfs:label "study_complt_stat" ;
	skos:definition "Specification of study completion status, if no the reason should be specified" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "YES or NO due to (1)adverse event (2) non-compliance (3) lost to follow up (4)other-specify" .
MIXS:0000899 dcterms:title "urine/collection method" ;
	schema1:keywords "method" ;
	a owl:ObjectProperty ;
	rdfs:label "urine_collect_meth" ;
	rdfs:range MIXS:UrineCollectMethEnum ;
	skos:definition "Specification of urine collection method" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000905 dcterms:title "special diet" ;
	schema1:keywords "diet" ;
	a owl:DatatypeProperty ;
	rdfs:label "special_diet" ;
	skos:definition "Specification of special diet; can include multiple special diets" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "enumeration" .
MIXS:0000924 dcterms:title "time since last toothbrushing" ;
	schema1:keywords "time" ;
	a owl:DatatypeProperty ;
	rdfs:label "time_last_toothbrush" ;
	rdfs:range xsd:string ;
	skos:definition "Specification of the time since last toothbrushing" ;
	skos:inScheme <https://w3id.org/mixs> ;
	skos:note "P2H45M does not match ^P(?!$)(\\\\d+Y)?(\\\\d+M)?(\\\\d+W)?(\\\\d+D)?(T(?=\\\\d+[HMS])(\\\\d+H)?(\\\\d+M)?(\\\\d+S)?)?$" , "problematic ISO 8601 period validation" .
MIXS:0000943 dcterms:title "time since last wash" ;
	schema1:keywords "time" ;
	a owl:DatatypeProperty ;
	rdfs:label "time_since_last_wash" ;
	rdfs:range xsd:string ;
	skos:definition "Specification of the time since last wash" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000944 dcterms:title "dominant hand" ;
	a owl:ObjectProperty ;
	rdfs:label "dominant_hand" ;
	rdfs:range MIXS:DominantHandEnum ;
	skos:definition "Dominant hand of the subject" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000965 dcterms:title "menarche" ;
	a owl:DatatypeProperty ;
	rdfs:label "menarche" ;
	rdfs:range xsd:dateTime ;
	skos:definition "Date of most recent menstruation" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000966 dcterms:title "pregnancy" ;
	a owl:DatatypeProperty ;
	rdfs:label "pregnancy" ;
	rdfs:range xsd:dateTime ;
	skos:definition "Date due of pregnancy" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000967 dcterms:title "douche" ;
	a owl:DatatypeProperty ;
	rdfs:label "douche" ;
	rdfs:range xsd:dateTime ;
	skos:definition "Date of most recent douche" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000968 dcterms:title "menopause" ;
	a owl:DatatypeProperty ;
	rdfs:label "menopause" ;
	rdfs:range xsd:dateTime ;
	skos:definition "Date of onset of menopause" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000969 dcterms:title "HRT" ;
	a owl:DatatypeProperty ;
	rdfs:label "hrt" ;
	rdfs:range xsd:dateTime ;
	skos:definition "Whether subject had hormone replacement theraphy, and if yes start date" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000988 dcterms:title "hydrocarbon resource type" ;
	schema1:keywords "hydrocarbon" , "resource" , "type" ;
	a owl:ObjectProperty ;
	rdfs:label "hcr" ;
	rdfs:range MIXS:HcrEnum ;
	skos:definition "Main Hydrocarbon Resource type. The term \"Hydrocarbon Resource\" HCR defined as a natural environmental feature containing large amounts of hydrocarbons at high concentrations potentially suitable for commercial exploitation. This term should not be confused with the Hydrocarbon Occurrence term which also includes hydrocarbon-rich environments with currently limited commercial interest such as seeps, outcrops, gas hydrates etc. If \"other\" is specified, please propose entry in \"additional info\" field" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000989 dcterms:title "hydrocarbon type produced" ;
	schema1:keywords "hydrocarbon" , "type" ;
	a owl:ObjectProperty ;
	rdfs:label "hc_produced" ;
	rdfs:range MIXS:HcProducedEnum ;
	skos:definition "Main hydrocarbon type produced from resource (i.e. Oil, gas, condensate, etc). If \"other\" is specified, please propose entry in \"additional info\" field" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000990 dcterms:title "lithology" ;
	schema1:keywords "lithology" ;
	a owl:ObjectProperty ;
	rdfs:label "lithology" ;
	rdfs:range MIXS:LithologyEnum ;
	skos:definition "Hydrocarbon resource main lithology (Additional information: http://petrowiki.org/Lithology_and_rock_type_determination). If \"other\" is specified, please propose entry in \"additional info\" field" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000992 dcterms:title "depositional environment" ;
	schema1:keywords "environment" ;
	a owl:ObjectProperty ;
	rdfs:label "depos_env" ;
	rdfs:range MIXS:DeposEnvEnum ;
	skos:definition "Main depositional environment (https://en.wikipedia.org/wiki/Depositional_environment). If \"other\" is specified, please propose entry in \"additional info\" field" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000993 dcterms:title "hydrocarbon resource geological age" ;
	schema1:keywords "age" , "hydrocarbon" , "resource" ;
	a owl:ObjectProperty ;
	rdfs:label "hcr_geol_age" ;
	rdfs:range MIXS:GeolAgeEnum ;
	skos:definition "Geological age of hydrocarbon resource (Additional info: https://en.wikipedia.org/wiki/Period_(geology)). If \"other\" is specified, please propose entry in \"additional info\" field" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000994 dcterms:title "source rock kerogen type" ;
	schema1:keywords "source" , "type" ;
	a owl:ObjectProperty ;
	rdfs:label "sr_kerog_type" ;
	rdfs:range MIXS:SrKerogTypeEnum ;
	skos:definition "Origin of kerogen. Type I: Algal (aquatic), Type II: planktonic and soft plant material (aquatic or terrestrial), Type III: terrestrial woody/ fibrous plant material (terrestrial), Type IV: oxidized recycled woody debris (terrestrial) (additional information: https://en.wikipedia.org/wiki/Kerogen). If \"other\" is specified, please propose entry in \"additional info\" field" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000995 dcterms:title "source rock lithology" ;
	schema1:keywords "lithology" , "source" ;
	a owl:ObjectProperty ;
	rdfs:label "sr_lithology" ;
	rdfs:range MIXS:SrLithologyEnum ;
	skos:definition "Lithology of source rock (https://en.wikipedia.org/wiki/Source_rock). If \"other\" is specified, please propose entry in \"additional info\" field" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000996 dcterms:title "source rock depositional environment" ;
	schema1:keywords "environment" , "source" ;
	a owl:ObjectProperty ;
	rdfs:label "sr_dep_env" ;
	rdfs:range MIXS:SrDepEnvEnum ;
	skos:definition "Source rock depositional environment (https://en.wikipedia.org/wiki/Source_rock). If \"other\" is specified, please propose entry in \"additional info\" field" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000997 dcterms:title "source rock geological age" ;
	schema1:keywords "age" , "source" ;
	a owl:ObjectProperty ;
	rdfs:label "sr_geol_age" ;
	rdfs:range MIXS:GeolAgeEnum ;
	skos:definition "Geological age of source rock (Additional info: https://en.wikipedia.org/wiki/Period_(geology)). If \"other\" is specified, please propose entry in \"additional info\" field" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000998 dcterms:title "sample type" ;
	schema1:keywords "sample" , "type" ;
	a owl:DatatypeProperty ;
	rdfs:label "samp_type" ;
	rdfs:range xsd:string ;
	skos:definition "The type of material from which the sample was obtained. For the Hydrocarbon package, samples include types like core, rock trimmings, drill cuttings, piping section, coupon, pigging debris, solid deposit, produced fluid, produced water, injected water, swabs, etc. For the Food Package, samples are usually categorized as food, body products or tissues, or environmental material. This field accepts terms listed under environmental specimen (http://purl.obolibrary.org/obo/GENEPIO_0001246)" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000999 dcterms:title "sample subtype" ;
	schema1:keywords "sample" ;
	a owl:ObjectProperty ;
	rdfs:label "samp_subtype" ;
	rdfs:range MIXS:SampSubtypeEnum ;
	skos:definition "Name of sample sub-type. For example if \"sample type\" is \"Produced Water\" then subtype could be \"Oil Phase\" or \"Water Phase\". If \"other\" is specified, please propose entry in \"additional info\" field" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001001 dcterms:title "pH" ;
	schema1:keywords "ph" ;
	a owl:DatatypeProperty ;
	rdfs:label "ph" ;
	rdfs:range xsd:float ;
	skos:definition "pH measurement of the sample, or liquid portion of sample, or aqueous phase of the fluid" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001008 dcterms:title "production start date" ;
	schema1:keywords "date" , "production" , "start" ;
	a owl:DatatypeProperty ;
	rdfs:label "prod_start_date" ;
	rdfs:range xsd:dateTime ;
	skos:definition "Date of field's first production" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001009 dcterms:title "secondary and tertiary recovery methods and start date" ;
	schema1:keywords "date" , "method" , "recover" , "secondary" , "start" ;
	a owl:DatatypeProperty ;
	rdfs:label "add_recov_method" ;
	skos:definition "Additional (i.e. Secondary, tertiary, etc.) recovery methods deployed for increase of hydrocarbon recovery from resource and start date for each one of them. If \"other\" is specified, please propose entry in \"additional info\" field" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001010 dcterms:title "injection water breakthrough date of specific well" ;
	schema1:keywords "date" , "water" ;
	a owl:DatatypeProperty ;
	rdfs:label "iw_bt_date_well" ;
	rdfs:range xsd:dateTime ;
	skos:definition "Injection water breakthrough date per well following a secondary and/or tertiary recovery" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001011 dcterms:title "biocide administration" ;
	schema1:keywords "administration" ;
	a owl:DatatypeProperty ;
	rdfs:label "biocide" ;
	skos:definition "List of biocides (commercial name of product and supplier) and date of administration" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "name;name;timestamp" .
MIXS:0001012 dcterms:title "chemical treatment" ;
	schema1:keywords "treatment" ;
	a owl:DatatypeProperty ;
	rdfs:label "chem_treatment" ;
	skos:definition "List of chemical compounds administered upstream the sampling location where sampling occurred (e.g. Glycols, H2S scavenger, corrosion and scale inhibitors, demulsifiers, and other production chemicals etc.). The commercial name of the product and name of the supplier should be provided. The date of administration should also be included" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "name;name;timestamp" .
MIXS:0001015 dcterms:title "sample collection point" ;
	schema1:keywords "sample" ;
	a owl:ObjectProperty ;
	rdfs:label "samp_collect_point" ;
	rdfs:range MIXS:SampCollectPointEnum ;
	skos:definition "Sampling point on the asset were sample was collected (e.g. Wellhead, storage tank, separator, etc). If \"other\" is specified, please propose entry in \"additional info\" field" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001038 dcterms:title "biotic regimen" ;
	schema1:keywords "regimen" ;
	a owl:DatatypeProperty ;
	rdfs:label "biotic_regm" ;
	rdfs:range xsd:string ;
	skos:definition "Information about treatment(s) involving use of biotic factors, such as bacteria, viruses or fungi" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001040 dcterms:title "climate environment" ;
	schema1:keywords "environment" ;
	a owl:DatatypeProperty ;
	rdfs:label "climate_environment" ;
	rdfs:range xsd:string ;
	skos:definition "Treatment involving an exposure to a particular climate; treatment regimen including how many times the treatment was repeated, how long each treatment lasted, and the start and end time of the entire treatment; can include multiple climates" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001041 dcterms:title "culture rooting medium" ;
	schema1:keywords "culture" ;
	a owl:DatatypeProperty ;
	rdfs:label "cult_root_med" ;
	skos:definition "Name or reference for the hydroponic or in vitro culture rooting medium; can be the name of a commonly used medium or reference to a specific medium, e.g. Murashige and Skoog medium. If the medium has not been formally published, use the rooting medium descriptors" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001043 dcterms:title "growth facility" ;
	schema1:keywords "facility" , "growth" ;
	a owl:DatatypeProperty ;
	rdfs:label "growth_facil" ;
	skos:definition "Type of facility where the sampled plant was grown; controlled vocabulary: growth chamber, open top chamber, glasshouse, experimental garden, field. Alternatively use Crop Ontology (CO) terms, see http://www.cropontology.org/ontology/CO_715/Crop%20Research" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "free text or CO" .
MIXS:0001044 dcterms:title "growth habit" ;
	schema1:keywords "growth" ;
	a owl:ObjectProperty ;
	rdfs:label "growth_habit" ;
	rdfs:range MIXS:GrowthHabitEnum ;
	skos:definition "Characteristic shape, appearance or growth form of a plant species" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001052 dcterms:title "mechanical damage" ;
	a owl:DatatypeProperty ;
	rdfs:label "mechanical_damage" ;
	skos:definition "Information about any mechanical damage exerted on the plant; can include multiple damages and sites" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "damage type;body site" .
MIXS:0001056 dcterms:title "pH regimen" ;
	schema1:keywords "ph" , "regimen" ;
	a owl:DatatypeProperty ;
	rdfs:label "ph_regm" ;
	rdfs:range xsd:string ;
	skos:definition "Information about treatment involving exposure of plants to varying levels of ph of the growth media, treatment regimen including how many times the treatment was repeated, how long each treatment lasted, and the start and end time of the entire treatment; can include multiple regimen" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001057 dcterms:title "plant growth medium" ;
	schema1:keywords "growth" , "plant" ;
	a owl:DatatypeProperty ;
	rdfs:label "plant_growth_med" ;
	skos:definition "Specification of the media for growing the plants or tissue cultured samples, e.g. soil, aeroponic, hydroponic, in vitro solid culture medium, in vitro liquid culture medium. Recommended value is a specific value from EO:plant growth medium (follow this link for terms http://purl.obolibrary.org/obo/EO_0007147) or other controlled vocabulary" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "EO or enumeration" .
MIXS:0001058 dcterms:title "plant product" ;
	schema1:keywords "plant" , "product" ;
	a owl:DatatypeProperty ;
	rdfs:label "plant_product" ;
	rdfs:range xsd:string ;
	skos:definition "Substance produced by the plant, where the sample was obtained from" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "product name" .
MIXS:0001059 dcterms:title "plant sex" ;
	schema1:keywords "plant" ;
	a owl:ObjectProperty ;
	rdfs:label "plant_sex" ;
	rdfs:range MIXS:PlantSexEnum ;
	skos:definition "Sex of the reproductive parts on the whole plant, e.g. pistillate, staminate, monoecieous, hermaphrodite" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001060 dcterms:title "plant structure" ;
	schema1:keywords "plant" ;
	a owl:DatatypeProperty ;
	rdfs:label "plant_struc" ;
	rdfs:range xsd:string ;
	skos:definition "Name of plant structure the sample was obtained from; for Plant Ontology (PO) (v releases/2017-12-14) terms, see http://purl.bioontology.org/ontology/PO, e.g. petiole epidermis (PO_0000051). If an individual flower is sampled, the sex of it can be recorded here" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001061 dcterms:title "rooting conditions" ;
	schema1:keywords "condition" ;
	a owl:DatatypeProperty ;
	rdfs:label "root_cond" ;
	rdfs:range xsd:string ;
	skos:definition "Relevant rooting conditions such as field plot size, sowing density, container dimensions, number of plants per container" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001062 dcterms:title "rooting medium pH" ;
	schema1:keywords "ph" ;
	a owl:DatatypeProperty ;
	rdfs:label "root_med_ph" ;
	rdfs:range xsd:float ;
	skos:definition "pH measurement of the culture rooting medium; e.g. 5.5" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001063 dcterms:title "rooting medium solidifier" ;
	a owl:DatatypeProperty ;
	rdfs:label "root_med_solid" ;
	rdfs:range xsd:string ;
	skos:definition "Specification of the solidifying agent in the culture rooting medium; e.g. agar" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001068 dcterms:title "seasonal environment" ;
	schema1:keywords "environment" , "season" ;
	a owl:DatatypeProperty ;
	rdfs:label "season_environment" ;
	rdfs:range xsd:string ;
	skos:definition "Treatment involving an exposure to a particular season (e.g. Winter, summer, rabi, rainy etc.), treatment regimen including how many times the treatment was repeated, how long each treatment lasted, and the start and end time of the entire treatment" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001069 dcterms:title "standing water regimen" ;
	schema1:keywords "regimen" , "water" ;
	a owl:DatatypeProperty ;
	rdfs:label "standing_water_regm" ;
	rdfs:range xsd:string ;
	skos:definition "Treatment involving an exposure to standing water during a plant's life span, types can be flood water or standing water, treatment regimen including how many times the treatment was repeated, how long each treatment lasted, and the start and end time of the entire treatment; can include multiple regimens" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001070 dcterms:title "tissue culture growth media" ;
	schema1:keywords "culture" , "growth" ;
	a owl:DatatypeProperty ;
	rdfs:label "tiss_cult_growth_med" ;
	rdfs:range xsd:string ;
	skos:definition "Description of plant tissue culture growth media used" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001078 dcterms:title "sediment type" ;
	schema1:keywords "sediment" , "type" ;
	a owl:ObjectProperty ;
	rdfs:label "sediment_type" ;
	rdfs:range MIXS:SedimentTypeEnum ;
	skos:definition "Information about the sediment type based on major constituents" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001080 dcterms:title "current land use" ;
	schema1:keywords "land" , "use" ;
	a owl:DatatypeProperty ;
	rdfs:label "cur_land_use" ;
	skos:definition "Present state of sample site" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "enumeration" .
MIXS:0001081 dcterms:title "history/tillage" ;
	schema1:keywords "history" ;
	a owl:ObjectProperty ;
	rdfs:label "tillage" ;
	rdfs:range MIXS:TillageEnum ;
	skos:definition "Note method(s) used for tilling" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001082 dcterms:title "soil horizon" ;
	schema1:keywords "horizon" , "soil" ;
	a owl:ObjectProperty ;
	rdfs:label "soil_horizon" ;
	rdfs:range MIXS:SoilHorizonEnum ;
	skos:definition "Specific layer in the land area which measures parallel to the soil surface and possesses physical characteristics which differ from the layers above and beneath" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001083 dcterms:title "soil_taxonomic/FAO classification" ;
	schema1:keywords "classification" ;
	a owl:ObjectProperty ;
	rdfs:label "fao_class" ;
	rdfs:range MIXS:FaoClassEnum ;
	skos:definition "Soil classification from the FAO World soil distribution from International Soil Reference and Information Centre (ISRIC). The list of available soil classifications can be found at https://www.isric.org/explore/world-soil-distribution" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001084 dcterms:title "profile position" ;
	a owl:ObjectProperty ;
	rdfs:label "profile_position" ;
	rdfs:range MIXS:ProfilePositionEnum ;
	skos:definition "Cross-sectional position in the hillslope where sample was collected.sample area position in relation to surrounding areas" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001085 dcterms:title "drainage classification" ;
	schema1:keywords "classification" ;
	a owl:ObjectProperty ;
	rdfs:label "drainage_class" ;
	rdfs:range MIXS:DrainageClassEnum ;
	skos:definition "Drainage classification from a standard system such as the USDA system" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001086 dcterms:title "history/fire" ;
	schema1:keywords "history" ;
	a owl:DatatypeProperty ;
	rdfs:label "fire" ;
	rdfs:range xsd:dateTime ;
	skos:definition "Historical and/or physical evidence of fire" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001097 dcterms:title "atmospheric data" ;
	a owl:DatatypeProperty ;
	rdfs:label "atmospheric_data" ;
	skos:definition "Measurement of atmospheric data; can include multiple data" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "atmospheric data name;measurement value" .
MIXS:0001106 dcterms:title "pH method" ;
	schema1:keywords "method" , "ph" ;
	a owl:DatatypeProperty ;
	rdfs:label "ph_meth" ;
	rdfs:range xsd:string ;
	skos:definition "Reference or method used in determining pH" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001107 dcterms:title "sample name" ;
	schema1:keywords "sample" ;
	a owl:DatatypeProperty ;
	rdfs:label "samp_name" ;
	rdfs:range xsd:string ;
	skos:definition "A local identifier or name that for the material sample used for extracting nucleic acids, and subsequent sequencing. It can refer either to the original material collected or to any derived sub-samples. It can have any format, but we suggest that you make it concise, unique and consistent within your lab, and as informative as possible. INSDC requires every sample name from a single Submitter to be unique. Use of a globally unique identifier for the field source_mat_id is recommended in addition to sample_name" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "" .
MIXS:0001108 dcterms:title "growth medium" ;
	schema1:keywords "growth" ;
	a owl:DatatypeProperty ;
	rdfs:label "growth_medium" ;
	rdfs:range xsd:string ;
	skos:definition "A liquid or gel containing nutrients, salts, and other factors formulated to support the growth of microorganisms, cells, or plants (National Cancer Institute Thesaurus).  The name of the medium used to grow the microorganism" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001110 dcterms:title "farm watering water source" ;
	schema1:keywords "farm" , "source" , "water" ;
	a owl:ObjectProperty ;
	rdfs:label "farm_water_source" ;
	rdfs:range MIXS:FarmWaterSourceEnum ;
	skos:definition "Source of water used on the farm for irrigation of crops or watering of livestock" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001111 dcterms:title "plant water delivery method" ;
	schema1:keywords "delivery" , "method" , "plant" , "water" ;
	a owl:DatatypeProperty ;
	rdfs:label "plant_water_method" ;
	rdfs:range xsd:string ;
	skos:definition "Description of the equipment or method used to distribute water to crops. This field accepts termed listed under irrigation process (http://purl.obolibrary.org/obo/AGRO_00000006). Multiple terms can be separated by pipes" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001113 dcterms:title "animal feeding equipment" ;
	schema1:keywords "animal" , "equipment" ;
	a owl:DatatypeProperty ;
	rdfs:label "animal_feed_equip" ;
	skos:definition "Description of the feeding equipment used for livestock. This field accepts terms listed under feed delivery (http://opendata.inra.fr/EOL/EOL_0001757). Multiple terms can be separated by pipes" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "EOL:0001757" .
MIXS:0001114 dcterms:title "animal intrusion near sample source" ;
	schema1:keywords "animal" , "sample" , "source" ;
	a owl:DatatypeProperty ;
	rdfs:label "animal_intrusion" ;
	rdfs:range xsd:string ;
	skos:definition "Identification of animals intruding on the sample or sample site including invertebrates (such as pests or pollinators) and vertebrates (such as wildlife or domesticated animals). This field accepts terms under organism (http://purl.obolibrary.org/obo/NCIT_C14250). This field also accepts identification numbers from NCBI under https://www.ncbi.nlm.nih.gov/taxonomy. Multiple terms can be separated by pipes" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001115 dcterms:title "animal water delivery method" ;
	schema1:keywords "animal" , "delivery" , "method" , "water" ;
	a owl:DatatypeProperty ;
	rdfs:label "anim_water_method" ;
	rdfs:range xsd:string ;
	skos:definition "Description of the equipment or method used to distribute water to livestock. This field accepts termed listed under water delivery equipment (http://opendata.inra.fr/EOL/EOL_0001653). Multiple terms can be separated by pipes" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001116 dcterms:title "crop yield" ;
	schema1:keywords "crop" ;
	a owl:DatatypeProperty ;
	rdfs:label "crop_yield" ;
	rdfs:range xsd:string ;
	skos:definition "Amount of crop produced per unit or area of land" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "kilogram per metre square" .
MIXS:0001117 dcterms:title "culture result" ;
	schema1:keywords "culture" ;
	a owl:ObjectProperty ;
	rdfs:label "cult_result" ;
	rdfs:range MIXS:CultResultEnum ;
	skos:definition "Any result of a bacterial culture experiment reported as a binary assessment such as positive/negative, active/inactive" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001118 dcterms:title "culture result organism" ;
	schema1:keywords "culture" , "organism" ;
	a owl:DatatypeProperty ;
	rdfs:label "cult_result_org" ;
	rdfs:range xsd:string ;
	skos:definition "Taxonomic information about the cultured organism(s)" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001119 dcterms:title "culture target microbial analyte" ;
	schema1:keywords "culture" , "microbial" , "target" ;
	a owl:DatatypeProperty ;
	rdfs:label "cult_target" ;
	skos:definition "The target microbial analyte in terms of investigation scope. This field accepts terms under organism (http://purl.obolibrary.org/obo/NCIT_C14250). This field also accepts identification numbers from NCBI under https://www.ncbi.nlm.nih.gov/taxonomy" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "NCIT:C14250 or NCBI taxid or culture independent" .
MIXS:0001120 dcterms:title "degree of plant part maturity" ;
	schema1:keywords "degree" , "plant" ;
	a owl:DatatypeProperty ;
	rdfs:label "plant_part_maturity" ;
	skos:definition "A description of the stage of development of a plant or plant part based on maturity or ripeness. This field accepts terms listed under degree of plant maturity (http://purl.obolibrary.org/obo/FOODON_03530050)" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "FOODON:03530050" .
MIXS:0001121 dcterms:title "environment adjacent to site" ;
	schema1:keywords "adjacent" , "environment" , "site" ;
	a owl:DatatypeProperty ;
	rdfs:label "adjacent_environment" ;
	skos:definition "Description of the environmental system or features that are adjacent to the sampling site. This field accepts terms under ecosystem (http://purl.obolibrary.org/obo/ENVO_01001110) and human construction (http://purl.obolibrary.org/obo/ENVO_00000070). Multiple terms can be separated by pipes" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "ENVO_01001110 or ENVO_00000070" .
MIXS:0001122 dcterms:title "environmental feature adjacent water source" ;
	schema1:keywords "adjacent" , "environmental" , "feature" , "source" , "water" ;
	a owl:DatatypeProperty ;
	rdfs:label "water_source_adjac" ;
	rdfs:range xsd:string ;
	skos:definition "Description of the environmental features that are adjacent to the farm water source. This field accepts terms under ecosystem (http://purl.obolibrary.org/obo/ENVO_01001110) and human construction (http://purl.obolibrary.org/obo/ENVO_00000070). Multiple terms can be separated by pipes" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "ENVO_01001110 or ENVO_00000070" .
MIXS:0001123 dcterms:title "equipment shared with other farms" ;
	schema1:keywords "equipment" , "farm" ;
	a owl:DatatypeProperty ;
	rdfs:label "farm_equip_shared" ;
	rdfs:range xsd:string ;
	skos:definition "List of planting, growing or harvesting equipment shared with other farms. This field accepts terms listed under agricultural implement (http://purl.obolibrary.org/obo/AGRO_00000416). Multiple terms can be separated by pipes" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001124 dcterms:title "farm equipment sanitization" ;
	schema1:keywords "equipment" , "farm" ;
	a owl:DatatypeProperty ;
	rdfs:label "farm_equip_san" ;
	skos:definition "Method used to sanitize growing and harvesting equipment. This can including type and concentration of sanitizing solution.  Multiple terms can be separated by one or more pipes" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "text or commercial name of sanitizer or class of sanitizer or active ingredient in sanitizer" ;
	MIXS:Preferred_unit "parts per million" .
MIXS:0001125 dcterms:title "farm equipment sanitization frequency" ;
	schema1:keywords "equipment" , "farm" , "frequency" ;
	a owl:DatatypeProperty ;
	rdfs:label "farm_equip_san_freq" ;
	rdfs:range xsd:string ;
	skos:definition "The number of times farm equipment is cleaned. Frequency of cleaning might be on a Daily basis, Weekly, Monthly, Quarterly or Annually" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001126 dcterms:title "farm equipment used" ;
	schema1:keywords "equipment" , "farm" , "use" ;
	a owl:DatatypeProperty ;
	rdfs:label "farm_equip" ;
	rdfs:range xsd:string ;
	skos:definition "List of equipment used for planting, fertilization, harvesting, irrigation, land levelling, residue management, weeding or transplanting during the growing season.  This field accepts terms listed under agricultural implement (http://purl.obolibrary.org/obo/AGRO_00000416). Multiple terms can be separated by pipes" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001127 dcterms:title "fertilizer administration" ;
	schema1:keywords "administration" ;
	a owl:DatatypeProperty ;
	rdfs:label "fertilizer_admin" ;
	rdfs:range xsd:string ;
	skos:definition "Type of fertilizer or amendment added to the soil or water for the purpose of improving substrate health and quality for plant growth. This field accepts terms listed under agronomic fertilizer (http://purl.obolibrary.org/obo/AGRO_00002062). Multiple terms may apply and can be separated by pipes, listing in reverse chronological order" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001128 dcterms:title "fertilizer administration date" ;
	schema1:keywords "administration" , "date" ;
	a owl:DatatypeProperty ;
	rdfs:label "fertilizer_date" ;
	rdfs:range xsd:dateTime ;
	skos:definition "Date of administration of soil amendment or fertilizer. Multiple terms may apply and can be separated by pipes, listing in reverse chronological order" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001129 dcterms:title "food animal group size" ;
	schema1:keywords "animal" , "food" , "size" ;
	a owl:DatatypeProperty ;
	rdfs:label "animal_group_size" ;
	rdfs:range xsd:integer ;
	skos:definition "The number of food animals of the same species that are maintained together as a unit, i.e. a herd or flock" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001130 dcterms:title "food animal source diet" ;
	schema1:keywords "animal" , "diet" , "food" , "source" ;
	a owl:DatatypeProperty ;
	rdfs:label "animal_diet" ;
	rdfs:range xsd:string ;
	skos:definition "If the isolate is from a food animal, the type of diet eaten by the food animal.  Please list the main food staple and the setting, if appropriate.  For a list of acceptable animal feed terms or categories, please see http://www.feedipedia.org.  Multiple terms may apply and can be separated by pipes |Food product for animal covers foods intended for consumption by domesticated animals. Consult http://purl.obolibrary.org/obo/FOODON_03309997. If the proper descriptor is not listed please use text to describe the food type. Multiple terms can be separated by one or more pipes. If the proper descriptor is not listed please use text to describe the food product type" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "text or FOODON_03309997" .
MIXS:0001131 dcterms:title "food contact surface" ;
	schema1:keywords "food" , "surface" ;
	a owl:DatatypeProperty ;
	rdfs:label "food_contact_surf" ;
	skos:definition "The specific container or coating materials in direct contact with the food. Multiple values can be assigned.  This field accepts terms listed under food contact surface (http://purl.obolibrary.org/obo/FOODON_03500010)" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "FOODON:03500010" .
MIXS:0001132 dcterms:title "food container or wrapping" ;
	schema1:keywords "food" ;
	a owl:DatatypeProperty ;
	rdfs:label "food_contain_wrap" ;
	skos:definition "Type of container or wrapping defined by the main container material, the container form, and the material of the liner lids or ends. Also type of container or wrapping by form; prefer description by material first, then by form. This field accepts terms listed under food container or wrapping (http://purl.obolibrary.org/obo/FOODON_03490100)" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "FOODON:03490100" .
MIXS:0001133 dcterms:title "Food harvesting process" ;
	schema1:keywords "food" , "process" ;
	a owl:DatatypeProperty ;
	rdfs:label "food_harvest_proc" ;
	rdfs:range xsd:string ;
	skos:definition "A harvesting process is a process which takes in some food material from an individual or community of plant or animal organisms in a given context and time, and outputs a precursor or consumable food product. This may include a part of an organism or the whole, and may involve killing the organism" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001134 dcterms:title "food packing medium" ;
	schema1:keywords "food" ;
	a owl:DatatypeProperty ;
	rdfs:label "food_pack_medium" ;
	skos:definition "The medium in which the food is packed for preservation and handling or the medium surrounding homemade foods, e.g., peaches cooked in sugar syrup. The packing medium may provide a controlled environment for the food. It may also serve to improve palatability and consumer appeal.  This includes edible packing media (e.g. fruit juice), gas other than air (e.g. carbon dioxide), vacuum packed, or packed with aerosol propellant. This field accepts terms under food packing medium (http://purl.obolibrary.org/obo/FOODON_03480020). Multiple terms may apply and can be separated by pipes" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "FOODON:03480020" .
MIXS:0001135 dcterms:title "food preservation process" ;
	schema1:keywords "food" , "process" ;
	a owl:DatatypeProperty ;
	rdfs:label "food_preserv_proc" ;
	skos:definition "The methods contributing to the prevention or retardation of microbial, enzymatic or oxidative spoilage and thus to the extension of shelf life. This field accepts terms listed under food preservation process (http://purl.obolibrary.org/obo/FOODON_03470107)" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "FOODON:03470107" .
MIXS:0001136 dcterms:title "food production characteristics" ;
	schema1:keywords "food" , "production" ;
	a owl:DatatypeProperty ;
	rdfs:label "food_prod_char" ;
	rdfs:range xsd:string ;
	skos:definition "Descriptors of the food production system such as wild caught, free-range, organic, free-range, industrial, dairy, beef" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001137 dcterms:title "food shipping transportation method" ;
	schema1:keywords "food" , "method" , "transport" ;
	a owl:DatatypeProperty ;
	rdfs:label "food_trav_mode" ;
	rdfs:range xsd:string ;
	skos:definition "A descriptor for the method of movement of food commodity along the food distribution system.  This field accepts terms listed under travel mode (http://purl.obolibrary.org/obo/GENEPIO_0001064). If the proper descrptor is not listed please use text to describe the mode of travel. Multiple terms can be separated by one or more pipes" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001138 dcterms:title "food shipping transportation vehicle" ;
	schema1:keywords "food" , "transport" ;
	a owl:DatatypeProperty ;
	rdfs:label "food_trav_vehic" ;
	skos:definition "A descriptor for the mobile machine which is used to transport food commodities along the food distribution system.  This field accepts terms listed under vehicle (http://purl.obolibrary.org/obo/ENVO_01000604). If the proper descrptor is not listed please use text to describe the mode of travel. Multiple terms can be separated by one or more pipes" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "ENVO:01000604" .
MIXS:0001139 dcterms:title "food source" ;
	schema1:keywords "food" , "source" ;
	a owl:DatatypeProperty ;
	rdfs:label "food_source" ;
	skos:definition "Type of plant or animal from which the food product or its major ingredient is derived or a chemical food source [FDA CFSAN 1995]" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "FOODON term" .
MIXS:0001140 dcterms:title "food treatment process" ;
	schema1:keywords "food" , "process" , "treatment" ;
	a owl:DatatypeProperty ;
	rdfs:label "food_treat_proc" ;
	skos:definition "Used to specifically characterize a food product based on the treatment or processes applied to the product or any indexed ingredient. The processes include adding, substituting or removing components or modifying the food or component, e.g., through fermentation. Multiple values can be assigned. This fields accepts terms listed under food treatment process (http://purl.obolibrary.org/obo/FOODON_03460111)" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "FOODON:03460111" .
MIXS:0001141 dcterms:title "extreme weather event" ;
	schema1:keywords "event" , "extreme" , "weather" ;
	a owl:ObjectProperty ;
	rdfs:label "extr_weather_event" ;
	rdfs:range MIXS:ExtrWeatherEventEnum ;
	skos:definition "Unusual weather events that may have affected microbial populations. Multiple terms can be separated by pipes, listed in reverse chronological order" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001142 dcterms:title "extreme weather date" ;
	schema1:keywords "date" , "extreme" , "weather" ;
	a owl:DatatypeProperty ;
	rdfs:label "date_extr_weath" ;
	rdfs:range xsd:dateTime ;
	skos:definition "Date of unusual weather events that may have affected microbial populations. Multiple terms can be separated by pipes, listed in reverse chronological order" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001144 dcterms:title "intended consumer" ;
	schema1:keywords "consumer" ;
	a owl:DatatypeProperty ;
	rdfs:label "intended_consumer" ;
	skos:definition "Food consumer type, human or animal, for which the food product is produced and marketed. This field accepts terms listed under food consumer group (http://purl.obolibrary.org/obo/FOODON_03510136) or NCBI taxid" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "FOODON_03510136 or NCBI taxid" .
MIXS:0001145 dcterms:title "library preparation kit" ;
	schema1:keywords "kit" , "library" , "preparation" ;
	a owl:DatatypeProperty ;
	rdfs:label "library_prep_kit" ;
	rdfs:range xsd:string ;
	skos:definition "Packaged kits (containing adapters, indexes, enzymes, buffers etc.), tailored for specific sequencing workflows, which allow the simplified preparation of sequencing-ready libraries for small genomes, amplicons, and plasmids" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "name of library preparation kit" .
MIXS:0001146 dcterms:title "local air flow impediments" ;
	schema1:keywords "air" ;
	a owl:DatatypeProperty ;
	rdfs:label "air_flow_impede" ;
	skos:definition "Presence of objects in the area that would influence or impede air flow through the air filter" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "enumeration;obstruction type; distance from sampling device" .
MIXS:0001147 dcterms:title "lot number" ;
	schema1:keywords "number" ;
	a owl:DatatypeProperty ;
	rdfs:label "lot_number" ;
	skos:definition "A distinctive alpha-numeric identification code assigned by the manufacturer or distributor to a specific quantity of manufactured material or product within a batch. Synonym: Batch Number.  The submitter should provide lot number of the item followed by the item name for which the lot number was provided" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "lot number, item" .
MIXS:0001148 dcterms:title "mean seasonal humidity" ;
	schema1:keywords "humidity" , "mean" , "season" ;
	a owl:DatatypeProperty ;
	rdfs:label "season_humidity" ;
	rdfs:range xsd:float ;
	skos:definition "Average humidity of the region throughout the growing season" ;
	skos:inScheme <https://w3id.org/mixs> ;
	skos:note "percent or float?" .
MIXS:0001149 dcterms:title "part of plant or animal" ;
	schema1:keywords "animal" , "plant" ;
	a owl:DatatypeProperty ;
	rdfs:label "part_plant_animal" ;
	skos:definition "The anatomical part of the organism being involved in food production or consumption; e.g., a carrot is the root of the plant (root vegetable). This field accepts terms listed under part of plant or animal (http://purl.obolibrary.org/obo/FOODON_03420116)" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "FOODON:03420116" .
MIXS:0001150 dcterms:title "plant reproductive part" ;
	schema1:keywords "plant" ;
	a owl:ObjectProperty ;
	rdfs:label "plant_reprod_crop" ;
	rdfs:range MIXS:PlantReprodCropEnum ;
	skos:definition "Plant reproductive part used in the field during planting to start the crop" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001151 dcterms:title "purpose of sampling" ;
	schema1:keywords "purpose" ;
	a owl:DatatypeProperty ;
	rdfs:label "samp_purpose" ;
	skos:definition "The reason that the sample was collected" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "enumeration or {text}" .
MIXS:0001152 dcterms:title "repository name" ;
	a owl:DatatypeProperty ;
	rdfs:label "repository_name" ;
	rdfs:range xsd:string ;
	skos:definition "The name of the institution where the sample or DNA extract is held or \"sample not available\" if the sample was used in its entirety for analysis or otherwise not retained" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "Institution" .
MIXS:0001153 dcterms:title "sample pooling" ;
	schema1:keywords "pooling" , "sample" ;
	a owl:DatatypeProperty ;
	rdfs:label "samp_pooling" ;
	rdfs:range xsd:string ;
	skos:definition "Physical combination of several instances of like material, e.g. RNA extracted from samples or dishes of cell cultures into one big aliquot of cells. Please provide a short description of the samples that were pooled" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001154 dcterms:title "sample source material category" ;
	schema1:keywords "material" , "sample" , "source" ;
	a owl:DatatypeProperty ;
	rdfs:label "samp_source_mat_cat" ;
	skos:definition "This is the scientific role or category that the subject organism or material has with respect to an investigation.  This field accepts terms listed under specimen source material category (http://purl.obolibrary.org/obo/GENEPIO_0001237 or http://purl.obolibrary.org/obo/OBI_0100051)" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "GENEPIO:0001237" .
MIXS:0001155 dcterms:title "sequencing kit" ;
	schema1:keywords "kit" ;
	a owl:DatatypeProperty ;
	rdfs:label "sequencing_kit" ;
	rdfs:range xsd:string ;
	skos:definition "Pre-filled, ready-to-use reagent cartridges. Used to produce improved chemistry, cluster density and read length as well as improve quality (Q) scores. Reagent components are encoded to interact with the sequencing system to validate compatibility with user-defined applications. Indicate name of the sequencing kit" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "name of sequencing kit used" .
MIXS:0001156 dcterms:title "sequencing location" ;
	schema1:keywords "location" ;
	a owl:DatatypeProperty ;
	rdfs:label "sequencing_location" ;
	rdfs:range xsd:string ;
	skos:definition "The location the sequencing run was performed. Indicate the name of the lab or core facility where samples were sequenced" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001157 dcterms:title "serovar or serotype" ;
	a owl:DatatypeProperty ;
	rdfs:label "serovar_or_serotype" ;
	rdfs:range xsd:string ;
	skos:definition "A characterization of a cell or microorganism based on the antigenic properties of the molecules on its surface. Indicate the name of a serovar or serotype of interest. This field accepts terms under organism (http://purl.obolibrary.org/obo/NCIT_C14250). This field also accepts identification numbers from NCBI under https://www.ncbi.nlm.nih.gov/taxonomy" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001158 dcterms:title "soil conductivity" ;
	schema1:keywords "soil" ;
	a owl:DatatypeProperty ;
	rdfs:label "soil_conductivity" ;
	rdfs:range xsd:string ;
	skos:definition "Conductivity of some soil." ;
	skos:inScheme <https://w3id.org/mixs> ;
	skos:note "Soil electrical conductivity (EC) is a measure of how well soil water can carry an electrical current. Electrical conductivity of soil solution is a reliable indicator of its solute (cation or anion) concentration with 1 dS/m approximately equivalent to 10 meq/L (U.S. Salinity Laboratory Staff, 1954)." ;
	MIXS:Preferred_unit "milliSiemens per centimeter" .
MIXS:0001159 dcterms:title "soil cover" ;
	schema1:keywords "soil" ;
	a owl:DatatypeProperty ;
	rdfs:label "soil_cover" ;
	skos:definition "Material covering the sampled soil. This field accepts terms under ENVO:00010483, environmental material" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "subclass of 'environmental material', http://purl.obolibrary.org/obo/ENVO_00010483" .
MIXS:0001160 dcterms:title "soil pH" ;
	schema1:keywords "ph" , "soil" ;
	a owl:DatatypeProperty ;
	rdfs:label "soil_pH" ;
	rdfs:range xsd:float ;
	skos:definition "pH measurement of some soil at the time of sampling" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001161 dcterms:title "relative location of sample" ;
	schema1:keywords "location" , "relative" , "sample" ;
	a owl:DatatypeProperty ;
	rdfs:label "rel_location" ;
	rdfs:range xsd:string ;
	skos:definition "Location of sampled soil to other parts of the farm e.g. under crop plant, near irrigation ditch, from the dirt road" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001162 dcterms:title "soil sediment porosity" ;
	schema1:keywords "porosity" , "sediment" , "soil" ;
	a owl:DatatypeProperty ;
	rdfs:label "soil_porosity" ;
	skos:definition "Porosity of soil or deposited sediment is volume of voids divided by the total volume of sample" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "percent porosity" ;
	MIXS:Preferred_unit "percentage" .
MIXS:0001163 dcterms:title "soil temperature" ;
	schema1:keywords "soil" , "temperature" ;
	a owl:DatatypeProperty ;
	rdfs:label "soil_temp" ;
	rdfs:range xsd:string ;
	skos:definition "Temperature of soil at the time of sampling" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "degree Celsius" .
MIXS:0001164 dcterms:title "soil texture classification" ;
	schema1:keywords "classification" , "soil" , "texture" ;
	a owl:ObjectProperty ;
	rdfs:label "soil_texture_class" ;
	rdfs:range MIXS:SoilTextureClassEnum ;
	skos:definition "One of the 12 soil texture classes use to describe soil texture based on the relative proportion of different grain sizes  of mineral particles [sand (50 um to 2 mm), silt (2 um to 50 um), and clay (<2 um)] in a soil" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001167 dcterms:title "spike in organism" ;
	schema1:keywords "organism" , "spike" ;
	a owl:DatatypeProperty ;
	rdfs:label "spikein_org" ;
	rdfs:range xsd:string ;
	skos:definition "Taxonomic information about the spike-in organism(s). This field accepts terms under organism (http://purl.obolibrary.org/obo/NCIT_C14250). This field also accepts identification numbers from NCBI under https://www.ncbi.nlm.nih.gov/taxonomy. Multiple terms can be separated by pipes" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001168 dcterms:title "spike-in bacterial serovar or serotype" ;
	schema1:keywords "spike" ;
	a owl:DatatypeProperty ;
	rdfs:label "spikein_serovar" ;
	skos:definition "Taxonomic information about the spike-in organism(s) at the serovar or serotype level. This field accepts terms under organism (http://purl.obolibrary.org/obo/NCIT_C14250). This field also accepts identification numbers from NCBI under https://www.ncbi.nlm.nih.gov/taxonomy. Multiple terms can be separated by pipes" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "NCIT:C14250 or antigenic formula or serovar name" .
MIXS:0001169 dcterms:title "spike-in growth medium" ;
	schema1:keywords "growth" , "spike" ;
	a owl:DatatypeProperty ;
	rdfs:label "spikein_growth_med" ;
	rdfs:range xsd:string ;
	skos:definition "A liquid or gel containing nutrients, salts, and other factors formulated to support the growth of microorganisms, cells, or plants (National Cancer Institute Thesaurus).  A growth medium is a culture medium which has the disposition to encourage growth of particular bacteria to the exclusion of others in the same growth environment.  In this case, list the culture medium used to propagate the spike-in bacteria during preparation of spike-in inoculum. This field accepts terms listed under microbiological culture medium (http://purl.obolibrary.org/obo/MICRO_0000067). If the proper descriptor is not listed please use text to describe the spike in growth media" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001170 dcterms:title "spike-in microbial strain" ;
	schema1:keywords "microbial" , "spike" ;
	a owl:DatatypeProperty ;
	rdfs:label "spikein_strain" ;
	skos:definition "Taxonomic information about the spike-in organism(s) at the strain level. This field accepts terms under organism (http://purl.obolibrary.org/obo/NCIT_C14250). This field also accepts identification numbers from NCBI under https://www.ncbi.nlm.nih.gov/taxonomy. Multiple terms can be separated by pipes" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "NCIT:C14250 or NCBI taxid or text" .
MIXS:0001171 dcterms:title "spike-in with antibiotics" ;
	schema1:keywords "spike" ;
	a owl:DatatypeProperty ;
	rdfs:label "spikein_antibiotic" ;
	skos:definition "Antimicrobials used in research study to assess effects of exposure on microbiome of a specific site.  Please list antimicrobial, common name and/or class and concentration used for spike-in" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "drug name; concentration" .
MIXS:0001172 dcterms:title "spike-in with heavy metals" ;
	schema1:keywords "heavy" , "spike" ;
	a owl:DatatypeProperty ;
	rdfs:label "spikein_metal" ;
	skos:definition "Heavy metals used in research study to assess effects of exposure on microbiome of a specific site.  Please list heavy metals and concentration used for spike-in" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "heavy metal name or chemical symbol; concentration" .
MIXS:0001173 dcterms:title "timepoint" ;
	schema1:keywords "time" ;
	a owl:DatatypeProperty ;
	rdfs:label "timepoint" ;
	rdfs:range xsd:string ;
	skos:definition "Time point at which a sample or observation is made or taken from a biomaterial as measured from some reference point. Indicate the timepoint written in ISO 8601 format" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "hours or days" .
MIXS:0001174 dcterms:title "water delivery frequency" ;
	schema1:keywords "delivery" , "frequency" , "water" ;
	a owl:DatatypeProperty ;
	rdfs:label "water_frequency" ;
	skos:definition "Number of water delivery events within a given period of time" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "rate" ;
	MIXS:Preferred_unit "per day, per week, per month" .
MIXS:0001175 dcterms:title "water pH" ;
	schema1:keywords "ph" , "water" ;
	a owl:DatatypeProperty ;
	rdfs:label "water_pH" ;
	rdfs:range xsd:float ;
	skos:definition "pH measurement of some water at the time of sampling" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001176 dcterms:title "water source shared" ;
	schema1:keywords "source" , "water" ;
	a owl:DatatypeProperty ;
	rdfs:label "water_source_shared" ;
	skos:definition "Other users sharing access to the same water source. Multiple terms can be separated by one or more pipes" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "enumeration" .
MIXS:0001177 dcterms:title "enrichment protocol" ;
	schema1:keywords "enrichment" , "protocol" ;
	a owl:DatatypeProperty ;
	rdfs:label "enrichment_protocol" ;
	rdfs:range xsd:string ;
	skos:definition "The microbiological workflow or protocol followed to test for the presence or enumeration of the target microbial analyte(s). Please provide a PubMed or DOI reference for published protocols" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001178 dcterms:title "food quality date" ;
	schema1:keywords "date" , "food" , "quality" ;
	a owl:DatatypeProperty ;
	rdfs:label "food_quality_date" ;
	skos:definition "The date recommended for the use of the product while at peak quality, this date is not a reflection of safety unless used on infant formula this date is not a reflection of safety and is typically labeled on a food product as \"best if used by,\" best by,\" \"use by,\" or \"freeze by.\"" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "enumeration, date" .
MIXS:0001179 dcterms:title "Interagency Food Safety Analytics Collaboration (IFSAC) category" ;
	schema1:keywords "food" ;
	a owl:DatatypeProperty ;
	rdfs:label "IFSAC_category" ;
	rdfs:range xsd:string ;
	skos:definition "The IFSAC food categorization scheme has five distinct levels to which foods can be assigned, depending upon the type of food. First, foods are assigned to one of four food groups (aquatic animals, land animals, plants, and other). Food groups include increasingly specific food categories; dairy, eggs, meat and poultry, and game are in the land animal food group, and the category meat and poultry is further subdivided into more specific categories of meat (beef, pork, other meat) and poultry (chicken, turkey, other poultry). Finally, foods are differentiated by differences in food processing (such as pasteurized fluid dairy products, unpasteurized fluid dairy products, pasteurized solid and semi-solid dairy products, and unpasteurized solid and semi-solid dairy products. An IFSAC food category chart is available from https://www.cdc.gov/foodsafety/ifsac/projects/food-categorization-scheme.html PMID: 28926300" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "IFSAC term" .
MIXS:0001180 dcterms:title "animal housing system" ;
	schema1:keywords "animal" ;
	a owl:DatatypeProperty ;
	rdfs:label "animal_housing" ;
	rdfs:range xsd:string ;
	skos:definition "Description of the housing system of the livestock. This field accepts terms listed under terrestrial management housing system (http://opendata.inra.fr/EOL/EOL_0001605)" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001181 dcterms:title "culture isolation date" ;
	schema1:keywords "culture" , "date" , "isolation" ;
	a owl:DatatypeProperty ;
	rdfs:label "cult_isol_date" ;
	rdfs:range xsd:dateTime ;
	skos:definition "The datetime marking the end of a process in which a sample yields a positive result for the target microbial analyte(s) in the form of an isolated colony or colonies" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001182 dcterms:title "food cleaning process" ;
	schema1:keywords "food" , "process" ;
	a owl:ObjectProperty ;
	rdfs:label "food_clean_proc" ;
	rdfs:range MIXS:FoodCleanProcEnum ;
	skos:definition "The process of cleaning food to separate other environmental materials from the food source. Multiple terms can be separated by pipes" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001183 dcterms:title "collection site geographic feature" ;
	schema1:keywords "feature" , "geographic" , "site" ;
	a owl:DatatypeProperty ;
	rdfs:label "coll_site_geo_feat" ;
	skos:definition "Text or terms that describe the geographic feature where the food sample was obtained by the researcher. This field accepts selected terms listed under the following ontologies: anthropogenic geographic feature (http://purl.obolibrary.org/obo/ENVO_00000002), for example agricultural fairground [ENVO:01000986]; garden [ENVO:00000011} or any of its subclasses; market [ENVO:01000987]; water well [ENVO:01000002]; or human construction (http://purl.obolibrary.org/obo/ENVO_00000070)" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "ENVO:00000002 or ENVO:00000070" .
MIXS:0001184 dcterms:title "food product type" ;
	schema1:keywords "food" , "product" , "type" ;
	a owl:DatatypeProperty ;
	rdfs:label "food_product_type" ;
	skos:definition "A food product type is a class of food products that is differentiated by its food composition (e.g., single- or multi-ingredient), processing and/or consumption characteristics. This does not include brand name products but it may include generic food dish categories. This field accepts terms under food product type (http://purl.obolibrary.org/obo/FOODON:03400361). For terms related to food product for an animal, consult food product for animal (http://purl.obolibrary.org/obo/FOODON_03309997). If the proper descriptor is not listed please use text to describe the food type. Multiple terms can be separated by one or more pipes" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "FOODON:00001002 or FOODON:03309997" .
MIXS:0001185 dcterms:title "fermentation chemical additives" ;
	schema1:keywords "fermentation" ;
	a owl:DatatypeProperty ;
	rdfs:label "ferm_chem_add" ;
	skos:definition "Any chemicals that are added to the fermentation process to achieve the desired final product" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "chemical ingredient" .
MIXS:0001186 dcterms:title "fermentation chemical additives percentage" ;
	schema1:keywords "fermentation" , "percent" ;
	a owl:DatatypeProperty ;
	rdfs:label "ferm_chem_add_perc" ;
	rdfs:range xsd:float ;
	skos:definition "The amount of chemical added to the fermentation process" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "percentage" .
MIXS:0001187 dcterms:title "fermentation headspace oxygen" ;
	schema1:keywords "fermentation" , "oxygen" ;
	a owl:DatatypeProperty ;
	rdfs:label "ferm_headspace_oxy" ;
	rdfs:range xsd:float ;
	skos:definition "The amount of headspace oxygen in a fermentation vessel" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "percentage" .
MIXS:0001188 dcterms:title "fermentation medium" ;
	schema1:keywords "fermentation" ;
	a owl:DatatypeProperty ;
	rdfs:label "ferm_medium" ;
	rdfs:range xsd:string ;
	skos:definition "The growth medium used for the fermented food fermentation process, which supplies the required nutrients.  Usually this includes a carbon and nitrogen source, water, micronutrients and chemical additives" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001189 dcterms:title "fermentation pH" ;
	schema1:keywords "fermentation" , "ph" ;
	a owl:DatatypeProperty ;
	rdfs:label "ferm_pH" ;
	rdfs:range xsd:float ;
	skos:definition "The pH of the fermented food fermentation process" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001190 dcterms:title "fermentation relative humidity" ;
	schema1:keywords "fermentation" , "humidity" , "relative" ;
	a owl:DatatypeProperty ;
	rdfs:label "ferm_rel_humidity" ;
	rdfs:range xsd:string ;
	skos:definition "The relative humidity of the fermented food fermentation process" ;
	skos:inScheme <https://w3id.org/mixs> ;
	skos:note "percent or float?" ;
	MIXS:Preferred_unit "percentage" .
MIXS:0001191 dcterms:title "fermentation temperature" ;
	schema1:keywords "fermentation" , "temperature" ;
	a owl:DatatypeProperty ;
	rdfs:label "ferm_temp" ;
	rdfs:range xsd:string ;
	skos:definition "The temperature of the fermented food fermentation process" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "degree Celsius" .
MIXS:0001192 dcterms:title "fermentation time" ;
	schema1:keywords "fermentation" , "time" ;
	a owl:DatatypeProperty ;
	rdfs:label "ferm_time" ;
	rdfs:range xsd:string ;
	skos:definition "The time duration of the fermented food fermentation process" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "days" .
MIXS:0001193 dcterms:title "fermentation vessel" ;
	schema1:keywords "fermentation" ;
	a owl:DatatypeProperty ;
	rdfs:label "ferm_vessel" ;
	rdfs:range xsd:string ;
	skos:definition "The type of vessel used for containment of the fermentation" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001194 dcterms:title "bacteria density" ;
	schema1:keywords "density" ;
	a owl:DatatypeProperty ;
	rdfs:label "bacterial_density" ;
	rdfs:range xsd:string ;
	skos:definition "Number of bacteria in sample, as defined by bacteria density (http://purl.obolibrary.org/obo/GENEPIO_0000043)" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "colony forming units per milliliter; colony forming units per gram of dry weight" .
MIXS:0001195 dcterms:title "food stored by consumer (storage duration)" ;
	schema1:keywords "consumer" , "duration)" , "food" , "storage" ;
	a owl:DatatypeProperty ;
	rdfs:label "cons_food_stor_dur" ;
	rdfs:range xsd:string ;
	skos:definition "The storage duration of the food commodity by the consumer, prior to onset of illness or sample collection.  Indicate the timepoint written in ISO 8601 format" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "hours or days" .
MIXS:0001196 dcterms:title "food stored by consumer (storage temperature)" ;
	schema1:keywords "consumer" , "food" , "storage" , "temperature" ;
	a owl:DatatypeProperty ;
	rdfs:label "cons_food_stor_temp" ;
	skos:definition "Temperature at which food commodity was stored by the consumer, prior to onset of illness or sample collection" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "text or measurement value" ;
	MIXS:Preferred_unit "degree Celsius" .
MIXS:0001197 dcterms:title "purchase date" ;
	schema1:keywords "date" ;
	a owl:DatatypeProperty ;
	rdfs:label "cons_purch_date" ;
	rdfs:range xsd:dateTime ;
	skos:definition "The date a food product was purchased by consumer" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001198 dcterms:title "quantity purchased" ;
	schema1:keywords "quantity" ;
	a owl:DatatypeProperty ;
	rdfs:label "cons_qty_purchased" ;
	rdfs:range xsd:string ;
	skos:definition "The quantity of food purchased by consumer" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001199 dcterms:title "dietary claim or use" ;
	schema1:keywords "diet" , "use" ;
	a owl:DatatypeProperty ;
	rdfs:label "dietary_claim_use" ;
	skos:definition "These descriptors are used either for foods intended for special dietary use as defined in 21 CFR 105 or for foods that have special characteristics indicated in the name or labeling. This field accepts terms listed under dietary claim or use (http://purl.obolibrary.org/obo/FOODON_03510023). Multiple terms can be separated by one or more pipes, but please consider limiting this list to the most prominent dietary claim or use" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "FOODON:03510023" .
MIXS:0001200 dcterms:title "food additive" ;
	schema1:keywords "food" ;
	a owl:DatatypeProperty ;
	rdfs:label "food_additive" ;
	skos:definition "A substance or substances added to food to maintain or improve safety and freshness, to improve or maintain nutritional value, or improve taste, texture and appearance.  This field accepts terms listed under food additive (http://purl.obolibrary.org/obo/FOODON_03412972). Multiple terms can be separated by one or more pipes, but please consider limiting this list to the top 5 ingredients listed in order as on the food label.  See also, https://www.fda.gov/food/food-ingredients-packaging/overview-food-ingredients-additives-colors" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "FOODON:03412972" .
MIXS:0001201 dcterms:title "food allergen labeling" ;
	schema1:keywords "food" ;
	a owl:DatatypeProperty ;
	rdfs:label "food_allergen_label" ;
	skos:definition "A label indication that the product contains a recognized allergen. This field accepts terms listed under dietary claim or use (http://purl.obolibrary.org/obo/FOODON_03510213)" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "FOODON:03510213" .
MIXS:0001202 dcterms:title "food cooking process" ;
	schema1:keywords "food" , "process" ;
	a owl:DatatypeProperty ;
	rdfs:label "food_cooking_proc" ;
	skos:definition "The transformation of raw food by the application of heat. This field accepts terms listed under food cooking (http://purl.obolibrary.org/obo/FOODON_03450002)" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "FOODON:03450002" .
MIXS:0001203 dcterms:title "food distribution point geographic location" ;
	schema1:keywords "food" , "geographic" , "location" ;
	a owl:DatatypeProperty ;
	rdfs:label "food_dis_point" ;
	rdfs:range xsd:string ;
	skos:definition "A reference to a place on the Earth, by its name or by its geographical location that refers to a distribution point along the food chain. This field accepts terms listed under geographic location (http://purl.obolibrary.org/obo/GAZ_00000448). Reference: Adam Diamond, James Barham. Moving Food Along the Value Chain: Innovations in Regional Food Distribution. U.S. Dept. of Agriculture, Agricultural Marketing Service. Washington, DC. March 2012. http://dx.doi.org/10.9752/MS045.03-2012" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001204 dcterms:title "food distribution point geographic location (city)" ;
	schema1:keywords "food" , "geographic" , "location" ;
	a owl:DatatypeProperty ;
	rdfs:label "food_dis_point_city" ;
	skos:definition "A reference to a place on the Earth, by its name or by its geographical location that refers to a distribution point along the food chain. This field accepts terms listed under geographic location (http://purl.obolibrary.org/obo/GAZ_00000448). Reference: Adam Diamond, James Barham. Moving Food Along the Value Chain: Innovations in Regional Food Distribution. U.S. Dept. of Agriculture, Agricultural Marketing Service. Washington, DC. March 2012. http://dx.doi.org/10.9752/MS045.03-2012" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "GAZ:00000448" .
MIXS:0001205 dcterms:title "food ingredient" ;
	schema1:keywords "food" , "ingredient" ;
	a owl:DatatypeProperty ;
	rdfs:label "food_ingredient" ;
	skos:definition "In this field, please list individual ingredients for multi-component food [FOODON:00002501] and simple foods that is not captured in food_type.  Please use terms that are present in FoodOn.  Multiple terms can be separated by one or more pipes |, but please consider limiting this list to the top 5 ingredients listed in order as on the food label.  See also, https://www.fda.gov/food/food-ingredients-packaging/overview-food-ingredients-additives-colors" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "FOODON" .
MIXS:0001206 dcterms:title "food product name legal status" ;
	schema1:keywords "food" , "product" , "status" ;
	a owl:DatatypeProperty ;
	rdfs:label "food_name_status" ;
	rdfs:range xsd:string ;
	skos:definition "A datum indicating that use of a food product name is regulated in some legal jurisdiction. This field accepts terms listed under food product name legal status (http://purl.obolibrary.org/obo/FOODON_03530087)" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001207 dcterms:title "food product origin geographic location" ;
	schema1:keywords "food" , "geographic" , "location" , "product" ;
	a owl:DatatypeProperty ;
	rdfs:label "food_origin" ;
	rdfs:range xsd:string ;
	skos:definition "A reference to a place on the Earth, by its name or by its geographical location that describes the origin of the food commodity, either in terms of its cultivation or production. This field accepts terms listed under geographic location (http://purl.obolibrary.org/obo/GAZ_00000448)" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001208 dcterms:title "food package capacity" ;
	schema1:keywords "food" , "package" ;
	a owl:DatatypeProperty ;
	rdfs:label "food_pack_capacity" ;
	rdfs:range xsd:string ;
	skos:definition "The maximum number of product units within a package" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "grams" .
MIXS:0001209 dcterms:title "food packing medium integrity" ;
	schema1:keywords "food" ;
	a owl:DatatypeProperty ;
	rdfs:label "food_pack_integrity" ;
	skos:definition "A term label and term id to describe the state of the packing material and text to explain the exact condition.  This field accepts terms listed under food packing medium integrity (http://purl.obolibrary.org/obo/FOODON_03530218)" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "FOODON:03530218" .
MIXS:0001210 dcterms:title "material of contact prior to food packaging" ;
	schema1:keywords "food" , "material" , "prior" ;
	a owl:DatatypeProperty ;
	rdfs:label "food_prior_contact" ;
	skos:definition "The material the food contacted (e.g., was processed in) prior to packaging. This field accepts terms listed under material of contact prior to food packaging (http://purl.obolibrary.org/obo/FOODON_03530077). If the proper descriptor is not listed please use text to describe the material of contact prior to food packaging" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "FOODON:03530077" .
MIXS:0001211 dcterms:title "food production system characteristics" ;
	schema1:keywords "food" , "production" ;
	a owl:DatatypeProperty ;
	rdfs:label "food_prod" ;
	rdfs:range xsd:string ;
	skos:definition "Descriptors of the food production system or of the agricultural environment and growing conditions related to the farm production system, such as wild caught, organic, free-range, industrial, dairy, beef,  domestic or cultivated food production. This field accepts terms listed under food production (http://purl.obolibrary.org/obo/FOODON_03530206). Multiple terms may apply and can be separated by pipes" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001212 dcterms:title "food product synonym" ;
	schema1:keywords "food" , "product" ;
	a owl:DatatypeProperty ;
	rdfs:label "food_prod_synonym" ;
	rdfs:range xsd:string ;
	skos:definition "Other names by which the food product is known by (e.g., regional or non-English names)" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001213 dcterms:title "food product by quality" ;
	schema1:keywords "food" , "product" , "quality" ;
	a owl:DatatypeProperty ;
	rdfs:label "food_product_qual" ;
	rdfs:range xsd:string ;
	skos:definition "Descriptors for describing food visually or via other senses, which is useful for tasks like food inspection where little prior knowledge of how the food came to be is available. Some terms like \"food (frozen)\" are both a quality descriptor and the output of a process. This field accepts terms listed under food product by quality (http://purl.obolibrary.org/obo/FOODON_00002454)" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001214 dcterms:title "food traceability list category" ;
	schema1:keywords "food" ;
	a owl:ObjectProperty ;
	rdfs:label "food_trace_list" ;
	rdfs:range MIXS:FoodTraceListEnum ;
	skos:definition "The FDA is proposing to establish additional traceability recordkeeping requirements (beyond what is already required in existing regulations) for persons who manufacture, process, pack, or hold foods the Agency has designated for inclusion on the Food Traceability List. The Food Traceability List (FTL) identifies the foods for which the additional traceability records described in the proposed rule would be required. The term  Food Traceability List  (FTL) refers not only to the foods specifically listed (https://www.fda.gov/media/142303/download), but also to any foods that contain listed foods as ingredients" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001215 dcterms:title "Hazard Analysis Critical Control Points (HACCP) guide food safety term" ;
	schema1:keywords "food" , "term" ;
	a owl:DatatypeProperty ;
	rdfs:label "HACCP_term" ;
	rdfs:range xsd:string ;
	skos:definition "Hazard Analysis Critical Control Points (HACCP) food safety terms; This field accepts terms listed under HACCP guide food safety term (http://purl.obolibrary.org/obo/FOODON_03530221)" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001216 dcterms:title "microbiological culture medium" ;
	schema1:keywords "culture" , "microbiological" ;
	a owl:DatatypeProperty ;
	rdfs:label "microb_cult_med" ;
	rdfs:range xsd:string ;
	skos:definition "A culture medium used to select for, grow, and maintain prokaryotic microorganisms. Can be in either liquid (broth) or solidified (e.g. with agar) forms. This field accepts terms listed under microbiological culture medium (http://purl.obolibrary.org/obo/MICRO_0000067). If the proper descriptor is not listed please use text to describe the culture medium" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001217 dcterms:title "microbial starter" ;
	schema1:keywords "microbial" ;
	a owl:DatatypeProperty ;
	rdfs:label "microb_start" ;
	skos:definition "Any type of microorganisms used in food production.  This field accepts terms listed under live organisms for food production (http://purl.obolibrary.org/obo/FOODON_0344453)" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "FOODON:03544453" .
MIXS:0001218 dcterms:title "microbial starter organism count" ;
	schema1:keywords "count" , "microbial" , "organism" ;
	a owl:DatatypeProperty ;
	rdfs:label "microb_start_count" ;
	skos:definition "Total cell count of starter culture per gram, volume or area of sample and the method that was used for the enumeration (e.g. qPCR, atp, mpn, etc.) should also be provided. (example : total prokaryotes; 3.5e7 cells per ml; qPCR)" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "organism name; measurement value; enumeration" ;
	MIXS:Preferred_unit "colony forming units per milliliter; colony forming units per gram of dry weight" .
MIXS:0001219 dcterms:title "microbial starter inoculation" ;
	schema1:keywords "microbial" ;
	a owl:DatatypeProperty ;
	rdfs:label "microb_start_inoc" ;
	rdfs:range xsd:string ;
	skos:definition "The amount of starter culture used to inoculate a new batch" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "milligram or gram" .
MIXS:0001220 dcterms:title "microbial starter preparation" ;
	schema1:keywords "microbial" , "preparation" ;
	a owl:DatatypeProperty ;
	rdfs:label "microb_start_prep" ;
	rdfs:range xsd:string ;
	skos:definition "Information about the protocol or method used to prepare the starter inoculum" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001221 dcterms:title "microbial starter source" ;
	schema1:keywords "microbial" , "source" ;
	a owl:DatatypeProperty ;
	rdfs:label "microb_start_source" ;
	rdfs:range xsd:string ;
	skos:definition "The source from which the microbial starter culture was sourced.  If commercially supplied, list supplier" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001222 dcterms:title "microbial starter NCBI taxonomy ID" ;
	schema1:keywords "identifier" , "microbial" , "ncbi" , "taxon" ;
	a owl:DatatypeProperty ;
	rdfs:label "microb_start_taxID" ;
	rdfs:range xsd:string ;
	skos:definition "Please include Genus species and strain ID, if known of microorganisms used in food production. For complex communities, pipes can be used to separate two or more microbes" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001223 dcterms:title "nucleic acid extraction kit" ;
	schema1:keywords "kit" ;
	a owl:DatatypeProperty ;
	rdfs:label "nucl_acid_ext_kit" ;
	rdfs:range xsd:string ;
	skos:definition "The name of the extraction kit used to recover the nucleic acid fraction of an input material is performed" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "The name of an extraction kit" .
MIXS:0001224 dcterms:title "number of samples collected" ;
	schema1:keywords "number" , "sample" ;
	a owl:DatatypeProperty ;
	rdfs:label "num_samp_collect" ;
	rdfs:range xsd:string ;
	skos:definition "The number of samples collected during the current sampling event" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001225 dcterms:title "sample collection method" ;
	schema1:keywords "method" , "sample" ;
	a owl:DatatypeProperty ;
	rdfs:label "samp_collect_method" ;
	rdfs:range xsd:string ;
	skos:definition "The method employed for collecting the sample" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001226 dcterms:title "biological sample replicate" ;
	schema1:keywords "sample" ;
	a owl:DatatypeProperty ;
	rdfs:label "samp_rep_biol" ;
	rdfs:range xsd:string ;
	skos:definition "Measurements of biologically distinct samples that show biological variation" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001227 dcterms:title "technical sample replicate" ;
	schema1:keywords "sample" ;
	a owl:DatatypeProperty ;
	rdfs:label "samp_rep_tech" ;
	rdfs:range xsd:string ;
	skos:definition "Repeated measurements of the same sample that show independent measures of the noise associated with the equipment and the protocols" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001228 dcterms:title "sample storage device" ;
	schema1:keywords "device" , "sample" , "storage" ;
	a owl:DatatypeProperty ;
	rdfs:label "samp_stor_device" ;
	skos:definition "The container used to store the  sample. This field accepts terms listed under container (http://purl.obolibrary.org/obo/NCIT_C43186). If the proper descriptor is not listed please use text to describe the storage device" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "NCIT:C4318" .
MIXS:0001229 dcterms:title "sample storage media" ;
	schema1:keywords "sample" , "storage" ;
	a owl:DatatypeProperty ;
	rdfs:label "samp_stor_media" ;
	rdfs:range xsd:string ;
	skos:definition "The liquid that is added to the sample collection device prior to sampling. If the sample is pre-hydrated, indicate the liquid media the sample is pre-hydrated with for storage purposes. This field accepts terms listed under microbiological culture medium (http://purl.obolibrary.org/obo/MICRO_0000067). If the proper descriptor is not listed please use text to describe the sample storage media" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001230 dcterms:title "sample transport container" ;
	schema1:keywords "sample" , "transport" ;
	a owl:ObjectProperty ;
	rdfs:label "samp_transport_cont" ;
	rdfs:range MIXS:SampTransportContEnum ;
	skos:definition "Container in which the sample was stored during transport. Indicate the location name" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001231 dcterms:title "sample transport duration" ;
	schema1:keywords "duration" , "period" , "sample" , "transport" ;
	a owl:DatatypeProperty ;
	rdfs:label "samp_transport_dur" ;
	rdfs:range xsd:string ;
	skos:definition "The duration of time from when the sample was collected until processed. Indicate the duration for which the sample was stored written in ISO 8601 format" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "days" .
MIXS:0001232 dcterms:title "sample transport temperature" ;
	schema1:keywords "sample" , "temperature" , "transport" ;
	a owl:DatatypeProperty ;
	rdfs:label "samp_transport_temp" ;
	skos:definition "Temperature at which sample was transported, e.g. -20 or 4 degree Celsius" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "text or measurement value" ;
	MIXS:Preferred_unit "degree Celsius" .
MIXS:0001234 dcterms:title "specific intended consumer" ;
	schema1:keywords "consumer" ;
	a owl:DatatypeProperty ;
	rdfs:label "spec_intended_cons" ;
	rdfs:range xsd:string ;
	skos:definition "Food consumer type, human or animal, for which the food product is produced and marketed. This field accepts terms listed under food consumer group (http://purl.obolibrary.org/obo/FOODON_03510136)" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001235 dcterms:title "antimicrobial phenotype of spike-in bacteria" ;
	schema1:keywords "antimicrobial" , "spike" ;
	a owl:DatatypeProperty ;
	rdfs:label "spikein_AMR" ;
	skos:definition "Qualitative description of a microbial response to antimicrobial agents. Bacteria may be susceptible or resistant to a broad range of antibiotic drugs or drug classes, with several intermediate states or phases. This field accepts terms under antimicrobial phenotype (http://purl.obolibrary.org/obo/ARO_3004299)" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "measurement value ARO:3004299" .
MIXS:0001236 dcterms:title "study design" ;
	a owl:DatatypeProperty ;
	rdfs:label "study_design" ;
	skos:definition "A plan specification comprised of protocols (which may specify how and what kinds of data will be gathered) that are executed as part of an investigation and is realized during a study design execution. This field accepts terms under study design (http://purl.obolibrary.org/obo/OBI_0500000). If the proper descriptor is not listed please use text to describe the study design. Multiple terms can be separated by pipes" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "OBI:0500000" .
MIXS:0001237 dcterms:title "study incubation duration" ;
	schema1:keywords "duration" , "incubation" , "period" ;
	a owl:DatatypeProperty ;
	rdfs:label "study_inc_dur" ;
	rdfs:range xsd:string ;
	skos:definition "Sample incubation duration if unpublished or unvalidated method is used. Indicate the timepoint written in ISO 8601 format" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "hours or days" .
MIXS:0001238 dcterms:title "study incubation temperature" ;
	schema1:keywords "incubation" , "temperature" ;
	a owl:DatatypeProperty ;
	rdfs:label "study_inc_temp" ;
	rdfs:range xsd:string ;
	skos:definition "Sample incubation temperature if unpublished or unvalidated method is used" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "degree Celsius" .
MIXS:0001239 dcterms:title "time-course duration" ;
	schema1:keywords "duration" , "period" , "time" ;
	a owl:DatatypeProperty ;
	rdfs:label "study_timecourse" ;
	rdfs:range xsd:string ;
	skos:definition "For time-course research studies involving samples of the food commodity, indicate the total duration of the time-course study" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "dpi" .
MIXS:0001240 dcterms:title "study treatment" ;
	schema1:keywords "treatment" ;
	a owl:DatatypeProperty ;
	rdfs:label "study_tmnt" ;
	skos:definition "A process in which the act is intended to modify or alter some other material entity.  From the study design, each treatment is comprised of one level of one or multiple factors. This field accepts terms listed under treatment (http://purl.obolibrary.org/obo/MCO_0000866). If the proper descriptor is not listed please use text to describe the study treatment. Multiple terms can be separated by one or more pipes" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "MCO:0000866" .
MIXS:0001243 dcterms:title "food animal antimicrobial" ;
	schema1:keywords "animal" , "antimicrobial" , "food" ;
	a owl:DatatypeProperty ;
	rdfs:label "animal_am" ;
	rdfs:range xsd:string ;
	skos:definition "The name(s) (generic or brand) of the antimicrobial(s) given to the food animal within the last 30 days" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001244 dcterms:title "food animal antimicrobial duration" ;
	schema1:keywords "animal" , "antimicrobial" , "duration" , "food" , "period" ;
	a owl:DatatypeProperty ;
	rdfs:label "animal_am_dur" ;
	skos:definition "The duration of time (days) that the antimicrobial was administered to the food animal" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001245 dcterms:title "food animal antimicrobial frequency" ;
	schema1:keywords "animal" , "antimicrobial" , "food" , "frequency" ;
	a owl:DatatypeProperty ;
	rdfs:label "animal_am_freq" ;
	rdfs:range xsd:float ;
	skos:definition "The frequency per day that the antimicrobial was administered to the food animal" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001246 dcterms:title "food animal antimicrobial route of administration" ;
	schema1:keywords "administration" , "animal" , "antimicrobial" , "food" , "route" ;
	a owl:DatatypeProperty ;
	rdfs:label "animal_am_route" ;
	rdfs:range xsd:string ;
	skos:definition "The route by which the antimicrobial is administered into the body of the food animal" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001247 dcterms:title "food animal antimicrobial intended use" ;
	schema1:keywords "animal" , "antimicrobial" , "food" , "use" ;
	a owl:DatatypeProperty ;
	rdfs:label "animal_am_use" ;
	rdfs:range xsd:string ;
	skos:definition "The prescribed intended use of or the condition treated by the antimicrobial given to the food animal by any route of administration" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001248 dcterms:title "food animal body condition" ;
	schema1:keywords "animal" , "body" , "condition" , "food" ;
	a owl:ObjectProperty ;
	rdfs:label "animal_body_cond" ;
	rdfs:range MIXS:AnimalBodyCondEnum ;
	skos:definition "Body condition scoring is a production management tool used to evaluate overall health and nutritional needs of a food animal. Because there are different scoring systems, this field is restricted to three categories" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001249 dcterms:title "food animal source sex category" ;
	schema1:keywords "animal" , "food" , "source" ;
	a owl:ObjectProperty ;
	rdfs:label "animal_sex" ;
	rdfs:range MIXS:AnimalSexEnum ;
	skos:definition "The sex and reproductive status of the food animal" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001251 dcterms:title "food source age" ;
	schema1:keywords "age" , "food" , "source" ;
	a owl:DatatypeProperty ;
	rdfs:label "food_source_age" ;
	rdfs:range xsd:string ;
	skos:definition "The age of the food source host organism. Depending on the type of host organism, age may be more appropriate to report in days, weeks, or years" ;
	skos:inScheme <https://w3id.org/mixs> ;
	skos:note "ISO 8601 period or measurement value?" ;
	MIXS:Preferred_unit "days" .
MIXS:0001252 dcterms:title "facility type" ;
	schema1:keywords "facility" , "type" ;
	a owl:ObjectProperty ;
	rdfs:label "facility_type" ;
	rdfs:range MIXS:FacilityTypeEnum ;
	skos:definition "Establishment details about the type of facility where the sample was taken. This is independent of the specific product(s) within the facility" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001253 dcterms:title "hygienic food production area" ;
	schema1:keywords "area" , "food" , "production" ;
	a owl:DatatypeProperty ;
	rdfs:label "hygienic_area" ;
	rdfs:range xsd:string ;
	skos:definition "The subdivision of areas within a food production facility according to hygienic requirements. This field accepts terms listed under hygienic food production area (http://purl.obolibrary.org/obo/ENVO). Please add a term that most accurately indicates the hygienic area your sample was taken from according to the definitions provided" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "Expected value" .
MIXS:0001254 dcterms:title "food production environmental monitoring zone" ;
	schema1:keywords "environmental" , "food" , "production" ;
	a owl:DatatypeProperty ;
	rdfs:label "env_monitoring_zone" ;
	rdfs:range xsd:string ;
	skos:definition "An environmental monitoring zone is a formal designation as part of an environmental monitoring program, in which areas of a food production facility are categorized, commonly as zones 1-4, based on likelihood or risk of foodborne pathogen contamination. This field accepts terms listed under food production environmental monitoring zone (http://purl.obolibrary.org/obo/ENVO). Please add a term to indicate the environmental monitoring zone the sample was taken from" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "ENVO" .
MIXS:0001255 dcterms:title "area sampled size" ;
	schema1:keywords "area" , "sample" , "size" ;
	a owl:DatatypeProperty ;
	rdfs:label "area_samp_size" ;
	skos:definition "The total amount or size (volume (ml), mass (g) or area (m2) ) of sample collected" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "measurement value" ;
	MIXS:Preferred_unit "centimeter" .
MIXS:0001256 dcterms:title "sample surface moisture" ;
	schema1:keywords "moisture" , "sample" , "surface" ;
	a owl:ObjectProperty ;
	rdfs:label "samp_surf_moisture" ;
	rdfs:range MIXS:SampSurfMoistureEnum ;
	skos:definition "Degree of water held on a sampled surface.  If present, user can state the degree of water held on surface (intermittent moisture, submerged). If no surface moisture is present indicate not present" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001257 dcterms:title "sample location condition" ;
	schema1:keywords "condition" , "location" , "sample" ;
	a owl:ObjectProperty ;
	rdfs:label "samp_loc_condition" ;
	rdfs:range MIXS:SampLocConditionEnum ;
	skos:definition "The condition of the sample location at the time of sampling" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001258 dcterms:title "biocide" ;
	a owl:DatatypeProperty ;
	rdfs:label "biocide_used" ;
	rdfs:range xsd:string ;
	skos:definition "Substance intended for preventing, neutralizing, destroying, repelling, or mitigating the effects of any pest or microorganism; that inhibits the growth, reproduction, and activity of organisms, including fungal cells; decreases the number of fungi or pests present; deters microbial growth and degradation of other ingredients in the formulation. Indicate the biocide used on the location where the sample was taken. Multiple terms can be separated by pipes" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "commercial name of biocide, active ingredient in biocide or class of biocide" .
MIXS:0001259 dcterms:title "sampling room sterilization method" ;
	schema1:keywords "method" , "room" ;
	a owl:DatatypeProperty ;
	rdfs:label "ster_meth_samp_room" ;
	skos:definition "The method used to sterilize the sampling room. This field accepts terms listed under electromagnetic radiation (http://purl.obolibrary.org/obo/ENVO_01001026). If the proper descriptor is not listed, please use text to describe the sampling room sterilization method. Multiple terms can be separated by pipes" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "ENVO:01001026" .
MIXS:0001296 dcterms:title "photosynthetic activity" ;
	a owl:DatatypeProperty ;
	rdfs:label "photosynt_activ" ;
	rdfs:range xsd:string ;
	skos:definition "Measurement of photosythetic activity (i.e. leaf gas exchange / chlorophyll fluorescence emissions / reflectance / transpiration) Please also include the term method term detailing the method of activity measurement" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "mol m-2 s-1" .
MIXS:0001298 dcterms:title "observed host symbionts" ;
	schema1:keywords "host" , "host." , "observed" , "symbiosis" ;
	a owl:DatatypeProperty ;
	rdfs:label "host_symbiont" ;
	rdfs:range xsd:string ;
	skos:definition "The taxonomic name of the organism(s) found living in mutualistic, commensalistic, or parasitic symbiosis with the specific host. The sampled symbiont can have its own symbionts. For example, parasites may have hyperparasites (=parasites of the parasite)" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "species name or common name" .
MIXS:0001299 dcterms:title "duration of association with the host" ;
	schema1:keywords "duration" , "host" , "host." , "period" ;
	a owl:DatatypeProperty ;
	rdfs:label "association_duration" ;
	rdfs:range xsd:string ;
	skos:definition "Time spent in host of the symbiotic organism at the time of sampling; relevant scale depends on symbiotic organism and study" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "year, day, hour" .
MIXS:0001300 dcterms:title "symbiotic host organism life cycle type" ;
	schema1:keywords "host" , "host." , "life" , "organism" , "symbiosis" , "type" ;
	a owl:ObjectProperty ;
	rdfs:label "sym_life_cycle_type" ;
	rdfs:range MIXS:SymLifeCycleTypeEnum ;
	skos:definition "Type of life cycle of the symbiotic host species (the thing being sampled). Simple life cycles occur within a single host, complex ones within multiple different hosts over the course of their normal life cycle" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "type of life cycle of the symbiotic organism (host of the samples)" .
MIXS:0001303 dcterms:title "host of the symbiont role" ;
	schema1:keywords "host" , "host." , "symbiosis" ;
	a owl:ObjectProperty ;
	rdfs:label "symbiont_host_role" ;
	rdfs:range MIXS:SymbiontHostRoleEnum ;
	skos:definition "Role of the host in the life cycle of the symbiotic organism" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001305 dcterms:title "host number individual" ;
	schema1:keywords "host" , "host." , "number" ;
	a owl:DatatypeProperty ;
	rdfs:label "host_number" ;
	skos:definition "Number of symbiotic host individuals pooled at the time of collection" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "count" .
MIXS:0001306 dcterms:title "host of the symbiotic host taxon id" ;
	schema1:keywords "host" , "host." , "identifier" , "symbiosis" , "taxon" ;
	a owl:DatatypeProperty ;
	rdfs:label "host_of_host_taxid" ;
	skos:definition "NCBI taxon id of the host of the symbiotic host organism" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "NCBI taxon identifier of the host of the symbiotic taxon organism" .
MIXS:0001307 dcterms:title "type of symbiosis" ;
	schema1:keywords "symbiosis" , "type" ;
	a owl:ObjectProperty ;
	rdfs:label "type_of_symbiosis" ;
	rdfs:range MIXS:TypeOfSymbiosisEnum ;
	skos:definition "Type of biological interaction established between the symbiotic host organism being sampled and its respective host" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001308 dcterms:title "host specificity" ;
	schema1:keywords "host" , "host." ;
	a owl:ObjectProperty ;
	rdfs:label "host_specificity" ;
	rdfs:range MIXS:HostSpecificityEnum ;
	skos:definition "Level of specificity of symbiont-host interaction: e.g. generalist (symbiont able to establish associations with distantly related hosts) or species-specific" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001310 dcterms:title "observed coinfecting organisms in host of host" ;
	schema1:keywords "host" , "host." , "observed" , "organism" ;
	a owl:DatatypeProperty ;
	rdfs:label "host_of_host_coinf" ;
	rdfs:range xsd:string ;
	skos:definition "The taxonomic name of any coinfecting organism observed in a symbiotic relationship with the host of the sampled host organism. e.g. where a sample collected from a host trematode species (A) which was collected from a host_of_host fish (B) that was also infected with a nematode (C), the value here would be (C) the nematode {species name} or {common name}. Multiple co-infecting species may be added in a comma-separated list. For listing symbiotic organisms associated with the host (A) use the term Observed host symbiont" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "species name of coinfecting organism(s)" .
MIXS:0001312 dcterms:title "mode of transmission" ;
	a owl:ObjectProperty ;
	rdfs:label "mode_transmission" ;
	rdfs:range MIXS:ModeTransmissionEnum ;
	skos:definition "The process through which the symbiotic host organism entered the host from which it was sampled" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001313 dcterms:title "host cellular location" ;
	schema1:keywords "host" , "host." , "location" ;
	a owl:ObjectProperty ;
	rdfs:label "host_cellular_loc" ;
	rdfs:range MIXS:HostCellularLocEnum ;
	skos:definition "The localization of the symbiotic host organism within the host from which it was sampled: e.g. intracellular if the symbiotic host organism is localized within the cells or extracellular if the symbiotic host organism is localized outside of cells" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001315 dcterms:title "host dependence" ;
	schema1:keywords "host" , "host." ;
	a owl:ObjectProperty ;
	rdfs:label "host_dependence" ;
	rdfs:range MIXS:HostDependenceEnum ;
	skos:definition "Type of host dependence for the symbiotic host organism to its host" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001316 dcterms:title "route of transmission" ;
	schema1:keywords "route" ;
	a owl:ObjectProperty ;
	rdfs:label "route_transmission" ;
	rdfs:range MIXS:RouteTransmissionEnum ;
	skos:definition "Description of path taken by the symbiotic host organism being sampled in order to establish a symbiotic relationship with the host (with which it was observed at the time of sampling) via a mode of transmission (specified in mode_transmission)" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001317 dcterms:title "sample storage solution" ;
	schema1:keywords "sample" , "storage" ;
	a owl:DatatypeProperty ;
	rdfs:label "samp_store_sol" ;
	rdfs:range xsd:string ;
	skos:definition "Solution within which sample was stored, if any" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "solution name" .
MIXS:0001318 dcterms:title "host subspecific genetic lineage" ;
	schema1:keywords "host" , "host." , "lineage" ;
	a owl:DatatypeProperty ;
	rdfs:label "host_subspecf_genlin" ;
	skos:definition "Information about the genetic distinctness of the host organism below the subspecies level e.g., serovar, serotype, biotype, ecotype, variety, cultivar, or any relevant genetic typing schemes like Group I plasmid. Subspecies should not be recorded in this term, but in the NCBI taxonomy. Supply both the lineage name and the lineage rank separated by a colon, e.g., biovar:abc123" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "Genetic lineage below lowest rank of NCBI taxonomy, which is subspecies, e.g. serovar, biotype, ecotype, variety, cultivar" .
MIXS:0001319 dcterms:title "host of the symbiotic host disease status" ;
	schema1:keywords "disease" , "host" , "host." , "status" , "symbiosis" ;
	a owl:DatatypeProperty ;
	rdfs:label "host_of_host_disease" ;
	skos:definition "List of diseases with which the host of the symbiotic host organism has been diagnosed; can include multiple diagnoses. The value of the field depends on host; for humans the terms should be chosen from the DO (Human Disease Ontology) at https://www.disease-ontology.org, non-human host diseases are free text" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "disease name or Disease Ontology term" .
MIXS:0001320 dcterms:title "taxonomy ID of DNA sample" ;
	schema1:keywords "dna" , "identifier" , "sample" , "taxon" ;
	a owl:DatatypeProperty ;
	rdfs:label "samp_taxon_id" ;
	rdfs:range xsd:string ;
	skos:definition "NCBI taxon id of the sample.  Maybe be a single taxon or mixed taxa sample. Use 'synthetic metagenome  for mock community/positive controls, or 'blank sample' for negative controls" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001321 dcterms:title "negative control type" ;
	schema1:keywords "type" ;
	a owl:ObjectProperty ;
	rdfs:label "neg_cont_type" ;
	rdfs:range MIXS:NegContTypeEnum ;
	skos:definition "The substance or equipment used as a negative control in an investigation" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "enumeration or text" .
MIXS:0001322 dcterms:title "positive control type" ;
	schema1:keywords "type" ;
	a owl:DatatypeProperty ;
	rdfs:label "pos_cont_type" ;
	skos:definition "The substance, mixture, product, or apparatus used to verify that a process which is part of an investigation delivers a true positive" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001324 dcterms:title "host of the symbiotic host common name" ;
	schema1:keywords "host" , "host." , "symbiosis" ;
	a owl:DatatypeProperty ;
	rdfs:label "host_of_host_name" ;
	rdfs:range xsd:string ;
	skos:definition "Common name of the host of the symbiotic host organism" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001325 dcterms:title "host of the symbiotic host local environmental context" ;
	schema1:keywords "context" , "environmental" , "host" , "host." , "symbiosis" ;
	a owl:DatatypeProperty ;
	rdfs:label "host_of_host_env_loc" ;
	skos:definition "For a symbiotic host organism the local anatomical environment within its host may have causal influences. Report the anatomical entity(s) which are in the direct environment of the symbiotic host organism being sampled and which you believe have significant causal influences on your sample or specimen. For example, if the symbiotic host organism being sampled is an intestinal worm, its local environmental context will be the term for intestine from UBERON (http://uberon.github.io/)" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "UBERON term(s), multiple values can be separated by pipes" .
MIXS:0001326 dcterms:title "host of the symbiotic host environmental medium" ;
	schema1:keywords "environmental" , "host" , "host." , "symbiosis" ;
	a owl:DatatypeProperty ;
	rdfs:label "host_of_host_env_med" ;
	skos:definition "Report the environmental material(s) immediately surrounding the symbiotic host organism at the time of sampling. This usually will be a tissue or substance type from the host, but may be another material if the symbiont is external to the host. We recommend using classes from the UBERON ontology, but subclasses of 'environmental material' (http://purl.obolibrary.org/obo/ENVO_00010483) may also be used. EnvO documentation about how to use the field: https://github.com/EnvironmentOntology/envo/wiki/Using-ENVO-with-MIxS . Terms from other OBO ontologies are permissible as long as they reference mass/volume nouns (e.g. air, water, blood) and not discrete, countable entities (e.g. intestines, heart).MIxS . Terms from other OBO ontologies are permissible as long as they reference mass/volume nouns (e.g. air, water, blood) and not discrete, countable entities (e.g. intestines, heart)" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "An ontology term for a material such as a tissue type or excreted substance" .
MIXS:0001327 dcterms:title "host of the symbiotic host subject id" ;
	schema1:keywords "host" , "host." , "identifier" , "symbiosis" ;
	a owl:DatatypeProperty ;
	rdfs:label "host_of_host_sub_id" ;
	rdfs:range xsd:string ;
	skos:definition "A unique identifier by which each host of the symbiotic host organism subject can be referred to, de-identified, e.g. #H14" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001328 dcterms:title "host of the symbiotic host family relationship" ;
	schema1:keywords "family" , "host" , "host." , "relationship" , "symbiosis" ;
	a owl:DatatypeProperty ;
	rdfs:label "host_of_host_fam_rel" ;
	skos:definition "Familial relationship of the host of the symbiotic host organisms to other hosts of symbiotic host organism in the same study; can include multiple relationships" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "relationship type;arbitrary identifier" .
MIXS:0001329 dcterms:title "host of the symbiotic host infra-specific name" ;
	schema1:keywords "host" , "host." , "symbiosis" ;
	a owl:DatatypeProperty ;
	rdfs:label "host_of_host_infname" ;
	rdfs:range xsd:string ;
	skos:definition "Taxonomic name information of the host of the symbiotic host organism below subspecies level" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001330 dcterms:title "host of the symbiotic host infra-specific rank" ;
	schema1:keywords "host" , "host." , "rank" , "symbiosis" ;
	a owl:DatatypeProperty ;
	rdfs:label "host_of_host_infrank" ;
	rdfs:range xsd:string ;
	skos:definition "Taxonomic rank information about the host of the symbiotic host organism below subspecies level, such as variety, form, rank etc" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001331 dcterms:title "host of the symbiotic host genotype" ;
	schema1:keywords "host" , "host." , "symbiosis" ;
	a owl:DatatypeProperty ;
	rdfs:label "host_of_host_geno" ;
	rdfs:range xsd:string ;
	skos:definition "Observed genotype of the host of the symbiotic host organism" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001332 dcterms:title "host of the symbiotic host phenotype" ;
	schema1:keywords "host" , "host." , "symbiosis" ;
	a owl:DatatypeProperty ;
	rdfs:label "host_of_host_pheno" ;
	skos:definition "Phenotype of the host of the symbiotic host organism. For phenotypic quality ontology (PATO) terms, see http://purl.bioontology.org/ontology/pato" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "phenotype of the host of the symbiotic organism; PATO" .
MIXS:0001333 dcterms:title "host of the symbiotic host gravidity" ;
	schema1:keywords "host" , "host." , "symbiosis" ;
	a owl:DatatypeProperty ;
	rdfs:label "host_of_host_gravid" ;
	skos:definition "Whether or not the host of the symbiotic host organism is gravid, and if yes date due or date post-conception, specifying which is used" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "gravidity status;timestamp" .
MIXS:0001334 dcterms:title "host of the symbiotic host total mass" ;
	schema1:keywords "host" , "host." , "mass" , "symbiosis" , "total" ;
	a owl:DatatypeProperty ;
	rdfs:label "host_of_host_totmass" ;
	rdfs:range xsd:string ;
	skos:definition "Total mass of the host of the symbiotic host organism at collection, the unit depends on the host" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001335 dcterms:title "spike-in organism count" ;
	schema1:keywords "count" , "organism" , "spike" ;
	a owl:DatatypeProperty ;
	rdfs:label "spikein_count" ;
	skos:definition "Total cell count of any organism (or group of organisms) per gram, volume or area of sample, should include name of organism followed by count. The method that was used for the enumeration (e.g. qPCR, atp, mpn, etc.) should also be provided (example: total prokaryotes; 3.5e7 cells per ml; qPCR)" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "organism name;measurement value;enumeration" ;
	MIXS:Preferred_unit "colony forming units per milliliter; colony forming units per gram of dry weight" .
MIXS:0001336 dcterms:title "photosynthetic activity method" ;
	schema1:keywords "method" ;
	a owl:DatatypeProperty ;
	rdfs:label "photosynt_activ_meth" ;
	rdfs:range xsd:string ;
	skos:definition "Reference or method used in measurement of photosythetic activity" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001338 dcterms:title "isotope" ;
	a owl:ObjectProperty ;
	rdfs:label "isotope" ;
	rdfs:range MIXS:IsotopeEnum ;
	skos:definition "The element and mass number of the stable isotope used in isotopologue labeling." ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001339 dcterms:title "isotopolog" ;
	a owl:DatatypeProperty ;
	rdfs:label "isotopolog" ;
	rdfs:range xsd:string ;
	skos:definition "Isotopologue (isotope source/substrate/molecule) added to the biological sample." ;
	skos:inScheme <https://w3id.org/mixs> ;
	skos:note "List the PubChem Compound Identification (CID) number. If it's an undefined mixture, enter 0." .
MIXS:0001340 dcterms:title "isotopolog label status" ;
	a owl:ObjectProperty ;
	rdfs:label "isotopolog_label" ;
	rdfs:range MIXS:IsotopologLabelEnum ;
	skos:definition "List whether the isotopologue added to this biological sample was heavy-labelled or natural abundance" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001341 dcterms:title "Labeling approach (number of labeled isotopologs supplied)" ;
	a owl:ObjectProperty ;
	rdfs:label "isotopolog_approach" ;
	rdfs:range MIXS:IsotopologApproachEnum ;
	skos:definition "The labelling approach of this SIP experiment. Details if multiple isotopically labelled isotopologues were added to samples (\"multiple\"), or was only one isotopologue added to each sample (\"single\")." ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001342 dcterms:title "gradient position" ;
	a owl:DatatypeProperty ;
	rdfs:label "gradient_position" ;
	rdfs:range xsd:integer ;
	skos:definition "A number designating the gradient position from heaviest (=1) to lightest. Unfractionated samples, from which fractionated samples were derived, should be denoted with –1." ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001343 dcterms:title "density of gradient position" ;
	a owl:DatatypeProperty ;
	rdfs:label "gradient_pos_density" ;
	skos:definition "Buoyant density of this fraction" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "g/mL" .
MIXS:0001344 dcterms:title "relative amount of nucleic acids in the gradient position" ;
	a owl:DatatypeProperty ;
	rdfs:label "gradient_pos_rel_am" ;
	rdfs:range xsd:float ;
	skos:definition "The total nucleic acids loaded onto the column in this fraction as a decimal. If uploading 16S rRNA gene (or other amplicon) sequencing data, this value should be calculated from qPCR data. If uploading untargetted sequencing data, this value should be calculated from total DNA concentration." ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001345 dcterms:title "method for SIP fractionating" ;
	a owl:DatatypeProperty ;
	rdfs:label "sip_method" ;
	rdfs:range xsd:string ;
	skos:definition "Method used to fractionate nucleic acids." ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001346 dcterms:title "atom fraction of isotopolog" ;
	a owl:DatatypeProperty ;
	rdfs:label "isotopolog_atom_frac" ;
	rdfs:range xsd:string ;
	skos:definition "The fraction of heavy-labelled atoms out of all atoms of a given element in the isotopolog. Multiple values allowed, separated by a | and should be orded the same as the isotopolog." ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001347 dcterms:title "set of labeled atoms in isotopologue" ;
	a owl:DatatypeProperty ;
	rdfs:label "isotopolog_atom_pos" ;
	rdfs:range xsd:string ;
	skos:definition "InChI label designating set of all isotopically enriched atoms in isotopologue. Multiple values allowed, separated by a | and should be orded the same as the isotopolog." ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001348 dcterms:title "dose of isotopolog" ;
	a owl:DatatypeProperty ;
	rdfs:label "isotopolog_dose" ;
	rdfs:range xsd:string ;
	skos:definition "The concentration (in ppm) of isotopolog added to environmental matrix as a total mass per volume." ;
	skos:inScheme <https://w3id.org/mixs> ;
	skos:note "isotopolog mass / total volume soil; ppm of isotopologue in total container volume" ;
	MIXS:Preferred_unit "ppm" .
MIXS:0001349 dcterms:title "nucleobase excess atom fraction" ;
	a owl:DatatypeProperty ;
	rdfs:label "nucleobase_atom_frac" ;
	rdfs:range _:c14n4200 ;
	skos:definition "Excess atom fraction of the nucleobases in this fraction." ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001350 dcterms:title "isotopolog incubation time" ;
	a owl:DatatypeProperty ;
	rdfs:label "isotopolog_incu_time" ;
	rdfs:range xsd:string ;
	skos:definition "Total time of incubation after isotopologue addition in hours" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "hours" .
MIXS:0001351 dcterms:title "internal standard method" ;
	a owl:DatatypeProperty ;
	rdfs:label "internal_standard" ;
	rdfs:range xsd:string ;
	skos:definition "Method used for internal standard for SIP fractionation, if an internal standard was used (i.e., spiking in a heavy-labelled DNA sequence)." ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001352 dcterms:title "sample dna concentration" ;
	a owl:DatatypeProperty ;
	rdfs:label "samp_dna_conc" ;
	skos:definition "DNA concentration of sample after dna extraction prior to pooling. Typically measured spectrophotometrically or with a fluorophore." ;
	skos:inScheme <https://w3id.org/mixs> ;
	skos:note "Unit is nanograms per microliter" ;
	MIXS:Preferred_unit "ng/uL" .
MIXS:0001353 dcterms:title "nucleic acid elution volume" ;
	a owl:DatatypeProperty ;
	rdfs:label "nucleic_acid_elution_vol" ;
	skos:definition "Volume the nucleic acid (DNA or RNA) sample is eluted in" ;
	skos:inScheme <https://w3id.org/mixs> ;
	skos:note "Unit is microliter" ;
	MIXS:Preferred_unit "uL" .
MIXS:0001354 dcterms:title "taxonomic marker gene recovered" ;
	schema1:keywords "marker gene" , "recover" , "taxonomy" ;
	a owl:DatatypeProperty ;
	rdfs:label "marker_gene_recov" ;
	rdfs:range xsd:boolean ;
	rdfs:seeAlso MIXS:0000065 ;
	skos:altLabel "x16s_recover" ;
	skos:definition "Recovery status of taxonomic marker genes from the assembled genome" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0001355 dcterms:title "taxonomic marker gene recovery software" ;
	schema1:keywords "marker gene" , "recover" , "software" , "taxonomy" ;
	a owl:DatatypeProperty ;
	rdfs:label "marker_gene_recov_sw" ;
	rdfs:range xsd:string ;
	rdfs:seeAlso MIXS:0000066 ;
	skos:altLabel "x16s_recover_software" ;
	skos:definition "Tools used for taxonomic marker gene extraction from assembled genomes" ;
	skos:inScheme <https://w3id.org/mixs> .
