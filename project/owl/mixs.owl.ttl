    dcterms:title "TaxIdentEnum" ;
    schema1:name "TaxIdentEnum" ;
    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( <https://w3id.org/mixs/TaxIdentEnum#16S%20rRNA%20gene> <https://w3id.org/mixs/TaxIdentEnum#multi-marker%20approach> <https://w3id.org/mixs/TaxIdentEnum#other> ) ;
    linkml:permissible_values <https://w3id.org/mixs/TaxIdentEnum#16S%20rRNA%20gene>,
        <https://w3id.org/mixs/TaxIdentEnum#multi-marker%20approach>,
        <https://w3id.org/mixs/TaxIdentEnum#other> .

MIXS:ViralGenomeTypeEnum a owl:Class ;
