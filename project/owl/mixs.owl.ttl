    MIXS:Expected_value "primary treatment type" .

MIXS:0000350 a owl:DatatypeProperty ;
    rdfs:label "reactor_type" ;
    dcterms:title "reactor type" ;
    schema1:name "reactor_type" ;
    rdfs:range xsd:string ;
