MIXS:0000568 dcterms:title "humidity regimen" ;
	schema1:keywords "humidity" , "regimen" ;
	a owl:DatatypeProperty ;
	rdfs:label "humidity_regm" ;
	skos:definition "Information about treatment involving an exposure to varying degree of humidity; information about treatment involving use of growth hormones; should include amount of humidity administered, treatment regimen including how many times the treatment was repeated, how long each treatment lasted, and the start and end time of the entire treatment; can include multiple regimens" ;
