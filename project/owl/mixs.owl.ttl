	schema1:keywords "dry" , "host" , "host." , "mass" ;
	a owl:DatatypeProperty ;
	rdfs:label "host_dry_mass" ;
	rdfs:range xsd:string ;
	skos:definition "Measurement of dry mass" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "kilogram, gram" .
MIXS:0000258 dcterms:title "host blood pressure diastolic" ;
	schema1:keywords "host" , "host." , "pressure" ;
	a owl:DatatypeProperty ;
	rdfs:label "blood_press_diast" ;
	rdfs:range xsd:string ;
