    schema1:name "heat_deliv_loc" ;
    rdfs:range MIXS:CompassDirections8Enum ;
    skos:definition "The location of heat delivery within the room" .

MIXS:0000812 a owl:ObjectProperty ;
    rdfs:label "heat_sys_deliv_meth" ;
