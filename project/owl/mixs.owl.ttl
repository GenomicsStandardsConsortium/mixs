MIXS:0000003 a owl:DatatypeProperty ;
    rdfs:label "isol_growth_condt" ;
    dcterms:title "isolation and growth condition" ;
    schema1:name "isol_growth_condt" ;
    rdfs:range xsd:string ;
    skos:definition "Publication reference in the form of pubmed ID (pmid), digital object identifier (doi) or url for isolation and growth condition specifications of the organism/material" .

MIXS:0000015 a owl:ObjectProperty ;
    rdfs:label "rel_to_oxygen" ;
    dcterms:title "relationship to oxygen" ;
    schema1:name "rel_to_oxygen" ;
    rdfs:range MIXS:RelToOxygenEnum ;
    skos:definition "Is this organism an aerobe, anaerobe? Please note that aerobic and anaerobic are valid descriptors for microbial environments" .

MIXS:0000020 a owl:DatatypeProperty ;
    rdfs:label "subspecf_gen_lin" ;
    dcterms:title "subspecific genetic lineage" ;
    schema1:name "subspecf_gen_lin" ;
    skos:definition "Information about the genetic distinctness of the sequenced organism below the subspecies level, e.g., serovar, serotype, biotype, ecotype, or any relevant genetic typing schemes like Group I plasmid. Subspecies should not be recorded in this term, but in the NCBI taxonomy. Supply both the lineage name and the lineage rank separated by a colon, e.g., biovar:abc123" ;
    MIXS:Expected_value "Genetic lineage below lowest rank of NCBI taxonomy, which is subspecies, e.g. serovar, biotype, ecotype, variety, cultivar" .

MIXS:0000053 a owl:ObjectProperty ;
    rdfs:label "tax_ident" ;
    dcterms:title "taxonomic identity marker" ;
    schema1:name "tax_ident" ;
    rdfs:range MIXS:TaxIdentEnum ;
    skos:definition "The phylogenetic marker(s) used to assign an organism name to the SAG or MAG" .

MIXS:0000069 a owl:DatatypeProperty ;
    rdfs:label "compl_score" ;
    dcterms:title "completeness score" ;
    schema1:name "compl_score" ;
    skos:definition "Completeness score is typically based on either the fraction of markers found as compared to a database or the percent of a genome found as compared to a closely related reference genome. High Quality Draft: >90%, Medium Quality Draft: >50%, and Low Quality Draft: < 50% should have the indicated completeness scores" ;
    MIXS:Expected_value "quality;percent completeness" .

MIXS:0000070 a owl:DatatypeProperty ;
    rdfs:label "compl_software" ;
    dcterms:title "completeness software" ;
    schema1:name "compl_software" ;
    skos:definition "Tools used for completion estimate, i.e. checkm, anvi'o, busco" ;
    MIXS:Expected_value "names and versions of software(s) used" .

MIXS:Extension a owl:Class ;
    rdfs:label "Extension" ;
    dcterms:title "Extension" ;
    schema1:name "Extension" ;
    rdfs:subClassOf linkml:ClassDefinition ;
    skos:altLabel "EnvironmentalPackage" ;
    skos:definition "A collection of recommended metadata terms (slots) developed by community experts, describing the specific context under which a sample was collected." .

MIXS:0010002 a owl:Class ;
    rdfs:label "MigsEu" ;
    dcterms:title "MIGS eukaryote" ;
    schema1:name "MigsEu" ;
    rdfs:subClassOf MIXS:Checklist ;
    skos:altLabel "migs_eu" ;
    skos:definition "Minimal Information about a Genome Sequence: eukaryote" .

MIXS:0010003 a owl:Class ;
    rdfs:label "MigsBa" ;
    dcterms:title "MIGS bacteria" ;
    schema1:name "MigsBa" ;
    rdfs:subClassOf MIXS:Checklist ;
    skos:altLabel "migs_ba" ;
    skos:definition "Minimal Information about a Genome Sequence: cultured bacteria/archaea" .

MIXS:0010004 a owl:Class ;
    rdfs:label "MigsPl" ;
    dcterms:title "MIGS pl" ;
    schema1:name "MigsPl" ;
    rdfs:subClassOf MIXS:Checklist ;
    skos:altLabel "migs_pl" ;
    skos:definition "Minimal Information about a Genome Sequence: plasmid" .

MIXS:0010005 a owl:Class ;
    rdfs:label "MigsVi" ;
    dcterms:title "MIGS virus" ;
    schema1:name "MigsVi" ;
    rdfs:subClassOf MIXS:Checklist ;
    skos:altLabel "migs_vi" ;
    skos:definition "Minimal Information about a Genome Sequence: virus" .

MIXS:0010006 a owl:Class ;
    rdfs:label "MigsOrg" ;
    dcterms:title "MIGS org" ;
    schema1:name "MigsOrg" ;
    rdfs:subClassOf MIXS:Checklist ;
    skos:altLabel "migs_org" ;
    skos:definition "Minimal Information about a Genome Sequence: organelle" .

MIXS:0010007 a owl:Class ;
    rdfs:label "Mims" ;
    dcterms:title "MIMS" ;
    schema1:name "Mims" ;
    rdfs:subClassOf MIXS:Checklist ;
    skos:altLabel "mims" ;
    skos:definition "Metagenome or Environmental" .

MIXS:0010008 a owl:Class ;
    rdfs:label "MimarksS" ;
    dcterms:title "MIMARKS survey" ;
    schema1:name "MimarksS" ;
    rdfs:subClassOf MIXS:Checklist ;
    skos:altLabel "MIMARKS-SP",
        "MIMARKS-survey",
        "mimarks_s" ;
    skos:definition "Minimal Information about a Marker Sequence: survey" ;
    skos:note "for marker gene sequences obtained directly from the environment" .

MIXS:0010009 a owl:Class ;
    rdfs:label "MimarksC" ;
    dcterms:title "MIMARKS specimen" ;
    schema1:name "MimarksC" ;
    rdfs:subClassOf MIXS:Checklist ;
    skos:altLabel "MIMARKS-SU",
        "MIMARKS-specimen",
        "mimarks_c" ;
    skos:definition "Minimal Information about a Marker Sequence: specimen" ;
    skos:note "for marker gene sequences from cultured or voucher-identifiable specimens" .

MIXS:0010010 a owl:Class ;
    rdfs:label "Misag" ;
    dcterms:title "Minimum Information About a Single Amplified Genome" ;
    schema1:name "Misag" ;
    rdfs:subClassOf MIXS:Checklist ;
    skos:altLabel "misag" ;
    skos:definition "Minimum Information About a Single Amplified Genome" .

MIXS:0010011 a owl:Class ;
    rdfs:label "Mimag" ;
    dcterms:title "MIMAG" ;
    schema1:name "Mimag" ;
    rdfs:subClassOf MIXS:Checklist ;
    skos:altLabel "mimag" ;
    skos:definition "Minimum Information About a Metagenome-Assembled Genome" .

MIXS:0010012 a owl:Class ;
    rdfs:label "Miuvig" ;
    dcterms:title "Minimum Information About an Uncultivated Virus Genome" ;
    schema1:name "Miuvig" ;
    rdfs:subClassOf MIXS:Checklist ;
    skos:altLabel "miuvig" ;
    skos:definition "Minimum Information About an Uncultivated Virus Genome" .

MIXS:0010014 a owl:Class ;
    rdfs:label "MimsMisip" ;
    dcterms:title "MIMS-MISIP" ;
    schema1:name "MimsMisip" ;
    rdfs:subClassOf MIXS:Checklist ;
    skos:altLabel "misip" ;
    skos:definition "Metagenome or Environmental with SIP" ;
    skos:note "Any changes made to MIMS should be reflected here, in MIMS-MISIP. This checklist includes all MIMS terms and additional MISIP terms." .

MIXS:0010015 a owl:Class ;
    rdfs:label "MimarksCMisip" ;
    dcterms:title "MIMARKS specimen-MISIP" ;
    schema1:name "MimarksCMisip" ;
    rdfs:subClassOf MIXS:Checklist ;
    skos:altLabel "MIMARKS-SU-MISIP",
        "MIMARKS-specimen-MISIP",
        "mimarks_c_misip",
        "misip" ;
    skos:definition "Marker Sequence-specimen with SIP" ;
    skos:note "Any changes made to MIMARKS-specimen (MimarksC) should be reflected here. This checklist includes all MIMARKS-specimen terms and additional MISIP terms." .

MIXS:0001001 a owl:DatatypeProperty ;
    rdfs:label "ph" ;
    dcterms:title "pH" ;
    schema1:name "ph" ;
    rdfs:range xsd:float ;
    skos:definition "pH measurement of the sample, or liquid portion of sample, or aqueous phase of the fluid" .

MIXS:0000090 a owl:DatatypeProperty ;
    rdfs:label "sop" ;
    dcterms:title "relevant standard operating procedures" ;
    schema1:name "sop" ;
    skos:definition "Standard operating procedures used in assembly and/or annotation of genomes, metagenomes or environmental sequences" ;
    MIXS:Expected_value "reference to SOP" .

MIXS:0000091 a owl:DatatypeProperty ;
    rdfs:label "associated_resource" ;
    dcterms:title "relevant electronic resources" ;
    schema1:name "associated_resource" ;
    skos:definition "A related resource that is referenced, cited, or otherwise associated to the sequence" ;
    MIXS:Expected_value "reference to resource" .

MIXS:0000025 a owl:DatatypeProperty ;
    rdfs:label "ref_biomaterial" ;
    dcterms:title "reference for biomaterial" ;
    schema1:name "ref_biomaterial" ;
    rdfs:range xsd:string ;
    skos:definition "Primary publication if isolated before genome publication; otherwise, primary genome report" .

MIXS:0000026 a owl:DatatypeProperty ;
    rdfs:label "source_mat_id" ;
    dcterms:title "source material identifiers" ;
    schema1:name "source_mat_id" ;
    rdfs:range xsd:string ;
    skos:definition "A unique identifier assigned to a material sample (as defined by http://rs.tdwg.org/dwc/terms/materialSampleID, and as opposed to a particular digital record of a material sample) used for extracting nucleic acids, and subsequent sequencing. The identifier can refer either to the original material collected or to any derived sub-samples. The INSDC qualifiers /specimen_voucher, /bio_material, or /culture_collection may or may not share the same value as the source_mat_id field. For instance, the /specimen_voucher qualifier and source_mat_id may both contain 'UAM:Herps:14' , referring to both the specimen voucher and sampled tissue with the same identifier. However, the /culture_collection qualifier may refer to a value from an initial culture (e.g. ATCC:11775) while source_mat_id would refer to an identifier from some derived culture from which the nucleic acids were extracted (e.g. xatc123 or ark:/2154/R2)" ;
    MIXS:Expected_value "for cultures of microorganisms: identifiers for two culture collections; for other material a unique arbitrary identifer" .

MIXS:0000060 a owl:DatatypeProperty ;
    rdfs:label "number_contig" ;
    dcterms:title "number of contigs" ;
    schema1:name "number_contig" ;
    rdfs:range xsd:integer ;
    skos:definition "Total number of contigs in the cleaned/submitted assembly that makes up a given genome, SAG, MAG, or UViG" .

MIXS:0000061 a owl:DatatypeProperty ;
    rdfs:label "feat_pred" ;
    dcterms:title "feature prediction" ;
    schema1:name "feat_pred" ;
    rdfs:range xsd:string ;
    skos:definition "Method used to predict UViGs features such as ORFs, integration site, etc" .

MIXS:0000062 a owl:DatatypeProperty ;
    rdfs:label "ref_db" ;
    dcterms:title "reference database(s)" ;
    schema1:name "ref_db" ;
    skos:definition "List of database(s) used for ORF annotation, along with version number and reference to website or publication" ;
    MIXS:Expected_value "names, versions, and references of databases" .

MIXS:0000063 a owl:DatatypeProperty ;
    rdfs:label "sim_search_meth" ;
    dcterms:title "similarity search method" ;
    schema1:name "sim_search_meth" ;
    rdfs:range xsd:string ;
    skos:definition "Tool used to compare ORFs with database, along with version and cutoffs used" .

MIXS:0000064 a owl:DatatypeProperty ;
    rdfs:label "tax_class" ;
    dcterms:title "taxonomic classification" ;
    schema1:name "tax_class" ;
    rdfs:range xsd:string ;
    skos:definition "Method used for taxonomic classification, along with reference database used, classification rank, and thresholds used to classify new genomes" .

MIXS:0000255 a owl:DatatypeProperty ;
    rdfs:label "host_age" ;
    dcterms:title "host age" ;
    schema1:name "host_age" ;
    rdfs:range xsd:string ;
    skos:definition "Age of host at the time of sampling; relevant scale depends on species and study, e.g. Could be seconds for amoebae or centuries for trees" ;
    MIXS:Preferred_unit "year, day, hour" .

MIXS:0000263 a owl:DatatypeProperty ;
    rdfs:label "host_tot_mass" ;
    dcterms:title "host total mass" ;
    schema1:name "host_tot_mass" ;
    rdfs:range xsd:string ;
    skos:definition "Total mass of the host at collection, the unit depends on host" ;
    MIXS:Preferred_unit "kilogram, gram" .

MIXS:0000264 a owl:DatatypeProperty ;
    rdfs:label "host_height" ;
    dcterms:title "host height" ;
    schema1:name "host_height" ;
    rdfs:range xsd:string ;
    skos:definition "The height of subject" ;
    MIXS:Preferred_unit "centimeter, millimeter, meter" .

MIXS:0000365 a owl:DatatypeProperty ;
    rdfs:label "host_genotype" ;
    dcterms:title "host genotype" ;
    schema1:name "host_genotype" ;
    rdfs:range xsd:string ;
    skos:definition "Observed genotype" .

MIXS:0000874 a owl:DatatypeProperty ;
    rdfs:label "host_phenotype" ;
    dcterms:title "host phenotype" ;
    schema1:name "host_phenotype" ;
    skos:definition "Phenotype of human or other host. Use terms from the phenotypic quality ontology (pato) or the Human Phenotype Ontology (HP)" ;
    MIXS:Expected_value "PATO or HP" .

MIXS:PlantSexEnum a owl:Class ;
    rdfs:label "PlantSexEnum" ;
    dcterms:title "PlantSexEnum" ;
    schema1:name "PlantSexEnum" ;
    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( <https://w3id.org/mixs/PlantSexEnum#Androdioecious> <https://w3id.org/mixs/PlantSexEnum#Androecious> <https://w3id.org/mixs/PlantSexEnum#Androgynomonoecious> <https://w3id.org/mixs/PlantSexEnum#Androgynous> <https://w3id.org/mixs/PlantSexEnum#Andromonoecious> <https://w3id.org/mixs/PlantSexEnum#Bisexual> <https://w3id.org/mixs/PlantSexEnum#Dichogamous> <https://w3id.org/mixs/PlantSexEnum#Diclinous> <https://w3id.org/mixs/PlantSexEnum#Dioecious> <https://w3id.org/mixs/PlantSexEnum#Gynodioecious> <https://w3id.org/mixs/PlantSexEnum#Gynoecious> <https://w3id.org/mixs/PlantSexEnum#Gynomonoecious> <https://w3id.org/mixs/PlantSexEnum#Hermaphroditic> <https://w3id.org/mixs/PlantSexEnum#Imperfect> <https://w3id.org/mixs/PlantSexEnum#Monoclinous> <https://w3id.org/mixs/PlantSexEnum#Monoecious> <https://w3id.org/mixs/PlantSexEnum#Perfect> <https://w3id.org/mixs/PlantSexEnum#Polygamodioecious> <https://w3id.org/mixs/PlantSexEnum#Polygamomonoecious> <https://w3id.org/mixs/PlantSexEnum#Polygamous> <https://w3id.org/mixs/PlantSexEnum#Protandrous> <https://w3id.org/mixs/PlantSexEnum#Protogynous> <https://w3id.org/mixs/PlantSexEnum#Subandroecious> <https://w3id.org/mixs/PlantSexEnum#Subdioecious> <https://w3id.org/mixs/PlantSexEnum#Subgynoecious> <https://w3id.org/mixs/PlantSexEnum#Synoecious> <https://w3id.org/mixs/PlantSexEnum#Trimonoecious> <https://w3id.org/mixs/PlantSexEnum#Trioecious> <https://w3id.org/mixs/PlantSexEnum#Unisexual> ) ;
    linkml:permissible_values <https://w3id.org/mixs/PlantSexEnum#Androdioecious>,
        <https://w3id.org/mixs/PlantSexEnum#Androecious>,
        <https://w3id.org/mixs/PlantSexEnum#Androgynomonoecious>,
        <https://w3id.org/mixs/PlantSexEnum#Androgynous>,
        <https://w3id.org/mixs/PlantSexEnum#Andromonoecious>,
        <https://w3id.org/mixs/PlantSexEnum#Bisexual>,
        <https://w3id.org/mixs/PlantSexEnum#Dichogamous>,
        <https://w3id.org/mixs/PlantSexEnum#Diclinous>,
        <https://w3id.org/mixs/PlantSexEnum#Dioecious>,
        <https://w3id.org/mixs/PlantSexEnum#Gynodioecious>,
        <https://w3id.org/mixs/PlantSexEnum#Gynoecious>,
        <https://w3id.org/mixs/PlantSexEnum#Gynomonoecious>,
        <https://w3id.org/mixs/PlantSexEnum#Hermaphroditic>,
        <https://w3id.org/mixs/PlantSexEnum#Imperfect>,
        <https://w3id.org/mixs/PlantSexEnum#Monoclinous>,
        <https://w3id.org/mixs/PlantSexEnum#Monoecious>,
        <https://w3id.org/mixs/PlantSexEnum#Perfect>,
        <https://w3id.org/mixs/PlantSexEnum#Polygamodioecious>,
        <https://w3id.org/mixs/PlantSexEnum#Polygamomonoecious>,
        <https://w3id.org/mixs/PlantSexEnum#Polygamous>,
        <https://w3id.org/mixs/PlantSexEnum#Protandrous>,
        <https://w3id.org/mixs/PlantSexEnum#Protogynous>,
        <https://w3id.org/mixs/PlantSexEnum#Subandroecious>,
        <https://w3id.org/mixs/PlantSexEnum#Subdioecious>,
        <https://w3id.org/mixs/PlantSexEnum#Subgynoecious>,
        <https://w3id.org/mixs/PlantSexEnum#Synoecious>,
        <https://w3id.org/mixs/PlantSexEnum#Trimonoecious>,
        <https://w3id.org/mixs/PlantSexEnum#Trioecious>,
        <https://w3id.org/mixs/PlantSexEnum#Unisexual> .

MIXS:0000008 a owl:DatatypeProperty ;
    rdfs:label "experimental_factor" ;
    dcterms:title "experimental factor" ;
    schema1:name "experimental_factor" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:intersectionOf ( xsd:string [ a rdfs:Datatype ;
                        owl:onDatatype xsd:string ;
                        owl:withRestrictions ( [ xsd:pattern "^\\S+.*\\S+ \\[[a-zA-Z]{2,}:\\d+\\]$" ] ) ] ) ] ;
    skos:definition "Variable aspects of an experiment design that can be used to describe an experiment, or set of experiments, in an increasingly detailed manner. This field accepts ontology terms from Experimental Factor Ontology (EFO) and/or Ontology for Biomedical Investigations (OBI)" ;
    MIXS:Expected_value "text or EFO and/or OBI" .

MIXS:0000751 a owl:DatatypeProperty ;
    rdfs:label "chem_administration" ;
    dcterms:title "chemical administration" ;
    schema1:name "chem_administration" ;
    skos:definition "List of chemical compounds administered to the host or site where sampling occurred, and when (e.g. Antibiotics, n fertilizer, air filter); can include multiple compounds. For chemical entities of biological interest ontology (chebi) (v 163), http://purl.bioontology.org/ontology/chebi" ;
    MIXS:Expected_value "CHEBI;timestamp" .

MIXS:0000056 a owl:ObjectProperty ;
    rdfs:label "assembly_qual" ;
    dcterms:title "assembly quality" ;
    schema1:name "assembly_qual" ;
    rdfs:range MIXS:AssemblyQualEnum ;
    skos:definition "The assembly quality category is based on sets of criteria outlined for each assembly quality category. For MISAG/MIMAG; Finished: Single, validated, contiguous sequence per replicon without gaps or ambiguities with a consensus error rate equivalent to Q50 or better. High Quality Draft:Multiple fragments where gaps span repetitive regions. Presence of the large subunit (LSU) RNA, small subunit (SSU) and the presence of 5.8S rRNA or 5S rRNA depending on whether it is a eukaryotic or prokaryotic genome, respectively. Medium Quality Draft:Many fragments with little to no review of assembly other than reporting of standard assembly statistics. Low Quality Draft:Many fragments with little to no review of assembly other than reporting of standard assembly statistics. Assembly statistics include, but are not limited to total assembly size, number of contigs, contig N50/L50, and maximum contig length. For MIUVIG; Finished: Single, validated, contiguous sequence per replicon without gaps or ambiguities, with extensive manual review and editing to annotate putative gene functions and transcriptional units. High-quality draft genome: One or multiple fragments, totaling   90% of the expected genome or replicon sequence or predicted complete. Genome fragment(s): One or multiple fragments, totalling < 90% of the expected genome or replicon sequence, or for which no genome size could be estimated" .

MIXS:0000057 a owl:DatatypeProperty ;
    rdfs:label "assembly_name" ;
    dcterms:title "assembly name" ;
    schema1:name "assembly_name" ;
    skos:definition "Name/version of the assembly provided by the submitter that is used in the genome browsers and in the community" ;
    MIXS:Expected_value "name and version of assembly" .

MIXS:0000059 a owl:DatatypeProperty ;
    rdfs:label "annot" ;
    dcterms:title "annotation" ;
    schema1:name "annot" ;
    rdfs:range xsd:string ;
    skos:definition "Tool used for annotation, or for cases where annotation was provided by a community jamboree or model organism database rather than by a specific submitter" ;
    MIXS:Expected_value "name of tool or pipeline used, or annotation source description" .

MIXS:0000039 a owl:DatatypeProperty ;
    rdfs:label "lib_size" ;
    dcterms:title "library size" ;
    schema1:name "lib_size" ;
    rdfs:range xsd:integer ;
    skos:definition "Total number of clones in the library prepared for the project" .

MIXS:0000040 a owl:DatatypeProperty ;
    rdfs:label "lib_reads_seqd" ;
    dcterms:title "library reads sequenced" ;
    schema1:name "lib_reads_seqd" ;
    rdfs:range xsd:integer ;
    skos:definition "Total number of clones sequenced from the library" .

MIXS:0000041 a owl:ObjectProperty ;
    rdfs:label "lib_layout" ;
    dcterms:title "library layout" ;
    schema1:name "lib_layout" ;
    rdfs:range MIXS:LibLayoutEnum ;
    skos:definition "Specify whether to expect single, paired, or other configuration of reads" .

MIXS:0000042 a owl:DatatypeProperty ;
    rdfs:label "lib_vector" ;
    dcterms:title "library vector" ;
    schema1:name "lib_vector" ;
    rdfs:range xsd:string ;
    skos:definition "Cloning vector type(s) used in construction of libraries" ;
    MIXS:Expected_value "vector" .

MIXS:0000043 a owl:DatatypeProperty ;
    rdfs:label "lib_screen" ;
    dcterms:title "library screening strategy" ;
    schema1:name "lib_screen" ;
    rdfs:range xsd:string ;
    skos:definition "Specific enrichment or screening methods applied before and/or after creating libraries" ;
    MIXS:Expected_value "screening strategy name" .

MIXS:0000048 a owl:DatatypeProperty ;
    rdfs:label "adapters" ;
    dcterms:title "adapters" ;
    schema1:name "adapters" ;
    skos:definition "Adapters provide priming sequences for both amplification and sequencing of the sample-library fragments. Both adapters should be reported; in uppercase letters" .

MIXS:0000058 a owl:DatatypeProperty ;
    rdfs:label "assembly_software" ;
    dcterms:title "assembly software" ;
    schema1:name "assembly_software" ;
    rdfs:range xsd:string ;
    skos:definition "Tool(s) used for assembly, including version number and parameters" .

MIXS:0000754 a owl:DatatypeProperty ;
    rdfs:label "perturbation" ;
    dcterms:title "perturbation" ;
    schema1:name "perturbation" ;
    skos:definition "Type of perturbation, e.g. chemical administration, physical disturbance, etc., coupled with perturbation regimen including how many times the perturbation was repeated, how long each perturbation lasted, and the start and end time of the entire perturbation period; can include multiple perturbation types" ;
    MIXS:Expected_value "perturbation type name;perturbation interval and duration" .

MIXS:TrophicLevelEnum a owl:Class ;
    rdfs:label "TrophicLevelEnum" ;
    dcterms:title "TrophicLevelEnum" ;
    schema1:name "TrophicLevelEnum" ;
    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( <https://w3id.org/mixs/TrophicLevelEnum#autotroph> <https://w3id.org/mixs/TrophicLevelEnum#carboxydotroph> <https://w3id.org/mixs/TrophicLevelEnum#chemoautolithotroph> <https://w3id.org/mixs/TrophicLevelEnum#chemoautotroph> <https://w3id.org/mixs/TrophicLevelEnum#chemoheterotroph> <https://w3id.org/mixs/TrophicLevelEnum#chemolithoautotroph> <https://w3id.org/mixs/TrophicLevelEnum#chemolithotroph> <https://w3id.org/mixs/TrophicLevelEnum#chemoorganoheterotroph> <https://w3id.org/mixs/TrophicLevelEnum#chemoorganotroph> <https://w3id.org/mixs/TrophicLevelEnum#chemosynthetic> <https://w3id.org/mixs/TrophicLevelEnum#chemotroph> <https://w3id.org/mixs/TrophicLevelEnum#copiotroph> <https://w3id.org/mixs/TrophicLevelEnum#diazotroph> <https://w3id.org/mixs/TrophicLevelEnum#facultative> <https://w3id.org/mixs/TrophicLevelEnum#heterotroph> <https://w3id.org/mixs/TrophicLevelEnum#lithoautotroph> <https://w3id.org/mixs/TrophicLevelEnum#lithoheterotroph> <https://w3id.org/mixs/TrophicLevelEnum#lithotroph> <https://w3id.org/mixs/TrophicLevelEnum#methanotroph> <https://w3id.org/mixs/TrophicLevelEnum#methylotroph> <https://w3id.org/mixs/TrophicLevelEnum#mixotroph> <https://w3id.org/mixs/TrophicLevelEnum#obligate> <https://w3id.org/mixs/TrophicLevelEnum#oligotroph> <https://w3id.org/mixs/TrophicLevelEnum#organoheterotroph> <https://w3id.org/mixs/TrophicLevelEnum#organotroph> <https://w3id.org/mixs/TrophicLevelEnum#photoautotroph> <https://w3id.org/mixs/TrophicLevelEnum#photoheterotroph> <https://w3id.org/mixs/TrophicLevelEnum#photolithoautotroph> <https://w3id.org/mixs/TrophicLevelEnum#photolithotroph> <https://w3id.org/mixs/TrophicLevelEnum#photosynthetic> <https://w3id.org/mixs/TrophicLevelEnum#phototroph> ) ;
    linkml:permissible_values <https://w3id.org/mixs/TrophicLevelEnum#autotroph>,
        <https://w3id.org/mixs/TrophicLevelEnum#carboxydotroph>,
        <https://w3id.org/mixs/TrophicLevelEnum#chemoautolithotroph>,
        <https://w3id.org/mixs/TrophicLevelEnum#chemoautotroph>,
        <https://w3id.org/mixs/TrophicLevelEnum#chemoheterotroph>,
        <https://w3id.org/mixs/TrophicLevelEnum#chemolithoautotroph>,
        <https://w3id.org/mixs/TrophicLevelEnum#chemolithotroph>,
        <https://w3id.org/mixs/TrophicLevelEnum#chemoorganoheterotroph>,
        <https://w3id.org/mixs/TrophicLevelEnum#chemoorganotroph>,
        <https://w3id.org/mixs/TrophicLevelEnum#chemosynthetic>,
        <https://w3id.org/mixs/TrophicLevelEnum#chemotroph>,
        <https://w3id.org/mixs/TrophicLevelEnum#copiotroph>,
        <https://w3id.org/mixs/TrophicLevelEnum#diazotroph>,
        <https://w3id.org/mixs/TrophicLevelEnum#facultative>,
        <https://w3id.org/mixs/TrophicLevelEnum#heterotroph>,
        <https://w3id.org/mixs/TrophicLevelEnum#lithoautotroph>,
        <https://w3id.org/mixs/TrophicLevelEnum#lithoheterotroph>,
        <https://w3id.org/mixs/TrophicLevelEnum#lithotroph>,
        <https://w3id.org/mixs/TrophicLevelEnum#methanotroph>,
        <https://w3id.org/mixs/TrophicLevelEnum#methylotroph>,
        <https://w3id.org/mixs/TrophicLevelEnum#mixotroph>,
        <https://w3id.org/mixs/TrophicLevelEnum#obligate>,
        <https://w3id.org/mixs/TrophicLevelEnum#oligotroph>,
        <https://w3id.org/mixs/TrophicLevelEnum#organoheterotroph>,
        <https://w3id.org/mixs/TrophicLevelEnum#organotroph>,
        <https://w3id.org/mixs/TrophicLevelEnum#photoautotroph>,
        <https://w3id.org/mixs/TrophicLevelEnum#photoheterotroph>,
        <https://w3id.org/mixs/TrophicLevelEnum#photolithoautotroph>,
        <https://w3id.org/mixs/TrophicLevelEnum#photolithotroph>,
        <https://w3id.org/mixs/TrophicLevelEnum#photosynthetic>,
        <https://w3id.org/mixs/TrophicLevelEnum#phototroph> .

MIXS:0000012 a owl:DatatypeProperty ;
    rdfs:label "env_broad_scale" ;
    dcterms:title "broad-scale environmental context" ;
    schema1:name "env_broad_scale" ;
    rdfs:range xsd:string ;
    skos:definition "Report the major environmental system the sample or specimen came from. The system(s) identified should have a coarse spatial grain, to provide the general environmental context of where the sampling was done (e.g. in the desert or a rainforest). We recommend using subclasses of EnvO s biome class:  http://purl.obolibrary.org/obo/ENVO_00000428. EnvO documentation about how to use the field: https://github.com/EnvironmentOntology/envo/wiki/Using-ENVO-with-MIxS" .

MIXS:0000013 a owl:DatatypeProperty ;
    rdfs:label "env_local_scale" ;
    dcterms:title "local environmental context" ;
    schema1:name "env_local_scale" ;
    skos:definition "Report the entity or entities which are in the sample or specimen s local vicinity and which you believe have significant causal influences on your sample or specimen. We recommend using EnvO terms which are of smaller spatial grain than your entry for env_broad_scale. Terms, such as anatomical sites, from other OBO Library ontologies which interoperate with EnvO (e.g. UBERON) are accepted in this field. EnvO documentation about how to use the field: https://github.com/EnvironmentOntology/envo/wiki/Using-ENVO-with-MIxS" ;
    MIXS:Expected_value "Environmental entities having causal influences upon the entity at time of sampling" .

MIXS:0000014 a owl:DatatypeProperty ;
    rdfs:label "env_medium" ;
    dcterms:title "environmental medium" ;
    schema1:name "env_medium" ;
    rdfs:range xsd:string ;
    skos:definition "Report the environmental material(s) immediately surrounding the sample or specimen at the time of sampling. We recommend using subclasses of 'environmental material' (http://purl.obolibrary.org/obo/ENVO_00010483). EnvO documentation about how to use the field: https://github.com/EnvironmentOntology/envo/wiki/Using-ENVO-with-MIxS . Terms from other OBO ontologies are permissible as long as they reference mass/volume nouns (e.g. air, water, blood) and not discrete, countable entities (e.g. a tree, a leaf, a table top)" .

MIXS:0000031 a owl:DatatypeProperty ;
    rdfs:label "host_disease_stat" ;
    dcterms:title "host disease status" ;
    schema1:name "host_disease_stat" ;
    skos:definition "List of diseases with which the host has been diagnosed; can include multiple diagnoses. The value of the field depends on host; for humans the terms should be chosen from the DO (Human Disease Ontology) at https://www.disease-ontology.org, non-human host diseases are free text" ;
    MIXS:Expected_value "disease name or Disease Ontology term" .

MIXS:0001320 a owl:DatatypeProperty ;
    rdfs:label "samp_taxon_id" ;
    dcterms:title "taxonomy ID of DNA sample" ;
    schema1:name "samp_taxon_id" ;
    rdfs:range xsd:string ;
    skos:definition "NCBI taxon id of the sample.  Maybe be a single taxon or mixed taxa sample. Use 'synthetic metagenome  for mock community/positive controls, or 'blank sample' for negative controls" .

MIXS:0001321 a owl:ObjectProperty ;
    rdfs:label "neg_cont_type" ;
    dcterms:title "negative control type" ;
    schema1:name "neg_cont_type" ;
    rdfs:range MIXS:NegContTypeEnum ;
    skos:definition "The substance or equipment used as a negative control in an investigation" ;
    MIXS:Expected_value "enumeration or text" .

MIXS:0001322 a owl:DatatypeProperty ;
    rdfs:label "pos_cont_type" ;
    dcterms:title "positive control type" ;
    schema1:name "pos_cont_type" ;
    skos:definition "The substance, mixture, product, or apparatus used to verify that a process which is part of an investigation delivers a true positive" .

MIXS:FaoClassEnum a owl:Class ;
    rdfs:label "FaoClassEnum" ;
    dcterms:title "FaoClassEnum" ;
    schema1:name "FaoClassEnum" ;
    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( <https://w3id.org/mixs/FaoClassEnum#Acrisols> <https://w3id.org/mixs/FaoClassEnum#Alisols> <https://w3id.org/mixs/FaoClassEnum#Andosols> <https://w3id.org/mixs/FaoClassEnum#Anthrosols> <https://w3id.org/mixs/FaoClassEnum#Arenosols> <https://w3id.org/mixs/FaoClassEnum#Calcisols> <https://w3id.org/mixs/FaoClassEnum#Cambisols> <https://w3id.org/mixs/FaoClassEnum#Chernozems> <https://w3id.org/mixs/FaoClassEnum#Cryosols> <https://w3id.org/mixs/FaoClassEnum#Durisols> <https://w3id.org/mixs/FaoClassEnum#Ferralsols> <https://w3id.org/mixs/FaoClassEnum#Fluvisols> <https://w3id.org/mixs/FaoClassEnum#Gleysols> <https://w3id.org/mixs/FaoClassEnum#Greyzems> <https://w3id.org/mixs/FaoClassEnum#Gypsisols> <https://w3id.org/mixs/FaoClassEnum#Histosols> <https://w3id.org/mixs/FaoClassEnum#Kastanozems> <https://w3id.org/mixs/FaoClassEnum#Lithosols> <https://w3id.org/mixs/FaoClassEnum#Leptosols> <https://w3id.org/mixs/FaoClassEnum#Lixisols> <https://w3id.org/mixs/FaoClassEnum#Luvisols> <https://w3id.org/mixs/FaoClassEnum#Nitosols> <https://w3id.org/mixs/FaoClassEnum#Phaeozems> <https://w3id.org/mixs/FaoClassEnum#Planosols> <https://w3id.org/mixs/FaoClassEnum#Plinthosols> <https://w3id.org/mixs/FaoClassEnum#Podzols> <https://w3id.org/mixs/FaoClassEnum#Podzoluvisols> <https://w3id.org/mixs/FaoClassEnum#Rankers> <https://w3id.org/mixs/FaoClassEnum#Regosols> <https://w3id.org/mixs/FaoClassEnum#Rendzinas> <https://w3id.org/mixs/FaoClassEnum#Solonchaks> <https://w3id.org/mixs/FaoClassEnum#Solonetz> <https://w3id.org/mixs/FaoClassEnum#Stagnosols> <https://w3id.org/mixs/FaoClassEnum#Technosols> <https://w3id.org/mixs/FaoClassEnum#Umbrisols> <https://w3id.org/mixs/FaoClassEnum#Vertisols> <https://w3id.org/mixs/FaoClassEnum#Yermosols> ) ;
    linkml:permissible_values <https://w3id.org/mixs/FaoClassEnum#Acrisols>,
        <https://w3id.org/mixs/FaoClassEnum#Alisols>,
        <https://w3id.org/mixs/FaoClassEnum#Andosols>,
        <https://w3id.org/mixs/FaoClassEnum#Anthrosols>,
        <https://w3id.org/mixs/FaoClassEnum#Arenosols>,
        <https://w3id.org/mixs/FaoClassEnum#Calcisols>,
        <https://w3id.org/mixs/FaoClassEnum#Cambisols>,
        <https://w3id.org/mixs/FaoClassEnum#Chernozems>,
        <https://w3id.org/mixs/FaoClassEnum#Cryosols>,
        <https://w3id.org/mixs/FaoClassEnum#Durisols>,
        <https://w3id.org/mixs/FaoClassEnum#Ferralsols>,
        <https://w3id.org/mixs/FaoClassEnum#Fluvisols>,
        <https://w3id.org/mixs/FaoClassEnum#Gleysols>,
        <https://w3id.org/mixs/FaoClassEnum#Greyzems>,
        <https://w3id.org/mixs/FaoClassEnum#Gypsisols>,
        <https://w3id.org/mixs/FaoClassEnum#Histosols>,
        <https://w3id.org/mixs/FaoClassEnum#Kastanozems>,
        <https://w3id.org/mixs/FaoClassEnum#Leptosols>,
        <https://w3id.org/mixs/FaoClassEnum#Lithosols>,
        <https://w3id.org/mixs/FaoClassEnum#Lixisols>,
        <https://w3id.org/mixs/FaoClassEnum#Luvisols>,
        <https://w3id.org/mixs/FaoClassEnum#Nitosols>,
        <https://w3id.org/mixs/FaoClassEnum#Phaeozems>,
        <https://w3id.org/mixs/FaoClassEnum#Planosols>,
        <https://w3id.org/mixs/FaoClassEnum#Plinthosols>,
        <https://w3id.org/mixs/FaoClassEnum#Podzols>,
        <https://w3id.org/mixs/FaoClassEnum#Podzoluvisols>,
        <https://w3id.org/mixs/FaoClassEnum#Rankers>,
        <https://w3id.org/mixs/FaoClassEnum#Regosols>,
        <https://w3id.org/mixs/FaoClassEnum#Rendzinas>,
        <https://w3id.org/mixs/FaoClassEnum#Solonchaks>,
        <https://w3id.org/mixs/FaoClassEnum#Solonetz>,
        <https://w3id.org/mixs/FaoClassEnum#Stagnosols>,
        <https://w3id.org/mixs/FaoClassEnum#Technosols>,
        <https://w3id.org/mixs/FaoClassEnum#Umbrisols>,
        <https://w3id.org/mixs/FaoClassEnum#Vertisols>,
        <https://w3id.org/mixs/FaoClassEnum#Yermosols> .

MIXS:0000016 a owl:DatatypeProperty ;
    rdfs:label "samp_mat_process" ;
    dcterms:title "sample material processing" ;
    schema1:name "samp_mat_process" ;
    rdfs:range xsd:string ;
    skos:definition "A brief description of any processing applied to the sample during or after retrieving the sample from environment, or a link to the relevant protocol(s) performed" .

MIXS:0000038 a owl:DatatypeProperty ;
    rdfs:label "nucl_acid_amp" ;
    dcterms:title "nucleic acid amplification" ;
    schema1:name "nucl_acid_amp" ;
    rdfs:range xsd:string ;
    skos:definition "A link to a literature reference, electronic resource or a standard operating procedure (SOP), that describes the enzymatic amplification (PCR, TMA, NASBA) of specific nucleic acids" .

MIXS:0000103 a owl:DatatypeProperty ;
    rdfs:label "organism_count" ;
    dcterms:title "organism count" ;
    schema1:name "organism_count" ;
    skos:definition "Total cell count of any organism (or group of organisms) per gram, volume or area of sample, should include name of organism followed by count. The method that was used for the enumeration (e.g. qPCR, atp, mpn, etc.) Should also be provided. (example: total prokaryotes; 3.5e7 cells per ml; qpcr)" ;
    MIXS:Expected_value "organism name;measurement value;enumeration" .

MIXS:0000752 a owl:DatatypeProperty ;
    rdfs:label "misc_param" ;
    dcterms:title "miscellaneous parameter" ;
    schema1:name "misc_param" ;
    skos:definition "Any other measurement performed or parameter collected, that is not listed here" ;
    MIXS:Expected_value "parameter name;measurement value" .

MIXS:0000094 a owl:DatatypeProperty ;
    rdfs:label "alt" ;
    dcterms:title "altitude" ;
    schema1:name "alt" ;
    rdfs:range xsd:string ;
    skos:definition "Heights of objects such as airplanes, space shuttles, rockets, atmospheric balloons and heights of places such as atmospheric layers and clouds. It is used to measure the height of an object which is above the earth's surface. In this context, the altitude measurement is the vertical distance between the earth's surface above sea level and the sampled position in the air" ;
    MIXS:Preferred_unit "meter" .

MIXS:0000183 a owl:DatatypeProperty ;
    rdfs:label "salinity" ;
    dcterms:title "salinity" ;
    schema1:name "salinity" ;
    rdfs:range xsd:string ;
    skos:definition "The total concentration of all dissolved salts in a liquid or solid sample. While salinity can be measured by a complete chemical analysis, this method is difficult and time consuming. More often, it is instead derived from the conductivity measurement. This is known as practical salinity. These derivations compare the specific conductance of the sample to a salinity standard such as seawater" ;
    MIXS:Preferred_unit "practical salinity unit, percentage" .

MIXS:0000753 a owl:ObjectProperty ;
    rdfs:label "oxy_stat_samp" ;
    dcterms:title "oxygenation status of sample" ;
    schema1:name "oxy_stat_samp" ;
    rdfs:range MIXS:OxyStatSampEnum ;
    skos:definition "Oxygenation status of sample" .

MIXS:0001225 a owl:DatatypeProperty ;
    rdfs:label "samp_collect_method" ;
    dcterms:title "sample collection method" ;
    schema1:name "samp_collect_method" ;
    rdfs:range xsd:string ;
    skos:definition "The method employed for collecting the sample" .

MIXS:0000001 a owl:DatatypeProperty ;
    rdfs:label "samp_size" ;
    dcterms:title "amount or size of sample collected" ;
    schema1:name "samp_size" ;
    rdfs:range xsd:string ;
    skos:definition "The total amount or size (volume (ml), mass (g) or area (m2) ) of sample collected" .

MIXS:0000002 a owl:DatatypeProperty ;
    rdfs:label "samp_collect_device" ;
    dcterms:title "sample collection device" ;
    schema1:name "samp_collect_device" ;
    skos:definition "The device used to collect an environmental sample. This field accepts terms listed under environmental sampling device (http://purl.obolibrary.org/obo/ENVO). This field also accepts terms listed under specimen collection device (http://purl.obolibrary.org/obo/GENEPIO_0002094)" ;
    MIXS:Expected_value "device name" .

MIXS:0000009 a owl:DatatypeProperty ;
    rdfs:label "lat_lon" ;
    dcterms:title "geographic location (latitude and longitude)" ;
    schema1:name "lat_lon" ;
    skos:definition "The geographical origin of the sample as defined by latitude and longitude. The values should be reported in decimal degrees, limited to 8 decimal points, and in WGS84 system" .

MIXS:0000010 a owl:DatatypeProperty ;
    rdfs:label "geo_loc_name" ;
    dcterms:title "geographic location (country and/or sea,region)" ;
    schema1:name "geo_loc_name" ;
    rdfs:range xsd:string ;
    skos:definition "The geographical origin of the sample as defined by the country or sea name followed by specific region name. Country or sea names should be chosen from the INSDC country list (http://insdc.org/country.html), or the GAZ ontology (http://purl.bioontology.org/ontology/GAZ)" .

MIXS:0000011 a owl:DatatypeProperty ;
    rdfs:label "collection_date" ;
    dcterms:title "collection date" ;
    schema1:name "collection_date" ;
    rdfs:range xsd:dateTime ;
    skos:definition "The time of sampling, either as an instance (single point in time) or interval. In case no exact time is available, the date/time can be right truncated i.e. all of these are valid times: 2008-01-23T19:23:10+00:00; 2008-01-23T19:23:10; 2008-01-23; 2008-01; 2008; Except: 2008-01; 2008 all are ISO8601 compliant" .

MIXS:0000037 a owl:DatatypeProperty ;
    rdfs:label "nucl_acid_ext" ;
    dcterms:title "nucleic acid extraction" ;
    schema1:name "nucl_acid_ext" ;
    rdfs:range xsd:string ;
    skos:definition "A link to a literature reference, electronic resource or a standard operating procedure (SOP), that describes the material separation to recover the nucleic acid fraction from a sample" .

MIXS:0000050 a owl:DatatypeProperty ;
    rdfs:label "seq_meth" ;
    dcterms:title "sequencing method" ;
    schema1:name "seq_meth" ;
    rdfs:range xsd:string ;
    skos:definition "Sequencing machine used. Where possible the term should be taken from the OBI list of DNA sequencers (http://purl.obolibrary.org/obo/OBI_0400103)" .

MIXS:0000755 a owl:DatatypeProperty ;
    rdfs:label "samp_store_loc" ;
    dcterms:title "sample storage location" ;
    schema1:name "samp_store_loc" ;
    rdfs:range xsd:string ;
    skos:definition "Location at which sample was stored, usually name of a specific freezer/room" ;
    MIXS:Expected_value "location name" .

MIXS:0000110 a owl:DatatypeProperty ;
    rdfs:label "samp_store_temp" ;
    dcterms:title "sample storage temperature" ;
    schema1:name "samp_store_temp" ;
    rdfs:range xsd:string ;
    skos:definition "Temperature at which sample was stored, e.g. -80 degree Celsius" ;
    MIXS:Preferred_unit "degree Celsius" .

MIXS:0000116 a owl:DatatypeProperty ;
    rdfs:label "samp_store_dur" ;
    dcterms:title "sample storage duration" ;
    schema1:name "samp_store_dur" ;
    rdfs:range xsd:string ;
    skos:definition "Duration for which the sample was stored. Indicate the duration for which the sample was stored written in ISO 8601 format" .

MIXS:0000018 a owl:DatatypeProperty ;
    rdfs:label "depth" ;
    dcterms:title "depth" ;
    schema1:name "depth" ;
    rdfs:range xsd:string ;
    skos:definition "The vertical distance below local surface. For sediment or soil samples depth is measured from sediment or soil surface, respectively. Depth can be reported as an interval for subsurface samples" ;
    MIXS:Preferred_unit "meter" .

MIXS:0000093 a owl:DatatypeProperty ;
    rdfs:label "elev" ;
    dcterms:title "elevation" ;
    schema1:name "elev" ;
    rdfs:range xsd:string ;
    skos:definition "Elevation of the sampling site is its height above a fixed reference point, most commonly the mean sea level. Elevation is mainly used when referring to points on the earth's surface, while altitude is used for points above the surface, such as an aircraft in flight or a spacecraft in orbit" ;
    MIXS:Preferred_unit "meter" .

MIXS:0000113 a owl:DatatypeProperty ;
    rdfs:label "temp" ;
    dcterms:title "temperature" ;
    schema1:name "temp" ;
    rdfs:range xsd:string ;
    skos:definition "Temperature of the sample at the time of sampling" ;
    MIXS:Preferred_unit "degree Celsius" .

MIXS:0000092 a owl:DatatypeProperty ;
    rdfs:label "project_name" ;
    dcterms:title "project name" ;
    schema1:name "project_name" ;
    rdfs:range xsd:string ;
    skos:definition "Name of the project within which the sequencing was organized" .

MIXS:0000111 a owl:DatatypeProperty ;
    rdfs:label "samp_vol_we_dna_ext" ;
    dcterms:title "sample volume or weight for DNA extraction" ;
    schema1:name "samp_vol_we_dna_ext" ;
    rdfs:range xsd:string ;
    skos:definition "Volume (ml) or mass (g) of total collected sample processed for DNA extraction. Note: total sample collected should be entered under the term Sample Size (MIXS:0000001)" ;
    MIXS:Preferred_unit "milliliter, gram, milligram, square centimeter" .

MIXS:0001107 a owl:DatatypeProperty ;
    rdfs:label "samp_name" ;
    dcterms:title "sample name" ;
    schema1:name "samp_name" ;
    rdfs:range xsd:string ;
    skos:definition "A local identifier or name that for the material sample used for extracting nucleic acids, and subsequent sequencing. It can refer either to the original material collected or to any derived sub-samples. It can have any format, but we suggest that you make it concise, unique and consistent within your lab, and as informative as possible. INSDC requires every sample name from a single Submitter to be unique. Use of a globally unique identifier for the field source_mat_id is recommended in addition to sample_name" ;
    MIXS:Preferred_unit "" .

linkml:EnumDefinition a owl:Class ;
    rdfs:label "EnumDefinition" ;
    dcterms:title "EnumDefinition" ;
    schema1:name "EnumDefinition" ;
    skos:definition "an element whose instances must be drawn from a specified set of permissible values" .

linkml:PermissibleValue a owl:Class ;
    rdfs:label "PermissibleValue" ;
    dcterms:title "PermissibleValue" ;
    schema1:name "PermissibleValue" ;
    skos:definition "a permissible value, accompanied by intended text and an optional mapping to a concept URI" .

