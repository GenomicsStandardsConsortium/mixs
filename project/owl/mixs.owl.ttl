	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "heavy metal name;measurement value unit" ;
	MIXS:Preferred_unit "microgram per gram" .
MIXS:0000653 dcterms:title "biochemical oxygen demand" ;
	schema1:keywords "oxygen" ;
	a owl:DatatypeProperty ;
	rdfs:label "biochem_oxygen_dem" ;
	rdfs:range xsd:string ;
	skos:definition "Amount of dissolved oxygen needed by aerobic biological organisms in a body of water to break down organic material present in a given water sample at certain temperature over a specific time period" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "milligram per liter" .
MIXS:0000656 dcterms:title "chemical oxygen demand" ;
	schema1:keywords "oxygen" ;
	a owl:DatatypeProperty ;
	rdfs:label "chem_oxygen_dem" ;
	rdfs:range xsd:string ;
	skos:definition "A measure of the capacity of water to consume oxygen during the decomposition of organic matter and the oxidation of inorganic chemicals such as ammonia and nitrite" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "milligram per liter" .
