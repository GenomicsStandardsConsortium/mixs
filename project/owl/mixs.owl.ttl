	a owl:DatatypeProperty ;
	rdfs:label "diss_org_nitro" ;
	rdfs:range xsd:string ;
	skos:definition "Dissolved organic nitrogen concentration measured as; total dissolved nitrogen - NH4 - NO3 - NO2" ;
	skos:inScheme <https://w3id.org/mixs> .
