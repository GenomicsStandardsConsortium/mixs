MIXS:0000022 a owl:DatatypeProperty ;
    rdfs:label "num_replicons" ;
    dcterms:title "number of replicons" ;
    schema1:name "num_replicons" ;
    rdfs:range xsd:integer ;
    skos:definition "Reports the number of replicons in a nuclear genome of eukaryotes, in the genome of a bacterium or archaea or the number of segments in a segmented virus. Always applied to the haploid chromosome count of a eukaryote" ;
    MIXS:Expected_value "for eukaryotes and bacteria: chromosomes (haploid count); for viruses: segments" .

MIXS:0000033 a owl:DatatypeProperty ;
    rdfs:label "propagation" ;
    dcterms:title "propagation" ;
    schema1:name "propagation" ;
    rdfs:range xsd:string ;
    skos:definition "The type of reproduction from the parent stock. Values for this field is specific to different taxa. For phage or virus: lytic/lysogenic/temperate/obligately lytic. For plasmids: incompatibility group. For eukaryotes: sexual/asexual" ;
    MIXS:Expected_value "for virus: lytic, lysogenic, temperate, obligately lytic; for plasmid: incompatibility group; for eukaryote: asexual, sexual; other more specific values (e.g., incompatibility group) are allowed" .

MIXS:0000034 a owl:DatatypeProperty ;
    rdfs:label "encoded_traits" ;
    dcterms:title "encoded traits" ;
    schema1:name "encoded_traits" ;
    rdfs:range xsd:string ;
    skos:definition "Should include key traits like antibiotic resistance or xenobiotic degradation phenotypes for plasmids, converting genes for phage" ;
    MIXS:Expected_value "for plasmid: antibiotic resistance; for phage: converting genes" .

MIXS:0000067 a owl:DatatypeProperty ;
    rdfs:label "trnas" ;
    dcterms:title "number of standard tRNAs extracted" ;
    schema1:name "trnas" ;
    skos:definition "The total number of tRNAs identified from the SAG or MAG" ;
    MIXS:Expected_value "value from 0-21" .

MIXS:0000068 a owl:DatatypeProperty ;
    rdfs:label "trna_ext_software" ;
    dcterms:title "tRNA extraction software" ;
    schema1:name "trna_ext_software" ;
    rdfs:range xsd:string ;
    skos:definition "Tools used for tRNA identification" .

MIXS:0000071 a owl:ObjectProperty ;
    rdfs:label "compl_appr" ;
    dcterms:title "completeness approach" ;
    schema1:name "compl_appr" ;
    rdfs:range MIXS:ComplApprEnum ;
    skos:definition "The approach used to determine the completeness of a given genomic assembly, which would typically make use of a set of conserved marker genes or a closely related reference genome. For UViG completeness, include reference genome or group used, and contig feature suggesting a complete genome" ;
    MIXS:Expected_value "text" .

MIXS:0000100 a owl:DatatypeProperty ;
    rdfs:label "humidity" ;
    dcterms:title "humidity" ;
    schema1:name "humidity" ;
    rdfs:range xsd:string ;
    skos:definition "Amount of water vapour in the air, at the time of sampling" .

MIXS:0000101 a owl:DatatypeProperty ;
    rdfs:label "methane" ;
    dcterms:title "methane" ;
    schema1:name "methane" ;
    rdfs:range xsd:string ;
    skos:definition "Methane (gas) amount or concentration at the time of sampling" ;
    MIXS:Preferred_unit "micromole per liter, parts per billion, parts per million" .

MIXS:0000106 a owl:DatatypeProperty ;
    rdfs:label "diss_inorg_phosp" ;
    dcterms:title "dissolved inorganic phosphorus" ;
    schema1:name "diss_inorg_phosp" ;
    rdfs:range xsd:string ;
    skos:definition "Concentration of dissolved inorganic phosphorus in the sample" .

MIXS:0000117 a owl:DatatypeProperty ;
    rdfs:label "tot_phosp" ;
    dcterms:title "total phosphorus" ;
    schema1:name "tot_phosp" ;
    rdfs:range xsd:string ;
    skos:definition "Total phosphorus concentration in the sample, calculated by: total phosphorus = total dissolved phosphorus + particulate phosphorus" ;
    MIXS:Preferred_unit "micromole per liter, milligram per liter, parts per million" .

MIXS:0000137 a owl:DatatypeProperty ;
    rdfs:label "glucosidase_act" ;
    dcterms:title "glucosidase activity" ;
    schema1:name "glucosidase_act" ;
    rdfs:range xsd:string ;
    skos:definition "Measurement of glucosidase activity" ;
    MIXS:Preferred_unit "mol per liter per hour" .

MIXS:0000172 a owl:DatatypeProperty ;
    rdfs:label "aminopept_act" ;
    dcterms:title "aminopeptidase activity" ;
    schema1:name "aminopept_act" ;
    rdfs:range xsd:string ;
    skos:definition "Measurement of aminopeptidase activity" ;
    MIXS:Preferred_unit "mole per liter per hour" .

MIXS:0000173 a owl:DatatypeProperty ;
    rdfs:label "bacteria_carb_prod" ;
    dcterms:title "bacterial carbon production" ;
    schema1:name "bacteria_carb_prod" ;
    rdfs:range xsd:string ;
    skos:definition "Measurement of bacterial carbon production" .

MIXS:0000175 a owl:DatatypeProperty ;
    rdfs:label "bishomohopanol" ;
    dcterms:title "bishomohopanol" ;
    schema1:name "bishomohopanol" ;
    rdfs:range xsd:string ;
    skos:definition "Concentration of bishomohopanol" ;
    MIXS:Preferred_unit "microgram per liter, microgram per gram" .

MIXS:0000182 a owl:DatatypeProperty ;
    rdfs:label "redox_potential" ;
    dcterms:title "redox potential" ;
    schema1:name "redox_potential" ;
    rdfs:range xsd:string ;
    skos:definition "Redox potential, measured relative to a hydrogen cell, indicating oxidation or reduction potential" ;
    MIXS:Preferred_unit "millivolt" .

MIXS:0000185 a owl:DatatypeProperty ;
    rdfs:label "water_content" ;
    dcterms:title "water content" ;
    schema1:name "water_content" ;
    rdfs:range xsd:string ;
    skos:definition "Water content measurement" ;
    MIXS:Preferred_unit "gram per gram or cubic centimeter per cubic centimeter" .

MIXS:0000211 a owl:DatatypeProperty ;
    rdfs:label "porosity" ;
    dcterms:title "porosity" ;
    schema1:name "porosity" ;
    skos:definition "Porosity of deposited sediment is volume of voids divided by the total volume of sample" ;
    MIXS:Expected_value "measurement value or range" ;
    MIXS:Preferred_unit "percentage" .

MIXS:0000298 a owl:DatatypeProperty ;
    rdfs:label "alkalinity_method" ;
    dcterms:title "alkalinity method" ;
    schema1:name "alkalinity_method" ;
    rdfs:range xsd:string ;
    skos:definition "Method used for alkalinity measurement" .

MIXS:0000310 a owl:DatatypeProperty ;
    rdfs:label "carb_nitro_ratio" ;
    dcterms:title "carbon/nitrogen ratio" ;
    schema1:name "carb_nitro_ratio" ;
    rdfs:range xsd:float ;
    skos:definition "Ratio of amount or concentrations of carbon to nitrogen" ;
    MIXS:Expected_value "measurement value" .

MIXS:0000315 a owl:DatatypeProperty ;
    rdfs:label "previous_land_use" ;
    dcterms:title "history/previous land use" ;
    schema1:name "previous_land_use" ;
    skos:definition "Previous land use and dates" ;
    MIXS:Expected_value "land use name;date" .

MIXS:0000318 a owl:DatatypeProperty ;
    rdfs:label "crop_rotation" ;
    dcterms:title "history/crop rotation" ;
    schema1:name "crop_rotation" ;
    skos:definition "Whether or not crop is rotated, and if yes, rotation schedule" ;
    MIXS:Expected_value "crop rotation status;schedule" .

MIXS:0000332 a owl:DatatypeProperty ;
    rdfs:label "soil_type" ;
    dcterms:title "soil type" ;
    schema1:name "soil_type" ;
    skos:definition "Description of the soil type or classification. This field accepts terms under soil (http://purl.obolibrary.org/obo/ENVO_00001998).  Multiple terms can be separated by pipes" ;
    MIXS:Expected_value "ENVO:00001998" .

MIXS:0000334 a owl:DatatypeProperty ;
    rdfs:label "soil_type_meth" ;
    dcterms:title "soil type method" ;
    schema1:name "soil_type_meth" ;
    rdfs:range xsd:string ;
    skos:definition "Reference or method used in determining soil series name or other lower-level classification" .

MIXS:0000336 a owl:DatatypeProperty ;
    rdfs:label "soil_texture_meth" ;
    dcterms:title "soil texture method" ;
    schema1:name "soil_texture_meth" ;
    rdfs:range xsd:string ;
    skos:definition "Reference or method used in determining soil texture" .

MIXS:0000337 a owl:DatatypeProperty ;
    rdfs:label "tot_org_c_meth" ;
    dcterms:title "total organic carbon method" ;
    schema1:name "tot_org_c_meth" ;
    rdfs:range xsd:string ;
    skos:definition "Reference or method used in determining total organic carbon" .

MIXS:0000338 a owl:DatatypeProperty ;
    rdfs:label "tot_nitro_cont_meth" ;
    dcterms:title "total nitrogen content method" ;
    schema1:name "tot_nitro_cont_meth" ;
    rdfs:range xsd:string ;
    skos:definition "Reference or method used in determining the total nitrogen" .

MIXS:0000490 a owl:DatatypeProperty ;
    rdfs:label "alkyl_diethers" ;
    dcterms:title "alkyl diethers" ;
    schema1:name "alkyl_diethers" ;
    rdfs:range xsd:string ;
    skos:definition "Concentration of alkyl diethers" .

MIXS:0000498 a owl:DatatypeProperty ;
    rdfs:label "mean_frict_vel" ;
    dcterms:title "mean friction velocity" ;
    schema1:name "mean_frict_vel" ;
    rdfs:range xsd:string ;
    skos:definition "Measurement of mean friction velocity" ;
    MIXS:Preferred_unit "meter per second" .

MIXS:0000502 a owl:DatatypeProperty ;
    rdfs:label "mean_peak_frict_vel" ;
    dcterms:title "mean peak friction velocity" ;
    schema1:name "mean_peak_frict_vel" ;
    rdfs:range xsd:string ;
    skos:definition "Measurement of mean peak friction velocity" ;
    MIXS:Preferred_unit "meter per second" .

MIXS:0000515 a owl:DatatypeProperty ;
    rdfs:label "part_org_carb" ;
    dcterms:title "particulate organic carbon" ;
    schema1:name "part_org_carb" ;
    rdfs:range xsd:string ;
    skos:definition "Concentration of particulate organic carbon" .

MIXS:0000516 a owl:DatatypeProperty ;
    rdfs:label "petroleum_hydrocarb" ;
    dcterms:title "petroleum hydrocarbon" ;
    schema1:name "petroleum_hydrocarb" ;
    rdfs:range xsd:string ;
    skos:definition "Concentration of petroleum hydrocarbon" ;
    MIXS:Preferred_unit "micromole per liter" .

MIXS:0000525 a owl:DatatypeProperty ;
    rdfs:label "tot_carb" ;
    dcterms:title "total carbon" ;
    schema1:name "tot_carb" ;
    rdfs:range xsd:string ;
    skos:definition "Total carbon content" .

MIXS:0000577 a owl:DatatypeProperty ;
    rdfs:label "root_med_carbon" ;
    dcterms:title "rooting medium carbon" ;
    schema1:name "root_med_carbon" ;
    skos:definition "Source of organic carbon in the culture rooting medium; e.g. sucrose" ;
    MIXS:Expected_value "carbon source name;measurement value" ;
    MIXS:Preferred_unit "milligram per liter" .

MIXS:0000578 a owl:DatatypeProperty ;
    rdfs:label "root_med_macronutr" ;
    dcterms:title "rooting medium macronutrients" ;
    schema1:name "root_med_macronutr" ;
    skos:definition "Measurement of the culture rooting medium macronutrients (N,P, K, Ca, Mg, S); e.g. KH2PO4 (170 mg/L)" ;
    MIXS:Expected_value "macronutrient name;measurement value" ;
    MIXS:Preferred_unit "milligram per liter" .

MIXS:0000643 a owl:DatatypeProperty ;
    rdfs:label "season_temp" ;
    dcterms:title "mean seasonal temperature" ;
    schema1:name "season_temp" ;
    rdfs:range xsd:string ;
    skos:definition "Mean seasonal temperature" ;
    skos:note "this slot should not be populated unless season is also populated" ;
    MIXS:Preferred_unit "degree Celsius" .

MIXS:0000645 a owl:DatatypeProperty ;
    rdfs:label "season_precpt" ;
    dcterms:title "mean seasonal precipitation" ;
    schema1:name "season_precpt" ;
    rdfs:range xsd:string ;
    skos:definition "The average of all seasonal precipitation values known, or an estimated equivalent value derived by such methods as regional indexes or Isohyetal maps" ;
    MIXS:Preferred_unit "millimeter" .

MIXS:0000735 a owl:DatatypeProperty ;
    rdfs:label "size_frac_low" ;
    dcterms:title "size-fraction lower threshold" ;
    schema1:name "size_frac_low" ;
    rdfs:range xsd:string ;
    skos:definition "Refers to the mesh/pore size used to pre-filter/pre-sort the sample. Materials smaller than the size threshold are excluded from the sample" ;
    MIXS:Preferred_unit "micrometer" .

MIXS:0000736 a owl:DatatypeProperty ;
    rdfs:label "size_frac_up" ;
    dcterms:title "size-fraction upper threshold" ;
    schema1:name "size_frac_up" ;
    rdfs:range xsd:string ;
    skos:definition "Mesh or pore size of the device used to retain the sample. Materials larger than the size threshold are excluded from the sample." ;
    MIXS:Preferred_unit "micrometer" .

MIXS:0001057 a owl:DatatypeProperty ;
    rdfs:label "plant_growth_med" ;
    dcterms:title "plant growth medium" ;
    schema1:name "plant_growth_med" ;
    skos:definition "Specification of the media for growing the plants or tissue cultured samples, e.g. soil, aeroponic, hydroponic, in vitro solid culture medium, in vitro liquid culture medium. Recommended value is a specific value from EO:plant growth medium (follow this link for terms http://purl.obolibrary.org/obo/EO_0007147) or other controlled vocabulary" ;
    MIXS:Expected_value "EO or enumeration" .

MIXS:0001062 a owl:DatatypeProperty ;
    rdfs:label "root_med_ph" ;
    dcterms:title "rooting medium pH" ;
    schema1:name "root_med_ph" ;
    rdfs:range xsd:float ;
    skos:definition "pH measurement of the culture rooting medium; e.g. 5.5" .

MIXS:0001106 a owl:DatatypeProperty ;
    rdfs:label "ph_meth" ;
    dcterms:title "pH method" ;
    schema1:name "ph_meth" ;
    rdfs:range xsd:string ;
    skos:definition "Reference or method used in determining pH" .

MIXS:0001183 a owl:DatatypeProperty ;
    rdfs:label "coll_site_geo_feat" ;
    dcterms:title "collection site geographic feature" ;
    schema1:name "coll_site_geo_feat" ;
    skos:definition "Text or terms that describe the geographic feature where the food sample was obtained by the researcher. This field accepts selected terms listed under the following ontologies: anthropogenic geographic feature (http://purl.obolibrary.org/obo/ENVO_00000002), for example agricultural fairground [ENVO:01000986]; garden [ENVO:00000011} or any of its subclasses; market [ENVO:01000987]; water well [ENVO:01000002]; or human construction (http://purl.obolibrary.org/obo/ENVO_00000070)" ;
    MIXS:Expected_value "ENVO:00000002 or ENVO:00000070" .

MIXS:0001194 a owl:DatatypeProperty ;
    rdfs:label "bacterial_density" ;
    dcterms:title "bacteria density" ;
    schema1:name "bacterial_density" ;
    rdfs:range xsd:string ;
    skos:definition "Number of bacteria in sample, as defined by bacteria density (http://purl.obolibrary.org/obo/GENEPIO_0000043)" ;
    MIXS:Preferred_unit "colony forming units per milliliter; colony forming units per gram of dry weight" .

MIXS:0001207 a owl:DatatypeProperty ;
    rdfs:label "food_origin" ;
    dcterms:title "food product origin geographic location" ;
    schema1:name "food_origin" ;
    rdfs:range xsd:string ;
    skos:definition "A reference to a place on the Earth, by its name or by its geographical location that describes the origin of the food commodity, either in terms of its cultivation or production. This field accepts terms listed under geographic location (http://purl.obolibrary.org/obo/GAZ_00000448)" .

MIXS:0001208 a owl:DatatypeProperty ;
    rdfs:label "food_pack_capacity" ;
    dcterms:title "food package capacity" ;
    schema1:name "food_pack_capacity" ;
    rdfs:range xsd:string ;
    skos:definition "The maximum number of product units within a package" ;
    MIXS:Preferred_unit "grams" .

MIXS:0001213 a owl:DatatypeProperty ;
    rdfs:label "food_product_qual" ;
    dcterms:title "food product by quality" ;
    schema1:name "food_product_qual" ;
    rdfs:range xsd:string ;
    skos:definition "Descriptors for describing food visually or via other senses, which is useful for tasks like food inspection where little prior knowledge of how the food came to be is available. Some terms like \"food (frozen)\" are both a quality descriptor and the output of a process. This field accepts terms listed under food product by quality (http://purl.obolibrary.org/obo/FOODON_00002454)" .

MIXS:0001214 a owl:ObjectProperty ;
    rdfs:label "food_trace_list" ;
    dcterms:title "food traceability list category" ;
    schema1:name "food_trace_list" ;
    rdfs:range MIXS:FoodTraceListEnum ;
    skos:definition "The FDA is proposing to establish additional traceability recordkeeping requirements (beyond what is already required in existing regulations) for persons who manufacture, process, pack, or hold foods the Agency has designated for inclusion on the Food Traceability List. The Food Traceability List (FTL) identifies the foods for which the additional traceability records described in the proposed rule would be required. The term  Food Traceability List  (FTL) refers not only to the foods specifically listed (https://www.fda.gov/media/142303/download), but also to any foods that contain listed foods as ingredients" .

MIXS:0001216 a owl:DatatypeProperty ;
    rdfs:label "microb_cult_med" ;
    dcterms:title "microbiological culture medium" ;
    schema1:name "microb_cult_med" ;
    rdfs:range xsd:string ;
    skos:definition "A culture medium used to select for, grow, and maintain prokaryotic microorganisms. Can be in either liquid (broth) or solidified (e.g. with agar) forms. This field accepts terms listed under microbiological culture medium (http://purl.obolibrary.org/obo/MICRO_0000067). If the proper descriptor is not listed please use text to describe the culture medium" .

MIXS:0001226 a owl:DatatypeProperty ;
    rdfs:label "samp_rep_biol" ;
    dcterms:title "biological sample replicate" ;
    schema1:name "samp_rep_biol" ;
    rdfs:range xsd:string ;
    skos:definition "Measurements of biologically distinct samples that show biological variation" .

MIXS:0001227 a owl:DatatypeProperty ;
    rdfs:label "samp_rep_tech" ;
    dcterms:title "technical sample replicate" ;
    schema1:name "samp_rep_tech" ;
    rdfs:range xsd:string ;
    skos:definition "Repeated measurements of the same sample that show independent measures of the noise associated with the equipment and the protocols" .

MIXS:0001228 a owl:DatatypeProperty ;
    rdfs:label "samp_stor_device" ;
    dcterms:title "sample storage device" ;
    schema1:name "samp_stor_device" ;
    skos:definition "The container used to store the  sample. This field accepts terms listed under container (http://purl.obolibrary.org/obo/NCIT_C43186). If the proper descriptor is not listed please use text to describe the storage device" ;
    MIXS:Expected_value "NCIT:C4318" .

MIXS:0001229 a owl:DatatypeProperty ;
    rdfs:label "samp_stor_media" ;
    dcterms:title "sample storage media" ;
    schema1:name "samp_stor_media" ;
    rdfs:range xsd:string ;
    skos:definition "The liquid that is added to the sample collection device prior to sampling. If the sample is pre-hydrated, indicate the liquid media the sample is pre-hydrated with for storage purposes. This field accepts terms listed under microbiological culture medium (http://purl.obolibrary.org/obo/MICRO_0000067). If the proper descriptor is not listed please use text to describe the sample storage media" .

MIXS:0001230 a owl:ObjectProperty ;
    rdfs:label "samp_transport_cont" ;
    dcterms:title "sample transport container" ;
    schema1:name "samp_transport_cont" ;
    rdfs:range MIXS:SampTransportContEnum ;
    skos:definition "Container in which the sample was stored during transport. Indicate the location name" .

MIXS:0001231 a owl:DatatypeProperty ;
    rdfs:label "samp_transport_dur" ;
    dcterms:title "sample transport duration" ;
    schema1:name "samp_transport_dur" ;
    rdfs:range xsd:string ;
    skos:definition "The duration of time from when the sample was collected until processed. Indicate the duration for which the sample was stored written in ISO 8601 format" ;
    MIXS:Preferred_unit "days" .

MIXS:0001232 a owl:DatatypeProperty ;
    rdfs:label "samp_transport_temp" ;
    dcterms:title "sample transport temperature" ;
    schema1:name "samp_transport_temp" ;
    skos:definition "Temperature at which sample was transported, e.g. -20 or 4 degree Celsius" ;
    MIXS:Expected_value "text or measurement value" ;
    MIXS:Preferred_unit "degree Celsius" .

MIXS:0001237 a owl:DatatypeProperty ;
    rdfs:label "study_inc_dur" ;
    dcterms:title "study incubation duration" ;
    schema1:name "study_inc_dur" ;
    rdfs:range xsd:string ;
    skos:definition "Sample incubation duration if unpublished or unvalidated method is used. Indicate the timepoint written in ISO 8601 format" ;
    MIXS:Preferred_unit "hours or days" .

MIXS:0001238 a owl:DatatypeProperty ;
    rdfs:label "study_inc_temp" ;
    dcterms:title "study incubation temperature" ;
    schema1:name "study_inc_temp" ;
    rdfs:range xsd:string ;
    skos:definition "Sample incubation temperature if unpublished or unvalidated method is used" ;
    MIXS:Preferred_unit "degree Celsius" .

MIXS:0001239 a owl:DatatypeProperty ;
    rdfs:label "study_timecourse" ;
    dcterms:title "time-course duration" ;
    schema1:name "study_timecourse" ;
    rdfs:range xsd:string ;
    skos:definition "For time-course research studies involving samples of the food commodity, indicate the total duration of the time-course study" ;
    MIXS:Preferred_unit "dpi" .

MIXS:0001335 a owl:DatatypeProperty ;
    rdfs:label "spikein_count" ;
    dcterms:title "spike-in organism count" ;
    schema1:name "spikein_count" ;
    skos:definition "Total cell count of any organism (or group of organisms) per gram, volume or area of sample, should include name of organism followed by count. The method that was used for the enumeration (e.g. qPCR, atp, mpn, etc.) should also be provided (example: total prokaryotes; 3.5e7 cells per ml; qPCR)" ;
    MIXS:Expected_value "organism name;measurement value;enumeration" ;
    MIXS:Preferred_unit "colony forming units per milliliter; colony forming units per gram of dry weight" .

MIXS:CeilTypeEnum a owl:Class ;
    rdfs:label "CeilTypeEnum" ;
    dcterms:title "CeilTypeEnum" ;
    schema1:name "CeilTypeEnum" ;
    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( <https://w3id.org/mixs/CeilTypeEnum#barrel-shaped> <https://w3id.org/mixs/CeilTypeEnum#cathedral> <https://w3id.org/mixs/CeilTypeEnum#coffered> <https://w3id.org/mixs/CeilTypeEnum#concave> <https://w3id.org/mixs/CeilTypeEnum#cove> <https://w3id.org/mixs/CeilTypeEnum#dropped> <https://w3id.org/mixs/CeilTypeEnum#stretched> ) ;
    linkml:permissible_values <https://w3id.org/mixs/CeilTypeEnum#barrel-shaped>,
        <https://w3id.org/mixs/CeilTypeEnum#cathedral>,
        <https://w3id.org/mixs/CeilTypeEnum#coffered>,
        <https://w3id.org/mixs/CeilTypeEnum#concave>,
        <https://w3id.org/mixs/CeilTypeEnum#cove>,
        <https://w3id.org/mixs/CeilTypeEnum#dropped>,
        <https://w3id.org/mixs/CeilTypeEnum#stretched> .

MIXS:DrainageClassEnum a owl:Class ;
    rdfs:label "DrainageClassEnum" ;
    dcterms:title "DrainageClassEnum" ;
    schema1:name "DrainageClassEnum" ;
    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( <https://w3id.org/mixs/DrainageClassEnum#excessively%20drained> <https://w3id.org/mixs/DrainageClassEnum#moderately%20well> <https://w3id.org/mixs/DrainageClassEnum#poorly> <https://w3id.org/mixs/DrainageClassEnum#somewhat%20poorly> <https://w3id.org/mixs/DrainageClassEnum#very%20poorly> <https://w3id.org/mixs/DrainageClassEnum#well> ) ;
    linkml:permissible_values <https://w3id.org/mixs/DrainageClassEnum#excessively%20drained>,
        <https://w3id.org/mixs/DrainageClassEnum#moderately%20well>,
        <https://w3id.org/mixs/DrainageClassEnum#poorly>,
        <https://w3id.org/mixs/DrainageClassEnum#somewhat%20poorly>,
        <https://w3id.org/mixs/DrainageClassEnum#very%20poorly>,
        <https://w3id.org/mixs/DrainageClassEnum#well> .

MIXS:FloorStrucEnum a owl:Class ;
    rdfs:label "FloorStrucEnum" ;
    dcterms:title "FloorStrucEnum" ;
    schema1:name "FloorStrucEnum" ;
    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( <https://w3id.org/mixs/FloorStrucEnum#balcony> <https://w3id.org/mixs/FloorStrucEnum#concrete> <https://w3id.org/mixs/FloorStrucEnum#floating%20floor> <https://w3id.org/mixs/FloorStrucEnum#glass%20floor> <https://w3id.org/mixs/FloorStrucEnum#raised%20floor> <https://w3id.org/mixs/FloorStrucEnum#sprung%20floor> <https://w3id.org/mixs/FloorStrucEnum#wood-framed> ) ;
    linkml:permissible_values <https://w3id.org/mixs/FloorStrucEnum#balcony>,
        <https://w3id.org/mixs/FloorStrucEnum#concrete>,
        <https://w3id.org/mixs/FloorStrucEnum#floating%20floor>,
        <https://w3id.org/mixs/FloorStrucEnum#glass%20floor>,
        <https://w3id.org/mixs/FloorStrucEnum#raised%20floor>,
        <https://w3id.org/mixs/FloorStrucEnum#sprung%20floor>,
        <https://w3id.org/mixs/FloorStrucEnum#wood-framed> .

MIXS:FoodCleanProcEnum a owl:Class ;
    rdfs:label "FoodCleanProcEnum" ;
    dcterms:title "FoodCleanProcEnum" ;
    schema1:name "FoodCleanProcEnum" ;
    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( <https://w3id.org/mixs/FoodCleanProcEnum#drum%20and%20drain> <https://w3id.org/mixs/FoodCleanProcEnum#manual%20spinner> <https://w3id.org/mixs/FoodCleanProcEnum#rinsed%20with%20sanitizer%20solution> <https://w3id.org/mixs/FoodCleanProcEnum#rinsed%20with%20water> <https://w3id.org/mixs/FoodCleanProcEnum#scrubbed%20with%20brush> <https://w3id.org/mixs/FoodCleanProcEnum#scrubbed%20with%20hand> <https://w3id.org/mixs/FoodCleanProcEnum#soaking> ) ;
    linkml:permissible_values <https://w3id.org/mixs/FoodCleanProcEnum#drum%20and%20drain>,
        <https://w3id.org/mixs/FoodCleanProcEnum#manual%20spinner>,
        <https://w3id.org/mixs/FoodCleanProcEnum#rinsed%20with%20sanitizer%20solution>,
        <https://w3id.org/mixs/FoodCleanProcEnum#rinsed%20with%20water>,
        <https://w3id.org/mixs/FoodCleanProcEnum#scrubbed%20with%20brush>,
        <https://w3id.org/mixs/FoodCleanProcEnum#scrubbed%20with%20hand>,
        <https://w3id.org/mixs/FoodCleanProcEnum#soaking> .

MIXS:FreqCleanEnum a owl:Class ;
