    rdfs:subClassOf linkml:PermissibleValue,
        MIXS:SoilHorizonEnum ;
    skos:definition "The surface horizon, also called topsoil. It has a defined soil structure, and is mostly made up of humus (decayed organic matter)." .

<https://w3id.org/mixs/SoilHorizonEnum#B%20horizon> a owl:Class ;
    rdfs:label "B horizon" ;
    dcterms:title "B horizon" ;
    schema1:name "B horizon" ;
    rdfs:subClassOf linkml:PermissibleValue,
        MIXS:SoilHorizonEnum ;
    skos:definition "Also known as the subsoil. It is greatly composed of material illuviated (washed in from) layers above it. It is typically denser than the A horizon and has a clayey texture." .

<https://w3id.org/mixs/SoilHorizonEnum#C%20horizon> a owl:Class ;
    rdfs:label "C horizon" ;
    dcterms:title "C horizon" ;
    schema1:name "C horizon" ;
    rdfs:subClassOf linkml:PermissibleValue,
        MIXS:SoilHorizonEnum ;
    skos:definition "Also known as the substratum is unconsolidated material deepest in the pit and closest to the bedrock." .

<https://w3id.org/mixs/SoilHorizonEnum#E%20horizon> a owl:Class ;
    rdfs:label "E horizon" ;
    dcterms:title "E horizon" ;
    schema1:name "E horizon" ;
    rdfs:subClassOf linkml:PermissibleValue,
        MIXS:SoilHorizonEnum ;
    skos:definition "Used to refer to subsurface horizons that have undergone a significant loss of minerals, also known as Eluviation (or leaching)." .

<https://w3id.org/mixs/SoilHorizonEnum#Permafrost> a owl:Class ;
    rdfs:label "Permafrost" ;
    dcterms:title "Permafrost" ;
    schema1:name "Permafrost" ;
    rdfs:subClassOf linkml:PermissibleValue,
        MIXS:SoilHorizonEnum ;
    skos:definition "Soil that continuously remains below 0 °C (32 °F) for two years or more." .

<https://w3id.org/mixs/SoilHorizonEnum#R%20layer> a owl:Class ;
    rdfs:label "R layer" ;
    dcterms:title "R layer" ;
    schema1:name "R layer" ;
    rdfs:subClassOf linkml:PermissibleValue,
        MIXS:SoilHorizonEnum ;
    skos:altLabel "R horizon" ;
    skos:definition "Hard bedrock, which is usually the lowest layer. It is characterized by tightly bound and unbreakable materials." .

