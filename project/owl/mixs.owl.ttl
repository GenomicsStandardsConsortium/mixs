    rdfs:label "nitrite" ;
    dcterms:title "nitrite" ;
    schema1:name "nitrite" ;
    rdfs:range xsd:string ;
    skos:definition "Concentration of nitrite in the sample" ;
    MIXS:Preferred_unit "micromole per liter, milligram per liter, parts per million" .

MIXS:0000427 a owl:DatatypeProperty ;
    rdfs:label "ammonium" ;
    dcterms:title "ammonium" ;
    schema1:name "ammonium" ;
    rdfs:range xsd:string ;
    skos:definition "Concentration of ammonium in the sample" ;
    MIXS:Preferred_unit "micromole per liter, milligram per liter, parts per million" .

MIXS:0000429 a owl:DatatypeProperty ;
    rdfs:label "chloride" ;
    dcterms:title "chloride" ;
    schema1:name "chloride" ;
    rdfs:range xsd:string ;
    skos:definition "Concentration of chloride in the sample" ;
    MIXS:Preferred_unit "milligram per liter, parts per million" .

MIXS:0000430 a owl:DatatypeProperty ;
    rdfs:label "potassium" ;
    dcterms:title "potassium" ;
    schema1:name "potassium" ;
    rdfs:range xsd:string ;
    skos:definition "Concentration of potassium in the sample" ;
    MIXS:Preferred_unit "milligram per liter, parts per million" .

MIXS:0000432 a owl:DatatypeProperty ;
    rdfs:label "calcium" ;
    dcterms:title "calcium" ;
    schema1:name "calcium" ;
    rdfs:range xsd:string ;
    skos:definition "Concentration of calcium in the sample" ;
    MIXS:Preferred_unit "milligram per liter, micromole per liter, parts per million" .

MIXS:0000434 a owl:DatatypeProperty ;
    rdfs:label "diss_inorg_carb" ;
    dcterms:title "dissolved inorganic carbon" ;
    schema1:name "diss_inorg_carb" ;
    rdfs:range xsd:string ;
    skos:definition "Dissolved inorganic carbon concentration in the sample, typically measured after filtering the sample using a 0.45 micrometer filter" ;
    MIXS:Preferred_unit "microgram per liter, milligram per liter, parts per million" .

MIXS:0000436 a owl:DatatypeProperty ;
    rdfs:label "diss_carb_dioxide" ;
    dcterms:title "dissolved carbon dioxide" ;
    schema1:name "diss_carb_dioxide" ;
    rdfs:range xsd:string ;
    skos:definition "Concentration of dissolved carbon dioxide in the sample or liquid portion of the sample" ;
    MIXS:Preferred_unit "micromole per liter, milligram per liter" .

MIXS:0000811 a owl:DatatypeProperty ;
    rdfs:label "host_sex" ;
    dcterms:title "host sex" ;
    schema1:name "host_sex" ;
    skos:definition "Gender or physical sex of the host" ;
    skos:note "example of non-binary from Excel sheets does not match any of the enumerated values" ;
    MIXS:Expected_value "enumeration" .

MIXS:0000859 a owl:DatatypeProperty ;
    rdfs:label "genetic_mod" ;
    dcterms:title "genetic modification" ;
    schema1:name "genetic_mod" ;
    skos:definition "Genetic modifications of the genome of an organism, which may occur naturally by spontaneous mutation, or be introduced by some experimental means, e.g. specification of a transgene or the gene knocked-out or details of transient transfection" .

MIXS:0001298 a owl:DatatypeProperty ;
    rdfs:label "host_symbiont" ;
    dcterms:title "observed host symbionts" ;
    schema1:name "host_symbiont" ;
    rdfs:range xsd:string ;
    skos:definition "The taxonomic name of the organism(s) found living in mutualistic, commensalistic, or parasitic symbiosis with the specific host. The sampled symbiont can have its own symbionts. For example, parasites may have hyperparasites (=parasites of the parasite)" ;
    MIXS:Expected_value "species name or common name" .

