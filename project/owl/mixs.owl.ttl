    rdfs:label "sulfate" ;
    dcterms:title "sulfate" ;
    schema1:name "sulfate" ;
    rdfs:range xsd:string ;
    skos:definition "Concentration of sulfate in the sample" ;
    MIXS:Preferred_unit "micromole per liter, milligram per liter, parts per million" .

MIXS:0000424 a owl:DatatypeProperty ;
    rdfs:label "sulfide" ;
    dcterms:title "sulfide" ;
    schema1:name "sulfide" ;
    rdfs:range xsd:string ;
    skos:definition "Concentration of sulfide in the sample" ;
    MIXS:Preferred_unit "micromole per liter, milligram per liter, parts per million" .

