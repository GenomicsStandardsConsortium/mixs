MIXS:prod_label_claims dcterms:title "production labeling claims" ;
	schema1:keywords "production" ;
	a owl:DatatypeProperty ;
	rdfs:label "prod_label_claims" ;
	rdfs:range xsd:string ;
	skos:definition "Labeling claims containing descriptors such as wild caught, free-range, organic, free-range, industrial, hormone-free, antibiotic free, cage free. Can include more than one term, separated by \";\"" ;
	skos:inScheme <https://w3id.org/mixs> .
