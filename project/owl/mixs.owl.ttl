	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "exposure type;light intensity;light quality" ;
	MIXS:Preferred_unit "lux; micrometer, nanometer, angstrom" .
MIXS:0000570 dcterms:title "mineral nutrient regimen" ;
	schema1:keywords "mineral" , "nutrient" , "regimen" ;
	a owl:DatatypeProperty ;
	rdfs:label "mineral_nutr_regm" ;
