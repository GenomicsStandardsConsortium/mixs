    owl:unionOf ( <https://w3id.org/mixs/MechStrucEnum#boat> <https://w3id.org/mixs/MechStrucEnum#bus> <https://w3id.org/mixs/MechStrucEnum#car> <https://w3id.org/mixs/MechStrucEnum#carriage> <https://w3id.org/mixs/MechStrucEnum#coach> <https://w3id.org/mixs/MechStrucEnum#elevator> <https://w3id.org/mixs/MechStrucEnum#escalator> <https://w3id.org/mixs/MechStrucEnum#subway> <https://w3id.org/mixs/MechStrucEnum#train> ) ;
    linkml:permissible_values <https://w3id.org/mixs/MechStrucEnum#boat>,
        <https://w3id.org/mixs/MechStrucEnum#bus>,
        <https://w3id.org/mixs/MechStrucEnum#car>,
        <https://w3id.org/mixs/MechStrucEnum#carriage>,
        <https://w3id.org/mixs/MechStrucEnum#coach>,
        <https://w3id.org/mixs/MechStrucEnum#elevator>,
        <https://w3id.org/mixs/MechStrucEnum#escalator>,
        <https://w3id.org/mixs/MechStrucEnum#subway>,
        <https://w3id.org/mixs/MechStrucEnum#train> .

MIXS:RoomSampPosEnum a owl:Class ;
    rdfs:label "RoomSampPosEnum" ;
    dcterms:title "RoomSampPosEnum" ;
    schema1:name "RoomSampPosEnum" ;
    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( <https://w3id.org/mixs/RoomSampPosEnum#center> <https://w3id.org/mixs/RoomSampPosEnum#east%20corner> <https://w3id.org/mixs/RoomSampPosEnum#north%20corner> <https://w3id.org/mixs/RoomSampPosEnum#northeast%20corner> <https://w3id.org/mixs/RoomSampPosEnum#northwest%20corner> <https://w3id.org/mixs/RoomSampPosEnum#south%20corner> <https://w3id.org/mixs/RoomSampPosEnum#southeast%20corner> <https://w3id.org/mixs/RoomSampPosEnum#southwest%20corner> <https://w3id.org/mixs/RoomSampPosEnum#west%20corner> ) ;
    linkml:permissible_values <https://w3id.org/mixs/RoomSampPosEnum#center>,
        <https://w3id.org/mixs/RoomSampPosEnum#east%20corner>,
        <https://w3id.org/mixs/RoomSampPosEnum#north%20corner>,
        <https://w3id.org/mixs/RoomSampPosEnum#northeast%20corner>,
        <https://w3id.org/mixs/RoomSampPosEnum#northwest%20corner>,
        <https://w3id.org/mixs/RoomSampPosEnum#south%20corner>,
        <https://w3id.org/mixs/RoomSampPosEnum#southeast%20corner>,
        <https://w3id.org/mixs/RoomSampPosEnum#southwest%20corner>,
        <https://w3id.org/mixs/RoomSampPosEnum#west%20corner> .

MIXS:SampWeatherEnum a owl:Class ;
    rdfs:label "SampWeatherEnum" ;
    dcterms:title "SampWeatherEnum" ;
    schema1:name "SampWeatherEnum" ;
    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( <https://w3id.org/mixs/SampWeatherEnum#clear%20sky> <https://w3id.org/mixs/SampWeatherEnum#cloudy> <https://w3id.org/mixs/SampWeatherEnum#foggy> <https://w3id.org/mixs/SampWeatherEnum#hail> <https://w3id.org/mixs/SampWeatherEnum#rain> <https://w3id.org/mixs/SampWeatherEnum#sleet> <https://w3id.org/mixs/SampWeatherEnum#snow> <https://w3id.org/mixs/SampWeatherEnum#sunny> <https://w3id.org/mixs/SampWeatherEnum#windy> ) ;
    linkml:permissible_values <https://w3id.org/mixs/SampWeatherEnum#clear%20sky>,
        <https://w3id.org/mixs/SampWeatherEnum#cloudy>,
        <https://w3id.org/mixs/SampWeatherEnum#foggy>,
        <https://w3id.org/mixs/SampWeatherEnum#hail>,
        <https://w3id.org/mixs/SampWeatherEnum#rain>,
        <https://w3id.org/mixs/SampWeatherEnum#sleet>,
        <https://w3id.org/mixs/SampWeatherEnum#snow>,
        <https://w3id.org/mixs/SampWeatherEnum#sunny>,
        <https://w3id.org/mixs/SampWeatherEnum#windy> .

MIXS:0000030 a owl:DatatypeProperty ;
    rdfs:label "host_spec_range" ;
    dcterms:title "host specificity or range" ;
    schema1:name "host_spec_range" ;
    skos:definition "The range and diversity of host species that an organism is capable of infecting, defined by NCBI taxonomy identifier" ;
    MIXS:Expected_value "NCBI taxid" .

MIXS:0000044 a owl:DatatypeProperty ;
    rdfs:label "target_gene" ;
    dcterms:title "target gene" ;
    schema1:name "target_gene" ;
    rdfs:range xsd:string ;
    skos:definition "Targeted gene or locus name for marker gene studies" .

MIXS:0000045 a owl:DatatypeProperty ;
    rdfs:label "target_subfragment" ;
    dcterms:title "target subfragment" ;
    schema1:name "target_subfragment" ;
    rdfs:range xsd:string ;
    skos:definition "Name of subfragment of a gene or locus. Important to e.g. identify special regions on marker genes like V6 on 16S rRNA" .

MIXS:0000046 a owl:DatatypeProperty ;
    rdfs:label "pcr_primers" ;
    dcterms:title "pcr primers" ;
    schema1:name "pcr_primers" ;
    skos:definition "PCR primers that were used to amplify the sequence of the targeted gene, locus or subfragment. This field should contain all the primers used for a single PCR reaction if multiple forward or reverse primers are present in a single PCR reaction. The primer sequence should be reported in uppercase letters" .

MIXS:0000049 a owl:DatatypeProperty ;
    rdfs:label "pcr_cond" ;
    dcterms:title "pcr conditions" ;
    schema1:name "pcr_cond" ;
    skos:definition "Description of reaction conditions and components of polymerase chain reaction performed during library preparation." ;
    MIXS:Expected_value "initial denaturation:degrees_minutes;annealing:degrees_minutes;elongation:degrees_minutes;final elongation:degrees_minutes;total cycles" .

MIXS:0000051 a owl:ObjectProperty ;
    rdfs:label "seq_quality_check" ;
    dcterms:title "sequence quality check" ;
    schema1:name "seq_quality_check" ;
    rdfs:range MIXS:SeqQualityCheckEnum ;
    skos:definition "Indicate if the sequence has been called by automatic systems (none) or undergone a manual editing procedure (e.g. by inspecting the raw data or chromatograms). Applied only for sequences that are not submitted to SRA,ENA or DRA" ;
    MIXS:Expected_value "none or manually edited" .

MIXS:0000052 a owl:DatatypeProperty ;
    rdfs:label "chimera_check" ;
    dcterms:title "chimera check software" ;
    schema1:name "chimera_check" ;
    rdfs:range xsd:string ;
    skos:definition "Tool(s) used for chimera checking, including version number and parameters, to discover and remove chimeric sequences. A chimeric sequence is comprised of two or more phylogenetically distinct parent sequences" .

MIXS:0000102 a owl:DatatypeProperty ;
    rdfs:label "tot_nitro" ;
    dcterms:title "total nitrogen concentration" ;
    schema1:name "tot_nitro" ;
    rdfs:range xsd:string ;
    skos:definition "Total nitrogen concentration of water samples, calculated by: total nitrogen = total dissolved nitrogen + particulate nitrogen. Can also be measured without filtering, reported as nitrogen" ;
    MIXS:Preferred_unit "microgram per liter, micromole per liter, milligram per liter" .

MIXS:0000119 a owl:DatatypeProperty ;
    rdfs:label "diss_oxygen" ;
    dcterms:title "dissolved oxygen" ;
    schema1:name "diss_oxygen" ;
    rdfs:range xsd:string ;
    skos:definition "Concentration of dissolved oxygen" ;
    MIXS:Preferred_unit "micromole per kilogram, milligram per liter" .

MIXS:0000162 a owl:DatatypeProperty ;
    rdfs:label "diss_org_nitro" ;
    dcterms:title "dissolved organic nitrogen" ;
    schema1:name "diss_org_nitro" ;
    rdfs:range xsd:string ;
    skos:definition "Dissolved organic nitrogen concentration measured as; total dissolved nitrogen - NH4 - NO3 - NO2" .

MIXS:0000176 a owl:DatatypeProperty ;
    rdfs:label "bromide" ;
    dcterms:title "bromide" ;
    schema1:name "bromide" ;
    rdfs:range xsd:string ;
    skos:definition "Concentration of bromide" ;
    MIXS:Preferred_unit "parts per million" .

MIXS:0000177 a owl:DatatypeProperty ;
    rdfs:label "chlorophyll" ;
    dcterms:title "chlorophyll" ;
    schema1:name "chlorophyll" ;
    rdfs:range xsd:string ;
    skos:definition "Concentration of chlorophyll" ;
    MIXS:Preferred_unit "milligram per cubic meter, microgram per liter" .

MIXS:0000179 a owl:DatatypeProperty ;
    rdfs:label "diss_hydrogen" ;
    dcterms:title "dissolved hydrogen" ;
    schema1:name "diss_hydrogen" ;
    rdfs:range xsd:string ;
    skos:definition "Concentration of dissolved hydrogen" ;
    MIXS:Preferred_unit "micromole per liter" .

MIXS:0000184 a owl:DatatypeProperty ;
    rdfs:label "silicate" ;
    dcterms:title "silicate" ;
    schema1:name "silicate" ;
    rdfs:range xsd:string ;
    skos:definition "Concentration of silicate" ;
    MIXS:Preferred_unit "micromole per liter" .

MIXS:0000191 a owl:DatatypeProperty ;
    rdfs:label "turbidity" ;
    dcterms:title "turbidity" ;
    schema1:name "turbidity" ;
    rdfs:range xsd:string ;
    skos:definition "Measure of the amount of cloudiness or haziness in water caused by individual particles" .

MIXS:0000247 a owl:DatatypeProperty ;
    rdfs:label "ances_data" ;
    dcterms:title "ancestral data" ;
    schema1:name "ances_data" ;
    rdfs:range xsd:string ;
    skos:definition "Information about either pedigree or other ancestral information description (e.g. parental variety in case of mutant or selection), e.g. A/3*B (meaning [(A x B) x B] x B)" .

MIXS:0000248 a owl:DatatypeProperty ;
    rdfs:label "host_common_name" ;
    dcterms:title "host common name" ;
    schema1:name "host_common_name" ;
    rdfs:range xsd:string ;
    skos:definition "Common name of the host" ;
    MIXS:Preferred_unit "" .

MIXS:0000251 a owl:DatatypeProperty ;
    rdfs:label "host_life_stage" ;
    dcterms:title "host life stage" ;
    schema1:name "host_life_stage" ;
    rdfs:range xsd:string ;
    skos:definition "Description of life stage of host" ;
    MIXS:Expected_value "stage" .

MIXS:0000504 a owl:DatatypeProperty ;
    rdfs:label "nitro" ;
    dcterms:title "nitrogen" ;
    schema1:name "nitro" ;
    rdfs:range xsd:string ;
    skos:definition "Concentration of nitrogen (total)" ;
    MIXS:Preferred_unit "micromole per liter" .

MIXS:0000508 a owl:DatatypeProperty ;
    rdfs:label "org_carb" ;
    dcterms:title "organic carbon" ;
    schema1:name "org_carb" ;
    rdfs:range xsd:string ;
    skos:definition "Concentration of organic carbon" .

MIXS:0000829 a owl:ObjectProperty ;
    rdfs:label "season" ;
    dcterms:title "season" ;
    schema1:name "season" ;
    rdfs:range MIXS:SeasonEnum ;
    skos:definition "The season when sampling occurred. Any of the four periods into which the year is divided by the equinoxes and solstices." .

MIXS:0000869 a owl:DatatypeProperty ;
    rdfs:label "host_diet" ;
    dcterms:title "host diet" ;
    schema1:name "host_diet" ;
    rdfs:range xsd:string ;
    skos:definition "Type of diet depending on the host, for animals omnivore, herbivore etc., for humans high-fat, meditteranean etc.; can include multiple diet types" .

MIXS:0000870 a owl:DatatypeProperty ;
    rdfs:label "host_last_meal" ;
    dcterms:title "host last meal" ;
    schema1:name "host_last_meal" ;
    skos:definition "Content of last meal and time since feeding; can include multiple values" ;
    MIXS:Expected_value "content;duration" .

MIXS:0000998 a owl:DatatypeProperty ;
    rdfs:label "samp_type" ;
    dcterms:title "sample type" ;
    schema1:name "samp_type" ;
    rdfs:range xsd:string ;
    skos:definition "The type of material from which the sample was obtained. For the Hydrocarbon package, samples include types like core, rock trimmings, drill cuttings, piping section, coupon, pigging debris, solid deposit, produced fluid, produced water, injected water, swabs, etc. For the Food Package, samples are usually categorized as food, body products or tissues, or environmental material. This field accepts terms listed under environmental specimen (http://purl.obolibrary.org/obo/GENEPIO_0001246)" .

MIXS:0001117 a owl:ObjectProperty ;
    rdfs:label "cult_result" ;
    dcterms:title "culture result" ;
    schema1:name "cult_result" ;
    rdfs:range MIXS:CultResultEnum ;
    skos:definition "Any result of a bacterial culture experiment reported as a binary assessment such as positive/negative, active/inactive" .

MIXS:0001132 a owl:DatatypeProperty ;
    rdfs:label "food_contain_wrap" ;
    dcterms:title "food container or wrapping" ;
    schema1:name "food_contain_wrap" ;
    skos:definition "Type of container or wrapping defined by the main container material, the container form, and the material of the liner lids or ends. Also type of container or wrapping by form; prefer description by material first, then by form. This field accepts terms listed under food container or wrapping (http://purl.obolibrary.org/obo/FOODON_03490100)" ;
    MIXS:Expected_value "FOODON:03490100" .

MIXS:0001151 a owl:DatatypeProperty ;
    rdfs:label "samp_purpose" ;
    dcterms:title "purpose of sampling" ;
    schema1:name "samp_purpose" ;
    skos:definition "The reason that the sample was collected" ;
    MIXS:Expected_value "enumeration or {text}" .

MIXS:0001154 a owl:DatatypeProperty ;
    rdfs:label "samp_source_mat_cat" ;
    dcterms:title "sample source material category" ;
    schema1:name "samp_source_mat_cat" ;
    skos:definition "This is the scientific role or category that the subject organism or material has with respect to an investigation.  This field accepts terms listed under specimen source material category (http://purl.obolibrary.org/obo/GENEPIO_0001237 or http://purl.obolibrary.org/obo/OBI_0100051)" ;
    MIXS:Expected_value "GENEPIO:0001237" .

MIXS:0001155 a owl:DatatypeProperty ;
    rdfs:label "sequencing_kit" ;
    dcterms:title "sequencing kit" ;
    schema1:name "sequencing_kit" ;
    rdfs:range xsd:string ;
    skos:definition "Pre-filled, ready-to-use reagent cartridges. Used to produce improved chemistry, cluster density and read length as well as improve quality (Q) scores. Reagent components are encoded to interact with the sequencing system to validate compatibility with user-defined applications. Indicate name of the sequencing kit" ;
    MIXS:Expected_value "name of sequencing kit used" .

MIXS:0001173 a owl:DatatypeProperty ;
    rdfs:label "timepoint" ;
    dcterms:title "timepoint" ;
    schema1:name "timepoint" ;
    rdfs:range xsd:string ;
    skos:definition "Time point at which a sample or observation is made or taken from a biomaterial as measured from some reference point. Indicate the timepoint written in ISO 8601 format" ;
    MIXS:Preferred_unit "hours or days" .

MIXS:0001178 a owl:DatatypeProperty ;
    rdfs:label "food_quality_date" ;
    dcterms:title "food quality date" ;
    schema1:name "food_quality_date" ;
    skos:definition "The date recommended for the use of the product while at peak quality, this date is not a reflection of safety unless used on infant formula this date is not a reflection of safety and is typically labeled on a food product as \"best if used by,\" best by,\" \"use by,\" or \"freeze by.\"" ;
    MIXS:Expected_value "enumeration, date" .

MIXS:CeilFinishMatEnum a owl:Class ;
    rdfs:label "CeilFinishMatEnum" ;
    dcterms:title "CeilFinishMatEnum" ;
    schema1:name "CeilFinishMatEnum" ;
    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( <https://w3id.org/mixs/CeilFinishMatEnum#PVC> <https://w3id.org/mixs/CeilFinishMatEnum#drywall> <https://w3id.org/mixs/CeilFinishMatEnum#fiberglass> <https://w3id.org/mixs/CeilFinishMatEnum#metal> <https://w3id.org/mixs/CeilFinishMatEnum#mineral%20fibre> <https://w3id.org/mixs/CeilFinishMatEnum#mineral%20wool%2Fcalcium%20silicate> <https://w3id.org/mixs/CeilFinishMatEnum#plasterboard> <https://w3id.org/mixs/CeilFinishMatEnum#stucco> <https://w3id.org/mixs/CeilFinishMatEnum#tiles> <https://w3id.org/mixs/CeilFinishMatEnum#wood> ) ;
    linkml:permissible_values <https://w3id.org/mixs/CeilFinishMatEnum#PVC>,
        <https://w3id.org/mixs/CeilFinishMatEnum#drywall>,
        <https://w3id.org/mixs/CeilFinishMatEnum#fiberglass>,
        <https://w3id.org/mixs/CeilFinishMatEnum#metal>,
        <https://w3id.org/mixs/CeilFinishMatEnum#mineral%20fibre>,
        <https://w3id.org/mixs/CeilFinishMatEnum#mineral%20wool%2Fcalcium%20silicate>,
        <https://w3id.org/mixs/CeilFinishMatEnum#plasterboard>,
        <https://w3id.org/mixs/CeilFinishMatEnum#stucco>,
        <https://w3id.org/mixs/CeilFinishMatEnum#tiles>,
        <https://w3id.org/mixs/CeilFinishMatEnum#wood> .

MIXS:DoorMatEnum a owl:Class ;
    rdfs:label "DoorMatEnum" ;
    dcterms:title "DoorMatEnum" ;
    schema1:name "DoorMatEnum" ;
    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( <https://w3id.org/mixs/DoorMatEnum#aluminum> <https://w3id.org/mixs/DoorMatEnum#cellular%20PVC> <https://w3id.org/mixs/DoorMatEnum#engineered%20plastic> <https://w3id.org/mixs/DoorMatEnum#fiberboard> <https://w3id.org/mixs/DoorMatEnum#fiberglass> <https://w3id.org/mixs/DoorMatEnum#metal> <https://w3id.org/mixs/DoorMatEnum#thermoplastic%20alloy> <https://w3id.org/mixs/DoorMatEnum#vinyl> <https://w3id.org/mixs/DoorMatEnum#wood> <https://w3id.org/mixs/DoorMatEnum#wood%2Fplastic%20composite> ) ;
    linkml:permissible_values <https://w3id.org/mixs/DoorMatEnum#aluminum>,
        <https://w3id.org/mixs/DoorMatEnum#cellular%20PVC>,
        <https://w3id.org/mixs/DoorMatEnum#engineered%20plastic>,
        <https://w3id.org/mixs/DoorMatEnum#fiberboard>,
        <https://w3id.org/mixs/DoorMatEnum#fiberglass>,
        <https://w3id.org/mixs/DoorMatEnum#metal>,
        <https://w3id.org/mixs/DoorMatEnum#thermoplastic%20alloy>,
        <https://w3id.org/mixs/DoorMatEnum#vinyl>,
        <https://w3id.org/mixs/DoorMatEnum#wood>,
        <https://w3id.org/mixs/DoorMatEnum#wood%2Fplastic%20composite> .

MIXS:MoldVisibilityEnum a owl:Class ;
    rdfs:label "MoldVisibilityEnum" ;
    dcterms:title "MoldVisibilityEnum" ;
    schema1:name "MoldVisibilityEnum" ;
    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( <https://w3id.org/mixs/MoldVisibilityEnum#no%20presence%20of%20mold%20visible> <https://w3id.org/mixs/MoldVisibilityEnum#presence%20of%20mold%20visible> ) ;
    linkml:permissible_values <https://w3id.org/mixs/MoldVisibilityEnum#no%20presence%20of%20mold%20visible>,
        <https://w3id.org/mixs/MoldVisibilityEnum#presence%20of%20mold%20visible> .

