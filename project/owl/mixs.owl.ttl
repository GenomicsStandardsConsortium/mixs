MIXS:0000028 a owl:ObjectProperty ;
    rdfs:label "biotic_relationship" ;
    dcterms:title "observed biotic relationship" ;
    schema1:name "biotic_relationship" ;
    rdfs:range MIXS:BioticRelationshipEnum ;
    skos:definition "Description of relationship(s) between the subject organism and other organism(s) it is associated with. E.g., parasite on species X; mutualist with species Y. The target organism is the subject of the relationship, and the other organism(s) is the object" .

MIXS:0000047 a owl:DatatypeProperty ;
    rdfs:label "mid" ;
    dcterms:title "multiplex identifiers" ;
    schema1:name "mid" ;
    rdfs:range xsd:string ;
    skos:definition "Molecular barcodes, called Multiplex Identifiers (MIDs), that are used to specifically tag unique samples in a sequencing run. Sequence should be reported in uppercase letters" .

MIXS:0000421 a owl:DatatypeProperty ;
    rdfs:label "alkalinity" ;
    dcterms:title "alkalinity" ;
    schema1:name "alkalinity" ;
    rdfs:range xsd:string ;
    skos:definition "Alkalinity, the ability of a solution to neutralize acids to the equivalence point of carbonate or bicarbonate" ;
    MIXS:Preferred_unit "milliequivalent per liter, milligram per liter" .

MIXS:0000425 a owl:DatatypeProperty ;
    rdfs:label "nitrate" ;
    dcterms:title "nitrate" ;
    schema1:name "nitrate" ;
    rdfs:range xsd:string ;
    skos:definition "Concentration of nitrate in the sample" ;
    MIXS:Preferred_unit "micromole per liter, milligram per liter, parts per million" .

MIXS:0000428 a owl:DatatypeProperty ;
    rdfs:label "sodium" ;
    dcterms:title "sodium" ;
    schema1:name "sodium" ;
    rdfs:range xsd:string ;
    skos:definition "Sodium concentration in the sample" ;
    MIXS:Preferred_unit "milligram per liter, parts per million" .

MIXS:0000861 a owl:DatatypeProperty ;
    rdfs:label "host_subject_id" ;
    dcterms:title "host subject id" ;
    schema1:name "host_subject_id" ;
    rdfs:range xsd:string ;
    skos:definition "A unique identifier by which each subject can be referred to, de-identified" .

MIXS:0000867 a owl:DatatypeProperty ;
    rdfs:label "host_body_site" ;
    dcterms:title "host body site" ;
    schema1:name "host_body_site" ;
    skos:definition "Name of body site where the sample was obtained from, such as a specific organ or tissue (tongue, lung etc...). Use terms from the foundational model of anatomy ontology (fma) or the Uber-anatomy ontology (UBERON)" ;
    MIXS:Expected_value "FMA or UBERON" .

MIXS:0000888 a owl:DatatypeProperty ;
    rdfs:label "host_body_product" ;
    dcterms:title "host body product" ;
    schema1:name "host_body_product" ;
    skos:definition "Substance produced by the body, e.g. Stool, mucus, where the sample was obtained from. Use terms from the foundational model of anatomy ontology (fma) or Uber-anatomy ontology (UBERON)" ;
    MIXS:Expected_value "FMA or UBERON" .

