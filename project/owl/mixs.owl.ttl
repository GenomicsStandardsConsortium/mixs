MIXS:0000409 a owl:DatatypeProperty ;
    rdfs:label "samp_tvdss" ;
    dcterms:title "sample true vertical depth subsea" ;
    schema1:name "samp_tvdss" ;
    skos:definition "Depth of the sample i.e. The vertical distance between the sea level and the sampled position in the subsurface. Depth can be reported as an interval for subsurface samples e.g. 1325.75-1362.25 m" ;
    MIXS:Expected_value "measurement value or measurement value range" ;
    MIXS:Preferred_unit "meter" .

MIXS:0000413 a owl:DatatypeProperty ;
    rdfs:label "samp_md" ;
    dcterms:title "sample measured depth" ;
    schema1:name "samp_md" ;
    skos:definition "In non deviated well, measured depth is equal to the true vertical depth, TVD (TVD=TVDSS plus the reference or datum it refers to). In deviated wells, the MD is the length of trajectory of the borehole measured from the same reference or datum. Common datums used are ground level (GL), drilling rig floor (DF), rotary table (RT), kelly bushing (KB) and mean sea level (MSL). If \"other\" is specified, please propose entry in \"additional info\" field" ;
    MIXS:Expected_value "measurement value;enumeration" ;
    MIXS:Preferred_unit "meter" .

MIXS:0000452 a owl:DatatypeProperty ;
    rdfs:label "prod_rate" ;
    dcterms:title "production rate" ;
    schema1:name "prod_rate" ;
    rdfs:range xsd:string ;
    skos:definition "Oil and/or gas production rates per well (e.g. 524 m3 / day)" ;
    MIXS:Preferred_unit "cubic meter per day" .

MIXS:0000453 a owl:DatatypeProperty ;
    rdfs:label "water_prod_rate" ;
    dcterms:title "water production rate" ;
    schema1:name "water_prod_rate" ;
    rdfs:range xsd:string ;
    skos:definition "Water production rates per well (e.g. 987 m3 / day)" ;
    MIXS:Preferred_unit "cubic meter per day" .

MIXS:0000454 a owl:DatatypeProperty ;
    rdfs:label "water_cut" ;
    dcterms:title "water cut" ;
    schema1:name "water_cut" ;
    rdfs:range xsd:string ;
    skos:definition "Current amount of water (%) in a produced fluid stream; or the average of the combined streams" ;
    skos:note "percent or float?" ;
    MIXS:Preferred_unit "percent" .

MIXS:0000455 a owl:DatatypeProperty ;
    rdfs:label "iwf" ;
    dcterms:title "injection water fraction" ;
    schema1:name "iwf" ;
    rdfs:range xsd:float ;
    skos:definition "Proportion of the produced fluids derived from injected water at the time of sampling. (e.g. 87%)" ;
    skos:note "percent or float?" ;
    MIXS:Preferred_unit "percent" .

MIXS:0000456 a owl:DatatypeProperty ;
    rdfs:label "biocide_admin_method" ;
    dcterms:title "biocide administration method" ;
    schema1:name "biocide_admin_method" ;
    skos:definition "Method of biocide administration (dose, frequency, duration, time elapsed between last biociding and sampling) (e.g. 150 mg/l; weekly; 4 hr; 3 days)" ;
    MIXS:Expected_value "measurement value;frequency;duration;duration" ;
    MIXS:Preferred_unit "milligram per liter" .

MIXS:0000457 a owl:DatatypeProperty ;
    rdfs:label "chem_treat_method" ;
    dcterms:title "chemical treatment method" ;
    schema1:name "chem_treat_method" ;
    skos:definition "Method of chemical administration(dose, frequency, duration, time elapsed between administration and sampling) (e.g. 50 mg/l; twice a week; 1 hr; 0 days)" ;
    MIXS:Expected_value "measurement value;frequency;duration;duration" ;
    MIXS:Preferred_unit "milligram per liter" .

MIXS:0000463 a owl:DatatypeProperty ;
    rdfs:label "samp_preserv" ;
    dcterms:title "preservative added to sample" ;
    schema1:name "samp_preserv" ;
    rdfs:range xsd:string ;
    skos:definition "Preservative added to the sample (e.g. Rnalater, alcohol, formaldehyde, etc.). Where appropriate include volume added (e.g. Rnalater; 2 ml)" ;
    MIXS:Preferred_unit "milliliter" .

MIXS:0000567 a owl:DatatypeProperty ;
    rdfs:label "host_wet_mass" ;
    dcterms:title "host wet mass" ;
    schema1:name "host_wet_mass" ;
    rdfs:range xsd:string ;
    skos:definition "Measurement of wet mass" ;
    MIXS:Preferred_unit "kilogram, gram" .

MIXS:0000569 a owl:DatatypeProperty ;
    rdfs:label "light_regm" ;
    dcterms:title "light regimen" ;
    schema1:name "light_regm" ;
    skos:definition "Information about treatment(s) involving exposure to light, including both light intensity and quality" ;
    MIXS:Expected_value "exposure type;light intensity;light quality" ;
    MIXS:Preferred_unit "lux; micrometer, nanometer, angstrom" .

MIXS:0000580 a owl:DatatypeProperty ;
    rdfs:label "root_med_suppl" ;
    dcterms:title "rooting medium organic supplements" ;
    schema1:name "root_med_suppl" ;
    skos:definition "Organic supplements of the culture rooting medium, such as vitamins, amino acids, organic acids, antibiotics activated charcoal; e.g. nicotinic acid (0.5  mg/L)" ;
    MIXS:Expected_value "supplement name;measurement value" ;
    MIXS:Preferred_unit "milligram per liter" .

MIXS:0000581 a owl:DatatypeProperty ;
    rdfs:label "root_med_regl" ;
    dcterms:title "rooting medium regulators" ;
    schema1:name "root_med_regl" ;
    skos:definition "Growth regulators in the culture rooting medium such as cytokinins, auxins, gybberellins, abscisic acid; e.g. 0.5  mg/L NAA" ;
    MIXS:Expected_value "regulator name;measurement value" ;
    MIXS:Preferred_unit "milligram per liter" .

MIXS:0000607 a owl:DatatypeProperty ;
    rdfs:label "al_sat" ;
    dcterms:title "extreme_unusual_properties/Al saturation" ;
    schema1:name "al_sat" ;
    rdfs:range xsd:string ;
    skos:definition "Aluminum saturation (esp. For tropical soils)" ;
    MIXS:Preferred_unit "percentage" .

MIXS:0000653 a owl:DatatypeProperty ;
    rdfs:label "biochem_oxygen_dem" ;
    dcterms:title "biochemical oxygen demand" ;
    schema1:name "biochem_oxygen_dem" ;
    rdfs:range xsd:string ;
    skos:definition "Amount of dissolved oxygen needed by aerobic biological organisms in a body of water to break down organic material present in a given water sample at certain temperature over a specific time period" ;
    MIXS:Preferred_unit "milligram per liter" .

MIXS:0000656 a owl:DatatypeProperty ;
    rdfs:label "chem_oxygen_dem" ;
    dcterms:title "chemical oxygen demand" ;
    schema1:name "chem_oxygen_dem" ;
    rdfs:range xsd:string ;
    skos:definition "A measure of the capacity of water to consume oxygen during the decomposition of organic matter and the oxidation of inorganic chemicals such as ammonia and nitrite" ;
    MIXS:Preferred_unit "milligram per liter" .

MIXS:0000657 a owl:DatatypeProperty ;
    rdfs:label "efficiency_percent" ;
    dcterms:title "efficiency percent" ;
    schema1:name "efficiency_percent" ;
    rdfs:range xsd:string ;
    skos:definition "Percentage of volatile solids removed from the anaerobic digestor" ;
    MIXS:Preferred_unit "micromole per liter" .

MIXS:0000662 a owl:DatatypeProperty ;
    rdfs:label "indust_eff_percent" ;
    dcterms:title "industrial effluent percent" ;
    schema1:name "indust_eff_percent" ;
    rdfs:range xsd:string ;
    skos:definition "Percentage of industrial effluents received by wastewater treatment plant" ;
    MIXS:Preferred_unit "percentage" .

MIXS:0000669 a owl:DatatypeProperty ;
    rdfs:label "sludge_retent_time" ;
    dcterms:title "sludge retention time" ;
    schema1:name "sludge_retent_time" ;
    rdfs:range xsd:string ;
    skos:definition "The time activated sludge remains in reactor" ;
    MIXS:Preferred_unit "hours" .

MIXS:0000683 a owl:DatatypeProperty ;
    rdfs:label "bac_prod" ;
    dcterms:title "bacterial production" ;
    schema1:name "bac_prod" ;
    rdfs:range xsd:string ;
    skos:definition "Bacterial production in the water column measured by isotope uptake" ;
    MIXS:Preferred_unit "milligram per cubic meter per day" .

MIXS:0000684 a owl:DatatypeProperty ;
    rdfs:label "bac_resp" ;
    dcterms:title "bacterial respiration" ;
    schema1:name "bac_resp" ;
    rdfs:range xsd:string ;
    skos:definition "Measurement of bacterial respiration in the water column" ;
    MIXS:Preferred_unit "milligram per cubic meter per day, micromole oxygen per liter per hour" .

MIXS:0000698 a owl:DatatypeProperty ;
    rdfs:label "diss_inorg_nitro" ;
    dcterms:title "dissolved inorganic nitrogen" ;
    schema1:name "diss_inorg_nitro" ;
    rdfs:range xsd:string ;
    skos:definition "Concentration of dissolved inorganic nitrogen" ;
    MIXS:Preferred_unit "microgram per liter, micromole per liter" .

MIXS:0000703 a owl:DatatypeProperty ;
    rdfs:label "down_par" ;
    dcterms:title "downward PAR" ;
    schema1:name "down_par" ;
    rdfs:range xsd:string ;
    skos:definition "Visible waveband radiance and irradiance measurements in the water column" ;
    MIXS:Preferred_unit "microEinstein per square meter per second, microEinstein per square centimeter per second" .

MIXS:0000704 a owl:DatatypeProperty ;
    rdfs:label "fluor" ;
    dcterms:title "fluorescence" ;
    schema1:name "fluor" ;
    rdfs:range xsd:string ;
    skos:definition "Raw or converted fluorescence of water" ;
    MIXS:Preferred_unit "milligram chlorophyll a per cubic meter, volts" .

MIXS:0000706 a owl:DatatypeProperty ;
    rdfs:label "light_intensity" ;
    dcterms:title "light intensity" ;
    schema1:name "light_intensity" ;
    rdfs:range xsd:string ;
    skos:definition "Measurement of light intensity" ;
    MIXS:Preferred_unit "lux" .

MIXS:0000719 a owl:DatatypeProperty ;
    rdfs:label "part_org_nitro" ;
    dcterms:title "particulate organic nitrogen" ;
    schema1:name "part_org_nitro" ;
    rdfs:range xsd:string ;
    skos:definition "Concentration of particulate organic nitrogen" ;
    MIXS:Preferred_unit "microgram per liter, micromole per liter" .

MIXS:0000721 a owl:DatatypeProperty ;
    rdfs:label "built_struc_type" ;
    dcterms:title "built structure type" ;
    schema1:name "built_struc_type" ;
    rdfs:range xsd:string ;
    skos:definition "A physical structure that is a body or assemblage of bodies in space to form a system capable of supporting loads" .

MIXS:0000725 a owl:DatatypeProperty ;
    rdfs:label "photon_flux" ;
    dcterms:title "photon flux" ;
    schema1:name "photon_flux" ;
    rdfs:range xsd:string ;
    skos:definition "Measurement of photon flux" ;
    MIXS:Preferred_unit "number of photons per second per unit area" .

MIXS:0000728 a owl:DatatypeProperty ;
    rdfs:label "primary_prod" ;
    dcterms:title "primary production" ;
    schema1:name "primary_prod" ;
    rdfs:range xsd:string ;
    skos:definition "Measurement of primary production, generally measured as isotope uptake" ;
    MIXS:Preferred_unit "milligram per cubic meter per day, gram per square meter per day" .

MIXS:0000738 a owl:DatatypeProperty ;
    rdfs:label "soluble_react_phosp" ;
    dcterms:title "soluble reactive phosphorus" ;
    schema1:name "soluble_react_phosp" ;
    rdfs:range xsd:string ;
    skos:definition "Concentration of soluble reactive phosphorus" ;
    MIXS:Preferred_unit "micromole per liter, milligram per liter, parts per million" .

MIXS:0000741 a owl:DatatypeProperty ;
    rdfs:label "suspend_part_matter" ;
    dcterms:title "suspended particulate matter" ;
    schema1:name "suspend_part_matter" ;
    rdfs:range xsd:string ;
    skos:definition "Concentration of suspended particulate matter" ;
    MIXS:Preferred_unit "milligram per liter" .

MIXS:0000744 a owl:DatatypeProperty ;
    rdfs:label "tot_diss_nitro" ;
    dcterms:title "total dissolved nitrogen" ;
    schema1:name "tot_diss_nitro" ;
    rdfs:range xsd:string ;
    skos:definition "Total dissolved nitrogen concentration, reported as nitrogen, measured by: total dissolved nitrogen = NH4 + NO3NO2 + dissolved organic nitrogen" ;
    MIXS:Preferred_unit "microgram per liter" .

MIXS:0000745 a owl:DatatypeProperty ;
    rdfs:label "tot_inorg_nitro" ;
    dcterms:title "total inorganic nitrogen" ;
    schema1:name "tot_inorg_nitro" ;
    rdfs:range xsd:string ;
    skos:definition "Total inorganic nitrogen content" ;
    MIXS:Preferred_unit "microgram per liter" .

MIXS:0000747 a owl:DatatypeProperty ;
    rdfs:label "tot_part_carb" ;
    dcterms:title "total particulate carbon" ;
    schema1:name "tot_part_carb" ;
    rdfs:range xsd:string ;
    skos:definition "Total particulate carbon content" ;
    MIXS:Preferred_unit "microgram per liter, micromole per liter" .

MIXS:0000760 a owl:DatatypeProperty ;
    rdfs:label "surf_moisture_ph" ;
    dcterms:title "surface moisture pH" ;
    schema1:name "surf_moisture_ph" ;
    rdfs:range xsd:float ;
    skos:definition "ph measurement of surface" .

MIXS:0000763 a owl:ObjectProperty ;
    rdfs:label "indoor_space" ;
    dcterms:title "indoor space" ;
    schema1:name "indoor_space" ;
    rdfs:range MIXS:IndoorSpaceEnum ;
    skos:definition "A distinguishable space within a structure, the purpose for which discrete areas of a building is used" .

MIXS:0000768 a owl:ObjectProperty ;
    rdfs:label "building_setting" ;
    dcterms:title "building setting" ;
    schema1:name "building_setting" ;
    rdfs:range MIXS:BuildingSettingEnum ;
    skos:definition "A location (geography) where a building is set" .

MIXS:0000770 a owl:ObjectProperty ;
    rdfs:label "space_typ_state" ;
    dcterms:title "space typical state" ;
    schema1:name "space_typ_state" ;
    rdfs:range MIXS:SpaceTypStateEnum ;
    skos:definition "Customary or normal state of the space" .

MIXS:0000771 a owl:DatatypeProperty ;
    rdfs:label "typ_occup_density" ;
    dcterms:title "typical occupant density" ;
    schema1:name "typ_occup_density" ;
    rdfs:range xsd:float ;
    skos:definition "Customary or normal density of occupants" .

MIXS:0000772 a owl:DatatypeProperty ;
    rdfs:label "occup_samp" ;
    dcterms:title "occupancy at sampling" ;
    schema1:name "occup_samp" ;
    rdfs:range xsd:float ;
    skos:definition "Number of occupants present at time of sample within the given space" .

MIXS:0000773 a owl:ObjectProperty ;
    rdfs:label "aero_struc" ;
    dcterms:title "aerospace structure" ;
    schema1:name "aero_struc" ;
    rdfs:range MIXS:AeroStrucEnum ;
    skos:definition "Aerospace structures typically consist of thin plates with stiffeners for the external surfaces, bulkheads and frames to support the shape and fasteners such as welds, rivets, screws and bolts to hold the components together" .

MIXS:0000774 a owl:ObjectProperty ;
    rdfs:label "arch_struc" ;
    dcterms:title "architectural structure" ;
    schema1:name "arch_struc" ;
    rdfs:range MIXS:ArchStrucEnum ;
    skos:definition "An architectural structure is a human-made, free-standing, immobile outdoor construction" .

MIXS:0000776 a owl:DatatypeProperty ;
    rdfs:label "bathroom_count" ;
    dcterms:title "bathroom count" ;
    schema1:name "bathroom_count" ;
    rdfs:range xsd:integer ;
    skos:definition "The number of bathrooms in the building" .

MIXS:0000777 a owl:DatatypeProperty ;
    rdfs:label "bedroom_count" ;
    dcterms:title "bedroom count" ;
    schema1:name "bedroom_count" ;
    rdfs:range xsd:integer ;
    skos:definition "The number of bedrooms in the building" .

MIXS:0000778 a owl:ObjectProperty ;
    rdfs:label "built_struc_set" ;
    dcterms:title "built structure setting" ;
    schema1:name "built_struc_set" ;
    rdfs:range MIXS:BuiltStrucSetEnum ;
    skos:definition "The characterization of the location of the built structure as high or low human density" .

MIXS:0000779 a owl:ObjectProperty ;
    rdfs:label "ceil_cond" ;
    dcterms:title "ceiling condition" ;
    schema1:name "ceil_cond" ;
    rdfs:range MIXS:DamagedEnum ;
    skos:definition "The physical condition of the ceiling at the time of sampling; photos or video preferred; use drawings to indicate location of damaged areas" .

MIXS:0000780 a owl:ObjectProperty ;
    rdfs:label "ceil_finish_mat" ;
    dcterms:title "ceiling finish material" ;
    schema1:name "ceil_finish_mat" ;
    rdfs:range MIXS:CeilFinishMatEnum ;
    skos:definition "The type of material used to finish a ceiling" .

MIXS:0000781 a owl:ObjectProperty ;
    rdfs:label "ceil_water_mold" ;
    dcterms:title "ceiling signs of water/mold" ;
    schema1:name "ceil_water_mold" ;
    rdfs:range MIXS:MoldVisibilityEnum ;
    skos:definition "Signs of the presence of mold or mildew on the ceiling" .

MIXS:0000782 a owl:ObjectProperty ;
    rdfs:label "ceil_struc" ;
    dcterms:title "ceiling structure" ;
    schema1:name "ceil_struc" ;
    rdfs:range MIXS:CeilStrucEnum ;
    skos:definition "The construction format of the ceiling" .

MIXS:0000783 a owl:ObjectProperty ;
    rdfs:label "ceil_texture" ;
    dcterms:title "ceiling texture" ;
    schema1:name "ceil_texture" ;
    rdfs:range MIXS:CeilingWallTextureEnum ;
    skos:definition "The feel, appearance, or consistency of a ceiling surface" .

MIXS:0000784 a owl:ObjectProperty ;
    rdfs:label "ceil_type" ;
    dcterms:title "ceiling type" ;
    schema1:name "ceil_type" ;
    rdfs:range MIXS:CeilTypeEnum ;
    skos:definition "The type of ceiling according to the ceiling's appearance or construction" .

MIXS:0000785 a owl:DatatypeProperty ;
    rdfs:label "cool_syst_id" ;
    dcterms:title "cooling system identifier" ;
    schema1:name "cool_syst_id" ;
    rdfs:range xsd:integer ;
    skos:definition "The cooling system identifier" .

MIXS:0000786 a owl:DatatypeProperty ;
    rdfs:label "date_last_rain" ;
    dcterms:title "date last rain" ;
    schema1:name "date_last_rain" ;
    rdfs:range xsd:dateTime ;
    skos:definition "The date of the last time it rained" .

MIXS:0000787 a owl:ObjectProperty ;
    rdfs:label "build_docs" ;
    dcterms:title "design, construction, and operation documents" ;
    schema1:name "build_docs" ;
    rdfs:range MIXS:BuildDocsEnum ;
    skos:definition "The building design, construction and operation documents" .

MIXS:0000788 a owl:ObjectProperty ;
    rdfs:label "door_cond" ;
    dcterms:title "door condition" ;
    schema1:name "door_cond" ;
    rdfs:range MIXS:DamagedRupturedEnum ;
    skos:definition "The physical condition of the door" .

MIXS:0000789 a owl:ObjectProperty ;
    rdfs:label "door_direct" ;
    dcterms:title "door direction of opening" ;
    schema1:name "door_direct" ;
    rdfs:range MIXS:DoorDirectEnum ;
    skos:definition "The direction the door opens" .

MIXS:0000790 a owl:ObjectProperty ;
    rdfs:label "door_loc" ;
    dcterms:title "door location" ;
    schema1:name "door_loc" ;
    rdfs:range MIXS:CompassDirections8Enum ;
    skos:definition "The relative location of the door in the room" .

MIXS:0000791 a owl:ObjectProperty ;
    rdfs:label "door_mat" ;
    dcterms:title "door material" ;
    schema1:name "door_mat" ;
    rdfs:range MIXS:DoorMatEnum ;
    skos:definition "The material the door is composed of" .

MIXS:0000792 a owl:ObjectProperty ;
    rdfs:label "door_move" ;
    dcterms:title "door movement" ;
    schema1:name "door_move" ;
    rdfs:range MIXS:DoorMoveEnum ;
    skos:definition "The type of movement of the door" .

MIXS:0000793 a owl:ObjectProperty ;
    rdfs:label "door_water_mold" ;
    dcterms:title "door signs of water/mold" ;
    schema1:name "door_water_mold" ;
    rdfs:range MIXS:MoldVisibilityEnum ;
    skos:definition "Signs of the presence of mold or mildew on a door" .

MIXS:0000794 a owl:ObjectProperty ;
    rdfs:label "door_type" ;
    dcterms:title "door type" ;
    schema1:name "door_type" ;
    rdfs:range MIXS:DoorTypeEnum ;
    skos:definition "The type of door material" .

MIXS:0000795 a owl:ObjectProperty ;
    rdfs:label "door_comp_type" ;
    dcterms:title "door type, composite" ;
    schema1:name "door_comp_type" ;
    rdfs:range MIXS:DoorCompTypeEnum ;
    skos:definition "The composite type of the door" .

MIXS:0000796 a owl:ObjectProperty ;
    rdfs:label "door_type_metal" ;
    dcterms:title "door type, metal" ;
    schema1:name "door_type_metal" ;
    rdfs:range MIXS:DoorTypeMetalEnum ;
    skos:definition "The type of metal door" .

MIXS:0000797 a owl:DatatypeProperty ;
    rdfs:label "door_type_wood" ;
    dcterms:title "door type, wood" ;
    schema1:name "door_type_wood" ;
    skos:definition "The type of wood door" ;
    MIXS:Expected_value "enumeration" .

MIXS:0000798 a owl:ObjectProperty ;
    rdfs:label "drawings" ;
    dcterms:title "drawings" ;
    schema1:name "drawings" ;
    rdfs:range MIXS:DrawingsEnum ;
    skos:definition "The buildings architectural drawings; if design is chosen, indicate phase-conceptual, schematic, design development, and construction documents" .

MIXS:0000799 a owl:DatatypeProperty ;
    rdfs:label "elevator" ;
    dcterms:title "elevator count" ;
    schema1:name "elevator" ;
    rdfs:range xsd:integer ;
    skos:definition "The number of elevators within the built structure" .

MIXS:0000800 a owl:DatatypeProperty ;
    rdfs:label "escalator" ;
    dcterms:title "escalator count" ;
    schema1:name "escalator" ;
    rdfs:range xsd:integer ;
    skos:definition "The number of escalators within the built structure" .

MIXS:0000802 a owl:ObjectProperty ;
    rdfs:label "fireplace_type" ;
    dcterms:title "fireplace type" ;
    schema1:name "fireplace_type" ;
    rdfs:range MIXS:FireplaceTypeEnum ;
    skos:definition "A firebox with chimney" .

MIXS:0000803 a owl:ObjectProperty ;
    rdfs:label "floor_cond" ;
    dcterms:title "floor condition" ;
    schema1:name "floor_cond" ;
    rdfs:range MIXS:DamagedEnum ;
    skos:definition "The physical condition of the floor at the time of sampling; photos or video preferred; use drawings to indicate location of damaged areas" .

MIXS:0000804 a owl:DatatypeProperty ;
    rdfs:label "floor_finish_mat" ;
    dcterms:title "floor finish material" ;
    schema1:name "floor_finish_mat" ;
    skos:definition "The floor covering type; the finished surface that is walked on" ;
    MIXS:Expected_value "enumeration" .

MIXS:0000805 a owl:ObjectProperty ;
    rdfs:label "floor_water_mold" ;
    dcterms:title "floor signs of water/mold" ;
    schema1:name "floor_water_mold" ;
    rdfs:range MIXS:FloorWaterMoldEnum ;
    skos:definition "Signs of the presence of mold or mildew in a room" .

MIXS:0000806 a owl:ObjectProperty ;
    rdfs:label "floor_struc" ;
    dcterms:title "floor structure" ;
    schema1:name "floor_struc" ;
    rdfs:range MIXS:FloorStrucEnum ;
    skos:definition "Refers to the structural elements and subfloor upon which the finish flooring is installed" .

MIXS:0000807 a owl:ObjectProperty ;
    rdfs:label "furniture" ;
    dcterms:title "furniture" ;
    schema1:name "furniture" ;
    rdfs:range MIXS:FurnitureEnum ;
    skos:definition "The types of furniture present in the sampled room" .

MIXS:0000808 a owl:ObjectProperty ;
    rdfs:label "gender_restroom" ;
    dcterms:title "gender of restroom" ;
    schema1:name "gender_restroom" ;
    rdfs:range MIXS:GenderRestroomEnum ;
    skos:definition "The gender type of the restroom" .

MIXS:0000809 a owl:ObjectProperty ;
    rdfs:label "handidness" ;
    dcterms:title "handidness" ;
    schema1:name "handidness" ;
    rdfs:range MIXS:HandidnessEnum ;
    skos:definition "The handidness of the individual sampled" .

MIXS:0000810 a owl:ObjectProperty ;
    rdfs:label "heat_deliv_loc" ;
