    MIXS:Expected_value "reactor type name" .

MIXS:0000351 a owl:DatatypeProperty ;
    rdfs:label "secondary_treatment" ;
    dcterms:title "secondary treatment" ;
    schema1:name "secondary_treatment" ;
    rdfs:range xsd:string ;
    skos:definition "The process for substantially degrading the biological content of the sewage" ;
    MIXS:Expected_value "secondary treatment type" .

MIXS:0000352 a owl:DatatypeProperty ;
    rdfs:label "tertiary_treatment" ;
    dcterms:title "tertiary treatment" ;
    schema1:name "tertiary_treatment" ;
    rdfs:range xsd:string ;
    skos:definition "The process providing a final treatment stage to raise the effluent quality before it is discharged to the receiving environment" ;
    MIXS:Expected_value "tertiary treatment type" .

MIXS:0000353 a owl:DatatypeProperty ;
    rdfs:label "wastewater_type" ;
    dcterms:title "wastewater type" ;
    schema1:name "wastewater_type" ;
    rdfs:range xsd:string ;
    skos:definition "The origin of wastewater such as human waste, rainfall, storm drains, etc" ;
    MIXS:Expected_value "wastewater type name" .

MIXS:0000404 a owl:DatatypeProperty ;
    rdfs:label "permeability" ;
    dcterms:title "permeability" ;
