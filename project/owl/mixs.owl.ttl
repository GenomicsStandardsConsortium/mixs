    schema1:name "diet_last_six_month" ;
    skos:definition "Specification of major diet changes in the last six months, if yes the change should be specified" ;
    MIXS:Expected_value "diet change;current diet" .

MIXS:0000272 a owl:DatatypeProperty ;
    rdfs:label "gestation_state" ;
    dcterms:title "amniotic fluid/gestation state" ;
