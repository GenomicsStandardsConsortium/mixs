MIXS:0000021 a owl:DatatypeProperty ;
    rdfs:label "ploidy" ;
    dcterms:title "ploidy" ;
    schema1:name "ploidy" ;
    rdfs:range xsd:string ;
    skos:definition "The ploidy level of the genome (e.g. allopolyploid, haploid, diploid, triploid, tetraploid). It has implications for the downstream study of duplicated gene and regions of the genomes (and perhaps for difficulties in assembly). For terms, please select terms listed under class ploidy (PATO:001374) of Phenotypic Quality Ontology (PATO), and for a browser of PATO (v 2018-03-27) please refer to http://purl.bioontology.org/ontology/PATO" .

MIXS:0000035 a owl:DatatypeProperty ;
    rdfs:label "source_uvig" ;
    dcterms:title "source of UViGs" ;
    schema1:name "source_uvig" ;
    skos:definition "Type of dataset from which the UViG was obtained" ;
    MIXS:Expected_value "enumeration" .

MIXS:0000081 a owl:DatatypeProperty ;
    rdfs:label "vir_ident_software" ;
    dcterms:title "viral identification software" ;
    schema1:name "vir_ident_software" ;
    skos:definition "Tool(s) used for the identification of UViG as a viral genome, software or protocol name including version number, parameters, and cutoffs used" ;
    MIXS:Expected_value "software name, version and relevant parameters" .

MIXS:0000082 a owl:ObjectProperty ;
    rdfs:label "pred_genome_type" ;
    dcterms:title "predicted genome type" ;
    schema1:name "pred_genome_type" ;
    rdfs:range MIXS:ViralGenomeTypeEnum ;
    skos:definition "Type of genome predicted for the UViG" ;
    MIXS:Expected_value "enumeration" .

MIXS:0000083 a owl:ObjectProperty ;
    rdfs:label "pred_genome_struc" ;
    dcterms:title "predicted genome structure" ;
    schema1:name "pred_genome_struc" ;
    rdfs:range MIXS:PredGenomeStrucEnum ;
    skos:definition "Expected structure of the viral genome" .

MIXS:0000084 a owl:DatatypeProperty ;
    rdfs:label "detec_type" ;
    dcterms:title "detection type" ;
    schema1:name "detec_type" ;
    skos:definition "Type of UViG detection" ;
    MIXS:Expected_value "enumeration" .

MIXS:0000085 a owl:DatatypeProperty ;
    rdfs:label "otu_class_appr" ;
    dcterms:title "OTU classification approach" ;
    schema1:name "otu_class_appr" ;
    skos:definition "Cutoffs and approach used when clustering species-level OTUs. Note that results from standard 95% ANI / 85% AF clustering should be provided alongside OTUs defined from another set of thresholds, even if the latter are the ones primarily used during the analysis" ;
    MIXS:Expected_value "cutoffs and method used" .

MIXS:0000086 a owl:DatatypeProperty ;
    rdfs:label "otu_seq_comp_appr" ;
    dcterms:title "OTU sequence comparison approach" ;
    schema1:name "otu_seq_comp_appr" ;
    skos:definition "Tool and thresholds used to compare sequences when computing \"species-level\" OTUs" ;
    MIXS:Expected_value "software name, version and relevant parameters" .

MIXS:0000087 a owl:DatatypeProperty ;
    rdfs:label "otu_db" ;
    dcterms:title "OTU database" ;
    schema1:name "otu_db" ;
    skos:definition "Reference database (i.e. sequences not generated as part of the current study) used to cluster new genomes in \"species-level\" OTUs, if any" ;
    MIXS:Expected_value "database and version" .

MIXS:0000088 a owl:ObjectProperty ;
    rdfs:label "host_pred_appr" ;
    dcterms:title "host prediction approach" ;
    schema1:name "host_pred_appr" ;
    rdfs:range MIXS:HostPredApprEnum ;
    skos:definition "Tool or approach used for host prediction" .

MIXS:0000089 a owl:DatatypeProperty ;
    rdfs:label "host_pred_est_acc" ;
    dcterms:title "host prediction estimated accuracy" ;
    schema1:name "host_pred_est_acc" ;
    rdfs:range xsd:string ;
    skos:definition "For each tool or approach used for host prediction, estimated false discovery rates should be included, either computed de novo or from the literature" .

MIXS:0000096 a owl:DatatypeProperty ;
    rdfs:label "barometric_press" ;
    dcterms:title "barometric pressure" ;
    schema1:name "barometric_press" ;
    rdfs:range xsd:string ;
    skos:definition "Force per unit area exerted against a surface by the weight of air above that surface" ;
    MIXS:Preferred_unit "millibar" .

MIXS:0000098 a owl:DatatypeProperty ;
    rdfs:label "carb_monoxide" ;
    dcterms:title "carbon monoxide" ;
    schema1:name "carb_monoxide" ;
    rdfs:range xsd:string ;
    skos:definition "Carbon monoxide (gas) amount or concentration at the time of sampling" ;
    MIXS:Preferred_unit "micromole per liter, parts per million" .

MIXS:0000104 a owl:DatatypeProperty ;
    rdfs:label "oxygen" ;
    dcterms:title "oxygen" ;
    schema1:name "oxygen" ;
    rdfs:range xsd:string ;
    skos:definition "Oxygen (gas) amount or concentration at the time of sampling" ;
    MIXS:Preferred_unit "milligram per liter, parts per million" .

MIXS:0000121 a owl:DatatypeProperty ;
    rdfs:label "rel_air_humidity" ;
    dcterms:title "relative air humidity" ;
    schema1:name "rel_air_humidity" ;
    rdfs:range xsd:float ;
    skos:definition "Partial vapor and air pressure, density of the vapor and air, or by the actual mass of the vapor and air" ;
    skos:note "percent or float?" ;
    MIXS:Preferred_unit "percentage" .

MIXS:0000122 a owl:DatatypeProperty ;
    rdfs:label "abs_air_humidity" ;
    dcterms:title "absolute air humidity" ;
    schema1:name "abs_air_humidity" ;
    rdfs:range xsd:string ;
    skos:definition "Actual mass of water vapor present in the air water vapor mixture." ;
    skos:note "Can be calculated via mass of water vapor divided by the volume of the air and water vapor mixture." ;
    MIXS:Preferred_unit "gram per gram, kilogram per kilogram, kilogram, pound, gram per cubic meter, kilogram per cubic meter, percent" .

MIXS:0000123 a owl:DatatypeProperty ;
    rdfs:label "surf_humidity" ;
    dcterms:title "surface humidity" ;
    schema1:name "surf_humidity" ;
    rdfs:range xsd:float ;
    skos:definition "Surfaces: water activity as a function of air and material moisture" ;
    skos:note "percent or float?" ;
    MIXS:Preferred_unit "percentage" .

MIXS:0000125 a owl:DatatypeProperty ;
    rdfs:label "surf_temp" ;
    dcterms:title "surface temperature" ;
    schema1:name "surf_temp" ;
    rdfs:range xsd:string ;
    skos:definition "Temperature of the surface at the time of sampling" ;
    MIXS:Preferred_unit "degree Celsius" .

MIXS:0000128 a owl:DatatypeProperty ;
    rdfs:label "surf_moisture" ;
    dcterms:title "surface moisture" ;
    schema1:name "surf_moisture" ;
    rdfs:range xsd:string ;
    skos:definition "Water held on a surface" ;
    MIXS:Preferred_unit "parts per million, gram per cubic meter, gram per square meter" .

MIXS:0000129 a owl:DatatypeProperty ;
    rdfs:label "dew_point" ;
    dcterms:title "dew point" ;
    schema1:name "dew_point" ;
    rdfs:range xsd:string ;
    skos:definition "The temperature to which a given parcel of humid air must be cooled, at constant barometric pressure, for water vapor to condense into water" ;
    MIXS:Preferred_unit "degree Celsius" .

MIXS:0000136 a owl:DatatypeProperty ;
    rdfs:label "samp_loc_corr_rate" ;
    dcterms:title "corrosion rate at sample location" ;
    schema1:name "samp_loc_corr_rate" ;
    rdfs:range xsd:string ;
    skos:definition "Metal corrosion rate is the speed of metal deterioration due to environmental conditions. As environmental conditions change corrosion rates change accordingly. Therefore, long term corrosion rates are generally more informative than short term rates and for that reason they are preferred during reporting. In the case of suspected MIC, corrosion rate measurements at the time of sampling might provide insights into the involvement of certain microbial community members in MIC as well as potential microbial interplays" ;
    MIXS:Preferred_unit "millimeter per year" .

MIXS:0000140 a owl:DatatypeProperty ;
    rdfs:label "amount_light" ;
    dcterms:title "amount of light" ;
    schema1:name "amount_light" ;
    rdfs:range xsd:string ;
    skos:definition "The unit of illuminance and luminous emittance, measuring luminous flux per unit area" ;
    MIXS:Preferred_unit "lux, lumens per square meter" .

MIXS:0000141 a owl:DatatypeProperty ;
    rdfs:label "avg_dew_point" ;
    dcterms:title "average dew point" ;
    schema1:name "avg_dew_point" ;
    rdfs:range xsd:string ;
    skos:definition "The average of dew point measures taken at the beginning of every hour over a 24 hour period on the sampling day" ;
    MIXS:Preferred_unit "degree Celsius" .

MIXS:0000142 a owl:DatatypeProperty ;
    rdfs:label "avg_temp" ;
    dcterms:title "average temperature" ;
    schema1:name "avg_temp" ;
    rdfs:range xsd:string ;
    skos:definition "The average of temperatures taken at the beginning of every hour over a 24 hour period on the sampling day" ;
    MIXS:Preferred_unit "degree Celsius" .

MIXS:0000143 a owl:DatatypeProperty ;
    rdfs:label "ceil_thermal_mass" ;
    dcterms:title "ceiling thermal mass" ;
    schema1:name "ceil_thermal_mass" ;
    rdfs:range xsd:string ;
    skos:definition "The ability of the ceiling to provide inertia against temperature fluctuations. Generally this means concrete that is exposed. A metal deck that supports a concrete slab will act thermally as long as it is exposed to room air flow" ;
    MIXS:Preferred_unit "joule per degree Celsius" .

MIXS:0000144 a owl:DatatypeProperty ;
    rdfs:label "exp_duct" ;
    dcterms:title "exposed ductwork" ;
    schema1:name "exp_duct" ;
    rdfs:range xsd:string ;
    skos:definition "The amount of exposed ductwork in the room" ;
    MIXS:Preferred_unit "square meter" .

MIXS:0000145 a owl:DatatypeProperty ;
    rdfs:label "built_struc_age" ;
    dcterms:title "built structure age" ;
    schema1:name "built_struc_age" ;
    rdfs:range xsd:string ;
    skos:definition "The age of the built structure since construction" ;
    MIXS:Preferred_unit "year" .

MIXS:0000148 a owl:DatatypeProperty ;
    rdfs:label "ceil_area" ;
    dcterms:title "ceiling area" ;
    schema1:name "ceil_area" ;
    rdfs:range xsd:string ;
    skos:definition "The area of the ceiling space within the room" ;
    MIXS:Preferred_unit "square meter" .

MIXS:0000158 a owl:DatatypeProperty ;
    rdfs:label "door_size" ;
    dcterms:title "door area or size" ;
    schema1:name "door_size" ;
    rdfs:range xsd:string ;
    skos:definition "The size of the door" ;
    MIXS:Preferred_unit "square meter" .

MIXS:0000164 a owl:DatatypeProperty ;
    rdfs:label "floor_age" ;
    dcterms:title "floor age" ;
    schema1:name "floor_age" ;
    rdfs:range xsd:string ;
    skos:definition "The time period since installment of the carpet or flooring" ;
    MIXS:Preferred_unit "years, weeks, days" .

MIXS:0000165 a owl:DatatypeProperty ;
    rdfs:label "floor_area" ;
    dcterms:title "floor area" ;
    schema1:name "floor_area" ;
    rdfs:range xsd:string ;
    skos:definition "The area of the floor space within the room" ;
    MIXS:Preferred_unit "square meter" .

MIXS:0000166 a owl:DatatypeProperty ;
    rdfs:label "floor_thermal_mass" ;
    dcterms:title "floor thermal mass" ;
    schema1:name "floor_thermal_mass" ;
    rdfs:range xsd:string ;
    skos:definition "The ability of the floor to provide inertia against temperature fluctuations" ;
    MIXS:Preferred_unit "joule per degree Celsius" .

MIXS:0000167 a owl:DatatypeProperty ;
    rdfs:label "height_carper_fiber" ;
    dcterms:title "height carpet fiber mat" ;
    schema1:name "height_carper_fiber" ;
    rdfs:range xsd:string ;
    skos:definition "The average carpet fiber height in the indoor environment" ;
    MIXS:Preferred_unit "centimeter" .

MIXS:0000168 a owl:DatatypeProperty ;
    rdfs:label "inside_lux" ;
    dcterms:title "inside lux light" ;
    schema1:name "inside_lux" ;
    rdfs:range xsd:string ;
    skos:definition "The recorded value at sampling time (power density)" ;
    MIXS:Preferred_unit "kilowatt per square metre" .

MIXS:0000169 a owl:DatatypeProperty ;
    rdfs:label "room_air_exch_rate" ;
    dcterms:title "room air exchange rate" ;
    schema1:name "room_air_exch_rate" ;
    rdfs:range xsd:string ;
    skos:definition "The rate at which outside air replaces indoor air in a given space" ;
    MIXS:Preferred_unit "liter per hour" .

MIXS:0000170 a owl:DatatypeProperty ;
    rdfs:label "ext_door" ;
    dcterms:title "exterior door count" ;
    schema1:name "ext_door" ;
    rdfs:range xsd:integer ;
    skos:definition "The number of exterior doors in the built structure" .

MIXS:0000188 a owl:DatatypeProperty ;
    rdfs:label "rel_humidity_out" ;
    dcterms:title "outside relative humidity" ;
    schema1:name "rel_humidity_out" ;
    rdfs:range xsd:string ;
    skos:definition "The recorded outside relative humidity value at the time of sampling" ;
    MIXS:Preferred_unit "gram of air, kilogram of air" .

MIXS:0000193 a owl:DatatypeProperty ;
    rdfs:label "room_door_dist" ;
    dcterms:title "room door distance" ;
    schema1:name "room_door_dist" ;
    rdfs:range xsd:string ;
    skos:definition "Distance between doors (meters) in the hallway between the sampling room and adjacent rooms" ;
    MIXS:Preferred_unit "meter" .

MIXS:0000194 a owl:DatatypeProperty ;
    rdfs:label "room_net_area" ;
    dcterms:title "room net area" ;
    schema1:name "room_net_area" ;
    rdfs:range xsd:string ;
    skos:definition "The net floor area of sampling room. Net area excludes wall thicknesses" ;
    MIXS:Preferred_unit "square feet, square meter" .

MIXS:0000195 a owl:DatatypeProperty ;
    rdfs:label "room_vol" ;
    dcterms:title "room volume" ;
    schema1:name "room_vol" ;
    rdfs:range xsd:string ;
    skos:definition "Volume of sampling room" ;
    MIXS:Preferred_unit "cubic feet, cubic meter" .

MIXS:0000196 a owl:DatatypeProperty ;
    rdfs:label "samp_time_out" ;
    dcterms:title "sampling time outside" ;
    schema1:name "samp_time_out" ;
    skos:definition "The recent and long term history of outside sampling" ;
    MIXS:Expected_value "time" ;
    MIXS:Preferred_unit "hour" .

MIXS:0000197 a owl:DatatypeProperty ;
    rdfs:label "temp_out" ;
    dcterms:title "temperature outside house" ;
    schema1:name "temp_out" ;
    rdfs:range xsd:string ;
    skos:definition "The recorded temperature value at sampling time outside" ;
    MIXS:Preferred_unit "degree Celsius" .

MIXS:0000198 a owl:DatatypeProperty ;
    rdfs:label "wall_area" ;
    dcterms:title "wall area" ;
    schema1:name "wall_area" ;
    rdfs:range xsd:string ;
    skos:definition "The total area of the sampled room's walls" ;
    MIXS:Preferred_unit "square meter" .

MIXS:0000214 a owl:DatatypeProperty ;
    rdfs:label "specific_humidity" ;
    dcterms:title "specific humidity" ;
    schema1:name "specific_humidity" ;
    rdfs:range xsd:string ;
    skos:definition "The mass of water vapour in a unit mass of moist air, usually expressed as grams of vapour per kilogram of air, or, in air conditioning, as grains per pound" ;
    MIXS:Preferred_unit "gram of air, kilogram of air" .

MIXS:0000215 a owl:DatatypeProperty ;
    rdfs:label "sewage_type" ;
    dcterms:title "sewage type" ;
    schema1:name "sewage_type" ;
    rdfs:range xsd:string ;
    skos:definition "Type of wastewater treatment plant as municipial or industrial" ;
    MIXS:Expected_value "sewage type name" .

MIXS:0000217 a owl:DatatypeProperty ;
    rdfs:label "occup_density_samp" ;
    dcterms:title "occupant density at sampling" ;
    schema1:name "occup_density_samp" ;
    rdfs:range xsd:float ;
    skos:definition "Average number of occupants at time of sampling per square footage" .

MIXS:0000218 a owl:DatatypeProperty ;
    rdfs:label "address" ;
    dcterms:title "address" ;
    schema1:name "address" ;
    skos:definition "The street name and building number where the sampling occurred" .

MIXS:0000219 a owl:DatatypeProperty ;
    rdfs:label "adj_room" ;
    dcterms:title "adjacent rooms" ;
    schema1:name "adj_room" ;
    rdfs:range xsd:string ;
    skos:definition "List of rooms (room number, room name) immediately adjacent to the sampling room" .

MIXS:0000220 a owl:DatatypeProperty ;
    rdfs:label "exp_pipe" ;
    dcterms:title "exposed pipes" ;
    schema1:name "exp_pipe" ;
    rdfs:range xsd:string ;
    skos:definition "The number of exposed pipes in the room" .

MIXS:0000221 a owl:DatatypeProperty ;
    rdfs:label "wall_height" ;
    dcterms:title "wall height" ;
    schema1:name "wall_height" ;
    rdfs:range xsd:string ;
    skos:definition "The average height of the walls in the sampled room" ;
    MIXS:Preferred_unit "centimeter" .

MIXS:0000222 a owl:DatatypeProperty ;
    rdfs:label "wall_thermal_mass" ;
    dcterms:title "wall thermal mass" ;
    schema1:name "wall_thermal_mass" ;
    rdfs:range xsd:string ;
    skos:definition "The ability of the wall to provide inertia against temperature fluctuations. Generally this means concrete or concrete block that is either exposed or covered only with paint" ;
    MIXS:Preferred_unit "joule per degree Celsius" .

MIXS:0000223 a owl:DatatypeProperty ;
    rdfs:label "water_feat_size" ;
    dcterms:title "water feature size" ;
    schema1:name "water_feat_size" ;
    rdfs:range xsd:string ;
    skos:definition "The size of the water feature" ;
    MIXS:Preferred_unit "square meter" .

MIXS:0000224 a owl:DatatypeProperty ;
    rdfs:label "window_size" ;
    dcterms:title "window area/size" ;
    schema1:name "window_size" ;
    skos:definition "The window's length and width" ;
    MIXS:Expected_value "measurement value" ;
    MIXS:Preferred_unit "inch, meter" .

MIXS:0000225 a owl:DatatypeProperty ;
    rdfs:label "floor_count" ;
    dcterms:title "floor count" ;
    schema1:name "floor_count" ;
    rdfs:range xsd:integer ;
    skos:definition "The number of floors in the building, including basements and mechanical penthouse" .

MIXS:0000227 a owl:DatatypeProperty ;
    rdfs:label "freq_cook" ;
    dcterms:title "frequency of cooking" ;
    schema1:name "freq_cook" ;
    rdfs:range xsd:string ;
    skos:definition "The number of times a meal is cooked per week" .

MIXS:0000228 a owl:DatatypeProperty ;
    rdfs:label "hall_count" ;
    dcterms:title "hallway/corridor count" ;
    schema1:name "hall_count" ;
    rdfs:range xsd:integer ;
    skos:definition "The total count of hallways and corridors in the built structure" .

MIXS:0000229 a owl:DatatypeProperty ;
    rdfs:label "max_occup" ;
    dcterms:title "maximum occupancy" ;
    schema1:name "max_occup" ;
    rdfs:range xsd:string ;
    skos:definition "The maximum amount of people allowed in the indoor environment" .

MIXS:0000230 a owl:DatatypeProperty ;
    rdfs:label "number_plants" ;
    dcterms:title "number of houseplants" ;
    schema1:name "number_plants" ;
    rdfs:range xsd:string ;
    skos:definition "The number of plant(s) in the sampling space" .

MIXS:0000231 a owl:DatatypeProperty ;
    rdfs:label "number_pets" ;
    dcterms:title "number of pets" ;
    schema1:name "number_pets" ;
    rdfs:range xsd:string ;
    skos:definition "The number of pets residing in the sampled space" .

MIXS:0000232 a owl:DatatypeProperty ;
    rdfs:label "number_resident" ;
    dcterms:title "number of residents" ;
    schema1:name "number_resident" ;
    rdfs:range xsd:string ;
    skos:definition "The number of individuals currently occupying in the sampling location" .

MIXS:0000233 a owl:DatatypeProperty ;
    rdfs:label "room_architec_elem" ;
    dcterms:title "room architectural elements" ;
    schema1:name "room_architec_elem" ;
    rdfs:range xsd:string ;
    skos:definition "The unique details and component parts that, together, form the architecture of a distinguishable space within a built structure" .

MIXS:0000234 a owl:DatatypeProperty ;
    rdfs:label "room_count" ;
    dcterms:title "room count" ;
    schema1:name "room_count" ;
    rdfs:range xsd:integer ;
    skos:definition "The total count of rooms in the built structure including all room types" .

MIXS:0000235 a owl:DatatypeProperty ;
    rdfs:label "room_moist_dam_hist" ;
    dcterms:title "room moisture damage or mold history" ;
    schema1:name "room_moist_dam_hist" ;
    rdfs:range xsd:integer ;
    skos:definition "The history of moisture damage or mold in the past 12 months. Number of events of moisture damage or mold observed" .

MIXS:0000236 a owl:DatatypeProperty ;
    rdfs:label "room_occup" ;
    dcterms:title "room occupancy" ;
    schema1:name "room_occup" ;
    rdfs:range xsd:string ;
    skos:definition "Count of room occupancy at time of sampling" .

MIXS:0000237 a owl:DatatypeProperty ;
    rdfs:label "room_window_count" ;
    dcterms:title "room window count" ;
    schema1:name "room_window_count" ;
    rdfs:range xsd:integer ;
    skos:definition "Number of windows in the room" .

MIXS:0000238 a owl:DatatypeProperty ;
