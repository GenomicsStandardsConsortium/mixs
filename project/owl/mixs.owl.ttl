linkml:ClassDefinition a owl:Class ;
    rdfs:label "ClassDefinition" ;
    dcterms:title "ClassDefinition" ;
    schema1:name "ClassDefinition" ;
    skos:definition "an element whose instances are complex objects that may have slot-value assignments" .

MIXS:0000107 a owl:DatatypeProperty ;
    rdfs:label "pollutants" ;
    dcterms:title "pollutants" ;
    schema1:name "pollutants" ;
    skos:definition "Pollutant types and, amount or concentrations measured at the time of sampling; can report multiple pollutants by entering numeric values preceded by name of pollutant" ;
    MIXS:Expected_value "pollutant name;measurement value" ;
    MIXS:Preferred_unit "gram, mole per liter, milligram per liter, microgram per cubic meter" .

MIXS:0000115 a owl:DatatypeProperty ;
    rdfs:label "volatile_org_comp" ;
    dcterms:title "volatile organic compounds" ;
    schema1:name "volatile_org_comp" ;
    skos:definition "Concentration of carbon-based chemicals that easily evaporate at room temperature; can report multiple volatile organic compounds by entering numeric values preceded by name of compound" ;
    MIXS:Expected_value "volatile organic compound name;measurement value" ;
    MIXS:Preferred_unit "microgram per cubic meter, parts per million, nanogram per liter" .

MIXS:0000206 a owl:DatatypeProperty ;
    rdfs:label "particle_class" ;
    dcterms:title "particle classification" ;
    schema1:name "particle_class" ;
    skos:definition "Particles are classified, based on their size, into six general categories:clay, silt, sand, gravel, cobbles, and boulders; should include amount of particle preceded by the name of the particle type; can include multiple values" ;
    MIXS:Expected_value "particle name;measurement value" ;
    MIXS:Preferred_unit "micrometer" .

MIXS:0000216 a owl:DatatypeProperty ;
    rdfs:label "samp_sort_meth" ;
    dcterms:title "sample size sorting method" ;
    schema1:name "samp_sort_meth" ;
    rdfs:range xsd:string ;
    skos:definition "Method by which samples are sorted; open face filter collecting total suspended particles, prefilter to remove particles larger than X micrometers in diameter, where common values of X would be 10 and 2.5 full size sorting in a cascade impactor" .

MIXS:0000267 a owl:DatatypeProperty ;
    rdfs:label "pet_farm_animal" ;
    dcterms:title "presence of pets or farm animals" ;
    schema1:name "pet_farm_animal" ;
    skos:definition "Specification of presence of pets or farm animals in the environment of subject, if yes the animals should be specified; can include multiple animals present" ;
    MIXS:Expected_value "presence status;type of animal or pet" .

MIXS:0000268 a owl:DatatypeProperty ;
    rdfs:label "travel_out_six_month" ;
    dcterms:title "travel outside the country in last six months" ;
    schema1:name "travel_out_six_month" ;
    rdfs:range xsd:string ;
    skos:definition "Specification of the countries travelled in the last six months; can include multiple travels" ;
    MIXS:Expected_value "country name" .

MIXS:0000269 a owl:DatatypeProperty ;
    rdfs:label "pulmonary_disord" ;
    dcterms:title "lung/pulmonary disorder" ;
    schema1:name "pulmonary_disord" ;
    rdfs:range xsd:string ;
    skos:definition "History of pulmonary disorders; can include multiple disorders. The terms should be chosen from the DO (Human Disease Ontology) at http://www.disease-ontology.org, lung disease (https://disease-ontology.org/?id=DOID:850)" .

MIXS:0000270 a owl:DatatypeProperty ;
    rdfs:label "nose_throat_disord" ;
    dcterms:title "nose throat disorder" ;
    schema1:name "nose_throat_disord" ;
    rdfs:range xsd:string ;
    skos:altLabel "nose_mouth_teeth_throat_disord" ;
    skos:definition """Report any history of nose, mouth, teeth and/or throat disorders in the subject. May include multiple disorders.
""" ;
    skos:note """The terms should be chosen from the DO (Human Disease Ontology) at http://www.disease-ontology.org, lung disease (https://disease-ontology.org/?id=DOID:850), upper respiratory tract disease (https://disease-ontology.org/?id=DOID:974)
""" .

MIXS:0000271 a owl:DatatypeProperty ;
    rdfs:label "blood_blood_disord" ;
    dcterms:title "blood/blood disorder" ;
    schema1:name "blood_blood_disord" ;
    rdfs:range xsd:string ;
    skos:definition "History of blood disorders; can include multiple disorders.  The terms should be chosen from the DO (Human Disease Ontology) at http://www.disease-ontology.org, hematopoietic system disease (https://disease-ontology.org/?id=DOID:74)" .

MIXS:0000277 a owl:DatatypeProperty ;
    rdfs:label "kidney_disord" ;
    dcterms:title "urine/kidney disorder" ;
    schema1:name "kidney_disord" ;
    rdfs:range xsd:string ;
    skos:definition "History of kidney disorders; can include multiple disorders. The terms should be chosen from the DO (Human Disease Ontology) at http://www.disease-ontology.org, kidney disease (https://disease-ontology.org/?id=DOID:557)" .

MIXS:0000278 a owl:DatatypeProperty ;
    rdfs:label "urogenit_tract_disor" ;
    dcterms:title "urine/urogenital tract disorder" ;
    schema1:name "urogenit_tract_disor" ;
    rdfs:range xsd:string ;
    skos:definition "History of urogenital tract disorders; can include multiple disorders. The terms should be chosen from the DO (Human Disease Ontology) at http://www.disease-ontology.org, urinary system disease (https://disease-ontology.org/?id=DOID:18)" .

MIXS:0000280 a owl:DatatypeProperty ;
    rdfs:label "gastrointest_disord" ;
    dcterms:title "gastrointestinal tract disorder" ;
    schema1:name "gastrointest_disord" ;
    rdfs:range xsd:string ;
    skos:definition "History of gastrointestinal tract disorders; can include multiple disorders. History of blood disorders; can include multiple disorders.  The terms should be chosen from the DO (Human Disease Ontology) at http://www.disease-ontology.org, gastrointestinal system disease (https://disease-ontology.org/?id=DOID:77)" .

MIXS:0000282 a owl:DatatypeProperty ;
    rdfs:label "liver_disord" ;
    dcterms:title "liver disorder" ;
    schema1:name "liver_disord" ;
    rdfs:range xsd:string ;
    skos:definition "History of liver disorders; can include multiple disorders. The terms should be chosen from the DO (Human Disease Ontology) at http://www.disease-ontology.org, liver disease (https://disease-ontology.org/?id=DOID:409)" .

MIXS:0000283 a owl:DatatypeProperty ;
    rdfs:label "nose_mouth_teeth_throat_disord" ;
    dcterms:title "nose/mouth/teeth/throat disorder" ;
    schema1:name "nose_mouth_teeth_throat_disord" ;
    rdfs:range xsd:string ;
    skos:definition """History of nose/mouth/teeth/throat disorders; can include multiple disorders. The terms should be chosen from the DO (Human Disease Ontology) at http://www.disease-ontology.org, nose disease (https://disease-ontology.org/?id=DOID:2825), mouth disease (https://disease-ontology.org/?id=DOID:403), tooth disease (https://disease-ontology.org/?id=DOID:1091), or upper respiratory tract disease (https://disease-ontology.org/?id=DOID:974)
""" .

MIXS:0000284 a owl:DatatypeProperty ;
    rdfs:label "dermatology_disord" ;
    dcterms:title "dermatology disorder" ;
    schema1:name "dermatology_disord" ;
    rdfs:range xsd:string ;
    skos:definition "History of dermatology disorders; can include multiple disorders. The terms should be chosen from the DO (Human Disease Ontology) at http://www.disease-ontology.org, skin disease (https://disease-ontology.org/?id=DOID:37)" .

MIXS:0000288 a owl:DatatypeProperty ;
    rdfs:label "gynecologic_disord" ;
    dcterms:title "gynecological disorder" ;
    schema1:name "gynecologic_disord" ;
    rdfs:range xsd:string ;
    skos:definition "History of gynecological disorders; can include multiple disorders. The terms should be chosen from the DO (Human Disease Ontology) at http://www.disease-ontology.org, female reproductive system disease (https://disease-ontology.org/?id=DOID:229)" .

MIXS:0000289 a owl:DatatypeProperty ;
    rdfs:label "urogenit_disord" ;
    dcterms:title "urogenital disorder" ;
    schema1:name "urogenit_disord" ;
    rdfs:range xsd:string ;
    skos:definition "History of urogenital disorders, can include multiple disorders. The terms should be chosen from the DO (Human Disease Ontology) at http://www.disease-ontology.org, reproductive system disease (https://disease-ontology.org/?id=DOID:15) or urinary system disease (https://disease-ontology.org/?id=DOID:18)" .

MIXS:0000551 a owl:DatatypeProperty ;
    rdfs:label "air_temp_regm" ;
    dcterms:title "air temperature regimen" ;
    schema1:name "air_temp_regm" ;
    skos:definition "Information about treatment involving an exposure to varying temperatures; should include the temperature, treatment regimen including how many times the treatment was repeated, how long each treatment lasted, and the start and end time of the entire treatment; can include different temperature regimens" ;
    MIXS:Expected_value "temperature value;treatment interval and duration" ;
    MIXS:Preferred_unit "degree Celsius" .

MIXS:0000553 a owl:DatatypeProperty ;
    rdfs:label "antibiotic_regm" ;
    dcterms:title "antibiotic regimen" ;
    schema1:name "antibiotic_regm" ;
    skos:definition "Information about treatment involving antibiotic administration; should include the name of antibiotic, amount administered, treatment regimen including how many times the treatment was repeated, how long each treatment lasted, and the start and end time of the entire treatment; can include multiple antibiotic regimens" ;
    MIXS:Expected_value "antibiotic name;antibiotic amount;treatment interval and duration" ;
    MIXS:Preferred_unit "milligram" .

MIXS:0000555 a owl:DatatypeProperty ;
    rdfs:label "chem_mutagen" ;
    dcterms:title "chemical mutagen" ;
    schema1:name "chem_mutagen" ;
    skos:definition "Treatment involving use of mutagens; should include the name of mutagen, amount administered, treatment regimen including how many times the treatment was repeated, how long each treatment lasted, and the start and end time of the entire treatment; can include multiple mutagen regimens" ;
    MIXS:Expected_value "mutagen name;mutagen amount;treatment interval and duration" ;
    MIXS:Preferred_unit "milligram per liter" .

MIXS:0000556 a owl:DatatypeProperty ;
    rdfs:label "fertilizer_regm" ;
    dcterms:title "fertilizer regimen" ;
    schema1:name "fertilizer_regm" ;
    skos:definition "Information about treatment involving the use of fertilizers; should include the name of fertilizer, amount administered, treatment regimen including how many times the treatment was repeated, how long each treatment lasted, and the start and end time of the entire treatment; can include multiple fertilizer regimens" ;
    MIXS:Expected_value "fertilizer name;fertilizer amount;treatment interval and duration" ;
    MIXS:Preferred_unit "gram, mole per liter, milligram per liter" .

MIXS:0000559 a owl:DatatypeProperty ;
    rdfs:label "gravity" ;
    dcterms:title "gravity" ;
    schema1:name "gravity" ;
    skos:definition "Information about treatment involving use of gravity factor to study various types of responses in presence, absence or modified levels of gravity; treatment regimen including how many times the treatment was repeated, how long each treatment lasted, and the start and end time of the entire treatment; can include multiple treatments" ;
    MIXS:Expected_value "gravity factor value;treatment interval and duration" ;
    MIXS:Preferred_unit "meter per square second, g" .

MIXS:0000560 a owl:DatatypeProperty ;
    rdfs:label "growth_hormone_regm" ;
    dcterms:title "growth hormone regimen" ;
    schema1:name "growth_hormone_regm" ;
    skos:definition "Information about treatment involving use of growth hormones; should include the name of growth hormone, amount administered, treatment regimen including how many times the treatment was repeated, how long each treatment lasted, and the start and end time of the entire treatment; can include multiple growth hormone regimens" ;
    MIXS:Expected_value "growth hormone name;growth hormone amount;treatment interval and duration" ;
    MIXS:Preferred_unit "gram, mole per liter, milligram per liter" .

MIXS:0000568 a owl:DatatypeProperty ;
    rdfs:label "humidity_regm" ;
    dcterms:title "humidity regimen" ;
    schema1:name "humidity_regm" ;
    skos:definition "Information about treatment involving an exposure to varying degree of humidity; information about treatment involving use of growth hormones; should include amount of humidity administered, treatment regimen including how many times the treatment was repeated, how long each treatment lasted, and the start and end time of the entire treatment; can include multiple regimens" ;
    MIXS:Expected_value "humidity value;treatment interval and duration" ;
    MIXS:Preferred_unit "gram per cubic meter" .

MIXS:0000570 a owl:DatatypeProperty ;
    rdfs:label "mineral_nutr_regm" ;
    dcterms:title "mineral nutrient regimen" ;
    schema1:name "mineral_nutr_regm" ;
    skos:definition "Information about treatment involving the use of mineral supplements; should include the name of mineral nutrient, amount administered, treatment regimen including how many times the treatment was repeated, how long each treatment lasted, and the start and end time of the entire treatment; can include multiple mineral nutrient regimens" ;
    MIXS:Expected_value "mineral nutrient name;mineral nutrient amount;treatment interval and duration" ;
    MIXS:Preferred_unit "gram, mole per liter, milligram per liter" .

MIXS:0000575 a owl:DatatypeProperty ;
    rdfs:label "radiation_regm" ;
    dcterms:title "radiation regimen" ;
    schema1:name "radiation_regm" ;
    skos:definition "Information about treatment involving exposure of plant or a plant part to a particular radiation regimen; should include the radiation type, amount or intensity administered, treatment regimen including how many times the treatment was repeated, how long each treatment lasted, and the start and end time of the entire treatment; can include multiple radiation regimens" ;
    MIXS:Expected_value "radiation type name;radiation amount;treatment interval and duration" ;
    MIXS:Preferred_unit "rad, gray" .

MIXS:0000576 a owl:DatatypeProperty ;
    rdfs:label "rainfall_regm" ;
    dcterms:title "rainfall regimen" ;
    schema1:name "rainfall_regm" ;
    skos:definition "Information about treatment involving an exposure to a given amount of rainfall, treatment regimen including how many times the treatment was repeated, how long each treatment lasted, and the start and end time of the entire treatment; can include multiple regimens" ;
    MIXS:Expected_value "measurement value;treatment interval and duration" ;
    MIXS:Preferred_unit "millimeter" .

MIXS:0000652 a owl:DatatypeProperty ;
    rdfs:label "heavy_metals" ;
    dcterms:title "extreme_unusual_properties/heavy metals" ;
    schema1:name "heavy_metals" ;
    skos:definition "Heavy metals present in the sequenced sample and their concentrations. For multiple heavy metals and concentrations, add multiple copies of this field" ;
    MIXS:Expected_value "heavy metal name;measurement value unit" ;
    MIXS:Preferred_unit "microgram per gram" .

MIXS:0000660 a owl:DatatypeProperty ;
    rdfs:label "emulsions" ;
    dcterms:title "emulsions" ;
    schema1:name "emulsions" ;
    skos:definition "Amount or concentration of substances such as paints, adhesives, mayonnaise, hair colorants, emulsified oils, etc.; can include multiple emulsion types" ;
    MIXS:Expected_value "emulsion name;measurement value" ;
    MIXS:Preferred_unit "gram per liter" .

MIXS:0000661 a owl:DatatypeProperty ;
    rdfs:label "gaseous_substances" ;
    dcterms:title "gaseous substances" ;
    schema1:name "gaseous_substances" ;
    skos:definition "Amount or concentration of substances such as hydrogen sulfide, carbon dioxide, methane, etc.; can include multiple substances" ;
    MIXS:Expected_value "gaseous substance name;measurement value" ;
    MIXS:Preferred_unit "micromole per liter" .

MIXS:0000664 a owl:DatatypeProperty ;
    rdfs:label "inorg_particles" ;
    dcterms:title "inorganic particles" ;
    schema1:name "inorg_particles" ;
    skos:definition "Concentration of particles such as sand, grit, metal particles, ceramics, etc.; can include multiple particles" ;
    MIXS:Expected_value "inorganic particle name;measurement value" ;
    MIXS:Preferred_unit "mole per liter, milligram per liter" .

MIXS:0000665 a owl:DatatypeProperty ;
    rdfs:label "org_particles" ;
    dcterms:title "organic particles" ;
    schema1:name "org_particles" ;
    skos:definition "Concentration of particles such as faeces, hairs, food, vomit, paper fibers, plant material, humus, etc" ;
    MIXS:Expected_value "particle name;measurement value" ;
    MIXS:Preferred_unit "gram per liter" .

MIXS:0000672 a owl:DatatypeProperty ;
    rdfs:label "soluble_inorg_mat" ;
    dcterms:title "soluble inorganic material" ;
    schema1:name "soluble_inorg_mat" ;
    skos:definition "Concentration of substances such as ammonia, road-salt, sea-salt, cyanide, hydrogen sulfide, thiocyanates, thiosulfates, etc" ;
    MIXS:Expected_value "soluble inorganic material name;measurement value" ;
    MIXS:Preferred_unit "gram, microgram, mole per liter, gram per liter, parts per million" .

MIXS:0000673 a owl:DatatypeProperty ;
    rdfs:label "soluble_org_mat" ;
    dcterms:title "soluble organic material" ;
    schema1:name "soluble_org_mat" ;
    skos:definition "Concentration of substances such as urea, fruit sugars, soluble proteins, drugs, pharmaceuticals, etc" ;
    MIXS:Expected_value "soluble organic material name;measurement value" ;
    MIXS:Preferred_unit "gram, microgram, mole per liter, gram per liter, parts per million" .

MIXS:0000759 a owl:ObjectProperty ;
    rdfs:label "surf_air_cont" ;
    dcterms:title "surface-air contaminant" ;
    schema1:name "surf_air_cont" ;
    rdfs:range MIXS:SurfAirContEnum ;
    skos:definition "Contaminant identified on surface" .

MIXS:0000761 a owl:ObjectProperty ;
    rdfs:label "build_occup_type" ;
    dcterms:title "building occupancy type" ;
    schema1:name "build_occup_type" ;
    rdfs:range MIXS:BuildOccupTypeEnum ;
    skos:definition "The primary function for which a building or discrete part of a building is intended to be used" .

MIXS:0000765 a owl:ObjectProperty ;
    rdfs:label "filter_type" ;
    dcterms:title "filter type" ;
    schema1:name "filter_type" ;
    rdfs:range MIXS:FilterTypeEnum ;
    skos:definition "A device which removes solid particulates or airborne molecular contaminants" .

MIXS:0000766 a owl:ObjectProperty ;
    rdfs:label "heat_cool_type" ;
    dcterms:title "heating and cooling system type" ;
    schema1:name "heat_cool_type" ;
    rdfs:range MIXS:HeatCoolTypeEnum ;
    skos:definition "Methods of conditioning or heating a room or building" .

MIXS:0000767 a owl:ObjectProperty ;
    rdfs:label "substructure_type" ;
    dcterms:title "substructure type" ;
    schema1:name "substructure_type" ;
    rdfs:range MIXS:SubstructureTypeEnum ;
    skos:definition "The substructure or under building is that largely hidden section of the building which is built off the foundations to the ground floor level" .

MIXS:0000769 a owl:ObjectProperty ;
    rdfs:label "light_type" ;
    dcterms:title "light type" ;
    schema1:name "light_type" ;
    rdfs:range MIXS:LightTypeEnum ;
    skos:definition "Application of light to achieve some practical or aesthetic effect. Lighting includes the use of both artificial light sources such as lamps and light fixtures, as well as natural illumination by capturing daylight. Can also include absence of light" .

MIXS:0000894 a owl:DatatypeProperty ;
    rdfs:label "drug_usage" ;
    dcterms:title "drug usage" ;
    schema1:name "drug_usage" ;
    skos:definition "Any drug used by subject and the frequency of usage; can include multiple drugs used" ;
    MIXS:Expected_value "drug name;frequency" .

MIXS:0000905 a owl:DatatypeProperty ;
    rdfs:label "special_diet" ;
    dcterms:title "special diet" ;
    schema1:name "special_diet" ;
    skos:definition "Specification of special diet; can include multiple special diets" ;
    MIXS:Expected_value "enumeration" .

MIXS:0001097 a owl:DatatypeProperty ;
    rdfs:label "atmospheric_data" ;
    dcterms:title "atmospheric data" ;
    schema1:name "atmospheric_data" ;
    skos:definition "Measurement of atmospheric data; can include multiple data" ;
    MIXS:Expected_value "atmospheric data name;measurement value" .

MIXS:0001114 a owl:DatatypeProperty ;
    rdfs:label "animal_intrusion" ;
    dcterms:title "animal intrusion near sample source" ;
    schema1:name "animal_intrusion" ;
    rdfs:range xsd:string ;
    skos:definition "Identification of animals intruding on the sample or sample site including invertebrates (such as pests or pollinators) and vertebrates (such as wildlife or domesticated animals). This field accepts terms under organism (http://purl.obolibrary.org/obo/NCIT_C14250). This field also accepts identification numbers from NCBI under https://www.ncbi.nlm.nih.gov/taxonomy. Multiple terms can be separated by pipes" .

MIXS:0001122 a owl:DatatypeProperty ;
    rdfs:label "water_source_adjac" ;
    dcterms:title "environmental feature adjacent water source" ;
    schema1:name "water_source_adjac" ;
    rdfs:range xsd:string ;
    skos:definition "Description of the environmental features that are adjacent to the farm water source. This field accepts terms under ecosystem (http://purl.obolibrary.org/obo/ENVO_01001110) and human construction (http://purl.obolibrary.org/obo/ENVO_00000070). Multiple terms can be separated by pipes" ;
    MIXS:Expected_value "ENVO_01001110 or ENVO_00000070" .

MIXS:0001141 a owl:ObjectProperty ;
    rdfs:label "extr_weather_event" ;
    dcterms:title "extreme weather event" ;
    schema1:name "extr_weather_event" ;
    rdfs:range MIXS:ExtrWeatherEventEnum ;
    skos:definition "Unusual weather events that may have affected microbial populations. Multiple terms can be separated by pipes, listed in reverse chronological order" .

MIXS:0001142 a owl:DatatypeProperty ;
    rdfs:label "date_extr_weath" ;
    dcterms:title "extreme weather date" ;
    schema1:name "date_extr_weath" ;
    rdfs:range xsd:dateTime ;
    skos:definition "Date of unusual weather events that may have affected microbial populations. Multiple terms can be separated by pipes, listed in reverse chronological order" .

MIXS:0001146 a owl:DatatypeProperty ;
    rdfs:label "air_flow_impede" ;
    dcterms:title "local air flow impediments" ;
    schema1:name "air_flow_impede" ;
    skos:definition "Presence of objects in the area that would influence or impede air flow through the air filter" ;
    MIXS:Expected_value "enumeration;obstruction type; distance from sampling device" .

MIXS:0001150 a owl:ObjectProperty ;
    rdfs:label "plant_reprod_crop" ;
    dcterms:title "plant reproductive part" ;
    schema1:name "plant_reprod_crop" ;
    rdfs:range MIXS:PlantReprodCropEnum ;
    skos:definition "Plant reproductive part used in the field during planting to start the crop" .

MIXS:0001185 a owl:DatatypeProperty ;
    rdfs:label "ferm_chem_add" ;
    dcterms:title "fermentation chemical additives" ;
    schema1:name "ferm_chem_add" ;
    skos:definition "Any chemicals that are added to the fermentation process to achieve the desired final product" ;
    MIXS:Expected_value "chemical ingredient" .

MIXS:0001186 a owl:DatatypeProperty ;
    rdfs:label "ferm_chem_add_perc" ;
    dcterms:title "fermentation chemical additives percentage" ;
    schema1:name "ferm_chem_add_perc" ;
    rdfs:range xsd:float ;
    skos:definition "The amount of chemical added to the fermentation process" ;
    MIXS:Preferred_unit "percentage" .

MIXS:0001234 a owl:DatatypeProperty ;
    rdfs:label "spec_intended_cons" ;
    dcterms:title "specific intended consumer" ;
    schema1:name "spec_intended_cons" ;
    rdfs:range xsd:string ;
    skos:definition "Food consumer type, human or animal, for which the food product is produced and marketed. This field accepts terms listed under food consumer group (http://purl.obolibrary.org/obo/FOODON_03510136)" .

MIXS:0001252 a owl:ObjectProperty ;
    rdfs:label "facility_type" ;
    dcterms:title "facility type" ;
    schema1:name "facility_type" ;
    rdfs:range MIXS:FacilityTypeEnum ;
    skos:definition "Establishment details about the type of facility where the sample was taken. This is independent of the specific product(s) within the facility" .

MIXS:0001256 a owl:ObjectProperty ;
    rdfs:label "samp_surf_moisture" ;
    dcterms:title "sample surface moisture" ;
    schema1:name "samp_surf_moisture" ;
    rdfs:range MIXS:SampSurfMoistureEnum ;
    skos:definition "Degree of water held on a sampled surface.  If present, user can state the degree of water held on surface (intermittent moisture, submerged). If no surface moisture is present indicate not present" .

MIXS:0001258 a owl:DatatypeProperty ;
    rdfs:label "biocide_used" ;
    dcterms:title "biocide" ;
    schema1:name "biocide_used" ;
    rdfs:range xsd:string ;
    skos:definition "Substance intended for preventing, neutralizing, destroying, repelling, or mitigating the effects of any pest or microorganism; that inhibits the growth, reproduction, and activity of organisms, including fungal cells; decreases the number of fungi or pests present; deters microbial growth and degradation of other ingredients in the formulation. Indicate the biocide used on the location where the sample was taken. Multiple terms can be separated by pipes" ;
    MIXS:Expected_value "commercial name of biocide, active ingredient in biocide or class of biocide" .

MIXS:0001259 a owl:DatatypeProperty ;
    rdfs:label "ster_meth_samp_room" ;
    dcterms:title "sampling room sterilization method" ;
    schema1:name "ster_meth_samp_room" ;
    skos:definition "The method used to sterilize the sampling room. This field accepts terms listed under electromagnetic radiation (http://purl.obolibrary.org/obo/ENVO_01001026). If the proper descriptor is not listed, please use text to describe the sampling room sterilization method. Multiple terms can be separated by pipes" ;
    MIXS:Expected_value "ENVO:01001026" .

MIXS:0001319 a owl:DatatypeProperty ;
    rdfs:label "host_of_host_disease" ;
    dcterms:title "host of the symbiotic host disease status" ;
    schema1:name "host_of_host_disease" ;
    skos:definition "List of diseases with which the host of the symbiotic host organism has been diagnosed; can include multiple diagnoses. The value of the field depends on host; for humans the terms should be chosen from the DO (Human Disease Ontology) at https://www.disease-ontology.org, non-human host diseases are free text" ;
    MIXS:Expected_value "disease name or Disease Ontology term" .

MIXS:0001325 a owl:DatatypeProperty ;
    rdfs:label "host_of_host_env_loc" ;
    dcterms:title "host of the symbiotic host local environmental context" ;
    schema1:name "host_of_host_env_loc" ;
    skos:definition "For a symbiotic host organism the local anatomical environment within its host may have causal influences. Report the anatomical entity(s) which are in the direct environment of the symbiotic host organism being sampled and which you believe have significant causal influences on your sample or specimen. For example, if the symbiotic host organism being sampled is an intestinal worm, its local environmental context will be the term for intestine from UBERON (http://uberon.github.io/)" ;
    MIXS:Expected_value "UBERON term(s), multiple values can be separated by pipes" .

MIXS:0001328 a owl:DatatypeProperty ;
    rdfs:label "host_of_host_fam_rel" ;
    dcterms:title "host of the symbiotic host family relationship" ;
    schema1:name "host_of_host_fam_rel" ;
    skos:definition "Familial relationship of the host of the symbiotic host organisms to other hosts of symbiotic host organism in the same study; can include multiple relationships" ;
    MIXS:Expected_value "relationship type;arbitrary identifier" .

MIXS:0001336 a owl:DatatypeProperty ;
    rdfs:label "photosynt_activ_meth" ;
    dcterms:title "photosynthetic activity method" ;
    schema1:name "photosynt_activ_meth" ;
    rdfs:range xsd:string ;
    skos:definition "Reference or method used in measurement of photosythetic activity" .

<https://w3id.org/mixs/AeroStrucEnum#glider> a owl:Class ;
    rdfs:label "glider" ;
    dcterms:title "glider" ;
    schema1:name "glider" ;
    rdfs:subClassOf linkml:PermissibleValue,
        MIXS:AeroStrucEnum .

<https://w3id.org/mixs/AeroStrucEnum#plane> a owl:Class ;
    rdfs:label "plane" ;
    dcterms:title "plane" ;
    schema1:name "plane" ;
    rdfs:subClassOf linkml:PermissibleValue,
        MIXS:AeroStrucEnum .

<https://w3id.org/mixs/AnimalBodyCondEnum#normal> a owl:Class ;
    rdfs:label "normal" ;
    dcterms:title "normal" ;
    schema1:name "normal" ;
