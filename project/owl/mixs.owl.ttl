        <https://w3id.org/mixs/ModeTransmissionEnum#vertical> .

MIXS:SampCollectPointEnum a owl:Class ;
    rdfs:label "SampCollectPointEnum" ;
    dcterms:title "SampCollectPointEnum" ;
    schema1:name "SampCollectPointEnum" ;
    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( <https://w3id.org/mixs/SampCollectPointEnum#drilling%20rig> <https://w3id.org/mixs/SampCollectPointEnum#other> <https://w3id.org/mixs/SampCollectPointEnum#separator> <https://w3id.org/mixs/SampCollectPointEnum#storage%20tank> <https://w3id.org/mixs/SampCollectPointEnum#test%20well> <https://w3id.org/mixs/SampCollectPointEnum#well> <https://w3id.org/mixs/SampCollectPointEnum#wellhead> ) ;
    linkml:permissible_values <https://w3id.org/mixs/SampCollectPointEnum#drilling%20rig>,
        <https://w3id.org/mixs/SampCollectPointEnum#other>,
        <https://w3id.org/mixs/SampCollectPointEnum#separator>,
        <https://w3id.org/mixs/SampCollectPointEnum#storage%20tank>,
        <https://w3id.org/mixs/SampCollectPointEnum#test%20well>,
        <https://w3id.org/mixs/SampCollectPointEnum#well>,
        <https://w3id.org/mixs/SampCollectPointEnum#wellhead> .

MIXS:SampDisStageEnum a owl:Class ;
    rdfs:label "SampDisStageEnum" ;
    dcterms:title "SampDisStageEnum" ;
