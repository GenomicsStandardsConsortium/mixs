MIXS:Checklist a owl:Class ;
    rdfs:label "Checklist" ;
    dcterms:title "Checklist" ;
    schema1:name "Checklist" ;
    rdfs:subClassOf linkml:ClassDefinition ;
    skos:definition "A collection of metadata terms (slots) to minimally describe the sampling and sequencing method of a specimen used to generate a nucleotide sequence." .

MIXS:ShadingDeviceTypeEnum a owl:Class ;
    rdfs:label "ShadingDeviceTypeEnum" ;
    dcterms:title "ShadingDeviceTypeEnum" ;
    schema1:name "ShadingDeviceTypeEnum" ;
    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( <https://w3id.org/mixs/ShadingDeviceTypeEnum#bahama%20shutters> <https://w3id.org/mixs/ShadingDeviceTypeEnum#exterior%20roll%20blind> <https://w3id.org/mixs/ShadingDeviceTypeEnum#gambrel%20awning> <https://w3id.org/mixs/ShadingDeviceTypeEnum#hood%20awning> <https://w3id.org/mixs/ShadingDeviceTypeEnum#porchroller%20awning> <https://w3id.org/mixs/ShadingDeviceTypeEnum#sarasota%20shutters> <https://w3id.org/mixs/ShadingDeviceTypeEnum#slatted%20aluminum> <https://w3id.org/mixs/ShadingDeviceTypeEnum#solid%20aluminum%20awning> <https://w3id.org/mixs/ShadingDeviceTypeEnum#sun%20screen> <https://w3id.org/mixs/ShadingDeviceTypeEnum#tree> <https://w3id.org/mixs/ShadingDeviceTypeEnum#trellis> <https://w3id.org/mixs/ShadingDeviceTypeEnum#venetian%20awning> ) ;
    linkml:permissible_values <https://w3id.org/mixs/ShadingDeviceTypeEnum#bahama%20shutters>,
        <https://w3id.org/mixs/ShadingDeviceTypeEnum#exterior%20roll%20blind>,
        <https://w3id.org/mixs/ShadingDeviceTypeEnum#gambrel%20awning>,
        <https://w3id.org/mixs/ShadingDeviceTypeEnum#hood%20awning>,
        <https://w3id.org/mixs/ShadingDeviceTypeEnum#porchroller%20awning>,
        <https://w3id.org/mixs/ShadingDeviceTypeEnum#sarasota%20shutters>,
        <https://w3id.org/mixs/ShadingDeviceTypeEnum#slatted%20aluminum>,
        <https://w3id.org/mixs/ShadingDeviceTypeEnum#solid%20aluminum%20awning>,
        <https://w3id.org/mixs/ShadingDeviceTypeEnum#sun%20screen>,
        <https://w3id.org/mixs/ShadingDeviceTypeEnum#tree>,
        <https://w3id.org/mixs/ShadingDeviceTypeEnum#trellis>,
        <https://w3id.org/mixs/ShadingDeviceTypeEnum#venetian%20awning> .

MIXS:SoilTextureClassEnum a owl:Class ;
    rdfs:label "SoilTextureClassEnum" ;
    dcterms:title "SoilTextureClassEnum" ;
    schema1:name "SoilTextureClassEnum" ;
    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( <https://w3id.org/mixs/SoilTextureClassEnum#clay> <https://w3id.org/mixs/SoilTextureClassEnum#clay%20loam> <https://w3id.org/mixs/SoilTextureClassEnum#loam> <https://w3id.org/mixs/SoilTextureClassEnum#loamy%20sand> <https://w3id.org/mixs/SoilTextureClassEnum#sand> <https://w3id.org/mixs/SoilTextureClassEnum#sandy%20clay> <https://w3id.org/mixs/SoilTextureClassEnum#sandy%20clay%20loam> <https://w3id.org/mixs/SoilTextureClassEnum#sandy%20loam> <https://w3id.org/mixs/SoilTextureClassEnum#silt> <https://w3id.org/mixs/SoilTextureClassEnum#silt%20loam> <https://w3id.org/mixs/SoilTextureClassEnum#silty%20clay> <https://w3id.org/mixs/SoilTextureClassEnum#silty%20clay%20loam> ) ;
    linkml:permissible_values <https://w3id.org/mixs/SoilTextureClassEnum#clay>,
        <https://w3id.org/mixs/SoilTextureClassEnum#clay%20loam>,
        <https://w3id.org/mixs/SoilTextureClassEnum#loam>,
        <https://w3id.org/mixs/SoilTextureClassEnum#loamy%20sand>,
        <https://w3id.org/mixs/SoilTextureClassEnum#sand>,
        <https://w3id.org/mixs/SoilTextureClassEnum#sandy%20clay>,
        <https://w3id.org/mixs/SoilTextureClassEnum#sandy%20clay%20loam>,
        <https://w3id.org/mixs/SoilTextureClassEnum#sandy%20loam>,
        <https://w3id.org/mixs/SoilTextureClassEnum#silt>,
        <https://w3id.org/mixs/SoilTextureClassEnum#silt%20loam>,
        <https://w3id.org/mixs/SoilTextureClassEnum#silty%20clay>,
        <https://w3id.org/mixs/SoilTextureClassEnum#silty%20clay%20loam> .

MIXS:0000023 a owl:DatatypeProperty ;
    rdfs:label "extrachrom_elements" ;
    dcterms:title "extrachromosomal elements" ;
    schema1:name "extrachrom_elements" ;
    rdfs:range xsd:integer ;
    skos:definition "Do plasmids exist of significant phenotypic consequence (e.g. ones that determine virulence or antibiotic resistance). Megaplasmids? Other plasmids (borrelia has 15+ plasmids)" .

MIXS:0000027 a owl:DatatypeProperty ;
    rdfs:label "pathogenicity" ;
    dcterms:title "known pathogenicity" ;
    schema1:name "pathogenicity" ;
    rdfs:range xsd:string ;
    skos:definition "To what is the entity pathogenic" ;
    MIXS:Expected_value "names of organisms that the entity is pathogenic to" .

MIXS:0000032 a owl:ObjectProperty ;
    rdfs:label "trophic_level" ;
    dcterms:title "trophic level" ;
    schema1:name "trophic_level" ;
    rdfs:range MIXS:TrophicLevelEnum ;
    skos:definition "Trophic levels are the feeding position in a food chain. Microbes can be a range of producers (e.g. chemolithotroph)" .

MIXS:0000204 a owl:DatatypeProperty ;
    rdfs:label "org_matter" ;
    dcterms:title "organic matter" ;
    schema1:name "org_matter" ;
    rdfs:range xsd:string ;
    skos:definition "Concentration of organic matter" ;
    MIXS:Preferred_unit "microgram per liter" .

MIXS:0000205 a owl:DatatypeProperty ;
    rdfs:label "org_nitro" ;
    dcterms:title "organic nitrogen" ;
    schema1:name "org_nitro" ;
    rdfs:range xsd:string ;
    skos:definition "Concentration of organic nitrogen" .

MIXS:0000250 a owl:DatatypeProperty ;
    rdfs:label "host_taxid" ;
    dcterms:title "host taxid" ;
    schema1:name "host_taxid" ;
    skos:definition "NCBI taxon id of the host, e.g. 9606" ;
    MIXS:Expected_value "NCBI taxon identifier" .

MIXS:0000256 a owl:DatatypeProperty ;
    rdfs:label "host_length" ;
    dcterms:title "host length" ;
    schema1:name "host_length" ;
    rdfs:range xsd:string ;
    skos:definition "The length of subject" ;
    MIXS:Preferred_unit "centimeter, millimeter, meter" .

MIXS:0000257 a owl:DatatypeProperty ;
    rdfs:label "host_dry_mass" ;
    dcterms:title "host dry mass" ;
    schema1:name "host_dry_mass" ;
    rdfs:range xsd:string ;
    skos:definition "Measurement of dry mass" ;
    MIXS:Preferred_unit "kilogram, gram" .

MIXS:0000317 a owl:DatatypeProperty ;
    rdfs:label "host_body_mass_index" ;
    dcterms:title "host body-mass index" ;
    schema1:name "host_body_mass_index" ;
    rdfs:range xsd:string ;
    skos:definition "Body mass index, calculated as weight/(height)squared" ;
    MIXS:Preferred_unit "kilogram per square meter" .

MIXS:0000325 a owl:DatatypeProperty ;
    rdfs:label "pool_dna_extracts" ;
    dcterms:title "pooling of DNA extracts (if done)" ;
    schema1:name "pool_dna_extracts" ;
    skos:definition "Indicate whether multiple DNA extractions were mixed. If the answer yes, the number of extracts that were pooled should be given" ;
    MIXS:Expected_value "pooling status;number of pooled extracts" ;
    MIXS:Preferred_unit "gram, milliliter, microliter" .

MIXS:0000333 a owl:DatatypeProperty ;
    rdfs:label "host_pulse" ;
    dcterms:title "host pulse" ;
    schema1:name "host_pulse" ;
    rdfs:range xsd:string ;
    skos:definition "Resting pulse, measured as beats per minute" ;
    MIXS:Preferred_unit "beats per minute" .

MIXS:0000431 a owl:DatatypeProperty ;
    rdfs:label "magnesium" ;
    dcterms:title "magnesium" ;
    schema1:name "magnesium" ;
    rdfs:range xsd:string ;
    skos:definition "Concentration of magnesium in the sample" ;
    MIXS:Preferred_unit "mole per liter, milligram per liter, parts per million, micromole per kilogram" .

MIXS:0000433 a owl:DatatypeProperty ;
    rdfs:label "diss_org_carb" ;
    dcterms:title "dissolved organic carbon" ;
    schema1:name "diss_org_carb" ;
    rdfs:range xsd:string ;
    skos:definition "Concentration of dissolved organic carbon in the sample, liquid portion of the sample, or aqueous phase of the fluid" ;
    MIXS:Preferred_unit "micromole per liter, milligram per liter" .

MIXS:0000435 a owl:DatatypeProperty ;
    rdfs:label "density" ;
    dcterms:title "density" ;
    schema1:name "density" ;
    rdfs:range xsd:string ;
    skos:definition "Density of the sample, which is its mass per unit volume (aka volumetric mass density)" ;
    MIXS:Preferred_unit "gram per cubic meter, gram per cubic centimeter" .

MIXS:0000505 a owl:DatatypeProperty ;
    rdfs:label "phosphate" ;
    dcterms:title "phosphate" ;
    schema1:name "phosphate" ;
    rdfs:range xsd:string ;
    skos:definition "Concentration of phosphate" ;
    MIXS:Preferred_unit "micromole per liter" .

MIXS:0000530 a owl:DatatypeProperty ;
    rdfs:label "tot_nitro_content" ;
    dcterms:title "total nitrogen content" ;
    schema1:name "tot_nitro_content" ;
    rdfs:range xsd:string ;
    skos:definition "Total nitrogen content of the sample" .

MIXS:0000533 a owl:DatatypeProperty ;
    rdfs:label "tot_org_carb" ;
    dcterms:title "total organic carbon" ;
    schema1:name "tot_org_carb" ;
    rdfs:range xsd:string ;
    skos:definition "Total organic carbon content" ;
    MIXS:Preferred_unit "gram Carbon per kilogram sample material" .

MIXS:0000896 a owl:DatatypeProperty ;
    rdfs:label "host_occupation" ;
    dcterms:title "host occupation" ;
    schema1:name "host_occupation" ;
    rdfs:range xsd:string ;
    skos:definition "Most frequent job performed by subject" ;
    skos:note "Couldn't convert host_occupation with value veterinary to integer",
        "almost all host_occupation values in the NCBI biosample_set are strings, not integers" .

MIXS:0000897 a owl:DatatypeProperty ;
    rdfs:label "medic_hist_perform" ;
    dcterms:title "medical history performed" ;
    schema1:name "medic_hist_perform" ;
    rdfs:range xsd:boolean ;
    skos:definition "Whether full medical history was collected" .

MIXS:0001139 a owl:DatatypeProperty ;
    rdfs:label "food_source" ;
    dcterms:title "food source" ;
    schema1:name "food_source" ;
    skos:definition "Type of plant or animal from which the food product or its major ingredient is derived or a chemical food source [FDA CFSAN 1995]" ;
    MIXS:Expected_value "FOODON term" .

MIXS:0001145 a owl:DatatypeProperty ;
    rdfs:label "library_prep_kit" ;
    dcterms:title "library preparation kit" ;
    schema1:name "library_prep_kit" ;
    rdfs:range xsd:string ;
    skos:definition "Packaged kits (containing adapters, indexes, enzymes, buffers etc.), tailored for specific sequencing workflows, which allow the simplified preparation of sequencing-ready libraries for small genomes, amplicons, and plasmids" ;
    MIXS:Expected_value "name of library preparation kit" .

MIXS:0001156 a owl:DatatypeProperty ;
    rdfs:label "sequencing_location" ;
    dcterms:title "sequencing location" ;
    schema1:name "sequencing_location" ;
    rdfs:range xsd:string ;
    skos:definition "The location the sequencing run was performed. Indicate the name of the lab or core facility where samples were sequenced" .

MIXS:0001177 a owl:DatatypeProperty ;
    rdfs:label "enrichment_protocol" ;
    dcterms:title "enrichment protocol" ;
    schema1:name "enrichment_protocol" ;
    rdfs:range xsd:string ;
    skos:definition "The microbiological workflow or protocol followed to test for the presence or enumeration of the target microbial analyte(s). Please provide a PubMed or DOI reference for published protocols" .

MIXS:0001181 a owl:DatatypeProperty ;
    rdfs:label "cult_isol_date" ;
    dcterms:title "culture isolation date" ;
    schema1:name "cult_isol_date" ;
    rdfs:range xsd:dateTime ;
    skos:definition "The datetime marking the end of a process in which a sample yields a positive result for the target microbial analyte(s) in the form of an isolated colony or colonies" .

MIXS:0001184 a owl:DatatypeProperty ;
    rdfs:label "food_product_type" ;
    dcterms:title "food product type" ;
    schema1:name "food_product_type" ;
    skos:definition "A food product type is a class of food products that is differentiated by its food composition (e.g., single- or multi-ingredient), processing and/or consumption characteristics. This does not include brand name products but it may include generic food dish categories. This field accepts terms under food product type (http://purl.obolibrary.org/obo/FOODON:03400361). For terms related to food product for an animal, consult food product for animal (http://purl.obolibrary.org/obo/FOODON_03309997). If the proper descriptor is not listed please use text to describe the food type. Multiple terms can be separated by one or more pipes" ;
    MIXS:Expected_value "FOODON:00001002 or FOODON:03309997" .

