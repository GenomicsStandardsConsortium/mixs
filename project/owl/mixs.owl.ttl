MIXS:InsdcMissingValueEnum\#missing\%3A\%20control\%20sample a owl:Class ;
	rdfs:label "missing: control sample" ;
	rdfs:subClassOf linkml:PermissibleValue , MIXS:InsdcMissingValueEnum ;
	skos:definition "Information is not applicable as the sample represents a negative control sample collected in a lab." .
MIXS:InsdcMissingValueEnum\#missing\%3A\%20data\%20agreement\%20established\%20pre-2023 a owl:Class ;
	rdfs:label "missing: data agreement established pre-2023" ;
	rdfs:subClassOf linkml:PermissibleValue , MIXS:InsdcMissingValueEnum ;
	skos:definition "Data agreements were established before the 2023 INSDC standard and metadata can not be provided. A value may be given at a later stage.\n" .
MIXS:InsdcMissingValueEnum\#missing\%3A\%20endangered\%20species a owl:Class ;
	rdfs:label "missing: endangered species" ;
	rdfs:subClassOf linkml:PermissibleValue , MIXS:InsdcMissingValueEnum ;
	skos:definition "Information can not be reported as the target organism is endangered e.g. on the IUCN red-list." .
MIXS:InsdcMissingValueEnum\#missing\%3A\%20human-identifiable a owl:Class ;
	rdfs:label "missing: human-identifiable" ;
	rdfs:subClassOf linkml:PermissibleValue , MIXS:InsdcMissingValueEnum ;
	skos:definition "Information can not be reported as the metadata would make the sample human-identifiable." .
MIXS:InsdcMissingValueEnum\#missing\%3A\%20lab\%20stock a owl:Class ;
	rdfs:label "missing: lab stock" ;
	rdfs:subClassOf linkml:PermissibleValue , MIXS:InsdcMissingValueEnum ;
	skos:definition "Information was not collected as the sample represents a cultured cell line or model organism under long-term lab control.\n" .
MIXS:InsdcMissingValueEnum\#missing\%3A\%20sample\%20group a owl:Class ;
	rdfs:label "missing: sample group" ;
	rdfs:subClassOf linkml:PermissibleValue , MIXS:InsdcMissingValueEnum ;
	skos:definition "Information is not applicable as the sample represents a group of samples that do not have a single origin. E.g. for co-assembly or transcriptome assembly.\n" .
MIXS:InsdcMissingValueEnum\#missing\%3A\%20synthetic\%20construct a owl:Class ;
	rdfs:label "missing: synthetic construct" ;
	rdfs:subClassOf linkml:PermissibleValue , MIXS:InsdcMissingValueEnum ;
	skos:definition "Information does not exist as the sample represents an ab-initio synthetic construct." .
MIXS:InsdcMissingValueEnum\#missing\%3A\%20third\%20party\%20data a owl:Class ;
	rdfs:label "missing: third party data" ;
	rdfs:subClassOf linkml:PermissibleValue , MIXS:InsdcMissingValueEnum ;
	skos:definition "Information does not exist as the metadata was not collected or reported in records predating the 2023 agreement. For use in Third PArty data submissions.\n" .
MIXS:InsdcMissingValueEnum\#missing a owl:Class ;
	rdfs:label "missing" ;
	rdfs:subClassOf linkml:PermissibleValue , MIXS:InsdcMissingValueEnum ;
	skos:altLabel "no data" , "not available" , "unavailable" , "unknown" , "unspecified" .
MIXS:InsdcMissingValueEnum\#not\%20applicable a owl:Class ;
	rdfs:label "not applicable" ;
	rdfs:subClassOf linkml:PermissibleValue , MIXS:InsdcMissingValueEnum ;
	skos:altLabel "n/a" , "na" ;
	skos:definition "Information is inappropriate to report, can indicate that the standard itself fails to model or represent the information appropriately\n" .
MIXS:InsdcMissingValueEnum\#not\%20collected a owl:Class ;
	rdfs:label "not collected" ;
	rdfs:subClassOf linkml:PermissibleValue , MIXS:InsdcMissingValueEnum ;
	skos:altLabel "not determined" , "not recorded" ;
	skos:definition "Information of an expected format was not given because it has not been collected" .
MIXS:InsdcMissingValueEnum\#not\%20provided a owl:Class ;
	rdfs:label "not provided" ;
	rdfs:subClassOf linkml:PermissibleValue , MIXS:InsdcMissingValueEnum ;
	skos:altLabel "not reported" ;
	skos:definition "Information of an expected format was not given, a value may be given at the later stage" .
MIXS:InsdcMissingValueEnum\#restricted\%20access a owl:Class ;
	rdfs:label "restricted access" ;
	rdfs:subClassOf linkml:PermissibleValue , MIXS:InsdcMissingValueEnum ;
	skos:altLabel "restricted" ;
	skos:definition "Information exists but can not be released openly because of privacy concerns" .
MIXS:InsdcMissingValueEnum a owl:Class ;
	rdfs:label "InsdcMissingValueEnum" ;
	rdfs:seeAlso <https://www.insdc.org/technical-specifications/missing-value-reporting/> ;
	rdfs:subClassOf linkml:EnumDefinition ;
	owl:unionOf _:c14n2318 ;
	skos:definition "Permissible values recommended by INSDC for reporting missing metadata values." ;
	skos:inScheme <https://w3id.org/mixs> ;
	skos:note "Please use the above standardised missing value vocabulary only if a true value of an expected format for a mandatory field is missing. If a true value is missing for a recommended or an optional field, then these fields should not be used for reporting at all. When reporting a missing mandatory field, the eight granular 'reporting level' terms need to be preceded with the term \"missing:\" to declare both the absence of a true value as well as the reason." , "The International Nucleotide Database Collaboration (INSDC) have a standardised missing/null value reporting language to be used where a value of an expected format for sample metadata reporting can not be provided." , "The controlled vocabulary takes into account different type of constraints. Submitters are strongly encouraged to always provide true values. However, if missing/null value reporting is required, submitters are asked to use a term with the finest granularity for their situation. See the table below for accepted missing value reporting terms." ;
	linkml:permissible_values MIXS:InsdcMissingValueEnum\#missing\%3A\%20control\%20sample , MIXS:InsdcMissingValueEnum\#missing\%3A\%20data\%20agreement\%20established\%20pre-2023 , MIXS:InsdcMissingValueEnum\#missing\%3A\%20endangered\%20species , MIXS:InsdcMissingValueEnum\#missing\%3A\%20human-identifiable , MIXS:InsdcMissingValueEnum\#missing\%3A\%20lab\%20stock , MIXS:InsdcMissingValueEnum\#missing\%3A\%20sample\%20group , MIXS:InsdcMissingValueEnum\#missing\%3A\%20synthetic\%20construct , MIXS:InsdcMissingValueEnum\#missing\%3A\%20third\%20party\%20data , MIXS:InsdcMissingValueEnum\#missing , MIXS:InsdcMissingValueEnum\#not\%20applicable , MIXS:InsdcMissingValueEnum\#not\%20collected , MIXS:InsdcMissingValueEnum\#not\%20provided , MIXS:InsdcMissingValueEnum\#restricted\%20access .
