MIXS:0000326 a owl:DatatypeProperty ;
    rdfs:label "twin_sibling" ;
    dcterms:title "twin sibling presence" ;
    schema1:name "twin_sibling" ;
    rdfs:range xsd:boolean ;
    skos:definition "Specification of twin sibling presence" .

MIXS:0000340 a owl:DatatypeProperty ;
    rdfs:label "link_addit_analys" ;
