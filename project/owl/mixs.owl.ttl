	a owl:DatatypeProperty ;
	rdfs:label "pesticide_regm" ;
	rdfs:range xsd:string ;
	skos:definition "Information about treatment involving use of insecticides; should include the name of pesticide, amount administered, treatment regimen including how many times the treatment was repeated, how long each treatment lasted, and the start and end time of the entire treatment; can include multiple pesticide regimens" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "gram, mole per liter, milligram per liter" .
MIXS:0000575 dcterms:title "radiation regimen" ;
