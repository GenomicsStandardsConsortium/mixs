MIXS:0000645 dcterms:title "mean seasonal precipitation" ;
	schema1:keywords "mean" , "season" ;
	a owl:DatatypeProperty ;
	rdfs:label "season_precpt" ;
	rdfs:range xsd:string ;
	skos:definition "The average of all seasonal precipitation values known, or an estimated equivalent value derived by such methods as regional indexes or Isohyetal maps" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "millimeter" .
MIXS:0000646 dcterms:title "slope gradient" ;
	schema1:keywords "slope" ;
	a owl:DatatypeProperty ;
	rdfs:label "slope_gradient" ;
	rdfs:range xsd:string ;
	skos:definition "Commonly called 'slope'. The angle between ground surface and a horizontal line (in percent). This is the direction that overland water would flow. This measure is usually taken with a hand level meter or clinometer" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "percentage" .
MIXS:0000647 dcterms:title "slope aspect" ;
	schema1:keywords "slope" ;
	a owl:DatatypeProperty ;
	rdfs:label "slope_aspect" ;
	rdfs:range xsd:string ;
	skos:definition "The direction a slope faces. While looking down a slope use a compass to record the direction you are facing (direction or degrees); e.g., nw or 315 degrees. This measure provides an indication of sun and wind exposure that will influence soil temperature and evapotranspiration" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "degree" .
MIXS:0000650 dcterms:title "microbial biomass" ;
	schema1:keywords "biomass" , "microbial" ;
	a owl:DatatypeProperty ;
	rdfs:label "microbial_biomass" ;
	rdfs:range xsd:string ;
	skos:definition "The part of the organic matter in the soil that constitutes living microorganisms smaller than 5-10 micrometer. If you keep this, you would need to have correction factors used for conversion to the final units" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "ton, kilogram, gram per kilogram soil" .
MIXS:0000652 dcterms:title "extreme_unusual_properties/heavy metals" ;
	schema1:keywords "extreme" , "properties" , "unusual" ;
	a owl:DatatypeProperty ;
	rdfs:label "heavy_metals" ;
