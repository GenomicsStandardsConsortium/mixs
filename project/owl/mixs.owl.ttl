@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix NCIT: <http://purl.obolibrary.org/obo/NCIT_> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix SO: <http://purl.obolibrary.org/obo/SO_> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix linkml: <https://w3id.org/linkml/> .
@prefix MIXS: <https://w3id.org/mixs/> .
@prefix pav: <http://purl.org/pav/> .
@prefix schema1: <http://schema.org/> .
<http://purl.obolibrary.org/obo/ENVO_03600018> a owl:Class ;
	rdfs:label "O horizon" ;
	rdfs:subClassOf linkml:PermissibleValue , MIXS:SoilHorizonEnum ;
	skos:definition "The organic horizon. Typically at the top of the soil structure and is made up of mostly organic matter." .
NCIT:C94730 a owl:Class ;
	rdfs:label "winter [NCIT:C94730]" ;
	rdfs:subClassOf linkml:PermissibleValue , MIXS:SeasonEnum .
NCIT:C94731 a owl:Class ;
	rdfs:label "spring [NCIT:C94731]" ;
	rdfs:subClassOf linkml:PermissibleValue , MIXS:SeasonEnum .
NCIT:C94732 a owl:Class ;
	rdfs:label "summer [NCIT:C94732]" ;
	rdfs:subClassOf linkml:PermissibleValue , MIXS:SeasonEnum .
NCIT:C94733 a owl:Class ;
	rdfs:label "autumn [NCIT:C94733]" ;
	rdfs:subClassOf linkml:PermissibleValue , MIXS:SeasonEnum .
SO:0000352 a owl:Class ;
	rdfs:label "DNA" ;
	rdfs:subClassOf linkml:PermissibleValue , MIXS:ViralGenomeTypeEnum .
SO:0000356 a owl:Class ;
	rdfs:label "RNA" ;
	rdfs:subClassOf linkml:PermissibleValue , MIXS:ViralGenomeTypeEnum .
SO:0001169 a owl:Class ;
	rdfs:label "dsRNA" ;
	rdfs:subClassOf linkml:PermissibleValue , MIXS:ViralGenomeTypeEnum .
SO:0001198 a owl:Class ;
	rdfs:label "dsDNA" ;
	rdfs:subClassOf linkml:PermissibleValue , MIXS:ViralGenomeTypeEnum .
SO:0001199 a owl:Class ;
	rdfs:label "ssRNA" ;
	rdfs:subClassOf linkml:PermissibleValue , MIXS:ViralGenomeTypeEnum .
SO:0001200 a owl:Class ;
	rdfs:label "ssRNA (-)" ;
	rdfs:subClassOf linkml:PermissibleValue , MIXS:ViralGenomeTypeEnum .
SO:0001201 a owl:Class ;
	rdfs:label "ssRNA (+)" ;
	rdfs:subClassOf linkml:PermissibleValue , MIXS:ViralGenomeTypeEnum .
linkml:ClassDefinition a owl:Class ;
	rdfs:label "ClassDefinition" ;
	skos:definition "an element whose instances are complex objects that may have slot-value assignments" .
linkml:EnumDefinition a owl:Class ;
	rdfs:label "EnumDefinition" ;
	skos:definition "an element whose instances must be drawn from a specified set of permissible values" .
linkml:PermissibleValue a owl:Class ;
	rdfs:label "PermissibleValue" ;
	skos:definition "a permissible value, accompanied by intended text and an optional mapping to a concept URI" .
<https://w3id.org/mixs.owl.ttl> dcterms:source <https://github.com/GenomicsStandardsConsortium/mixs/raw/issue-610-temp-mixs-xlsx-home/mixs/excel/mixs_v6.xlsx> ;
	pav:version "v6.2.0" ;
	a owl:Ontology ;
	rdfs:label "mixs" ;
	skos:definition "This file contains a YAML-formatted specification of the Minimum Information about any (x) Sequence (MIxS) standard, generated using LinkML (https://linkml.io/linkml/). This file is released by the Genomic Standards Consortium (GSC; https://www.gensc.org/) for use by anyone handling data or information about biological sequences. This file is also used as an authoritative 'source of truth' to generate downstream GSC artifacts, available here: https://github.com/GenomicsStandardsConsortium/mixs/tree/main/project" ;
	skos:note "slot titles that are associated with more than one slot name/SCN: host sex" .
MIXS:0000001 dcterms:title "amount or size of sample collected" ;
	schema1:keywords "sample" , "size" ;
	a owl:DatatypeProperty ;
	rdfs:label "samp_size" ;
	rdfs:range xsd:string ;
	skos:definition "The total amount or size (volume (ml), mass (g) or area (m2) ) of sample collected" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000002 dcterms:title "sample collection device" ;
	schema1:keywords "device" , "sample" ;
	a owl:DatatypeProperty ;
	rdfs:label "samp_collect_device" ;
	skos:definition "The device used to collect an environmental sample. This field accepts terms listed under environmental sampling device (http://purl.obolibrary.org/obo/ENVO). This field also accepts terms listed under specimen collection device (http://purl.obolibrary.org/obo/GENEPIO_0002094)" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "device name" .
MIXS:0000003 dcterms:title "isolation and growth condition" ;
	schema1:keywords "condition" , "growth" , "isolation" ;
	a owl:DatatypeProperty ;
	rdfs:label "isol_growth_condt" ;
	rdfs:range xsd:string ;
	skos:definition "Publication reference in the form of pubmed ID (pmid), digital object identifier (doi) or url for isolation and growth condition specifications of the organism/material" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000005 dcterms:title "contamination screening input" ;
	a owl:ObjectProperty ;
	rdfs:label "contam_screen_input" ;
	rdfs:range MIXS:ContamScreenInputEnum ;
	skos:definition "The type of sequence data used as input" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000006 dcterms:title "WGA amplification kit" ;
	schema1:keywords "kit" ;
	a owl:DatatypeProperty ;
	rdfs:label "wga_amp_kit" ;
	rdfs:range xsd:string ;
	skos:definition "Kit used to amplify genomic DNA in preparation for sequencing" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "kit name" .
MIXS:0000008 dcterms:title "experimental factor" ;
	schema1:keywords "experimental" , "factor" ;
	a owl:DatatypeProperty ;
	rdfs:label "experimental_factor" ;
	rdfs:range _:c14n5991 ;
	skos:definition "Variable aspects of an experiment design that can be used to describe an experiment, or set of experiments, in an increasingly detailed manner. This field accepts ontology terms from Experimental Factor Ontology (EFO) and/or Ontology for Biomedical Investigations (OBI)" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "text or EFO and/or OBI" .
MIXS:0000009 dcterms:title "geographic location (latitude and longitude)" ;
	schema1:keywords "geographic" , "location" ;
	a owl:DatatypeProperty ;
	rdfs:label "lat_lon" ;
	skos:definition "The geographical origin of the sample as defined by latitude and longitude. The values should be reported in decimal degrees, limited to 8 decimal points, and in WGS84 system" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000010 dcterms:title "geographic location (country and/or sea,region)" ;
	schema1:keywords "geographic" , "location" ;
	a owl:DatatypeProperty ;
	rdfs:label "geo_loc_name" ;
	rdfs:range xsd:string ;
	skos:definition "The geographical origin of the sample as defined by the country or sea name followed by specific region name. Country or sea names should be chosen from the INSDC country list (http://insdc.org/country.html), or the GAZ ontology (http://purl.bioontology.org/ontology/GAZ)" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000011 dcterms:title "collection date" ;
	schema1:keywords "date" ;
	a owl:DatatypeProperty ;
	rdfs:label "collection_date" ;
	rdfs:range xsd:dateTime ;
	skos:definition "The time of sampling, either as an instance (single point in time) or interval. In case no exact time is available, the date/time can be right truncated i.e. all of these are valid times: 2008-01-23T19:23:10+00:00; 2008-01-23T19:23:10; 2008-01-23; 2008-01; 2008; Except: 2008-01; 2008 all are ISO8601 compliant" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000012 dcterms:title "broad-scale environmental context" ;
	schema1:keywords "context" , "environmental" ;
	a owl:DatatypeProperty ;
	rdfs:label "env_broad_scale" ;
	rdfs:range xsd:string ;
	skos:definition "Report the major environmental system the sample or specimen came from. The system(s) identified should have a coarse spatial grain, to provide the general environmental context of where the sampling was done (e.g. in the desert or a rainforest). We recommend using subclasses of EnvO s biome class:  http://purl.obolibrary.org/obo/ENVO_00000428. EnvO documentation about how to use the field: https://github.com/EnvironmentOntology/envo/wiki/Using-ENVO-with-MIxS" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000013 dcterms:title "local environmental context" ;
	schema1:keywords "context" , "environmental" ;
	a owl:DatatypeProperty ;
	rdfs:label "env_local_scale" ;
	skos:definition "Report the entity or entities which are in the sample or specimen s local vicinity and which you believe have significant causal influences on your sample or specimen. We recommend using EnvO terms which are of smaller spatial grain than your entry for env_broad_scale. Terms, such as anatomical sites, from other OBO Library ontologies which interoperate with EnvO (e.g. UBERON) are accepted in this field. EnvO documentation about how to use the field: https://github.com/EnvironmentOntology/envo/wiki/Using-ENVO-with-MIxS" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "Environmental entities having causal influences upon the entity at time of sampling" .
MIXS:0000014 dcterms:title "environmental medium" ;
	schema1:keywords "environmental" ;
	a owl:DatatypeProperty ;
	rdfs:label "env_medium" ;
	rdfs:range xsd:string ;
	skos:definition "Report the environmental material(s) immediately surrounding the sample or specimen at the time of sampling. We recommend using subclasses of 'environmental material' (http://purl.obolibrary.org/obo/ENVO_00010483). EnvO documentation about how to use the field: https://github.com/EnvironmentOntology/envo/wiki/Using-ENVO-with-MIxS . Terms from other OBO ontologies are permissible as long as they reference mass/volume nouns (e.g. air, water, blood) and not discrete, countable entities (e.g. a tree, a leaf, a table top)" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000015 dcterms:title "relationship to oxygen" ;
	schema1:keywords "oxygen" , "relationship" ;
	a owl:ObjectProperty ;
	rdfs:label "rel_to_oxygen" ;
	rdfs:range MIXS:RelToOxygenEnum ;
	skos:definition "Is this organism an aerobe, anaerobe? Please note that aerobic and anaerobic are valid descriptors for microbial environments" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000016 dcterms:title "sample material processing" ;
	schema1:keywords "material" , "process" , "sample" ;
	a owl:DatatypeProperty ;
	rdfs:label "samp_mat_process" ;
	rdfs:range xsd:string ;
	skos:definition "A brief description of any processing applied to the sample during or after retrieving the sample from environment, or a link to the relevant protocol(s) performed" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000017 dcterms:title "size fraction selected" ;
	schema1:keywords "fraction" , "size" ;
	a owl:DatatypeProperty ;
	rdfs:label "size_frac" ;
	skos:definition "Filtering pore size used in sample preparation" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "filter size value range" .
MIXS:0000018 dcterms:title "depth" ;
	schema1:keywords "depth" ;
	a owl:DatatypeProperty ;
	rdfs:label "depth" ;
	rdfs:range xsd:string ;
	skos:definition "The vertical distance below local surface. For sediment or soil samples depth is measured from sediment or soil surface, respectively. Depth can be reported as an interval for subsurface samples" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "meter" .
MIXS:0000020 dcterms:title "subspecific genetic lineage" ;
	schema1:keywords "lineage" ;
	a owl:DatatypeProperty ;
	rdfs:label "subspecf_gen_lin" ;
	skos:definition "Information about the genetic distinctness of the sequenced organism below the subspecies level, e.g., serovar, serotype, biotype, ecotype, or any relevant genetic typing schemes like Group I plasmid. Subspecies should not be recorded in this term, but in the NCBI taxonomy. Supply both the lineage name and the lineage rank separated by a colon, e.g., biovar:abc123" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "Genetic lineage below lowest rank of NCBI taxonomy, which is subspecies, e.g. serovar, biotype, ecotype, variety, cultivar" .
MIXS:0000021 dcterms:title "ploidy" ;
	a owl:DatatypeProperty ;
	rdfs:label "ploidy" ;
	rdfs:range xsd:string ;
	skos:definition "The ploidy level of the genome (e.g. allopolyploid, haploid, diploid, triploid, tetraploid). It has implications for the downstream study of duplicated gene and regions of the genomes (and perhaps for difficulties in assembly). For terms, please select terms listed under class ploidy (PATO:001374) of Phenotypic Quality Ontology (PATO), and for a browser of PATO (v 2018-03-27) please refer to http://purl.bioontology.org/ontology/PATO" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000022 dcterms:title "number of replicons" ;
	schema1:keywords "number" ;
	a owl:DatatypeProperty ;
	rdfs:label "num_replicons" ;
	rdfs:range xsd:integer ;
	skos:definition "Reports the number of replicons in a nuclear genome of eukaryotes, in the genome of a bacterium or archaea or the number of segments in a segmented virus. Always applied to the haploid chromosome count of a eukaryote" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "for eukaryotes and bacteria: chromosomes (haploid count); for viruses: segments" .
MIXS:0000023 dcterms:title "extrachromosomal elements" ;
	a owl:DatatypeProperty ;
	rdfs:label "extrachrom_elements" ;
	rdfs:range xsd:integer ;
	skos:definition "Do plasmids exist of significant phenotypic consequence (e.g. ones that determine virulence or antibiotic resistance). Megaplasmids? Other plasmids (borrelia has 15+ plasmids)" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000024 dcterms:title "estimated genome size" ;
	schema1:keywords "size" ;
	a owl:DatatypeProperty ;
	rdfs:label "estimated_genome_size" ;
	skos:definition "The estimated size of the genome prior to sequencing. Of particular importance in the sequencing of (eukaryotic) genome which could remain in draft form for a long or unspecified period" ;
	skos:inScheme <https://w3id.org/mixs> ;
	skos:note "Slot updated 2026-02-10 `estimated_size` and title 'estimated size'" ;
	MIXS:Expected_value "number of base pairs" .
MIXS:0000025 dcterms:title "reference for biomaterial" ;
	a owl:DatatypeProperty ;
	rdfs:label "ref_biomaterial" ;
	rdfs:range xsd:string ;
	skos:definition "Primary publication if isolated before genome publication; otherwise, primary genome report" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000026 dcterms:title "source material identifiers" ;
	schema1:keywords "identifier" , "material" , "source" ;
	a owl:DatatypeProperty ;
	rdfs:label "source_mat_id" ;
	rdfs:range xsd:string ;
	skos:definition "A unique identifier assigned to a material sample (as defined by http://rs.tdwg.org/dwc/terms/materialSampleID, and as opposed to a particular digital record of a material sample) used for extracting nucleic acids, and subsequent sequencing. The identifier can refer either to the original material collected or to any derived sub-samples. The INSDC qualifiers /specimen_voucher, /bio_material, or /culture_collection may or may not share the same value as the source_mat_id field. For instance, the /specimen_voucher qualifier and source_mat_id may both contain 'UAM:Herps:14' , referring to both the specimen voucher and sampled tissue with the same identifier. However, the /culture_collection qualifier may refer to a value from an initial culture (e.g. ATCC:11775) while source_mat_id would refer to an identifier from some derived culture from which the nucleic acids were extracted (e.g. xatc123 or ark:/2154/R2)" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "for cultures of microorganisms: identifiers for two culture collections; for other material a unique arbitrary identifer" .
MIXS:0000027 dcterms:title "known pathogenicity" ;
	a owl:DatatypeProperty ;
	rdfs:label "pathogenicity" ;
	rdfs:range xsd:string ;
	skos:definition "To what is the entity pathogenic" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "names of organisms that the entity is pathogenic to" .
MIXS:0000028 dcterms:title "observed biotic relationship" ;
	schema1:keywords "observed" , "relationship" ;
	a owl:ObjectProperty ;
	rdfs:label "biotic_relationship" ;
	rdfs:range MIXS:BioticRelationshipEnum ;
	skos:definition "Description of relationship(s) between the subject organism and other organism(s) it is associated with. E.g., parasite on species X; mutualist with species Y. The target organism is the subject of the relationship, and the other organism(s) is the object" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000029 dcterms:title "host scientific name" ;
	schema1:keywords "host" , "host." ;
	a owl:DatatypeProperty ;
	rdfs:label "specific_host" ;
	skos:definition "Report the host's taxonomic name and/or NCBI taxonomy ID" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "host scientific name, taxonomy ID" .
MIXS:0000030 dcterms:title "host specificity or range" ;
	schema1:keywords "host" , "host." , "range" ;
	a owl:DatatypeProperty ;
	rdfs:label "host_spec_range" ;
	skos:definition "The range and diversity of host species that an organism is capable of infecting, defined by NCBI taxonomy identifier" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "NCBI taxid" .
MIXS:0000031 dcterms:title "host disease status" ;
	schema1:keywords "disease" , "host" , "host." , "status" ;
	a owl:DatatypeProperty ;
	rdfs:label "host_disease_stat" ;
	skos:definition "List of diseases with which the host has been diagnosed; can include multiple diagnoses. The value of the field depends on host; for humans the terms should be chosen from the DO (Human Disease Ontology) at https://www.disease-ontology.org, non-human host diseases are free text" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "disease name or Disease Ontology term" .
MIXS:0000032 dcterms:title "trophic level" ;
	schema1:keywords "level" ;
	a owl:ObjectProperty ;
	rdfs:label "trophic_level" ;
	rdfs:range MIXS:TrophicLevelEnum ;
	skos:definition "Trophic levels are the feeding position in a food chain. Microbes can be a range of producers (e.g. chemolithotroph)" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000033 dcterms:title "propagation" ;
	a owl:DatatypeProperty ;
	rdfs:label "propagation" ;
	rdfs:range xsd:string ;
	skos:definition "The type of reproduction from the parent stock. Values for this field is specific to different taxa. For phage or virus: lytic/lysogenic/temperate/obligately lytic. For plasmids: incompatibility group. For eukaryotes: sexual/asexual" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "for virus: lytic, lysogenic, temperate, obligately lytic; for plasmid: incompatibility group; for eukaryote: asexual, sexual; other more specific values (e.g., incompatibility group) are allowed" .
MIXS:0000034 dcterms:title "encoded traits" ;
	a owl:DatatypeProperty ;
	rdfs:label "encoded_traits" ;
	rdfs:range xsd:string ;
	skos:definition "Should include key traits like antibiotic resistance or xenobiotic degradation phenotypes for plasmids, converting genes for phage" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "for plasmid: antibiotic resistance; for phage: converting genes" .
MIXS:0000035 dcterms:title "source of UViGs" ;
	schema1:keywords "source" ;
	a owl:DatatypeProperty ;
	rdfs:label "source_uvig" ;
	skos:definition "Type of dataset from which the UViG was obtained" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "enumeration" .
MIXS:0000036 dcterms:title "virus enrichment approach" ;
	schema1:keywords "enrichment" ;
	a owl:ObjectProperty ;
	rdfs:label "virus_enrich_appr" ;
	rdfs:range MIXS:VirusEnrichApprEnum ;
	skos:definition "List of approaches used to enrich the sample for viruses, if any" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000037 dcterms:title "nucleic acid extraction" ;
	a owl:DatatypeProperty ;
	rdfs:label "nucl_acid_ext" ;
	rdfs:range xsd:string ;
	skos:definition "A link to a literature reference, electronic resource or a standard operating procedure (SOP), that describes the material separation to recover the nucleic acid fraction from a sample" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000038 dcterms:title "nucleic acid amplification" ;
	a owl:DatatypeProperty ;
	rdfs:label "nucl_acid_amp" ;
	rdfs:range xsd:string ;
	skos:definition "A link to a literature reference, electronic resource or a standard operating procedure (SOP), that describes the enzymatic amplification (PCR, TMA, NASBA) of specific nucleic acids" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000039 dcterms:title "library size" ;
	schema1:keywords "library" , "size" ;
	a owl:DatatypeProperty ;
	rdfs:label "lib_size" ;
	rdfs:range xsd:integer ;
	skos:definition "Total number of clones in the library prepared for the project" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000040 dcterms:title "library reads sequenced" ;
	schema1:keywords "library" ;
	a owl:DatatypeProperty ;
	rdfs:label "lib_reads_seqd" ;
	rdfs:range xsd:integer ;
	skos:definition "Total number of clones sequenced from the library" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000041 dcterms:title "library layout" ;
	schema1:keywords "library" ;
	a owl:ObjectProperty ;
	rdfs:label "lib_layout" ;
	rdfs:range MIXS:LibLayoutEnum ;
	skos:definition "Specify whether to expect single, paired, or other configuration of reads" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000042 dcterms:title "library vector" ;
	schema1:keywords "library" ;
	a owl:DatatypeProperty ;
	rdfs:label "lib_vector" ;
	rdfs:range xsd:string ;
	skos:definition "Cloning vector type(s) used in construction of libraries" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "vector" .
MIXS:0000043 dcterms:title "library screening strategy" ;
	schema1:keywords "library" ;
	a owl:DatatypeProperty ;
	rdfs:label "lib_screen" ;
	rdfs:range xsd:string ;
	skos:definition "Specific enrichment or screening methods applied before and/or after creating libraries" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "screening strategy name" .
MIXS:0000044 dcterms:title "target gene" ;
	schema1:keywords "target" ;
	a owl:DatatypeProperty ;
	rdfs:label "target_gene" ;
	rdfs:range xsd:string ;
	skos:definition "Targeted gene or locus name for marker gene studies" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000045 dcterms:title "target subfragment" ;
	schema1:keywords "target" ;
	a owl:DatatypeProperty ;
	rdfs:label "target_subfragment" ;
	rdfs:range xsd:string ;
	skos:definition "Name of subfragment of a gene or locus. Important to e.g. identify special regions on marker genes like V6 on 16S rRNA" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000046 dcterms:title "pcr primers" ;
	schema1:keywords "pcr" ;
	a owl:DatatypeProperty ;
	rdfs:label "pcr_primers" ;
	skos:definition "PCR primers that were used to amplify the sequence of the targeted gene, locus or subfragment. This field should contain all the primers used for a single PCR reaction if multiple forward or reverse primers are present in a single PCR reaction. The primer sequence should be reported in uppercase letters" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000047 dcterms:title "multiplex identifiers" ;
	schema1:keywords "identifier" ;
	a owl:DatatypeProperty ;
	rdfs:label "mid" ;
	rdfs:range xsd:string ;
	skos:definition "Molecular barcodes, called Multiplex Identifiers (MIDs), that are used to specifically tag unique samples in a sequencing run. Sequence should be reported in uppercase letters" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000048 dcterms:title "adapters" ;
	a owl:DatatypeProperty ;
	rdfs:label "adapters" ;
	skos:definition "Adapters provide priming sequences for both amplification and sequencing of the sample-library fragments. Both adapters should be reported; in uppercase letters" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000049 dcterms:title "pcr conditions" ;
	schema1:keywords "condition" , "pcr" ;
	a owl:DatatypeProperty ;
	rdfs:label "pcr_cond" ;
	skos:definition "Description of reaction conditions and components of polymerase chain reaction performed during library preparation." ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "initial denaturation:degrees_minutes;annealing:degrees_minutes;elongation:degrees_minutes;final elongation:degrees_minutes;total cycles" .
MIXS:0000050 dcterms:title "sequencing method" ;
	schema1:keywords "method" ;
	a owl:DatatypeProperty ;
	rdfs:label "seq_meth" ;
	rdfs:range xsd:string ;
	skos:definition "Sequencing machine used. Where possible the term should be taken from the OBI list of DNA sequencers (http://purl.obolibrary.org/obo/OBI_0400103)" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000051 dcterms:title "sequence quality check" ;
	schema1:keywords "quality" ;
	a owl:ObjectProperty ;
	rdfs:label "seq_quality_check" ;
	rdfs:range MIXS:SeqQualityCheckEnum ;
	skos:definition "Indicate if the sequence has been called by automatic systems (none) or undergone a manual editing procedure (e.g. by inspecting the raw data or chromatograms). Applied only for sequences that are not submitted to SRA,ENA or DRA" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "none or manually edited" .
MIXS:0000052 dcterms:title "chimera check software" ;
	schema1:keywords "software" ;
	a owl:DatatypeProperty ;
	rdfs:label "chimera_check" ;
	rdfs:range xsd:string ;
	skos:definition "Tool(s) used for chimera checking, including version number and parameters, to discover and remove chimeric sequences. A chimeric sequence is comprised of two or more phylogenetically distinct parent sequences" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000053 dcterms:title "taxonomic identity marker" ;
	schema1:keywords "identifier" , "marker" , "taxon" ;
	a owl:ObjectProperty ;
	rdfs:label "tax_ident" ;
	rdfs:range MIXS:TaxIdentEnum ;
	skos:definition "The phylogenetic marker(s) used to assign an organism name to the SAG or MAG" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000054 dcterms:title "single cell or viral particle lysis kit protocol" ;
	schema1:keywords "kit" , "particle" , "protocol" , "single" ;
	a owl:DatatypeProperty ;
	rdfs:label "sc_lysis_method" ;
	rdfs:range xsd:string ;
	skos:definition "Name of the kit or standard protocol used for cell(s) or particle(s) lysis" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "kit, protocol name" .
MIXS:0000055 dcterms:title "WGA amplification approach" ;
	a owl:ObjectProperty ;
	rdfs:label "wga_amp_appr" ;
	rdfs:range MIXS:WgaAmpApprEnum ;
	skos:definition "Method used to amplify genomic DNA in preparation for sequencing" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000056 dcterms:title "assembly quality" ;
	schema1:keywords "quality" ;
	a owl:ObjectProperty ;
	rdfs:label "assembly_qual" ;
	rdfs:range MIXS:AssemblyQualEnum ;
	skos:definition "The assembly quality category is based on sets of criteria outlined for each assembly quality category. For MISAG/MIMAG; Finished: Single, validated, contiguous sequence per replicon without gaps or ambiguities with a consensus error rate equivalent to Q50 or better. High Quality Draft:Multiple fragments where gaps span repetitive regions. Presence of the large subunit (LSU) RNA, small subunit (SSU) and the presence of 5.8S rRNA or 5S rRNA depending on whether it is a eukaryotic or prokaryotic genome, respectively. Medium Quality Draft:Many fragments with little to no review of assembly other than reporting of standard assembly statistics. Low Quality Draft:Many fragments with little to no review of assembly other than reporting of standard assembly statistics. Assembly statistics include, but are not limited to total assembly size, number of contigs, contig N50/L50, and maximum contig length. For MIUVIG; Finished: Single, validated, contiguous sequence per replicon without gaps or ambiguities, with extensive manual review and editing to annotate putative gene functions and transcriptional units. High-quality draft genome: One or multiple fragments, totaling   90% of the expected genome or replicon sequence or predicted complete. Genome fragment(s): One or multiple fragments, totalling < 90% of the expected genome or replicon sequence, or for which no genome size could be estimated" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000057 dcterms:title "assembly name" ;
	a owl:DatatypeProperty ;
	rdfs:label "assembly_name" ;
	skos:definition "Name/version of the assembly provided by the submitter that is used in the genome browsers and in the community" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "name and version of assembly" .
MIXS:0000058 dcterms:title "assembly software" ;
	schema1:keywords "software" ;
	a owl:DatatypeProperty ;
	rdfs:label "assembly_software" ;
	rdfs:range xsd:string ;
	skos:definition "Tool(s) used for assembly, including version number and parameters" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000059 dcterms:title "annotation" ;
	a owl:DatatypeProperty ;
	rdfs:label "annot" ;
	rdfs:range xsd:string ;
	skos:definition "Tool used for annotation, or for cases where annotation was provided by a community jamboree or model organism database rather than by a specific submitter" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "name of tool or pipeline used, or annotation source description" .
MIXS:0000060 dcterms:title "number of contigs" ;
	schema1:keywords "number" ;
	a owl:DatatypeProperty ;
	rdfs:label "number_contig" ;
	rdfs:range xsd:integer ;
	skos:definition "Total number of contigs in the cleaned/submitted assembly that makes up a given genome, SAG, MAG, or UViG" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000061 dcterms:title "feature prediction" ;
	schema1:keywords "feature" , "predict" ;
	a owl:DatatypeProperty ;
	rdfs:label "feat_pred" ;
	rdfs:range xsd:string ;
	skos:definition "Method used to predict UViGs features such as ORFs, integration site, etc" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000062 dcterms:title "reference database(s)" ;
	schema1:keywords "database" ;
	a owl:DatatypeProperty ;
	rdfs:label "ref_db" ;
	skos:definition "List of database(s) used for ORF annotation, along with version number and reference to website or publication" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "names, versions, and references of databases" .
MIXS:0000063 dcterms:title "similarity search method" ;
	schema1:keywords "method" ;
	a owl:DatatypeProperty ;
	rdfs:label "sim_search_meth" ;
	rdfs:range xsd:string ;
	skos:definition "Tool used to compare ORFs with database, along with version and cutoffs used" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000064 dcterms:title "taxonomic classification" ;
	schema1:keywords "classification" , "taxon" ;
	a owl:DatatypeProperty ;
	rdfs:label "tax_class" ;
	rdfs:range xsd:string ;
	skos:definition "Method used for taxonomic classification, along with reference database used, classification rank, and thresholds used to classify new genomes" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000065 dcterms:title "16S recovered" ;
	schema1:keywords "recover" ;
	a owl:DatatypeProperty ;
	rdfs:label "x16s_recover" ;
	rdfs:range xsd:boolean ;
	skos:definition "Can a 16S gene be recovered from the submitted SAG or MAG?" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000066 dcterms:title "16S recovery software" ;
	schema1:keywords "recover" , "software" ;
	a owl:DatatypeProperty ;
	rdfs:label "x16s_recover_software" ;
	rdfs:range xsd:string ;
	skos:definition "Tools used for 16S rRNA gene extraction" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000067 dcterms:title "number of standard tRNAs extracted" ;
	schema1:keywords "number" ;
	a owl:DatatypeProperty ;
	rdfs:label "trnas" ;
	skos:definition "The total number of tRNAs identified from the SAG or MAG" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "value from 0-21" .
MIXS:0000068 dcterms:title "tRNA extraction software" ;
	schema1:keywords "software" ;
	a owl:DatatypeProperty ;
	rdfs:label "trna_ext_software" ;
	rdfs:range xsd:string ;
	skos:definition "Tools used for tRNA identification" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000069 dcterms:title "completeness score" ;
	schema1:keywords "score" ;
	a owl:DatatypeProperty ;
	rdfs:label "compl_score" ;
	skos:definition "Completeness score is typically based on either the fraction of markers found as compared to a database or the percent of a genome found as compared to a closely related reference genome. High Quality Draft: >90%, Medium Quality Draft: >50%, and Low Quality Draft: < 50% should have the indicated completeness scores" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "quality;percent completeness" .
MIXS:0000070 dcterms:title "completeness software" ;
	schema1:keywords "software" ;
	a owl:DatatypeProperty ;
	rdfs:label "compl_software" ;
	skos:definition "Tools used for completion estimate, i.e. checkm, anvi'o, busco" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "names and versions of software(s) used" .
MIXS:0000071 dcterms:title "completeness approach" ;
	a owl:ObjectProperty ;
	rdfs:label "compl_appr" ;
	rdfs:range MIXS:ComplApprEnum ;
	skos:definition "The approach used to determine the completeness of a given genomic assembly, which would typically make use of a set of conserved marker genes or a closely related reference genome. For UViG completeness, include reference genome or group used, and contig feature suggesting a complete genome" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "text" .
MIXS:0000072 dcterms:title "contamination score" ;
	schema1:keywords "score" ;
	a owl:DatatypeProperty ;
	rdfs:label "contam_score" ;
	rdfs:range xsd:float ;
	skos:definition "The contamination score is based on the fraction of single-copy genes that are observed more than once in a query genome. The following scores are acceptable for; High Quality Draft: < 5%, Medium Quality Draft: < 10%, Low Quality Draft: < 10%. Contamination must be below 5% for a SAG or MAG to be deposited into any of the public databases" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000073 dcterms:title "contamination screening parameters" ;
	schema1:keywords "parameter" ;
	a owl:DatatypeProperty ;
	rdfs:label "contam_screen_param" ;
	skos:definition "Specific parameters used in the decontamination sofware, such as reference database, coverage, and kmers. Combinations of these parameters may also be used, i.e. kmer and coverage, or reference database and kmer" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "enumeration;value or name" .
MIXS:0000074 dcterms:title "decontamination software" ;
	schema1:keywords "software" ;
	a owl:DatatypeProperty ;
	rdfs:label "decontam_software" ;
	skos:definition "Tool(s) used in contamination screening" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "enumeration" .
MIXS:0000075 dcterms:title "sorting technology" ;
	a owl:ObjectProperty ;
	rdfs:label "sort_tech" ;
	rdfs:range MIXS:SortTechEnum ;
	skos:definition "Method used to sort/isolate cells or particles of interest" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000076 dcterms:title "single cell or viral particle lysis approach" ;
	schema1:keywords "particle" , "single" ;
	a owl:ObjectProperty ;
	rdfs:label "sc_lysis_approach" ;
	rdfs:range MIXS:ScLysisApproachEnum ;
	skos:definition "Method used to free DNA from interior of the cell(s) or particle(s)" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000077 dcterms:title "binning parameters" ;
	schema1:keywords "parameter" ;
	a owl:ObjectProperty ;
	rdfs:label "bin_param" ;
	rdfs:range MIXS:BinParamEnum ;
	skos:definition "The parameters that have been applied during the extraction of genomes from metagenomic datasets" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000078 dcterms:title "binning software" ;
	schema1:keywords "software" ;
	a owl:DatatypeProperty ;
	rdfs:label "bin_software" ;
	skos:definition "Tool(s) used for the extraction of genomes from metagenomic datasets, where possible include a product ID (PID) of the tool(s) used" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "names and versions of software(s) used" .
MIXS:0000079 dcterms:title "reassembly post binning" ;
	schema1:keywords "post" ;
	a owl:DatatypeProperty ;
	rdfs:label "reassembly_bin" ;
	rdfs:range xsd:boolean ;
	skos:definition "Has an assembly been performed on a genome bin extracted from a metagenomic assembly?" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000080 dcterms:title "MAG coverage software" ;
	schema1:keywords "software" ;
	a owl:ObjectProperty ;
	rdfs:label "mag_cov_software" ;
	rdfs:range MIXS:MagCovSoftwareEnum ;
	skos:definition "Tool(s) used to determine the genome coverage if coverage is used as a binning parameter in the extraction of genomes from metagenomic datasets" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000081 dcterms:title "viral identification software" ;
	schema1:keywords "identifier" , "software" ;
	a owl:DatatypeProperty ;
	rdfs:label "vir_ident_software" ;
	skos:definition "Tool(s) used for the identification of UViG as a viral genome, software or protocol name including version number, parameters, and cutoffs used" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "software name, version and relevant parameters" .
MIXS:0000082 dcterms:title "predicted genome type" ;
	schema1:keywords "predict" , "type" ;
	a owl:ObjectProperty ;
	rdfs:label "pred_genome_type" ;
	rdfs:range MIXS:ViralGenomeTypeEnum ;
	skos:definition "Type of genome predicted for the UViG" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "enumeration" .
MIXS:0000083 dcterms:title "predicted genome structure" ;
	schema1:keywords "predict" ;
	a owl:ObjectProperty ;
	rdfs:label "pred_genome_struc" ;
	rdfs:range MIXS:PredGenomeStrucEnum ;
	skos:definition "Expected structure of the viral genome" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000084 dcterms:title "detection type" ;
	schema1:keywords "type" ;
	a owl:DatatypeProperty ;
	rdfs:label "detec_type" ;
	skos:definition "Type of UViG detection" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "enumeration" .
MIXS:0000085 dcterms:title "OTU classification approach" ;
	schema1:keywords "classification" , "otu" ;
	a owl:DatatypeProperty ;
	rdfs:label "otu_class_appr" ;
	skos:definition "Cutoffs and approach used when clustering species-level OTUs. Note that results from standard 95% ANI / 85% AF clustering should be provided alongside OTUs defined from another set of thresholds, even if the latter are the ones primarily used during the analysis" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "cutoffs and method used" .
MIXS:0000086 dcterms:title "OTU sequence comparison approach" ;
	schema1:keywords "otu" ;
	a owl:DatatypeProperty ;
	rdfs:label "otu_seq_comp_appr" ;
	skos:definition "Tool and thresholds used to compare sequences when computing \"species-level\" OTUs" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "software name, version and relevant parameters" .
MIXS:0000087 dcterms:title "OTU database" ;
	schema1:keywords "database" , "otu" ;
	a owl:DatatypeProperty ;
	rdfs:label "otu_db" ;
	skos:definition "Reference database (i.e. sequences not generated as part of the current study) used to cluster new genomes in \"species-level\" OTUs, if any" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "database and version" .
MIXS:0000088 dcterms:title "host prediction approach" ;
	schema1:keywords "host" , "host." , "predict" ;
	a owl:ObjectProperty ;
	rdfs:label "host_pred_appr" ;
	rdfs:range MIXS:HostPredApprEnum ;
	skos:definition "Tool or approach used for host prediction" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000089 dcterms:title "host prediction estimated accuracy" ;
	schema1:keywords "host" , "host." , "predict" ;
	a owl:DatatypeProperty ;
	rdfs:label "host_pred_est_acc" ;
	rdfs:range xsd:string ;
	skos:definition "For each tool or approach used for host prediction, estimated false discovery rates should be included, either computed de novo or from the literature" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000090 dcterms:title "relevant standard operating procedures" ;
	schema1:keywords "procedures" ;
	a owl:DatatypeProperty ;
	rdfs:label "sop" ;
	skos:definition "Standard operating procedures used in assembly and/or annotation of genomes, metagenomes or environmental sequences" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "reference to SOP" .
MIXS:0000091 dcterms:title "relevant electronic resources" ;
	schema1:keywords "resource" ;
	a owl:DatatypeProperty ;
	rdfs:label "associated_resource" ;
	skos:definition "A related resource that is referenced, cited, or otherwise associated to the sequence" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "reference to resource" .
MIXS:0000092 dcterms:title "project name" ;
	schema1:keywords "project" ;
	a owl:DatatypeProperty ;
	rdfs:label "project_name" ;
	rdfs:range xsd:string ;
	skos:definition "Name of the project within which the sequencing was organized" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000093 dcterms:title "elevation" ;
	schema1:keywords "elevation" ;
	a owl:DatatypeProperty ;
	rdfs:label "elev" ;
	rdfs:range xsd:string ;
	skos:definition "Elevation of the sampling site is its height above a fixed reference point, most commonly the mean sea level. Elevation is mainly used when referring to points on the earth's surface, while altitude is used for points above the surface, such as an aircraft in flight or a spacecraft in orbit" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "meter" .
MIXS:0000094 dcterms:title "altitude" ;
	a owl:DatatypeProperty ;
	rdfs:label "alt" ;
	rdfs:range xsd:string ;
	skos:definition "Heights of objects such as airplanes, space shuttles, rockets, atmospheric balloons and heights of places such as atmospheric layers and clouds. It is used to measure the height of an object which is above the earth's surface. In this context, the altitude measurement is the vertical distance between the earth's surface above sea level and the sampled position in the air" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "meter" .
MIXS:0000096 dcterms:title "barometric pressure" ;
	schema1:keywords "pressure" ;
	a owl:DatatypeProperty ;
	rdfs:label "barometric_press" ;
	rdfs:range xsd:string ;
	skos:definition "Force per unit area exerted against a surface by the weight of air above that surface" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "millibar" .
MIXS:0000097 dcterms:title "carbon dioxide" ;
	schema1:keywords "carbon" ;
	a owl:DatatypeProperty ;
	rdfs:label "carb_dioxide" ;
	rdfs:range xsd:string ;
	skos:definition "Carbon dioxide (gas) amount or concentration at the time of sampling" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "micromole per liter, parts per million" .
MIXS:0000098 dcterms:title "carbon monoxide" ;
	schema1:keywords "carbon" ;
	a owl:DatatypeProperty ;
	rdfs:label "carb_monoxide" ;
	rdfs:range xsd:string ;
	skos:definition "Carbon monoxide (gas) amount or concentration at the time of sampling" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "micromole per liter, parts per million" .
MIXS:0000099 dcterms:title "organism count qPCR information" ;
	schema1:keywords "count" , "information" , "organism" ;
	a owl:DatatypeProperty ;
	rdfs:label "org_count_qpcr_info" ;
	skos:definition "If qpcr was used for the cell count, the target gene name, the primer sequence and the cycling conditions should also be provided. (Example: 16S rrna; FWD:ACGTAGCTATGACGT REV:GTGCTAGTCGAGTAC; initial denaturation:90C_5min; denaturation:90C_2min; annealing:52C_30 sec; elongation:72C_30 sec; 90 C for 1 min; final elongation:72C_5min; 30 cycles)" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "gene name;FWD:forward primer sequence;REV:reverse primer sequence;initial denaturation:degrees_minutes;denaturation:degrees_minutes;annealing:degrees_minutes;elongation:degrees_minutes;final elongation:degrees_minutes; total cycles" ;
	MIXS:Preferred_unit "number of cells per gram (or ml or cm^2)" .
MIXS:0000100 dcterms:title "humidity" ;
	schema1:keywords "humidity" ;
	a owl:DatatypeProperty ;
	rdfs:label "humidity" ;
	rdfs:range xsd:string ;
	skos:definition "Amount of water vapour in the air, at the time of sampling" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000101 dcterms:title "methane" ;
	a owl:DatatypeProperty ;
	rdfs:label "methane" ;
	rdfs:range xsd:string ;
	skos:definition "Methane (gas) amount or concentration at the time of sampling" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "micromole per liter, parts per billion, parts per million" .
MIXS:0000102 dcterms:title "total nitrogen concentration" ;
	schema1:keywords "concentration" , "nitrogen" , "total" ;
	a owl:DatatypeProperty ;
	rdfs:label "tot_nitro" ;
	rdfs:range xsd:string ;
	skos:definition "Total nitrogen concentration of water samples, calculated by: total nitrogen = total dissolved nitrogen + particulate nitrogen. Can also be measured without filtering, reported as nitrogen" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "microgram per liter, micromole per liter, milligram per liter" .
MIXS:0000103 dcterms:title "organism count" ;
	schema1:keywords "count" , "organism" ;
	a owl:DatatypeProperty ;
	rdfs:label "organism_count" ;
	skos:definition "Total cell count of any organism (or group of organisms) per gram, volume or area of sample, should include name of organism followed by count. The method that was used for the enumeration (e.g. qPCR, atp, mpn, etc.) Should also be provided. (example: total prokaryotes; 3.5e7 cells per ml; qpcr)" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "organism name;measurement value;enumeration" .
MIXS:0000104 dcterms:title "oxygen" ;
	schema1:keywords "oxygen" ;
	a owl:DatatypeProperty ;
	rdfs:label "oxygen" ;
	rdfs:range xsd:string ;
	skos:definition "Oxygen (gas) amount or concentration at the time of sampling" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "milligram per liter, parts per million" .
MIXS:0000105 dcterms:title "total iron" ;
	schema1:keywords "total" ;
	a owl:DatatypeProperty ;
	rdfs:label "tot_iron" ;
	rdfs:range xsd:string ;
	skos:definition "Concentration of total iron in the sample" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "milligram per liter, milligram per kilogram" .
MIXS:0000106 dcterms:title "dissolved inorganic phosphorus" ;
	schema1:keywords "dissolved" , "inorganic" , "phosphorus" ;
	a owl:DatatypeProperty ;
	rdfs:label "diss_inorg_phosp" ;
	rdfs:range xsd:string ;
	skos:definition "Concentration of dissolved inorganic phosphorus in the sample" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000107 dcterms:title "pollutants" ;
	a owl:DatatypeProperty ;
	rdfs:label "pollutants" ;
	skos:definition "Pollutant types and, amount or concentrations measured at the time of sampling; can report multiple pollutants by entering numeric values preceded by name of pollutant" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "pollutant name;measurement value" ;
	MIXS:Preferred_unit "gram, mole per liter, milligram per liter, microgram per cubic meter" .
MIXS:0000108 dcterms:title "air particulate matter concentration" ;
	schema1:keywords "air" , "concentration" , "particle" , "particulate" ;
	a owl:DatatypeProperty ;
	rdfs:label "air_PM_concen" ;
	skos:definition "Concentration of substances that remain suspended in the air, and comprise mixtures of organic and inorganic substances (PM10 and PM2.5); can report multiple PM's by entering numeric values preceded by name of PM" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000110 dcterms:title "sample storage temperature" ;
	schema1:keywords "sample" , "storage" , "temperature" ;
	a owl:DatatypeProperty ;
	rdfs:label "samp_store_temp" ;
	rdfs:range xsd:string ;
	skos:definition "Temperature at which sample was stored, e.g. -80 degree Celsius" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "degree Celsius" .
MIXS:0000111 dcterms:title "sample volume or weight for DNA extraction" ;
	schema1:keywords "dna" , "sample" , "volume" , "weight" ;
	a owl:DatatypeProperty ;
	rdfs:label "samp_vol_we_dna_ext" ;
	rdfs:range xsd:string ;
	skos:definition "Volume (ml) or mass (g) of total collected sample processed for DNA extraction. Note: total sample collected should be entered under the term Sample Size (MIXS:0000001)" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "milliliter, gram, milligram, square centimeter" .
MIXS:0000112 dcterms:title "solar irradiance" ;
	a owl:DatatypeProperty ;
	rdfs:label "solar_irradiance" ;
	rdfs:range xsd:string ;
	skos:definition "The amount of solar energy that arrives at a specific area of a surface during a specific time interval" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "kilowatts per square meter per day, ergs per square centimeter per second" .
MIXS:0000113 dcterms:title "temperature" ;
	schema1:keywords "temperature" ;
	a owl:DatatypeProperty ;
	rdfs:label "temp" ;
	rdfs:range xsd:string ;
	skos:definition "Temperature of the sample at the time of sampling" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "degree Celsius" .
MIXS:0000114 dcterms:title "ventilation rate" ;
	schema1:keywords "rate" ;
	a owl:DatatypeProperty ;
	rdfs:label "ventilation_rate" ;
	rdfs:range xsd:string ;
	skos:definition "Ventilation rate of the system in the sampled premises" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "cubic meter per minute, liters per second" .
MIXS:0000115 dcterms:title "volatile organic compounds" ;
	schema1:keywords "organic" ;
	a owl:DatatypeProperty ;
	rdfs:label "volatile_org_comp" ;
	skos:definition "Concentration of carbon-based chemicals that easily evaporate at room temperature; can report multiple volatile organic compounds by entering numeric values preceded by name of compound" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "volatile organic compound name;measurement value" ;
	MIXS:Preferred_unit "microgram per cubic meter, parts per million, nanogram per liter" .
MIXS:0000116 dcterms:title "sample storage duration" ;
	schema1:keywords "duration" , "period" , "sample" , "storage" ;
	a owl:DatatypeProperty ;
	rdfs:label "samp_store_dur" ;
	rdfs:range xsd:string ;
	skos:definition "Duration for which the sample was stored. Indicate the duration for which the sample was stored written in ISO 8601 format" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000117 dcterms:title "total phosphorus" ;
	schema1:keywords "phosphorus" , "total" ;
	a owl:DatatypeProperty ;
	rdfs:label "tot_phosp" ;
	rdfs:range xsd:string ;
	skos:definition "Total phosphorus concentration in the sample, calculated by: total phosphorus = total dissolved phosphorus + particulate phosphorus" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "micromole per liter, milligram per liter, parts per million" .
MIXS:0000118 dcterms:title "wind speed" ;
	schema1:keywords "speed" , "wind" ;
	a owl:DatatypeProperty ;
	rdfs:label "wind_speed" ;
	rdfs:range xsd:string ;
	skos:definition "speed of wind measured at the time of sampling" ;
	skos:inScheme <https://w3id.org/mixs> .
MIXS:0000119 dcterms:title "dissolved oxygen" ;
	schema1:keywords "dissolved" , "oxygen" ;
	a owl:DatatypeProperty ;
	rdfs:label "diss_oxygen" ;
	rdfs:range xsd:string ;
	skos:definition "Concentration of dissolved oxygen" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "micromole per kilogram, milligram per liter" .
MIXS:0000120 dcterms:title "total acid number" ;
	schema1:keywords "number" , "total" ;
	a owl:DatatypeProperty ;
	rdfs:label "tan" ;
	rdfs:range xsd:string ;
	skos:definition "Total Acid Number (TAN) is a measurement of acidity that is determined by the amount of potassium hydroxide in milligrams that is needed to neutralize the acids in one gram of oil. It is an important quality measurement of crude oil. (source: https://en.wikipedia.org/wiki/Total_acid_number)" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "milligram per liter" .
MIXS:0000121 dcterms:title "relative air humidity" ;
	schema1:keywords "air" , "humidity" , "relative" ;
	a owl:DatatypeProperty ;
	rdfs:label "rel_air_humidity" ;
	rdfs:range xsd:float ;
	skos:definition "Partial vapor and air pressure, density of the vapor and air, or by the actual mass of the vapor and air" ;
	skos:inScheme <https://w3id.org/mixs> ;
	skos:note "percent or float?" ;
	MIXS:Preferred_unit "percentage" .
MIXS:0000122 dcterms:title "absolute air humidity" ;
	schema1:keywords "absolute" , "air" , "humidity" ;
	a owl:DatatypeProperty ;
	rdfs:label "abs_air_humidity" ;
	rdfs:range xsd:string ;
	skos:definition "Actual mass of water vapor present in the air water vapor mixture." ;
	skos:inScheme <https://w3id.org/mixs> ;
	skos:note "Can be calculated via mass of water vapor divided by the volume of the air and water vapor mixture." ;
	MIXS:Preferred_unit "gram per gram, kilogram per kilogram, kilogram, pound, gram per cubic meter, kilogram per cubic meter, percent" .
MIXS:0000123 dcterms:title "surface humidity" ;
	schema1:keywords "humidity" , "surface" ;
	a owl:DatatypeProperty ;
	rdfs:label "surf_humidity" ;
	rdfs:range xsd:float ;
	skos:definition "Surfaces: water activity as a function of air and material moisture" ;
	skos:inScheme <https://w3id.org/mixs> ;
	skos:note "percent or float?" ;
	MIXS:Preferred_unit "percentage" .
MIXS:0000124 dcterms:title "air temperature" ;
	schema1:keywords "air" , "temperature" ;
	a owl:DatatypeProperty ;
	rdfs:label "air_temp" ;
	rdfs:range xsd:string ;
	skos:definition "Temperature of the air at the time of sampling" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "degree Celsius" .
MIXS:0000125 dcterms:title "surface temperature" ;
	schema1:keywords "surface" , "temperature" ;
	a owl:DatatypeProperty ;
	rdfs:label "surf_temp" ;
	rdfs:range xsd:string ;
	skos:definition "Temperature of the surface at the time of sampling" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "degree Celsius" .
MIXS:0000126 dcterms:title "viscosity" ;
	a owl:DatatypeProperty ;
	rdfs:label "viscosity" ;
	skos:definition "A measure of oil's resistance to gradual deformation by shear stress or tensile stress (e.g. 3.5 cp; 100 °C)" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "measurement value;measurement value" ;
	MIXS:Preferred_unit "cP at degree Celsius" .
MIXS:0000127 dcterms:title "pour point" ;
	a owl:DatatypeProperty ;
	rdfs:label "pour_point" ;
	rdfs:range xsd:string ;
	skos:definition "Temperature at which a liquid becomes semi solid and loses its flow characteristics. In crude oil a high pour point is generally associated with a high paraffin content, typically found in crude deriving from a larger proportion of plant material. (source: https://en.wikipedia.org/wiki/pour_point)" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "degree Celsius" .
MIXS:0000128 dcterms:title "surface moisture" ;
	schema1:keywords "moisture" , "surface" ;
	a owl:DatatypeProperty ;
	rdfs:label "surf_moisture" ;
	rdfs:range xsd:string ;
	skos:definition "Water held on a surface" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "parts per million, gram per cubic meter, gram per square meter" .
MIXS:0000129 dcterms:title "dew point" ;
	a owl:DatatypeProperty ;
	rdfs:label "dew_point" ;
	rdfs:range xsd:string ;
	skos:definition "The temperature to which a given parcel of humid air must be cooled, at constant barometric pressure, for water vapor to condense into water" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "degree Celsius" .
MIXS:0000131 dcterms:title "saturates wt%" ;
	a owl:DatatypeProperty ;
	rdfs:label "saturates_pc" ;
	rdfs:range xsd:string ;
	skos:definition "Saturate, Aromatic, Resin and Asphaltene (SARA) is an analysis method that divides crude oil components according to their polarizability and polarity. There are three main methods to obtain SARA results. The most popular one is known as the Iatroscan TLC-FID and is referred to as IP-143 (source: https://en.wikipedia.org/wiki/Saturate,_aromatic,_resin_and_asphaltene)" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "percent" .
MIXS:0000133 dcterms:title "aromatics wt%" ;
	a owl:DatatypeProperty ;
	rdfs:label "aromatics_pc" ;
	rdfs:range xsd:string ;
	skos:definition "Saturate, Aromatic, Resin and Asphaltene (SARA) is an analysis method that divides crude oil components according to their polarizability and polarity. There are three main methods to obtain SARA results. The most popular one is known as the Iatroscan TLC-FID and is referred to as IP-143 (source: https://en.wikipedia.org/wiki/Saturate,_aromatic,_resin_and_asphaltene)" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "percent" .
MIXS:0000134 dcterms:title "resins wt%" ;
	a owl:DatatypeProperty ;
	rdfs:label "resins_pc" ;
	rdfs:range xsd:string ;
	skos:definition "Saturate, Aromatic, Resin and Asphaltene (SARA) is an analysis method that divides crude oil components according to their polarizability and polarity. There are three main methods to obtain SARA results. The most popular one is known as the Iatroscan TLC-FID and is referred to as IP-143 (source: https://en.wikipedia.org/wiki/Saturate,_aromatic,_resin_and_asphaltene)" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "percent" .
MIXS:0000135 dcterms:title "asphaltenes wt%" ;
	a owl:DatatypeProperty ;
	rdfs:label "asphaltenes_pc" ;
	rdfs:range xsd:string ;
	skos:definition "Saturate, Aromatic, Resin and Asphaltene (SARA) is an analysis method that divides crude oil components according to their polarizability and polarity. There are three main methods to obtain SARA results. The most popular one is known as the Iatroscan TLC-FID and is referred to as IP-143 (source: https://en.wikipedia.org/wiki/Saturate,_aromatic,_resin_and_asphaltene)" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "percent" .
MIXS:0000136 dcterms:title "corrosion rate at sample location" ;
	schema1:keywords "location" , "rate" , "sample" ;
	a owl:DatatypeProperty ;
	rdfs:label "samp_loc_corr_rate" ;
	rdfs:range xsd:string ;
	skos:definition "Metal corrosion rate is the speed of metal deterioration due to environmental conditions. As environmental conditions change corrosion rates change accordingly. Therefore, long term corrosion rates are generally more informative than short term rates and for that reason they are preferred during reporting. In the case of suspected MIC, corrosion rate measurements at the time of sampling might provide insights into the involvement of certain microbial community members in MIC as well as potential microbial interplays" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "millimeter per year" .
MIXS:0000137 dcterms:title "glucosidase activity" ;
	a owl:DatatypeProperty ;
	rdfs:label "glucosidase_act" ;
	rdfs:range xsd:string ;
	skos:definition "Measurement of glucosidase activity" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "mol per liter per hour" .
MIXS:0000139 dcterms:title "dissolved iron" ;
	schema1:keywords "dissolved" ;
	a owl:DatatypeProperty ;
	rdfs:label "diss_iron" ;
	rdfs:range xsd:string ;
	skos:definition "Concentration of dissolved iron in the sample" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "milligram per liter" .
MIXS:0000140 dcterms:title "amount of light" ;
	schema1:keywords "light" ;
	a owl:DatatypeProperty ;
	rdfs:label "amount_light" ;
	rdfs:range xsd:string ;
	skos:definition "The unit of illuminance and luminous emittance, measuring luminous flux per unit area" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "lux, lumens per square meter" .
MIXS:0000141 dcterms:title "average dew point" ;
	schema1:keywords "average" ;
	a owl:DatatypeProperty ;
	rdfs:label "avg_dew_point" ;
	rdfs:range xsd:string ;
	skos:definition "The average of dew point measures taken at the beginning of every hour over a 24 hour period on the sampling day" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "degree Celsius" .
MIXS:0000142 dcterms:title "average temperature" ;
	schema1:keywords "average" , "temperature" ;
	a owl:DatatypeProperty ;
	rdfs:label "avg_temp" ;
	rdfs:range xsd:string ;
	skos:definition "The average of temperatures taken at the beginning of every hour over a 24 hour period on the sampling day" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "degree Celsius" .
MIXS:0000143 dcterms:title "ceiling thermal mass" ;
	schema1:keywords "ceiling" , "mass" ;
	a owl:DatatypeProperty ;
	rdfs:label "ceil_thermal_mass" ;
	rdfs:range xsd:string ;
	skos:definition "The ability of the ceiling to provide inertia against temperature fluctuations. Generally this means concrete that is exposed. A metal deck that supports a concrete slab will act thermally as long as it is exposed to room air flow" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "joule per degree Celsius" .
MIXS:0000144 dcterms:title "exposed ductwork" ;
	a owl:DatatypeProperty ;
	rdfs:label "exp_duct" ;
	rdfs:range xsd:string ;
	skos:definition "The amount of exposed ductwork in the room" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "square meter" .
MIXS:0000145 dcterms:title "built structure age" ;
	schema1:keywords "age" ;
	a owl:DatatypeProperty ;
	rdfs:label "built_struc_age" ;
	rdfs:range xsd:string ;
	skos:definition "The age of the built structure since construction" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "year" .
MIXS:0000148 dcterms:title "ceiling area" ;
	schema1:keywords "area" , "ceiling" ;
	a owl:DatatypeProperty ;
	rdfs:label "ceil_area" ;
	rdfs:range xsd:string ;
	skos:definition "The area of the ceiling space within the room" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "square meter" .
MIXS:0000150 dcterms:title "suspended solids" ;
	schema1:keywords "solids" , "suspended" ;
	a owl:DatatypeProperty ;
	rdfs:label "suspend_solids" ;
	skos:definition "Concentration of substances including a wide variety of material, such as silt, decaying plant and animal matter; can include multiple substances" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "suspended solid name;measurement value" ;
	MIXS:Preferred_unit "gram, microgram, milligram per liter, mole per liter, gram per liter, part per million" .
