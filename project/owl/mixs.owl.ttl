    MIXS:Expected_value "pre-treatment type" .

MIXS:0000349 a owl:DatatypeProperty ;
    rdfs:label "primary_treatment" ;
    dcterms:title "primary treatment" ;
    schema1:name "primary_treatment" ;
    rdfs:range xsd:string ;
