MIXS:SampSurfMoistureEnum a owl:Class ;
    rdfs:label "SampSurfMoistureEnum" ;
    dcterms:title "SampSurfMoistureEnum" ;
    schema1:name "SampSurfMoistureEnum" ;
    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( <https://w3id.org/mixs/SampSurfMoistureEnum#intermittent%20moisture> <https://w3id.org/mixs/SampSurfMoistureEnum#not%20present> <https://w3id.org/mixs/SampSurfMoistureEnum#submerged> ) ;
    linkml:permissible_values <https://w3id.org/mixs/SampSurfMoistureEnum#intermittent%20moisture>,
        <https://w3id.org/mixs/SampSurfMoistureEnum#not%20present>,
        <https://w3id.org/mixs/SampSurfMoistureEnum#submerged> .

MIXS:SubstructureTypeEnum a owl:Class ;
    rdfs:label "SubstructureTypeEnum" ;
    dcterms:title "SubstructureTypeEnum" ;
    schema1:name "SubstructureTypeEnum" ;
    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( <https://w3id.org/mixs/SubstructureTypeEnum#basement> <https://w3id.org/mixs/SubstructureTypeEnum#crawlspace> <https://w3id.org/mixs/SubstructureTypeEnum#slab%20on%20grade> ) ;
    linkml:permissible_values <https://w3id.org/mixs/SubstructureTypeEnum#basement>,
        <https://w3id.org/mixs/SubstructureTypeEnum#crawlspace>,
        <https://w3id.org/mixs/SubstructureTypeEnum#slab%20on%20grade> .

MIXS:TrainLineEnum a owl:Class ;
    rdfs:label "TrainLineEnum" ;
    dcterms:title "TrainLineEnum" ;
    schema1:name "TrainLineEnum" ;
    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( <https://w3id.org/mixs/TrainLineEnum#green> <https://w3id.org/mixs/TrainLineEnum#orange> <https://w3id.org/mixs/TrainLineEnum#red> ) ;
    linkml:permissible_values <https://w3id.org/mixs/TrainLineEnum#green>,
        <https://w3id.org/mixs/TrainLineEnum#orange>,
        <https://w3id.org/mixs/TrainLineEnum#red> .

MIXS:TrainStopLocEnum a owl:Class ;
    rdfs:label "TrainStopLocEnum" ;
    dcterms:title "TrainStopLocEnum" ;
    schema1:name "TrainStopLocEnum" ;
    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( <https://w3id.org/mixs/TrainStopLocEnum#downtown> <https://w3id.org/mixs/TrainStopLocEnum#end> <https://w3id.org/mixs/TrainStopLocEnum#mid> ) ;
    linkml:permissible_values <https://w3id.org/mixs/TrainStopLocEnum#downtown>,
        <https://w3id.org/mixs/TrainStopLocEnum#end>,
        <https://w3id.org/mixs/TrainStopLocEnum#mid> .

MIXS:TypeOfSymbiosisEnum a owl:Class ;
    rdfs:label "TypeOfSymbiosisEnum" ;
    dcterms:title "TypeOfSymbiosisEnum" ;
    schema1:name "TypeOfSymbiosisEnum" ;
    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( <https://w3id.org/mixs/TypeOfSymbiosisEnum#commensalistic> <https://w3id.org/mixs/TypeOfSymbiosisEnum#mutualistic> <https://w3id.org/mixs/TypeOfSymbiosisEnum#parasitic> ) ;
    linkml:permissible_values <https://w3id.org/mixs/TypeOfSymbiosisEnum#commensalistic>,
        <https://w3id.org/mixs/TypeOfSymbiosisEnum#mutualistic>,
        <https://w3id.org/mixs/TypeOfSymbiosisEnum#parasitic> .

MIXS:WgaAmpApprEnum a owl:Class ;
    rdfs:label "WgaAmpApprEnum" ;
    dcterms:title "WgaAmpApprEnum" ;
    schema1:name "WgaAmpApprEnum" ;
    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( <https://w3id.org/mixs/WgaAmpApprEnum#mda%20based> <https://w3id.org/mixs/WgaAmpApprEnum#pcr%20based> ) ;
    linkml:permissible_values <https://w3id.org/mixs/WgaAmpApprEnum#mda%20based>,
        <https://w3id.org/mixs/WgaAmpApprEnum#pcr%20based> .

MIXS:WindowCoverEnum a owl:Class ;
    rdfs:label "WindowCoverEnum" ;
    dcterms:title "WindowCoverEnum" ;
    schema1:name "WindowCoverEnum" ;
    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( <https://w3id.org/mixs/WindowCoverEnum#blinds> <https://w3id.org/mixs/WindowCoverEnum#curtains> <https://w3id.org/mixs/WindowCoverEnum#none> ) ;
    linkml:permissible_values <https://w3id.org/mixs/WindowCoverEnum#blinds>,
        <https://w3id.org/mixs/WindowCoverEnum#curtains>,
        <https://w3id.org/mixs/WindowCoverEnum#none> .

MIXS:WindowHorizPosEnum a owl:Class ;
    rdfs:label "WindowHorizPosEnum" ;
    dcterms:title "WindowHorizPosEnum" ;
    schema1:name "WindowHorizPosEnum" ;
    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( <https://w3id.org/mixs/WindowHorizPosEnum#left> <https://w3id.org/mixs/WindowHorizPosEnum#middle> <https://w3id.org/mixs/WindowHorizPosEnum#right> ) ;
    linkml:permissible_values <https://w3id.org/mixs/WindowHorizPosEnum#left>,
        <https://w3id.org/mixs/WindowHorizPosEnum#middle>,
        <https://w3id.org/mixs/WindowHorizPosEnum#right> .

MIXS:WindowTypeEnum a owl:Class ;
    rdfs:label "WindowTypeEnum" ;
    dcterms:title "WindowTypeEnum" ;
    schema1:name "WindowTypeEnum" ;
    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( <https://w3id.org/mixs/WindowTypeEnum#fixed%20window> <https://w3id.org/mixs/WindowTypeEnum#horizontal%20sash%20window> <https://w3id.org/mixs/WindowTypeEnum#single-hung%20sash%20window> ) ;
    linkml:permissible_values <https://w3id.org/mixs/WindowTypeEnum#fixed%20window>,
        <https://w3id.org/mixs/WindowTypeEnum#horizontal%20sash%20window>,
        <https://w3id.org/mixs/WindowTypeEnum#single-hung%20sash%20window> .

MIXS:0000005 a owl:ObjectProperty ;
    rdfs:label "contam_screen_input" ;
    dcterms:title "contamination screening input" ;
    schema1:name "contam_screen_input" ;
    rdfs:range MIXS:ContamScreenInputEnum ;
    skos:definition "The type of sequence data used as input" .

MIXS:0000006 a owl:DatatypeProperty ;
    rdfs:label "wga_amp_kit" ;
    dcterms:title "WGA amplification kit" ;
    schema1:name "wga_amp_kit" ;
    rdfs:range xsd:string ;
    skos:definition "Kit used to amplify genomic DNA in preparation for sequencing" ;
    MIXS:Expected_value "kit name" .

MIXS:0000036 a owl:ObjectProperty ;
    rdfs:label "virus_enrich_appr" ;
    dcterms:title "virus enrichment approach" ;
    schema1:name "virus_enrich_appr" ;
    rdfs:range MIXS:VirusEnrichApprEnum ;
    skos:definition "List of approaches used to enrich the sample for viruses, if any" .

MIXS:0000054 a owl:DatatypeProperty ;
    rdfs:label "sc_lysis_method" ;
    dcterms:title "single cell or viral particle lysis kit protocol" ;
    schema1:name "sc_lysis_method" ;
    rdfs:range xsd:string ;
    skos:definition "Name of the kit or standard protocol used for cell(s) or particle(s) lysis" ;
    MIXS:Expected_value "kit, protocol name" .

MIXS:0000055 a owl:ObjectProperty ;
    rdfs:label "wga_amp_appr" ;
    dcterms:title "WGA amplification approach" ;
    schema1:name "wga_amp_appr" ;
    rdfs:range MIXS:WgaAmpApprEnum ;
    skos:definition "Method used to amplify genomic DNA in preparation for sequencing" .

MIXS:0000072 a owl:DatatypeProperty ;
    rdfs:label "contam_score" ;
    dcterms:title "contamination score" ;
    schema1:name "contam_score" ;
    rdfs:range xsd:float ;
    skos:definition "The contamination score is based on the fraction of single-copy genes that are observed more than once in a query genome. The following scores are acceptable for; High Quality Draft: < 5%, Medium Quality Draft: < 10%, Low Quality Draft: < 10%. Contamination must be below 5% for a SAG or MAG to be deposited into any of the public databases" .

MIXS:0000073 a owl:DatatypeProperty ;
    rdfs:label "contam_screen_param" ;
    dcterms:title "contamination screening parameters" ;
    schema1:name "contam_screen_param" ;
    skos:definition "Specific parameters used in the decontamination sofware, such as reference database, coverage, and kmers. Combinations of these parameters may also be used, i.e. kmer and coverage, or reference database and kmer" ;
    MIXS:Expected_value "enumeration;value or name" .

MIXS:0000074 a owl:DatatypeProperty ;
    rdfs:label "decontam_software" ;
    dcterms:title "decontamination software" ;
    schema1:name "decontam_software" ;
    skos:definition "Tool(s) used in contamination screening" ;
    MIXS:Expected_value "enumeration" .

MIXS:0000075 a owl:ObjectProperty ;
    rdfs:label "sort_tech" ;
    dcterms:title "sorting technology" ;
    schema1:name "sort_tech" ;
    rdfs:range MIXS:SortTechEnum ;
    skos:definition "Method used to sort/isolate cells or particles of interest" .

MIXS:0000076 a owl:ObjectProperty ;
    rdfs:label "sc_lysis_approach" ;
    dcterms:title "single cell or viral particle lysis approach" ;
    schema1:name "sc_lysis_approach" ;
    rdfs:range MIXS:ScLysisApproachEnum ;
    skos:definition "Method used to free DNA from interior of the cell(s) or particle(s)" .

MIXS:0000077 a owl:ObjectProperty ;
    rdfs:label "bin_param" ;
    dcterms:title "binning parameters" ;
    schema1:name "bin_param" ;
    rdfs:range MIXS:BinParamEnum ;
    skos:definition "The parameters that have been applied during the extraction of genomes from metagenomic datasets" .

MIXS:0000078 a owl:DatatypeProperty ;
    rdfs:label "bin_software" ;
    dcterms:title "binning software" ;
    schema1:name "bin_software" ;
    skos:definition "Tool(s) used for the extraction of genomes from metagenomic datasets, where possible include a product ID (PID) of the tool(s) used" ;
    MIXS:Expected_value "names and versions of software(s) used" .

MIXS:0000079 a owl:DatatypeProperty ;
    rdfs:label "reassembly_bin" ;
    dcterms:title "reassembly post binning" ;
    schema1:name "reassembly_bin" ;
    rdfs:range xsd:boolean ;
    skos:definition "Has an assembly been performed on a genome bin extracted from a metagenomic assembly?" .

MIXS:0000080 a owl:ObjectProperty ;
    rdfs:label "mag_cov_software" ;
    dcterms:title "MAG coverage software" ;
    schema1:name "mag_cov_software" ;
    rdfs:range MIXS:MagCovSoftwareEnum ;
    skos:definition "Tool(s) used to determine the genome coverage if coverage is used as a binning parameter in the extraction of genomes from metagenomic datasets" .

MIXS:0000097 a owl:DatatypeProperty ;
    rdfs:label "carb_dioxide" ;
    dcterms:title "carbon dioxide" ;
    schema1:name "carb_dioxide" ;
    rdfs:range xsd:string ;
    skos:definition "Carbon dioxide (gas) amount or concentration at the time of sampling" ;
    MIXS:Preferred_unit "micromole per liter, parts per million" .

MIXS:0000099 a owl:DatatypeProperty ;
    rdfs:label "org_count_qpcr_info" ;
    dcterms:title "organism count qPCR information" ;
    schema1:name "org_count_qpcr_info" ;
    skos:definition "If qpcr was used for the cell count, the target gene name, the primer sequence and the cycling conditions should also be provided. (Example: 16S rrna; FWD:ACGTAGCTATGACGT REV:GTGCTAGTCGAGTAC; initial denaturation:90C_5min; denaturation:90C_2min; annealing:52C_30 sec; elongation:72C_30 sec; 90 C for 1 min; final elongation:72C_5min; 30 cycles)" ;
    MIXS:Expected_value "gene name;FWD:forward primer sequence;REV:reverse primer sequence;initial denaturation:degrees_minutes;denaturation:degrees_minutes;annealing:degrees_minutes;elongation:degrees_minutes;final elongation:degrees_minutes; total cycles" ;
    MIXS:Preferred_unit "number of cells per gram (or ml or cm^2)" .

MIXS:0000105 a owl:DatatypeProperty ;
    rdfs:label "tot_iron" ;
    dcterms:title "total iron" ;
    schema1:name "tot_iron" ;
    rdfs:range xsd:string ;
    skos:definition "Concentration of total iron in the sample" ;
    MIXS:Preferred_unit "milligram per liter, milligram per kilogram" .

MIXS:0000112 a owl:DatatypeProperty ;
    rdfs:label "solar_irradiance" ;
    dcterms:title "solar irradiance" ;
    schema1:name "solar_irradiance" ;
    rdfs:range xsd:string ;
    skos:definition "The amount of solar energy that arrives at a specific area of a surface during a specific time interval" ;
    MIXS:Preferred_unit "kilowatts per square meter per day, ergs per square centimeter per second" .

MIXS:0000114 a owl:DatatypeProperty ;
    rdfs:label "ventilation_rate" ;
    dcterms:title "ventilation rate" ;
    schema1:name "ventilation_rate" ;
    rdfs:range xsd:string ;
    skos:definition "Ventilation rate of the system in the sampled premises" ;
    MIXS:Preferred_unit "cubic meter per minute, liters per second" .

MIXS:0000118 a owl:DatatypeProperty ;
    rdfs:label "wind_speed" ;
    dcterms:title "wind speed" ;
    schema1:name "wind_speed" ;
    rdfs:range xsd:string ;
    skos:definition "speed of wind measured at the time of sampling" .

MIXS:0000120 a owl:DatatypeProperty ;
    rdfs:label "tan" ;
    dcterms:title "total acid number" ;
    schema1:name "tan" ;
    rdfs:range xsd:string ;
    skos:definition "Total Acid Number (TAN) is a measurement of acidity that is determined by the amount of potassium hydroxide in milligrams that is needed to neutralize the acids in one gram of oil. It is an important quality measurement of crude oil. (source: https://en.wikipedia.org/wiki/Total_acid_number)" ;
    MIXS:Preferred_unit "milligram per liter" .

MIXS:0000124 a owl:DatatypeProperty ;
    rdfs:label "air_temp" ;
    dcterms:title "air temperature" ;
    schema1:name "air_temp" ;
    rdfs:range xsd:string ;
    skos:definition "Temperature of the air at the time of sampling" ;
    MIXS:Preferred_unit "degree Celsius" .

MIXS:0000126 a owl:DatatypeProperty ;
    rdfs:label "viscosity" ;
    dcterms:title "viscosity" ;
    schema1:name "viscosity" ;
    skos:definition "A measure of oil's resistance to gradual deformation by shear stress or tensile stress (e.g. 3.5 cp; 100 °C)" ;
    MIXS:Expected_value "measurement value;measurement value" ;
    MIXS:Preferred_unit "cP at degree Celsius" .

MIXS:0000127 a owl:DatatypeProperty ;
    rdfs:label "pour_point" ;
    dcterms:title "pour point" ;
    schema1:name "pour_point" ;
    rdfs:range xsd:string ;
    skos:definition "Temperature at which a liquid becomes semi solid and loses its flow characteristics. In crude oil a high pour point is generally associated with a high paraffin content, typically found in crude deriving from a larger proportion of plant material. (source: https://en.wikipedia.org/wiki/pour_point)" ;
    MIXS:Preferred_unit "degree Celsius" .

MIXS:0000131 a owl:DatatypeProperty ;
    rdfs:label "saturates_pc" ;
    dcterms:title "saturates wt%" ;
    schema1:name "saturates_pc" ;
    rdfs:range xsd:string ;
    skos:definition "Saturate, Aromatic, Resin and Asphaltene (SARA) is an analysis method that divides crude oil components according to their polarizability and polarity. There are three main methods to obtain SARA results. The most popular one is known as the Iatroscan TLC-FID and is referred to as IP-143 (source: https://en.wikipedia.org/wiki/Saturate,_aromatic,_resin_and_asphaltene)" ;
    MIXS:Preferred_unit "percent" .

MIXS:0000133 a owl:DatatypeProperty ;
    rdfs:label "aromatics_pc" ;
    dcterms:title "aromatics wt%" ;
    schema1:name "aromatics_pc" ;
    rdfs:range xsd:string ;
    skos:definition "Saturate, Aromatic, Resin and Asphaltene (SARA) is an analysis method that divides crude oil components according to their polarizability and polarity. There are three main methods to obtain SARA results. The most popular one is known as the Iatroscan TLC-FID and is referred to as IP-143 (source: https://en.wikipedia.org/wiki/Saturate,_aromatic,_resin_and_asphaltene)" ;
    MIXS:Preferred_unit "percent" .

MIXS:0000134 a owl:DatatypeProperty ;
    rdfs:label "resins_pc" ;
    dcterms:title "resins wt%" ;
    schema1:name "resins_pc" ;
    rdfs:range xsd:string ;
    skos:definition "Saturate, Aromatic, Resin and Asphaltene (SARA) is an analysis method that divides crude oil components according to their polarizability and polarity. There are three main methods to obtain SARA results. The most popular one is known as the Iatroscan TLC-FID and is referred to as IP-143 (source: https://en.wikipedia.org/wiki/Saturate,_aromatic,_resin_and_asphaltene)" ;
    MIXS:Preferred_unit "percent" .

MIXS:0000135 a owl:DatatypeProperty ;
    rdfs:label "asphaltenes_pc" ;
    dcterms:title "asphaltenes wt%" ;
    schema1:name "asphaltenes_pc" ;
    rdfs:range xsd:string ;
    skos:definition "Saturate, Aromatic, Resin and Asphaltene (SARA) is an analysis method that divides crude oil components according to their polarizability and polarity. There are three main methods to obtain SARA results. The most popular one is known as the Iatroscan TLC-FID and is referred to as IP-143 (source: https://en.wikipedia.org/wiki/Saturate,_aromatic,_resin_and_asphaltene)" ;
    MIXS:Preferred_unit "percent" .

MIXS:0000139 a owl:DatatypeProperty ;
    rdfs:label "diss_iron" ;
    dcterms:title "dissolved iron" ;
    schema1:name "diss_iron" ;
    rdfs:range xsd:string ;
    skos:definition "Concentration of dissolved iron in the sample" ;
    MIXS:Preferred_unit "milligram per liter" .

MIXS:0000150 a owl:DatatypeProperty ;
    rdfs:label "suspend_solids" ;
    dcterms:title "suspended solids" ;
    schema1:name "suspend_solids" ;
    skos:definition "Concentration of substances including a wide variety of material, such as silt, decaying plant and animal matter; can include multiple substances" ;
    MIXS:Expected_value "suspended solid name;measurement value" ;
    MIXS:Preferred_unit "gram, microgram, milligram per liter, mole per liter, gram per liter, part per million" .

MIXS:0000152 a owl:DatatypeProperty ;
    rdfs:label "vfa" ;
    dcterms:title "volatile fatty acids" ;
    schema1:name "vfa" ;
    rdfs:range xsd:string ;
    skos:definition "Concentration of Volatile Fatty Acids in the sample" ;
    MIXS:Preferred_unit "milligram per liter, parts per million" .

MIXS:0000153 a owl:DatatypeProperty ;
    rdfs:label "benzene" ;
    dcterms:title "benzene" ;
    schema1:name "benzene" ;
    rdfs:range xsd:string ;
    skos:definition "Concentration of benzene in the sample" ;
    MIXS:Preferred_unit "milligram per liter, parts per million" .

MIXS:0000154 a owl:DatatypeProperty ;
    rdfs:label "toluene" ;
    dcterms:title "toluene" ;
    schema1:name "toluene" ;
    rdfs:range xsd:string ;
    skos:definition "Concentration of toluene in the sample" ;
    MIXS:Preferred_unit "milligram per liter, parts per million" .

MIXS:0000155 a owl:DatatypeProperty ;
    rdfs:label "ethylbenzene" ;
    dcterms:title "ethylbenzene" ;
    schema1:name "ethylbenzene" ;
    rdfs:range xsd:string ;
    skos:definition "Concentration of ethylbenzene in the sample" ;
    MIXS:Preferred_unit "milligram per liter, parts per million" .

MIXS:0000156 a owl:DatatypeProperty ;
    rdfs:label "xylene" ;
    dcterms:title "xylene" ;
    schema1:name "xylene" ;
    rdfs:range xsd:string ;
    skos:definition "Concentration of xylene in the sample" ;
    MIXS:Preferred_unit "milligram per liter, parts per million" .

MIXS:0000157 a owl:DatatypeProperty ;
    rdfs:label "api" ;
    dcterms:title "API gravity" ;
    schema1:name "api" ;
    rdfs:range xsd:string ;
    skos:definition "API gravity is a measure of how heavy or light a petroleum liquid is compared to water (source: https://en.wikipedia.org/wiki/API_gravity) (e.g. 31.1   API)" ;
    MIXS:Preferred_unit "degrees API" .

MIXS:0000180 a owl:DatatypeProperty ;
    rdfs:label "phaeopigments" ;
    dcterms:title "phaeopigments" ;
    schema1:name "phaeopigments" ;
    skos:definition "Concentration of phaeopigments; can include multiple phaeopigments" ;
    MIXS:Expected_value "phaeopigment name;measurement value" ;
    MIXS:Preferred_unit "milligram per cubic meter" .

MIXS:0000192 a owl:DatatypeProperty ;
    rdfs:label "room_dim" ;
    dcterms:title "room dimensions" ;
    schema1:name "room_dim" ;
    skos:definition "The length, width and height of sampling room" ;
    MIXS:Expected_value "measurement value" ;
    MIXS:Preferred_unit "meter" .

MIXS:0000203 a owl:DatatypeProperty ;
    rdfs:label "water_current" ;
    dcterms:title "water current" ;
    schema1:name "water_current" ;
    rdfs:range xsd:string ;
    skos:definition "Measurement of magnitude and direction of flow within a fluid" ;
    MIXS:Preferred_unit "cubic meter per second, knots" .

MIXS:0000226 a owl:ObjectProperty ;
    rdfs:label "freq_clean" ;
    dcterms:title "frequency of cleaning" ;
    schema1:name "freq_clean" ;
    rdfs:range MIXS:FreqCleanEnum ;
    skos:definition "The number of times the sample location is cleaned. Frequency of cleaning might be on a Daily basis, Weekly, Monthly, Quarterly or Annually" .

MIXS:0000244 a owl:DatatypeProperty ;
    rdfs:label "samp_room_id" ;
    dcterms:title "sampling room ID or name" ;
    schema1:name "samp_room_id" ;
    rdfs:range xsd:integer ;
    skos:definition "Sampling room number. This ID should be consistent with the designations on the building floor plans" .

MIXS:0000249 a owl:ObjectProperty ;
    rdfs:label "samp_dis_stage" ;
    dcterms:title "sample disease stage" ;
    schema1:name "samp_dis_stage" ;
    rdfs:range MIXS:SampDisStageEnum ;
    skos:definition "Stage of the disease at the time of sample collection, e.g. inoculation, penetration, infection, growth and reproduction, dissemination of pathogen" .

MIXS:0000252 a owl:DatatypeProperty ;
    rdfs:label "host_substrate" ;
    dcterms:title "host substrate" ;
    schema1:name "host_substrate" ;
    rdfs:range xsd:string ;
    skos:definition "The growth substrate of the host" .

MIXS:0000260 a owl:DatatypeProperty ;
    rdfs:label "host_color" ;
    dcterms:title "host color" ;
    schema1:name "host_color" ;
    rdfs:range xsd:string ;
    skos:definition "The color of host" .

MIXS:0000261 a owl:DatatypeProperty ;
    rdfs:label "host_shape" ;
    dcterms:title "host shape" ;
    schema1:name "host_shape" ;
    rdfs:range xsd:string ;
    skos:definition "Morphological shape of host" .

MIXS:0000290 a owl:DatatypeProperty ;
    rdfs:label "basin" ;
    dcterms:title "basin name" ;
    schema1:name "basin" ;
    rdfs:range xsd:string ;
    skos:definition "Name of the basin (e.g. Campos)" .

MIXS:0000291 a owl:DatatypeProperty ;
    rdfs:label "field" ;
    dcterms:title "field name" ;
    schema1:name "field" ;
    rdfs:range xsd:string ;
    skos:definition "Name of the hydrocarbon field (e.g. Albacora)" .

MIXS:0000296 a owl:DatatypeProperty ;
    rdfs:label "samp_well_name" ;
    dcterms:title "sample well name" ;
    schema1:name "samp_well_name" ;
    rdfs:range xsd:string ;
    skos:definition "Name of the well (e.g. BXA1123) where sample was taken" .

MIXS:0000297 a owl:DatatypeProperty ;
    rdfs:label "win" ;
    dcterms:title "well identification number" ;
    schema1:name "win" ;
    rdfs:range xsd:string ;
    skos:definition "A unique identifier of a well or wellbore. This is part of the Global Framework for Well Identification initiative which is compiled by the Professional Petroleum Data Management Association (PPDM) in an effort to improve well identification systems. (Supporting information: https://ppdm.org/ and http://dl.ppdm.org/dl/690)" .

MIXS:0000300 a owl:DatatypeProperty ;
    rdfs:label "additional_info" ;
    dcterms:title "additional info" ;
    schema1:name "additional_info" ;
    rdfs:range xsd:string ;
    skos:definition "Information that doesn't fit anywhere else. Can also be used to propose new entries for fields with controlled vocabulary" .

MIXS:0000303 a owl:DatatypeProperty ;
    rdfs:label "reservoir" ;
    dcterms:title "reservoir name" ;
    schema1:name "reservoir" ;
    rdfs:range xsd:string ;
    skos:definition "Name of the reservoir (e.g. Carapebus)" .

MIXS:0000312 a owl:DatatypeProperty ;
    rdfs:label "cur_vegetation" ;
    dcterms:title "current vegetation" ;
    schema1:name "cur_vegetation" ;
    rdfs:range xsd:string ;
    skos:definition "Vegetation classification from one or more standard classification systems, or agricultural crop" ;
    MIXS:Expected_value "current vegetation type" .

MIXS:0000314 a owl:DatatypeProperty ;
    rdfs:label "cur_vegetation_meth" ;
    dcterms:title "current vegetation method" ;
    schema1:name "cur_vegetation_meth" ;
    rdfs:range xsd:string ;
    skos:definition "Reference or method used in vegetation classification" .

MIXS:0000316 a owl:DatatypeProperty ;
    rdfs:label "prev_land_use_meth" ;
    dcterms:title "history/previous land use method" ;
    schema1:name "prev_land_use_meth" ;
    rdfs:range xsd:string ;
    skos:definition "Reference or method used in determining previous land use and dates" .

MIXS:0000319 a owl:DatatypeProperty ;
    rdfs:label "flooding" ;
    dcterms:title "history/flooding" ;
    schema1:name "flooding" ;
    rdfs:range xsd:dateTime ;
    skos:definition "Historical and/or physical evidence of flooding" .

MIXS:0000320 a owl:DatatypeProperty ;
    rdfs:label "extreme_event" ;
    dcterms:title "history/extreme events" ;
    schema1:name "extreme_event" ;
    rdfs:range xsd:dateTime ;
    skos:definition "Unusual physical events that may have affected microbial populations" .

MIXS:0000321 a owl:DatatypeProperty ;
    rdfs:label "horizon_meth" ;
    dcterms:title "horizon method" ;
    schema1:name "horizon_meth" ;
    rdfs:range xsd:string ;
    skos:definition "Reference or method used in determining the horizon" .

MIXS:0000322 a owl:DatatypeProperty ;
    rdfs:label "sieving" ;
    dcterms:title "sieving" ;
    schema1:name "sieving" ;
    skos:definition "Collection design of pooled samples and/or sieve size and amount of sample sieved" ;
    MIXS:Expected_value "design name and/or size;amount" .

MIXS:0000327 a owl:DatatypeProperty ;
    rdfs:label "store_cond" ;
    dcterms:title "storage conditions" ;
    schema1:name "store_cond" ;
    skos:definition "Explain how and for how long the soil sample was stored before DNA extraction (fresh/frozen/other)" .

MIXS:0000328 a owl:DatatypeProperty ;
    rdfs:label "link_climate_info" ;
    dcterms:title "link to climate information" ;
    schema1:name "link_climate_info" ;
    rdfs:range xsd:string ;
    skos:definition "Link to climate resource" .

MIXS:0000329 a owl:DatatypeProperty ;
    rdfs:label "link_class_info" ;
    dcterms:title "link to classification information" ;
    schema1:name "link_class_info" ;
    skos:definition "Link to digitized soil maps or other soil classification information" ;
    MIXS:Expected_value "PMID,DOI or url" .

MIXS:0000330 a owl:DatatypeProperty ;
    rdfs:label "local_class" ;
    dcterms:title "soil_taxonomic/local classification" ;
    schema1:name "local_class" ;
    rdfs:range xsd:string ;
    skos:definition "Soil classification based on local soil classification system" ;
    MIXS:Expected_value "local classification name" .

MIXS:0000331 a owl:DatatypeProperty ;
    rdfs:label "local_class_meth" ;
    dcterms:title "soil_taxonomic/local classification method" ;
    schema1:name "local_class_meth" ;
    rdfs:range xsd:string ;
    skos:definition "Reference or method used in determining the local soil classification" .

MIXS:0000335 a owl:DatatypeProperty ;
    rdfs:label "soil_texture" ;
    dcterms:title "soil texture" ;
    schema1:name "soil_texture" ;
    rdfs:range xsd:string ;
    skos:definition "The relative proportion of different grain sizes of mineral particles in a soil, as described using a standard system; express as % sand (50 um to 2 mm), silt (2 um to 50 um), and clay (<2 um) with textural name (e.g., silty clay loam) optional" .

MIXS:0000339 a owl:DatatypeProperty ;
    rdfs:label "micro_biomass_meth" ;
    dcterms:title "microbial biomass method" ;
    schema1:name "micro_biomass_meth" ;
    rdfs:range xsd:string ;
    skos:definition "Reference or method used in determining microbial biomass" ;
    skos:note "slot name/scn was microbial_biomass_meth" .

MIXS:0000343 a owl:DatatypeProperty ;
    rdfs:label "heavy_metals_meth" ;
    dcterms:title "extreme_unusual_properties/heavy metals method" ;
    schema1:name "heavy_metals_meth" ;
    rdfs:range xsd:string ;
    skos:definition "Reference or method used in determining heavy metals" .

MIXS:0000393 a owl:DatatypeProperty ;
    rdfs:label "hcr_temp" ;
    dcterms:title "hydrocarbon resource original temperature" ;
    schema1:name "hcr_temp" ;
    rdfs:range xsd:string ;
    skos:definition "Original temperature of the hydrocarbon resource" ;
    MIXS:Preferred_unit "degree Celsius" .

MIXS:0000394 a owl:DatatypeProperty ;
    rdfs:label "tvdss_of_hcr_temp" ;
    dcterms:title "depth (TVDSS) of hydrocarbon resource temperature" ;
    schema1:name "tvdss_of_hcr_temp" ;
    rdfs:range xsd:string ;
    skos:definition "True vertical depth subsea (TVDSS) of the hydrocarbon resource where the original temperature was measured (e.g. 1345 m)" ;
    MIXS:Preferred_unit "meter" .

MIXS:0000395 a owl:DatatypeProperty ;
    rdfs:label "hcr_pressure" ;
    dcterms:title "hydrocarbon resource original pressure" ;
    schema1:name "hcr_pressure" ;
    rdfs:range xsd:string ;
    skos:definition "Original pressure of the hydrocarbon resource" ;
    MIXS:Preferred_unit "atmosphere, kilopascal" .

MIXS:0000397 a owl:DatatypeProperty ;
    rdfs:label "tvdss_of_hcr_press" ;
    dcterms:title "depth (TVDSS) of hydrocarbon resource pressure" ;
    schema1:name "tvdss_of_hcr_press" ;
    rdfs:range xsd:string ;
    skos:definition "True vertical depth subsea (TVDSS) of the hydrocarbon resource where the original pressure was measured (e.g. 1578 m)" ;
    MIXS:Preferred_unit "meter" .

MIXS:0000406 a owl:DatatypeProperty ;
    rdfs:label "hcr_fw_salinity" ;
    dcterms:title "formation water salinity" ;
    schema1:name "hcr_fw_salinity" ;
    rdfs:range xsd:string ;
    skos:definition "Original formation water salinity (prior to secondary recovery e.g. Waterflooding) expressed as TDS" ;
    MIXS:Preferred_unit "milligram per liter" .

MIXS:0000407 a owl:DatatypeProperty ;
    rdfs:label "sulfate_fw" ;
    dcterms:title "sulfate in formation water" ;
    schema1:name "sulfate_fw" ;
    rdfs:range xsd:string ;
    skos:definition "Original sulfate concentration in the hydrocarbon resource" ;
    MIXS:Preferred_unit "milligram per liter" .

MIXS:0000408 a owl:DatatypeProperty ;
    rdfs:label "vfa_fw" ;
    dcterms:title "vfa in formation water" ;
    schema1:name "vfa_fw" ;
    rdfs:range xsd:string ;
    skos:definition "Original volatile fatty acid concentration in the hydrocarbon resource" ;
    MIXS:Preferred_unit "milligram per liter" .

MIXS:0000410 a owl:DatatypeProperty ;
    rdfs:label "samp_transport_cond" ;
    dcterms:title "sample transport conditions" ;
    schema1:name "samp_transport_cond" ;
    skos:definition "Sample transport duration (in days or hrs) and temperature the sample was exposed to (e.g. 5.5 days; 20   C)" ;
    MIXS:Expected_value "measurement value;measurement value" ;
    MIXS:Preferred_unit "days;degree Celsius" .

MIXS:0000419 a owl:DatatypeProperty ;
    rdfs:label "tot_sulfur" ;
    dcterms:title "total sulfur" ;
    schema1:name "tot_sulfur" ;
    rdfs:range xsd:string ;
    skos:definition "Concentration of total sulfur in the sample" ;
    MIXS:Preferred_unit "milligram per liter, parts per million" .

MIXS:0000438 a owl:DatatypeProperty ;
    rdfs:label "diss_oxygen_fluid" ;
    dcterms:title "dissolved oxygen in fluids" ;
    schema1:name "diss_oxygen_fluid" ;
    rdfs:range xsd:string ;
    skos:definition "Concentration of dissolved oxygen in the oil field produced fluids as it contributes to oxygen-corrosion and microbial activity (e.g. Mic)" ;
    MIXS:Preferred_unit "micromole per kilogram, milligram per liter" .

MIXS:0000503 a owl:DatatypeProperty ;
    rdfs:label "n_alkanes" ;
    dcterms:title "n-alkanes" ;
    schema1:name "n_alkanes" ;
    skos:definition "Concentration of n-alkanes; can include multiple n-alkanes" ;
    MIXS:Expected_value "n-alkane name;measurement value" .

MIXS:0000579 a owl:DatatypeProperty ;
    rdfs:label "root_med_micronutr" ;
    dcterms:title "rooting medium micronutrients" ;
    schema1:name "root_med_micronutr" ;
    skos:definition "Measurement of the culture rooting medium micronutrients (Fe, Mn, Zn, B, Cu, Mo); e.g. H3BO3 (6.2 mg/L)" ;
    MIXS:Expected_value "micronutrient name;measurement value" ;
    MIXS:Preferred_unit "milligram per liter" .

MIXS:0000634 a owl:DatatypeProperty ;
    rdfs:label "tot_depth_water_col" ;
    dcterms:title "total depth of water column" ;
    schema1:name "tot_depth_water_col" ;
    rdfs:range xsd:string ;
    skos:definition "Measurement of total depth of water column" ;
    MIXS:Preferred_unit "meter" .

MIXS:0000642 a owl:DatatypeProperty ;
    rdfs:label "annual_temp" ;
    dcterms:title "mean annual temperature" ;
    schema1:name "annual_temp" ;
    rdfs:range xsd:string ;
    skos:definition "Mean annual temperature" ;
    MIXS:Preferred_unit "degree Celsius" .

MIXS:0000644 a owl:DatatypeProperty ;
    rdfs:label "annual_precpt" ;
    dcterms:title "mean annual precipitation" ;
    schema1:name "annual_precpt" ;
    rdfs:range xsd:string ;
    skos:definition "The average of all annual precipitation values known, or an estimated equivalent value derived by such methods as regional indexes or Isohyetal maps" ;
    MIXS:Preferred_unit "millimeter" .

MIXS:0000646 a owl:DatatypeProperty ;
    rdfs:label "slope_gradient" ;
    dcterms:title "slope gradient" ;
    schema1:name "slope_gradient" ;
    rdfs:range xsd:string ;
    skos:definition "Commonly called 'slope'. The angle between ground surface and a horizontal line (in percent). This is the direction that overland water would flow. This measure is usually taken with a hand level meter or clinometer" ;
    MIXS:Preferred_unit "percentage" .

MIXS:0000647 a owl:DatatypeProperty ;
    rdfs:label "slope_aspect" ;
    dcterms:title "slope aspect" ;
    schema1:name "slope_aspect" ;
    rdfs:range xsd:string ;
    skos:definition "The direction a slope faces. While looking down a slope use a compass to record the direction you are facing (direction or degrees); e.g., nw or 315 degrees. This measure provides an indication of sun and wind exposure that will influence soil temperature and evapotranspiration" ;
    MIXS:Preferred_unit "degree" .

MIXS:0000650 a owl:DatatypeProperty ;
    rdfs:label "microbial_biomass" ;
    dcterms:title "microbial biomass" ;
    schema1:name "microbial_biomass" ;
    rdfs:range xsd:string ;
    skos:definition "The part of the organic matter in the soil that constitutes living microorganisms smaller than 5-10 micrometer. If you keep this, you would need to have correction factors used for conversion to the final units" ;
    MIXS:Preferred_unit "ton, kilogram, gram per kilogram soil" .

MIXS:0000689 a owl:DatatypeProperty ;
    rdfs:label "tot_phosphate" ;
    dcterms:title "total phosphate" ;
    schema1:name "tot_phosphate" ;
    rdfs:range xsd:string ;
    skos:definition "Total amount or concentration of phosphate" ;
    MIXS:Preferred_unit "microgram per liter, micromole per liter" .

MIXS:0000692 a owl:DatatypeProperty ;
    rdfs:label "conduc" ;
    dcterms:title "conductivity" ;
    schema1:name "conduc" ;
    rdfs:range xsd:string ;
    skos:definition "Electrical conductivity of water" ;
    MIXS:Preferred_unit "milliSiemens per centimeter" .

MIXS:0000750 a owl:ObjectProperty ;
    rdfs:label "tidal_stage" ;
    dcterms:title "tidal stage" ;
    schema1:name "tidal_stage" ;
    rdfs:range MIXS:TidalStageEnum ;
    skos:definition "Stage of tide" .

MIXS:0000756 a owl:DatatypeProperty ;
    rdfs:label "ventilation_type" ;
    dcterms:title "ventilation type" ;
    schema1:name "ventilation_type" ;
    rdfs:range xsd:string ;
    skos:definition "Ventilation system used in the sampled premises" ;
    MIXS:Expected_value "ventilation type name" .

MIXS:0000757 a owl:DatatypeProperty ;
    rdfs:label "wind_direction" ;
    dcterms:title "wind direction" ;
    schema1:name "wind_direction" ;
    rdfs:range xsd:string ;
    skos:definition "Wind direction is the direction from which a wind originates" ;
    MIXS:Preferred_unit "degrees or cardinal direction" .

MIXS:0000758 a owl:ObjectProperty ;
    rdfs:label "surf_material" ;
    dcterms:title "surface material" ;
    schema1:name "surf_material" ;
    rdfs:range MIXS:SurfMaterialEnum ;
    skos:definition "Surface materials at the point of sampling" .

MIXS:0000764 a owl:ObjectProperty ;
    rdfs:label "indoor_surf" ;
    dcterms:title "indoor surface" ;
    schema1:name "indoor_surf" ;
    rdfs:range MIXS:IndoorSurfEnum ;
    skos:definition "Type of indoor surface" .

MIXS:0000775 a owl:DatatypeProperty ;
    rdfs:label "avg_occup" ;
    dcterms:title "average daily occupancy" ;
    schema1:name "avg_occup" ;
    rdfs:range xsd:float ;
    skos:definition "Daily average occupancy of room. Indicate the number of person(s) daily occupying the sampling room" .

MIXS:0000819 a owl:DatatypeProperty ;
    rdfs:label "pres_animal_insect" ;
    dcterms:title "presence of pets, animals, or insects" ;
    schema1:name "pres_animal_insect" ;
    skos:definition "The type and number of animals or insects present in the sampling space" ;
    MIXS:Expected_value "enumeration;count" .

MIXS:0000828 a owl:DatatypeProperty ;
    rdfs:label "samp_floor" ;
    dcterms:title "sampling floor" ;
    schema1:name "samp_floor" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:onDatatype xsd:string ;
            owl:withRestrictions ( [ xsd:pattern "^(?:(?:\\d*1[1-3]th|\\d*1st|\\d*2nd|\\d*3rd|\\d*[04-9]th) floor|basement|lobby)$" ] ) ] ;
    skos:definition "The floor of the building, where the sampling room is located" ;
    MIXS:Expected_value "enumeration" .

MIXS:0000858 a owl:ObjectProperty ;
    rdfs:label "biol_stat" ;
    dcterms:title "biological status" ;
    schema1:name "biol_stat" ;
    rdfs:range MIXS:BiolStatEnum ;
    skos:definition "The level of genome modification" .

MIXS:0000860 a owl:ObjectProperty ;
    rdfs:label "samp_capt_status" ;
    dcterms:title "sample capture status" ;
    schema1:name "samp_capt_status" ;
    rdfs:range MIXS:SampCaptStatusEnum ;
    skos:definition "Reason for the sample" .

MIXS:0000866 a owl:DatatypeProperty ;
    rdfs:label "host_body_habitat" ;
    dcterms:title "host body habitat" ;
    schema1:name "host_body_habitat" ;
    rdfs:range xsd:string ;
    skos:definition "Original body habitat where the sample was obtained from" .

MIXS:0000871 a owl:DatatypeProperty ;
    rdfs:label "host_growth_cond" ;
    dcterms:title "host growth conditions" ;
    schema1:name "host_growth_cond" ;
    rdfs:range xsd:string ;
    skos:definition "Literature reference giving growth conditions of the host" .

MIXS:0000875 a owl:DatatypeProperty ;
    rdfs:label "gravidity" ;
    dcterms:title "gravidity" ;
    schema1:name "gravidity" ;
    skos:definition "Whether or not subject is gravid, and if yes date due or date post-conception, specifying which is used" .

MIXS:0000988 a owl:ObjectProperty ;
    rdfs:label "hcr" ;
    dcterms:title "hydrocarbon resource type" ;
    schema1:name "hcr" ;
    rdfs:range MIXS:HcrEnum ;
    skos:definition "Main Hydrocarbon Resource type. The term \"Hydrocarbon Resource\" HCR defined as a natural environmental feature containing large amounts of hydrocarbons at high concentrations potentially suitable for commercial exploitation. This term should not be confused with the Hydrocarbon Occurrence term which also includes hydrocarbon-rich environments with currently limited commercial interest such as seeps, outcrops, gas hydrates etc. If \"other\" is specified, please propose entry in \"additional info\" field" .

MIXS:0000989 a owl:ObjectProperty ;
    rdfs:label "hc_produced" ;
    dcterms:title "hydrocarbon type produced" ;
    schema1:name "hc_produced" ;
    rdfs:range MIXS:HcProducedEnum ;
    skos:definition "Main hydrocarbon type produced from resource (i.e. Oil, gas, condensate, etc). If \"other\" is specified, please propose entry in \"additional info\" field" .

MIXS:0000990 a owl:ObjectProperty ;
    rdfs:label "lithology" ;
    dcterms:title "lithology" ;
    schema1:name "lithology" ;
    rdfs:range MIXS:LithologyEnum ;
    skos:definition "Hydrocarbon resource main lithology (Additional information: http://petrowiki.org/Lithology_and_rock_type_determination). If \"other\" is specified, please propose entry in \"additional info\" field" .

MIXS:0000992 a owl:ObjectProperty ;
    rdfs:label "depos_env" ;
    dcterms:title "depositional environment" ;
    schema1:name "depos_env" ;
    rdfs:range MIXS:DeposEnvEnum ;
    skos:definition "Main depositional environment (https://en.wikipedia.org/wiki/Depositional_environment). If \"other\" is specified, please propose entry in \"additional info\" field" .

MIXS:0000993 a owl:ObjectProperty ;
    rdfs:label "hcr_geol_age" ;
    dcterms:title "hydrocarbon resource geological age" ;
    schema1:name "hcr_geol_age" ;
    rdfs:range MIXS:GeolAgeEnum ;
    skos:definition "Geological age of hydrocarbon resource (Additional info: https://en.wikipedia.org/wiki/Period_(geology)). If \"other\" is specified, please propose entry in \"additional info\" field" .

MIXS:0000999 a owl:ObjectProperty ;
    rdfs:label "samp_subtype" ;
    dcterms:title "sample subtype" ;
    schema1:name "samp_subtype" ;
    rdfs:range MIXS:SampSubtypeEnum ;
    skos:definition "Name of sample sub-type. For example if \"sample type\" is \"Produced Water\" then subtype could be \"Oil Phase\" or \"Water Phase\". If \"other\" is specified, please propose entry in \"additional info\" field" .

MIXS:0001044 a owl:ObjectProperty ;
    rdfs:label "growth_habit" ;
    dcterms:title "growth habit" ;
    schema1:name "growth_habit" ;
    rdfs:range MIXS:GrowthHabitEnum ;
    skos:definition "Characteristic shape, appearance or growth form of a plant species" .

MIXS:0001058 a owl:DatatypeProperty ;
    rdfs:label "plant_product" ;
    dcterms:title "plant product" ;
    schema1:name "plant_product" ;
    rdfs:range xsd:string ;
    skos:definition "Substance produced by the plant, where the sample was obtained from" ;
    MIXS:Expected_value "product name" .

MIXS:0001060 a owl:DatatypeProperty ;
    rdfs:label "plant_struc" ;
    dcterms:title "plant structure" ;
    schema1:name "plant_struc" ;
    rdfs:range xsd:string ;
    skos:definition "Name of plant structure the sample was obtained from; for Plant Ontology (PO) (v releases/2017-12-14) terms, see http://purl.bioontology.org/ontology/PO, e.g. petiole epidermis (PO_0000051). If an individual flower is sampled, the sex of it can be recorded here" .

MIXS:0001061 a owl:DatatypeProperty ;
    rdfs:label "root_cond" ;
    dcterms:title "rooting conditions" ;
    schema1:name "root_cond" ;
    rdfs:range xsd:string ;
    skos:definition "Relevant rooting conditions such as field plot size, sowing density, container dimensions, number of plants per container" .

MIXS:0001080 a owl:DatatypeProperty ;
    rdfs:label "cur_land_use" ;
    dcterms:title "current land use" ;
    schema1:name "cur_land_use" ;
    skos:definition "Present state of sample site" ;
    MIXS:Expected_value "enumeration" .

MIXS:0001081 a owl:ObjectProperty ;
    rdfs:label "tillage" ;
    dcterms:title "history/tillage" ;
    schema1:name "tillage" ;
    rdfs:range MIXS:TillageEnum ;
    skos:definition "Note method(s) used for tilling" .

MIXS:0001082 a owl:ObjectProperty ;
    rdfs:label "soil_horizon" ;
    dcterms:title "soil horizon" ;
    schema1:name "soil_horizon" ;
    rdfs:range MIXS:SoilHorizonEnum ;
    skos:definition "Specific layer in the land area which measures parallel to the soil surface and possesses physical characteristics which differ from the layers above and beneath" .

MIXS:0001083 a owl:ObjectProperty ;
    rdfs:label "fao_class" ;
    dcterms:title "soil_taxonomic/FAO classification" ;
    schema1:name "fao_class" ;
    rdfs:range MIXS:FaoClassEnum ;
    skos:definition "Soil classification from the FAO World soil distribution from International Soil Reference and Information Centre (ISRIC). The list of available soil classifications can be found at https://www.isric.org/explore/world-soil-distribution" .

MIXS:0001084 a owl:ObjectProperty ;
    rdfs:label "profile_position" ;
    dcterms:title "profile position" ;
    schema1:name "profile_position" ;
    rdfs:range MIXS:ProfilePositionEnum ;
    skos:definition "Cross-sectional position in the hillslope where sample was collected.sample area position in relation to surrounding areas" .

MIXS:0001085 a owl:ObjectProperty ;
    rdfs:label "drainage_class" ;
    dcterms:title "drainage classification" ;
    schema1:name "drainage_class" ;
    rdfs:range MIXS:DrainageClassEnum ;
    skos:definition "Drainage classification from a standard system such as the USDA system" .

MIXS:0001086 a owl:DatatypeProperty ;
    rdfs:label "fire" ;
    dcterms:title "history/fire" ;
    schema1:name "fire" ;
    rdfs:range xsd:dateTime ;
    skos:definition "Historical and/or physical evidence of fire" .

MIXS:0001110 a owl:ObjectProperty ;
    rdfs:label "farm_water_source" ;
    dcterms:title "farm watering water source" ;
    schema1:name "farm_water_source" ;
    rdfs:range MIXS:FarmWaterSourceEnum ;
    skos:definition "Source of water used on the farm for irrigation of crops or watering of livestock" .

MIXS:0001111 a owl:DatatypeProperty ;
    rdfs:label "plant_water_method" ;
    dcterms:title "plant water delivery method" ;
    schema1:name "plant_water_method" ;
    rdfs:range xsd:string ;
    skos:definition "Description of the equipment or method used to distribute water to crops. This field accepts termed listed under irrigation process (http://purl.obolibrary.org/obo/AGRO_00000006). Multiple terms can be separated by pipes" .

MIXS:0001116 a owl:DatatypeProperty ;
    rdfs:label "crop_yield" ;
    dcterms:title "crop yield" ;
    schema1:name "crop_yield" ;
    rdfs:range xsd:string ;
    skos:definition "Amount of crop produced per unit or area of land" ;
    MIXS:Preferred_unit "kilogram per metre square" .

MIXS:0001127 a owl:DatatypeProperty ;
    rdfs:label "fertilizer_admin" ;
    dcterms:title "fertilizer administration" ;
    schema1:name "fertilizer_admin" ;
    rdfs:range xsd:string ;
    skos:definition "Type of fertilizer or amendment added to the soil or water for the purpose of improving substrate health and quality for plant growth. This field accepts terms listed under agronomic fertilizer (http://purl.obolibrary.org/obo/AGRO_00002062). Multiple terms may apply and can be separated by pipes, listing in reverse chronological order" .

MIXS:0001129 a owl:DatatypeProperty ;
    rdfs:label "animal_group_size" ;
    dcterms:title "food animal group size" ;
    schema1:name "animal_group_size" ;
    rdfs:range xsd:integer ;
    skos:definition "The number of food animals of the same species that are maintained together as a unit, i.e. a herd or flock" .

MIXS:0001148 a owl:DatatypeProperty ;
    rdfs:label "season_humidity" ;
    dcterms:title "mean seasonal humidity" ;
    schema1:name "season_humidity" ;
    rdfs:range xsd:float ;
    skos:definition "Average humidity of the region throughout the growing season" ;
    skos:note "percent or float?" .

MIXS:0001157 a owl:DatatypeProperty ;
    rdfs:label "serovar_or_serotype" ;
    dcterms:title "serovar or serotype" ;
    schema1:name "serovar_or_serotype" ;
    rdfs:range xsd:string ;
    skos:definition "A characterization of a cell or microorganism based on the antigenic properties of the molecules on its surface. Indicate the name of a serovar or serotype of interest. This field accepts terms under organism (http://purl.obolibrary.org/obo/NCIT_C14250). This field also accepts identification numbers from NCBI under https://www.ncbi.nlm.nih.gov/taxonomy" .

MIXS:0001158 a owl:DatatypeProperty ;
    rdfs:label "soil_conductivity" ;
    dcterms:title "soil conductivity" ;
    schema1:name "soil_conductivity" ;
    rdfs:range xsd:string ;
    skos:definition "Conductivity of some soil." ;
    skos:note "Soil electrical conductivity (EC) is a measure of how well soil water can carry an electrical current. Electrical conductivity of soil solution is a reliable indicator of its solute (cation or anion) concentration with 1 dS/m approximately equivalent to 10 meq/L (U.S. Salinity Laboratory Staff, 1954)." ;
    MIXS:Preferred_unit "milliSiemens per centimeter" .

MIXS:0001159 a owl:DatatypeProperty ;
    rdfs:label "soil_cover" ;
    dcterms:title "soil cover" ;
    schema1:name "soil_cover" ;
    skos:definition "Material covering the sampled soil. This field accepts terms under ENVO:00010483, environmental material" ;
    MIXS:Expected_value "subclass of 'environmental material', http://purl.obolibrary.org/obo/ENVO_00010483" .

MIXS:0001160 a owl:DatatypeProperty ;
    rdfs:label "soil_pH" ;
    dcterms:title "soil pH" ;
    schema1:name "soil_pH" ;
    rdfs:range xsd:float ;
    skos:definition "pH measurement of some soil at the time of sampling" .

MIXS:0001161 a owl:DatatypeProperty ;
    rdfs:label "rel_location" ;
    dcterms:title "relative location of sample" ;
    schema1:name "rel_location" ;
    rdfs:range xsd:string ;
    skos:definition "Location of sampled soil to other parts of the farm e.g. under crop plant, near irrigation ditch, from the dirt road" .

MIXS:0001163 a owl:DatatypeProperty ;
    rdfs:label "soil_temp" ;
    dcterms:title "soil temperature" ;
    schema1:name "soil_temp" ;
    rdfs:range xsd:string ;
    skos:definition "Temperature of soil at the time of sampling" ;
    MIXS:Preferred_unit "degree Celsius" .

MIXS:0001167 a owl:DatatypeProperty ;
    rdfs:label "spikein_org" ;
    dcterms:title "spike in organism" ;
    schema1:name "spikein_org" ;
    rdfs:range xsd:string ;
    skos:definition "Taxonomic information about the spike-in organism(s). This field accepts terms under organism (http://purl.obolibrary.org/obo/NCIT_C14250). This field also accepts identification numbers from NCBI under https://www.ncbi.nlm.nih.gov/taxonomy. Multiple terms can be separated by pipes" .

MIXS:0001168 a owl:DatatypeProperty ;
    rdfs:label "spikein_serovar" ;
    dcterms:title "spike-in bacterial serovar or serotype" ;
    schema1:name "spikein_serovar" ;
    skos:definition "Taxonomic information about the spike-in organism(s) at the serovar or serotype level. This field accepts terms under organism (http://purl.obolibrary.org/obo/NCIT_C14250). This field also accepts identification numbers from NCBI under https://www.ncbi.nlm.nih.gov/taxonomy. Multiple terms can be separated by pipes" ;
    MIXS:Expected_value "NCIT:C14250 or antigenic formula or serovar name" .

MIXS:0001169 a owl:DatatypeProperty ;
    rdfs:label "spikein_growth_med" ;
    dcterms:title "spike-in growth medium" ;
    schema1:name "spikein_growth_med" ;
    rdfs:range xsd:string ;
    skos:definition "A liquid or gel containing nutrients, salts, and other factors formulated to support the growth of microorganisms, cells, or plants (National Cancer Institute Thesaurus).  A growth medium is a culture medium which has the disposition to encourage growth of particular bacteria to the exclusion of others in the same growth environment.  In this case, list the culture medium used to propagate the spike-in bacteria during preparation of spike-in inoculum. This field accepts terms listed under microbiological culture medium (http://purl.obolibrary.org/obo/MICRO_0000067). If the proper descriptor is not listed please use text to describe the spike in growth media" .

MIXS:0001171 a owl:DatatypeProperty ;
    rdfs:label "spikein_antibiotic" ;
    dcterms:title "spike-in with antibiotics" ;
    schema1:name "spikein_antibiotic" ;
    skos:definition "Antimicrobials used in research study to assess effects of exposure on microbiome of a specific site.  Please list antimicrobial, common name and/or class and concentration used for spike-in" ;
    MIXS:Expected_value "drug name; concentration" .

MIXS:0001172 a owl:DatatypeProperty ;
    rdfs:label "spikein_metal" ;
    dcterms:title "spike-in with heavy metals" ;
    schema1:name "spikein_metal" ;
    skos:definition "Heavy metals used in research study to assess effects of exposure on microbiome of a specific site.  Please list heavy metals and concentration used for spike-in" ;
    MIXS:Expected_value "heavy metal name or chemical symbol; concentration" .

MIXS:0001175 a owl:DatatypeProperty ;
    rdfs:label "water_pH" ;
    dcterms:title "water pH" ;
    schema1:name "water_pH" ;
    rdfs:range xsd:float ;
    skos:definition "pH measurement of some water at the time of sampling" .

MIXS:0001195 a owl:DatatypeProperty ;
    rdfs:label "cons_food_stor_dur" ;
    dcterms:title "food stored by consumer (storage duration)" ;
    schema1:name "cons_food_stor_dur" ;
    rdfs:range xsd:string ;
    skos:definition "The storage duration of the food commodity by the consumer, prior to onset of illness or sample collection.  Indicate the timepoint written in ISO 8601 format" ;
    MIXS:Preferred_unit "hours or days" .

MIXS:0001196 a owl:DatatypeProperty ;
    rdfs:label "cons_food_stor_temp" ;
    dcterms:title "food stored by consumer (storage temperature)" ;
    schema1:name "cons_food_stor_temp" ;
    skos:definition "Temperature at which food commodity was stored by the consumer, prior to onset of illness or sample collection" ;
    MIXS:Expected_value "text or measurement value" ;
    MIXS:Preferred_unit "degree Celsius" .

MIXS:0001197 a owl:DatatypeProperty ;
    rdfs:label "cons_purch_date" ;
    dcterms:title "purchase date" ;
    schema1:name "cons_purch_date" ;
    rdfs:range xsd:dateTime ;
    skos:definition "The date a food product was purchased by consumer" .

MIXS:0001198 a owl:DatatypeProperty ;
    rdfs:label "cons_qty_purchased" ;
    dcterms:title "quantity purchased" ;
    schema1:name "cons_qty_purchased" ;
    rdfs:range xsd:string ;
    skos:definition "The quantity of food purchased by consumer" .

MIXS:0001200 a owl:DatatypeProperty ;
    rdfs:label "food_additive" ;
    dcterms:title "food additive" ;
    schema1:name "food_additive" ;
    skos:definition "A substance or substances added to food to maintain or improve safety and freshness, to improve or maintain nutritional value, or improve taste, texture and appearance.  This field accepts terms listed under food additive (http://purl.obolibrary.org/obo/FOODON_03412972). Multiple terms can be separated by one or more pipes, but please consider limiting this list to the top 5 ingredients listed in order as on the food label.  See also, https://www.fda.gov/food/food-ingredients-packaging/overview-food-ingredients-additives-colors" ;
    MIXS:Expected_value "FOODON:03412972" .

MIXS:0001202 a owl:DatatypeProperty ;
    rdfs:label "food_cooking_proc" ;
    dcterms:title "food cooking process" ;
    schema1:name "food_cooking_proc" ;
    skos:definition "The transformation of raw food by the application of heat. This field accepts terms listed under food cooking (http://purl.obolibrary.org/obo/FOODON_03450002)" ;
    MIXS:Expected_value "FOODON:03450002" .

MIXS:0001203 a owl:DatatypeProperty ;
    rdfs:label "food_dis_point" ;
    dcterms:title "food distribution point geographic location" ;
    schema1:name "food_dis_point" ;
    rdfs:range xsd:string ;
    skos:definition "A reference to a place on the Earth, by its name or by its geographical location that refers to a distribution point along the food chain. This field accepts terms listed under geographic location (http://purl.obolibrary.org/obo/GAZ_00000448). Reference: Adam Diamond, James Barham. Moving Food Along the Value Chain: Innovations in Regional Food Distribution. U.S. Dept. of Agriculture, Agricultural Marketing Service. Washington, DC. March 2012. http://dx.doi.org/10.9752/MS045.03-2012" .

MIXS:0001205 a owl:DatatypeProperty ;
    rdfs:label "food_ingredient" ;
    dcterms:title "food ingredient" ;
    schema1:name "food_ingredient" ;
    skos:definition "In this field, please list individual ingredients for multi-component food [FOODON:00002501] and simple foods that is not captured in food_type.  Please use terms that are present in FoodOn.  Multiple terms can be separated by one or more pipes |, but please consider limiting this list to the top 5 ingredients listed in order as on the food label.  See also, https://www.fda.gov/food/food-ingredients-packaging/overview-food-ingredients-additives-colors" ;
    MIXS:Expected_value "FOODON" .

MIXS:0001206 a owl:DatatypeProperty ;
    rdfs:label "food_name_status" ;
    dcterms:title "food product name legal status" ;
    schema1:name "food_name_status" ;
    rdfs:range xsd:string ;
    skos:definition "A datum indicating that use of a food product name is regulated in some legal jurisdiction. This field accepts terms listed under food product name legal status (http://purl.obolibrary.org/obo/FOODON_03530087)" .

MIXS:0001209 a owl:DatatypeProperty ;
    rdfs:label "food_pack_integrity" ;
    dcterms:title "food packing medium integrity" ;
    schema1:name "food_pack_integrity" ;
    skos:definition "A term label and term id to describe the state of the packing material and text to explain the exact condition.  This field accepts terms listed under food packing medium integrity (http://purl.obolibrary.org/obo/FOODON_03530218)" ;
    MIXS:Expected_value "FOODON:03530218" .

MIXS:0001210 a owl:DatatypeProperty ;
    rdfs:label "food_prior_contact" ;
    dcterms:title "material of contact prior to food packaging" ;
    schema1:name "food_prior_contact" ;
    skos:definition "The material the food contacted (e.g., was processed in) prior to packaging. This field accepts terms listed under material of contact prior to food packaging (http://purl.obolibrary.org/obo/FOODON_03530077). If the proper descriptor is not listed please use text to describe the material of contact prior to food packaging" ;
    MIXS:Expected_value "FOODON:03530077" .

MIXS:0001212 a owl:DatatypeProperty ;
    rdfs:label "food_prod_synonym" ;
    dcterms:title "food product synonym" ;
    schema1:name "food_prod_synonym" ;
    rdfs:range xsd:string ;
    skos:definition "Other names by which the food product is known by (e.g., regional or non-English names)" .

MIXS:0001215 a owl:DatatypeProperty ;
    rdfs:label "HACCP_term" ;
    dcterms:title "Hazard Analysis Critical Control Points (HACCP) guide food safety term" ;
    schema1:name "HACCP_term" ;
    rdfs:range xsd:string ;
    skos:definition "Hazard Analysis Critical Control Points (HACCP) food safety terms; This field accepts terms listed under HACCP guide food safety term (http://purl.obolibrary.org/obo/FOODON_03530221)" .

MIXS:0001224 a owl:DatatypeProperty ;
    rdfs:label "num_samp_collect" ;
    dcterms:title "number of samples collected" ;
    schema1:name "num_samp_collect" ;
    rdfs:range xsd:string ;
    skos:definition "The number of samples collected during the current sampling event" .

MIXS:0001236 a owl:DatatypeProperty ;
    rdfs:label "study_design" ;
    dcterms:title "study design" ;
    schema1:name "study_design" ;
    skos:definition "A plan specification comprised of protocols (which may specify how and what kinds of data will be gathered) that are executed as part of an investigation and is realized during a study design execution. This field accepts terms under study design (http://purl.obolibrary.org/obo/OBI_0500000). If the proper descriptor is not listed please use text to describe the study design. Multiple terms can be separated by pipes" ;
    MIXS:Expected_value "OBI:0500000" .

MIXS:0001240 a owl:DatatypeProperty ;
    rdfs:label "study_tmnt" ;
    dcterms:title "study treatment" ;
    schema1:name "study_tmnt" ;
    skos:definition "A process in which the act is intended to modify or alter some other material entity.  From the study design, each treatment is comprised of one level of one or multiple factors. This field accepts terms listed under treatment (http://purl.obolibrary.org/obo/MCO_0000866). If the proper descriptor is not listed please use text to describe the study treatment. Multiple terms can be separated by one or more pipes" ;
    MIXS:Expected_value "MCO:0000866" .

MIXS:0001340 a owl:ObjectProperty ;
    rdfs:label "isotopolog_label" ;
    dcterms:title "isotopolog label status" ;
    schema1:name "isotopolog_label" ;
    rdfs:range MIXS:IsotopologLabelEnum ;
    skos:definition "List whether the isotopologue added to this biological sample was heavy-labelled or natural abundance" .

MIXS:0001341 a owl:ObjectProperty ;
    rdfs:label "isotopolog_approach" ;
    dcterms:title "Labeling approach (number of labeled isotopologs supplied)" ;
    schema1:name "isotopolog_approach" ;
    rdfs:range MIXS:IsotopologApproachEnum ;
    skos:definition "The labelling approach of this SIP experiment. Details if multiple isotopically labelled isotopologues were added to samples (\"multiple\"), or was only one isotopologue added to each sample (\"single\")." .

MIXS:0001342 a owl:DatatypeProperty ;
    rdfs:label "gradient_position" ;
    dcterms:title "gradient position" ;
    schema1:name "gradient_position" ;
    rdfs:range xsd:integer ;
    skos:definition "A number designating the gradient position from heaviest (=1) to lightest. Unfractionated samples, from which fractionated samples were derived, should be denoted with –1." .

MIXS:0001343 a owl:DatatypeProperty ;
    rdfs:label "gradient_pos_density" ;
    dcterms:title "density of gradient position" ;
    schema1:name "gradient_pos_density" ;
    skos:definition "Buoyant density of this fraction" ;
    MIXS:Preferred_unit "g/mL" .

MIXS:0001344 a owl:DatatypeProperty ;
    rdfs:label "gradient_pos_rel_am" ;
    dcterms:title "relative amount of nucleic acids in the gradient position" ;
    schema1:name "gradient_pos_rel_am" ;
    rdfs:range xsd:float ;
    skos:definition "The total nucleic acids loaded onto the column in this fraction as a decimal. If uploading 16S rRNA gene (or other amplicon) sequencing data, this value should be calculated from qPCR data. If uploading untargetted sequencing data, this value should be calculated from total DNA concentration." .

MIXS:0001345 a owl:DatatypeProperty ;
    rdfs:label "sip_method" ;
    dcterms:title "method for SIP fractionating" ;
    schema1:name "sip_method" ;
    rdfs:range xsd:string ;
    skos:definition "Method used to fractionate nucleic acids." .

MIXS:0001346 a owl:DatatypeProperty ;
    rdfs:label "isotopolog_atom_frac" ;
    dcterms:title "atom fraction of isotopolog" ;
    schema1:name "isotopolog_atom_frac" ;
    rdfs:range xsd:string ;
    skos:definition "The fraction of heavy-labelled atoms out of all atoms of a given element in the isotopolog. Multiple values allowed, separated by a | and should be orded the same as the isotopolog." .

MIXS:0001347 a owl:DatatypeProperty ;
    rdfs:label "isotopolog_atom_pos" ;
    dcterms:title "set of labeled atoms in isotopologue" ;
    schema1:name "isotopolog_atom_pos" ;
    rdfs:range xsd:string ;
    skos:definition "InChI label designating set of all isotopically enriched atoms in isotopologue. Multiple values allowed, separated by a | and should be orded the same as the isotopolog." .

MIXS:0001348 a owl:DatatypeProperty ;
    rdfs:label "isotopolog_dose" ;
    dcterms:title "dose of isotopolog" ;
    schema1:name "isotopolog_dose" ;
    rdfs:range xsd:string ;
    skos:definition "The concentration (in ppm) of isotopolog added to environmental matrix as a total mass per volume." ;
    skos:note "isotopolog mass / total volume soil; ppm of isotopologue in total container volume" ;
    MIXS:Preferred_unit "ppm" .

MIXS:0001349 a owl:DatatypeProperty ;
    rdfs:label "nucleobase_atom_frac" ;
    dcterms:title "nucleobase excess atom fraction" ;
    schema1:name "nucleobase_atom_frac" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:intersectionOf ( xsd:float [ a rdfs:Datatype ;
                        owl:onDatatype xsd:integer ;
                        owl:withRestrictions ( [ xsd:minInclusive 0 ] ) ] [ a rdfs:Datatype ;
                        owl:onDatatype xsd:integer ;
                        owl:withRestrictions ( [ xsd:maxInclusive 1 ] ) ] ) ] ;
    skos:definition "Excess atom fraction of the nucleobases in this fraction." .

MIXS:0001350 a owl:DatatypeProperty ;
    rdfs:label "isotopolog_incu_time" ;
    dcterms:title "isotopolog incubation time" ;
    schema1:name "isotopolog_incu_time" ;
    rdfs:range xsd:string ;
    skos:definition "Total time of incubation after isotopologue addition in hours" ;
    MIXS:Preferred_unit "hours" .

MIXS:0001351 a owl:DatatypeProperty ;
    rdfs:label "internal_standard" ;
    dcterms:title "internal standard method" ;
    schema1:name "internal_standard" ;
    rdfs:range xsd:string ;
    skos:definition "Method used for internal standard for SIP fractionation, if an internal standard was used (i.e., spiking in a heavy-labelled DNA sequence)." .

MIXS:0001352 a owl:DatatypeProperty ;
    rdfs:label "samp_dna_conc" ;
    dcterms:title "sample dna concentration" ;
    schema1:name "samp_dna_conc" ;
    skos:definition "DNA concentration of sample after dna extraction prior to pooling. Typically measured spectrophotometrically or with a fluorophore." ;
    skos:note "Unit is nanograms per microliter" ;
    MIXS:Preferred_unit "ng/uL" .

MIXS:0001353 a owl:DatatypeProperty ;
    rdfs:label "nucleic_acid_elution_vol" ;
    dcterms:title "nucleic acid elution volume" ;
    schema1:name "nucleic_acid_elution_vol" ;
    skos:definition "Volume the nucleic acid (DNA or RNA) sample is eluted in" ;
    skos:note "Unit is microliter" ;
    MIXS:Preferred_unit "uL" .

MIXS:0001354 a owl:DatatypeProperty ;
    rdfs:label "marker_gene_recov" ;
    dcterms:title "taxonomic marker gene recovered" ;
    schema1:name "marker_gene_recov" ;
    rdfs:range xsd:boolean ;
    rdfs:seeAlso MIXS:0000065 ;
    skos:altLabel "x16s_recover" ;
    skos:definition "Recovery status of taxonomic marker genes from the assembled genome" .

MIXS:0001355 a owl:DatatypeProperty ;
    rdfs:label "marker_gene_recov_sw" ;
    dcterms:title "taxonomic marker gene recovery software" ;
    schema1:name "marker_gene_recov_sw" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso MIXS:0000066 ;
    skos:altLabel "x16s_recover_software" ;
    skos:definition "Tools used for taxonomic marker gene extraction from assembled genomes" .

MIXS:AnimalSexEnum a owl:Class ;
    rdfs:label "AnimalSexEnum" ;
    dcterms:title "AnimalSexEnum" ;
    schema1:name "AnimalSexEnum" ;
    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( <https://w3id.org/mixs/AnimalSexEnum#castrated%20female> <https://w3id.org/mixs/AnimalSexEnum#castrated%20male> <https://w3id.org/mixs/AnimalSexEnum#intact%20female> <https://w3id.org/mixs/AnimalSexEnum#intact%20male> ) ;
    linkml:permissible_values <https://w3id.org/mixs/AnimalSexEnum#castrated%20female>,
        <https://w3id.org/mixs/AnimalSexEnum#castrated%20male>,
        <https://w3id.org/mixs/AnimalSexEnum#intact%20female>,
        <https://w3id.org/mixs/AnimalSexEnum#intact%20male> .

MIXS:BuildingSettingEnum a owl:Class ;
    rdfs:label "BuildingSettingEnum" ;
    dcterms:title "BuildingSettingEnum" ;
    schema1:name "BuildingSettingEnum" ;
    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( <https://w3id.org/mixs/BuildingSettingEnum#exurban> <https://w3id.org/mixs/BuildingSettingEnum#rural> <https://w3id.org/mixs/BuildingSettingEnum#suburban> <https://w3id.org/mixs/BuildingSettingEnum#urban> ) ;
    linkml:permissible_values <https://w3id.org/mixs/BuildingSettingEnum#exurban>,
        <https://w3id.org/mixs/BuildingSettingEnum#rural>,
        <https://w3id.org/mixs/BuildingSettingEnum#suburban>,
        <https://w3id.org/mixs/BuildingSettingEnum#urban> .

MIXS:DoorCompTypeEnum a owl:Class ;
    rdfs:label "DoorCompTypeEnum" ;
    dcterms:title "DoorCompTypeEnum" ;
    schema1:name "DoorCompTypeEnum" ;
    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( <https://w3id.org/mixs/DoorCompTypeEnum#metal%20covered> <https://w3id.org/mixs/DoorCompTypeEnum#revolving> <https://w3id.org/mixs/DoorCompTypeEnum#sliding> <https://w3id.org/mixs/DoorCompTypeEnum#telescopic> ) ;
    linkml:permissible_values <https://w3id.org/mixs/DoorCompTypeEnum#metal%20covered>,
        <https://w3id.org/mixs/DoorCompTypeEnum#revolving>,
        <https://w3id.org/mixs/DoorCompTypeEnum#sliding>,
        <https://w3id.org/mixs/DoorCompTypeEnum#telescopic> .

MIXS:HandidnessEnum a owl:Class ;
    rdfs:label "HandidnessEnum" ;
    dcterms:title "HandidnessEnum" ;
    schema1:name "HandidnessEnum" ;
    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( <https://w3id.org/mixs/HandidnessEnum#ambidexterity> <https://w3id.org/mixs/HandidnessEnum#left%20handedness> <https://w3id.org/mixs/HandidnessEnum#mixed-handedness> <https://w3id.org/mixs/HandidnessEnum#right%20handedness> ) ;
    linkml:permissible_values <https://w3id.org/mixs/HandidnessEnum#ambidexterity>,
        <https://w3id.org/mixs/HandidnessEnum#left%20handedness>,
        <https://w3id.org/mixs/HandidnessEnum#mixed-handedness>,
        <https://w3id.org/mixs/HandidnessEnum#right%20handedness> .

MIXS:HostSpecificityEnum a owl:Class ;
    rdfs:label "HostSpecificityEnum" ;
    dcterms:title "HostSpecificityEnum" ;
    schema1:name "HostSpecificityEnum" ;
    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( <https://w3id.org/mixs/HostSpecificityEnum#family-specific> <https://w3id.org/mixs/HostSpecificityEnum#generalist> <https://w3id.org/mixs/HostSpecificityEnum#genus-specific> <https://w3id.org/mixs/HostSpecificityEnum#species-specific> ) ;
    linkml:permissible_values <https://w3id.org/mixs/HostSpecificityEnum#family-specific>,
        <https://w3id.org/mixs/HostSpecificityEnum#generalist>,
        <https://w3id.org/mixs/HostSpecificityEnum#genus-specific>,
        <https://w3id.org/mixs/HostSpecificityEnum#species-specific> .

MIXS:OccupDocumentEnum a owl:Class ;
    rdfs:label "OccupDocumentEnum" ;
    dcterms:title "OccupDocumentEnum" ;
    schema1:name "OccupDocumentEnum" ;
    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( <https://w3id.org/mixs/OccupDocumentEnum#automated%20count> <https://w3id.org/mixs/OccupDocumentEnum#estimate> <https://w3id.org/mixs/OccupDocumentEnum#manual%20count> <https://w3id.org/mixs/OccupDocumentEnum#videos> ) ;
    linkml:permissible_values <https://w3id.org/mixs/OccupDocumentEnum#automated%20count>,
        <https://w3id.org/mixs/OccupDocumentEnum#estimate>,
        <https://w3id.org/mixs/OccupDocumentEnum#manual%20count>,
        <https://w3id.org/mixs/OccupDocumentEnum#videos> .

MIXS:QuadPosEnum a owl:Class ;
    rdfs:label "QuadPosEnum" ;
    dcterms:title "QuadPosEnum" ;
    schema1:name "QuadPosEnum" ;
    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( <https://w3id.org/mixs/QuadPosEnum#East%20side> <https://w3id.org/mixs/QuadPosEnum#North%20side> <https://w3id.org/mixs/QuadPosEnum#South%20side> <https://w3id.org/mixs/QuadPosEnum#West%20side> ) ;
    linkml:permissible_values <https://w3id.org/mixs/QuadPosEnum#East%20side>,
        <https://w3id.org/mixs/QuadPosEnum#North%20side>,
        <https://w3id.org/mixs/QuadPosEnum#South%20side>,
        <https://w3id.org/mixs/QuadPosEnum#West%20side> .

MIXS:SeasonUseEnum a owl:Class ;
    rdfs:label "SeasonUseEnum" ;
    dcterms:title "SeasonUseEnum" ;
    schema1:name "SeasonUseEnum" ;
    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( <https://w3id.org/mixs/SeasonUseEnum#Fall> <https://w3id.org/mixs/SeasonUseEnum#Spring> <https://w3id.org/mixs/SeasonUseEnum#Summer> <https://w3id.org/mixs/SeasonUseEnum#Winter> ) ;
    linkml:permissible_values <https://w3id.org/mixs/SeasonUseEnum#Fall>,
