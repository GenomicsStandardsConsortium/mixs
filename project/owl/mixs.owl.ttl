MIXS:0000273 a owl:DatatypeProperty ;
    rdfs:label "maternal_health_stat" ;
    dcterms:title "amniotic fluid/maternal health status" ;
    schema1:name "maternal_health_stat" ;
    rdfs:range xsd:string ;
    skos:definition "Specification of the maternal health status" .

MIXS:0000275 a owl:DatatypeProperty ;
    rdfs:label "foetal_health_stat" ;
    dcterms:title "amniotic fluid/foetal health status" ;
    schema1:name "foetal_health_stat" ;
    rdfs:range xsd:string ;
    skos:definition "Specification of foetal health status, should also include abortion" .

MIXS:0000276 a owl:DatatypeProperty ;
    rdfs:label "amniotic_fluid_color" ;
    dcterms:title "amniotic fluid/color" ;
    schema1:name "amniotic_fluid_color" ;
    rdfs:range xsd:string ;
    skos:definition "Specification of the color of the amniotic fluid sample" .

MIXS:0000285 a owl:DatatypeProperty ;
    rdfs:label "sexual_act" ;
    dcterms:title "sexual activity" ;
    schema1:name "sexual_act" ;
    rdfs:range xsd:string ;
    skos:definition "Current sexual partner and frequency of sex" ;
    MIXS:Expected_value "partner sex;frequency" .

MIXS:0000286 a owl:DatatypeProperty ;
    rdfs:label "birth_control" ;
    dcterms:title "birth control" ;
    schema1:name "birth_control" ;
    rdfs:range xsd:string ;
    skos:definition "Specification of birth control medication used" ;
    MIXS:Expected_value "medication name" .

MIXS:0000287 a owl:DatatypeProperty ;
    rdfs:label "hysterectomy" ;
    dcterms:title "hysterectomy" ;
    schema1:name "hysterectomy" ;
    rdfs:range xsd:boolean ;
