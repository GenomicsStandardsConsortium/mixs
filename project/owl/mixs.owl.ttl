	schema1:keywords "host" , "host." ;
	a owl:DatatypeProperty ;
	rdfs:label "host_color" ;
	rdfs:range xsd:string ;
	skos:definition "The color of host" ;
	skos:inScheme <https://w3id.org/mixs> .
