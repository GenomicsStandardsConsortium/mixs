MIXS:0000174 a owl:DatatypeProperty ;
    rdfs:label "biomass" ;
    dcterms:title "biomass" ;
    schema1:name "biomass" ;
    skos:definition "Amount of biomass; should include the name for the part of biomass measured, e.g. Microbial, total. Can include multiple measurements" ;
    MIXS:Expected_value "biomass type;measurement value" ;
    MIXS:Preferred_unit "ton, kilogram, gram" .

MIXS:0000178 a owl:DatatypeProperty ;
    rdfs:label "diether_lipids" ;
    dcterms:title "diether lipids" ;
    schema1:name "diether_lipids" ;
    skos:definition "Concentration of diether lipids; can include multiple types of diether lipids" ;
    MIXS:Expected_value "diether lipid name;measurement value" ;
    MIXS:Preferred_unit "nanogram per liter" .

MIXS:0000181 a owl:DatatypeProperty ;
    rdfs:label "phosplipid_fatt_acid" ;
    dcterms:title "phospholipid fatty acid" ;
    schema1:name "phosplipid_fatt_acid" ;
    skos:definition "Concentration of phospholipid fatty acids; can include multiple values" ;
    MIXS:Expected_value "phospholipid fatty acid name;measurement value" .

MIXS:0001118 a owl:DatatypeProperty ;
    rdfs:label "cult_result_org" ;
    dcterms:title "culture result organism" ;
    schema1:name "cult_result_org" ;
    rdfs:range xsd:string ;
    skos:definition "Taxonomic information about the cultured organism(s)" .

MIXS:0001119 a owl:DatatypeProperty ;
    rdfs:label "cult_target" ;
    dcterms:title "culture target microbial analyte" ;
    schema1:name "cult_target" ;
    skos:definition "The target microbial analyte in terms of investigation scope. This field accepts terms under organism (http://purl.obolibrary.org/obo/NCIT_C14250). This field also accepts identification numbers from NCBI under https://www.ncbi.nlm.nih.gov/taxonomy" ;
    MIXS:Expected_value "NCIT:C14250 or NCBI taxid or culture independent" .

MIXS:0001131 a owl:DatatypeProperty ;
    rdfs:label "food_contact_surf" ;
    dcterms:title "food contact surface" ;
    schema1:name "food_contact_surf" ;
    skos:definition "The specific container or coating materials in direct contact with the food. Multiple values can be assigned.  This field accepts terms listed under food contact surface (http://purl.obolibrary.org/obo/FOODON_03500010)" ;
    MIXS:Expected_value "FOODON:03500010" .

MIXS:0001134 a owl:DatatypeProperty ;
    rdfs:label "food_pack_medium" ;
    dcterms:title "food packing medium" ;
    schema1:name "food_pack_medium" ;
    skos:definition "The medium in which the food is packed for preservation and handling or the medium surrounding homemade foods, e.g., peaches cooked in sugar syrup. The packing medium may provide a controlled environment for the food. It may also serve to improve palatability and consumer appeal.  This includes edible packing media (e.g. fruit juice), gas other than air (e.g. carbon dioxide), vacuum packed, or packed with aerosol propellant. This field accepts terms under food packing medium (http://purl.obolibrary.org/obo/FOODON_03480020). Multiple terms may apply and can be separated by pipes" ;
    MIXS:Expected_value "FOODON:03480020" .

MIXS:0001135 a owl:DatatypeProperty ;
    rdfs:label "food_preserv_proc" ;
    dcterms:title "food preservation process" ;
    schema1:name "food_preserv_proc" ;
    skos:definition "The methods contributing to the prevention or retardation of microbial, enzymatic or oxidative spoilage and thus to the extension of shelf life. This field accepts terms listed under food preservation process (http://purl.obolibrary.org/obo/FOODON_03470107)" ;
    MIXS:Expected_value "FOODON:03470107" .

MIXS:0001140 a owl:DatatypeProperty ;
    rdfs:label "food_treat_proc" ;
    dcterms:title "food treatment process" ;
    schema1:name "food_treat_proc" ;
    skos:definition "Used to specifically characterize a food product based on the treatment or processes applied to the product or any indexed ingredient. The processes include adding, substituting or removing components or modifying the food or component, e.g., through fermentation. Multiple values can be assigned. This fields accepts terms listed under food treatment process (http://purl.obolibrary.org/obo/FOODON_03460111)" ;
    MIXS:Expected_value "FOODON:03460111" .

MIXS:0001144 a owl:DatatypeProperty ;
    rdfs:label "intended_consumer" ;
    dcterms:title "intended consumer" ;
    schema1:name "intended_consumer" ;
    skos:definition "Food consumer type, human or animal, for which the food product is produced and marketed. This field accepts terms listed under food consumer group (http://purl.obolibrary.org/obo/FOODON_03510136) or NCBI taxid" ;
    MIXS:Expected_value "FOODON_03510136 or NCBI taxid" .

MIXS:0001149 a owl:DatatypeProperty ;
    rdfs:label "part_plant_animal" ;
    dcterms:title "part of plant or animal" ;
    schema1:name "part_plant_animal" ;
    skos:definition "The anatomical part of the organism being involved in food production or consumption; e.g., a carrot is the root of the plant (root vegetable). This field accepts terms listed under part of plant or animal (http://purl.obolibrary.org/obo/FOODON_03420116)" ;
    MIXS:Expected_value "FOODON:03420116" .

MIXS:0001152 a owl:DatatypeProperty ;
    rdfs:label "repository_name" ;
    dcterms:title "repository name" ;
    schema1:name "repository_name" ;
    rdfs:range xsd:string ;
    skos:definition "The name of the institution where the sample or DNA extract is held or \"sample not available\" if the sample was used in its entirety for analysis or otherwise not retained" ;
    MIXS:Expected_value "Institution" .

MIXS:0001170 a owl:DatatypeProperty ;
    rdfs:label "spikein_strain" ;
    dcterms:title "spike-in microbial strain" ;
    schema1:name "spikein_strain" ;
    skos:definition "Taxonomic information about the spike-in organism(s) at the strain level. This field accepts terms under organism (http://purl.obolibrary.org/obo/NCIT_C14250). This field also accepts identification numbers from NCBI under https://www.ncbi.nlm.nih.gov/taxonomy. Multiple terms can be separated by pipes" ;
    MIXS:Expected_value "NCIT:C14250 or NCBI taxid or text" .

MIXS:0001179 a owl:DatatypeProperty ;
    rdfs:label "IFSAC_category" ;
    dcterms:title "Interagency Food Safety Analytics Collaboration (IFSAC) category" ;
    schema1:name "IFSAC_category" ;
    rdfs:range xsd:string ;
    skos:definition "The IFSAC food categorization scheme has five distinct levels to which foods can be assigned, depending upon the type of food. First, foods are assigned to one of four food groups (aquatic animals, land animals, plants, and other). Food groups include increasingly specific food categories; dairy, eggs, meat and poultry, and game are in the land animal food group, and the category meat and poultry is further subdivided into more specific categories of meat (beef, pork, other meat) and poultry (chicken, turkey, other poultry). Finally, foods are differentiated by differences in food processing (such as pasteurized fluid dairy products, unpasteurized fluid dairy products, pasteurized solid and semi-solid dairy products, and unpasteurized solid and semi-solid dairy products. An IFSAC food category chart is available from https://www.cdc.gov/foodsafety/ifsac/projects/food-categorization-scheme.html PMID: 28926300" ;
    MIXS:Expected_value "IFSAC term" .

MIXS:0001211 a owl:DatatypeProperty ;
    rdfs:label "food_prod" ;
    dcterms:title "food production system characteristics" ;
    schema1:name "food_prod" ;
    rdfs:range xsd:string ;
    skos:definition "Descriptors of the food production system or of the agricultural environment and growing conditions related to the farm production system, such as wild caught, organic, free-range, industrial, dairy, beef,  domestic or cultivated food production. This field accepts terms listed under food production (http://purl.obolibrary.org/obo/FOODON_03530206). Multiple terms may apply and can be separated by pipes" .

MIXS:0001318 a owl:DatatypeProperty ;
    rdfs:label "host_subspecf_genlin" ;
    dcterms:title "host subspecific genetic lineage" ;
    schema1:name "host_subspecf_genlin" ;
    skos:definition "Information about the genetic distinctness of the host organism below the subspecies level e.g., serovar, serotype, biotype, ecotype, variety, cultivar, or any relevant genetic typing schemes like Group I plasmid. Subspecies should not be recorded in this term, but in the NCBI taxonomy. Supply both the lineage name and the lineage rank separated by a colon, e.g., biovar:abc123" ;
    MIXS:Expected_value "Genetic lineage below lowest rank of NCBI taxonomy, which is subspecies, e.g. serovar, biotype, ecotype, variety, cultivar" .

