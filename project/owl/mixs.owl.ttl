	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Expected_value "measurement value;treatment interval and duration" ;
	MIXS:Preferred_unit "millimeter" .
MIXS:0000577 dcterms:title "rooting medium carbon" ;
	schema1:keywords "carbon" ;
	a owl:DatatypeProperty ;
	rdfs:label "root_med_carbon" ;
