	skos:altLabel "MIxS-human-associated" ;
	skos:definition "A collection of terms appropriate when collecting samples and sequencing samples obtained from a person to examine their human-associated microbiome or genome, that does not have a specific extension (e.g., skin, gut, vaginal)." ;
	skos:inScheme <https://w3id.org/mixs> ;
	skos:note "For stool samples use MIxS-human-gut extension." ;
	MIXS:use_cases "blood samples or biopsy samples." .
