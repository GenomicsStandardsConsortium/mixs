	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "years, weeks, days" .
MIXS:0000165 dcterms:title "floor area" ;
	schema1:keywords "area" , "floor" ;
	a owl:DatatypeProperty ;
	rdfs:label "floor_area" ;
	rdfs:range xsd:string ;
	skos:definition "The area of the floor space within the room" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "square meter" .
MIXS:0000166 dcterms:title "floor thermal mass" ;
	schema1:keywords "floor" , "mass" ;
	a owl:DatatypeProperty ;
	rdfs:label "floor_thermal_mass" ;
	rdfs:range xsd:string ;
	skos:definition "The ability of the floor to provide inertia against temperature fluctuations" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "joule per degree Celsius" .
MIXS:0000167 dcterms:title "height carpet fiber mat" ;
	schema1:keywords "height" ;
	a owl:DatatypeProperty ;
	rdfs:label "height_carper_fiber" ;
	rdfs:range xsd:string ;
	skos:definition "The average carpet fiber height in the indoor environment" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "centimeter" .
MIXS:0000168 dcterms:title "inside lux light" ;
	schema1:keywords "inside" , "light" ;
	a owl:DatatypeProperty ;
	rdfs:label "inside_lux" ;
	rdfs:range xsd:string ;
	skos:definition "The recorded value at sampling time (power density)" ;
	skos:inScheme <https://w3id.org/mixs> ;
	MIXS:Preferred_unit "kilowatt per square metre" .
MIXS:0000169 dcterms:title "room air exchange rate" ;
	schema1:keywords "air" , "rate" , "room" ;
	a owl:DatatypeProperty ;
	rdfs:label "room_air_exch_rate" ;
	rdfs:range xsd:string ;
